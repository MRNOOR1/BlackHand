  80:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     if(scale_x == 0) {
  81:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         scale_x = 1;
  82:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     }
  83:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
  84:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     if(scale_y == 0) {
  85:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         scale_y = 1;
  86:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     }
  87:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
