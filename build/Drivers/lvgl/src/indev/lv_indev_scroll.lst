 236:Drivers/lvgl/src/indev/lv_indev_scroll.c **** int32_t lv_indev_scroll_throw_predict(lv_indev_t * indev, lv_dir_t dir)
 237:Drivers/lvgl/src/indev/lv_indev_scroll.c **** {
 238:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     if(indev == NULL) return 0;
 239:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     int32_t v;
 240:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     switch(dir) {
 241:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         case LV_DIR_VER:
 242:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             v = indev->pointer.scroll_throw_vect_ori.y;
 243:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             break;
 244:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         case LV_DIR_HOR:
 245:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             v = indev->pointer.scroll_throw_vect_ori.x;
 246:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             break;
 247:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         default:
 248:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             return 0;
 249:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     }
 250:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
 251:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     int32_t scroll_throw = indev->scroll_throw;
 252:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     int32_t sum = 0;
 253:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     while(v) {
 254:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         sum += v;
 255:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         v = v * (100 - scroll_throw) / 100;
 256:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     }
 257:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
 258:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     return sum;
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//ccspqae8.s 			page 6


 259:Drivers/lvgl/src/indev/lv_indev_scroll.c **** }
