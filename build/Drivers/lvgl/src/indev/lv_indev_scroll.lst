 506:Drivers/lvgl/src/indev/lv_indev_scroll.c **** /**
 507:Drivers/lvgl/src/indev/lv_indev_scroll.c ****  * Search for snap point in the min..max range.
 508:Drivers/lvgl/src/indev/lv_indev_scroll.c ****  * @param obj the object on which snap point should be found
 509:Drivers/lvgl/src/indev/lv_indev_scroll.c ****  * @param min ignore snap points smaller than this. (Absolute coordinate)
 510:Drivers/lvgl/src/indev/lv_indev_scroll.c ****  * @param max ignore snap points greater than this. (Absolute coordinate)
 511:Drivers/lvgl/src/indev/lv_indev_scroll.c ****  * @param ofs offset to snap points. Useful the get a snap point in an imagined case
 512:Drivers/lvgl/src/indev/lv_indev_scroll.c ****  *            what if children are already moved by this value
 513:Drivers/lvgl/src/indev/lv_indev_scroll.c ****  * @return the absolute x coordinate of the nearest snap point
 514:Drivers/lvgl/src/indev/lv_indev_scroll.c ****  *         or `LV_COORD_MAX` if there is no snap point in the min..max range
 515:Drivers/lvgl/src/indev/lv_indev_scroll.c ****  */
 516:Drivers/lvgl/src/indev/lv_indev_scroll.c **** static int32_t find_snap_point_x(const lv_obj_t * obj, int32_t min, int32_t max, int32_t ofs)
 517:Drivers/lvgl/src/indev/lv_indev_scroll.c **** {
 518:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     lv_scroll_snap_t align = lv_obj_get_scroll_snap_x(obj);
 519:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     if(align == LV_SCROLL_SNAP_NONE) return LV_COORD_MAX;
 520:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
 521:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     int32_t dist = LV_COORD_MAX;
 522:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
 523:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     int32_t pad_left = lv_obj_get_style_pad_left(obj, LV_PART_MAIN);
 524:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     int32_t pad_right = lv_obj_get_style_pad_right(obj, LV_PART_MAIN);
 525:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
 526:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     uint32_t i;
 527:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     uint32_t child_cnt = lv_obj_get_child_count(obj);
 528:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     for(i = 0; i < child_cnt; i++) {
 529:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         lv_obj_t * child = obj->spec_attr->children[i];
 530:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         if(lv_obj_has_flag_any(child, LV_OBJ_FLAG_HIDDEN | LV_OBJ_FLAG_FLOATING)) continue;
 531:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         if(lv_obj_has_flag(child, LV_OBJ_FLAG_SNAPPABLE)) {
 532:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             int32_t x_child = 0;
 533:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             int32_t x_parent = 0;
 534:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             switch(align) {
 535:Drivers/lvgl/src/indev/lv_indev_scroll.c ****                 case LV_SCROLL_SNAP_START:
 536:Drivers/lvgl/src/indev/lv_indev_scroll.c ****                     x_child = child->coords.x1;
 537:Drivers/lvgl/src/indev/lv_indev_scroll.c ****                     x_parent = obj->coords.x1 + pad_left;
 538:Drivers/lvgl/src/indev/lv_indev_scroll.c ****                     break;
 539:Drivers/lvgl/src/indev/lv_indev_scroll.c ****                 case LV_SCROLL_SNAP_END:
 540:Drivers/lvgl/src/indev/lv_indev_scroll.c ****                     x_child = child->coords.x2;
 541:Drivers/lvgl/src/indev/lv_indev_scroll.c ****                     x_parent = obj->coords.x2 - pad_right;
 542:Drivers/lvgl/src/indev/lv_indev_scroll.c ****                     break;
 543:Drivers/lvgl/src/indev/lv_indev_scroll.c ****                 case LV_SCROLL_SNAP_CENTER:
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//ccspqae8.s 			page 11


 544:Drivers/lvgl/src/indev/lv_indev_scroll.c ****                     x_child = child->coords.x1 + lv_area_get_width(&child->coords) / 2;
 545:Drivers/lvgl/src/indev/lv_indev_scroll.c ****                     x_parent = obj->coords.x1 + pad_left + (lv_area_get_width(&obj->coords) - pad_l
 546:Drivers/lvgl/src/indev/lv_indev_scroll.c ****                     break;
 547:Drivers/lvgl/src/indev/lv_indev_scroll.c ****                 default:
 548:Drivers/lvgl/src/indev/lv_indev_scroll.c ****                     continue;
 549:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             }
 550:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
 551:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             x_child += ofs;
 552:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             if(x_child >= min && x_child <= max) {
 553:Drivers/lvgl/src/indev/lv_indev_scroll.c ****                 int32_t x = x_child -  x_parent;
 554:Drivers/lvgl/src/indev/lv_indev_scroll.c ****                 if(LV_ABS(x) < LV_ABS(dist)) dist = x;
 555:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             }
 556:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         }
 557:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     }
 558:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
 559:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     return dist == LV_COORD_MAX ? LV_COORD_MAX : -dist;
 560:Drivers/lvgl/src/indev/lv_indev_scroll.c **** }
