 261:Drivers/lvgl/src/indev/lv_indev_scroll.c **** void lv_indev_scroll_get_snap_dist(lv_obj_t * obj, lv_point_t * p)
 262:Drivers/lvgl/src/indev/lv_indev_scroll.c **** {
 263:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     p->x = find_snap_point_x(obj, obj->coords.x1, obj->coords.x2, 0);
 264:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     p->y = find_snap_point_y(obj, obj->coords.y1, obj->coords.y2, 0);
 265:Drivers/lvgl/src/indev/lv_indev_scroll.c **** }
 266:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
 267:Drivers/lvgl/src/indev/lv_indev_scroll.c **** lv_obj_t * lv_indev_find_scroll_obj(lv_indev_t * indev)
 268:Drivers/lvgl/src/indev/lv_indev_scroll.c **** {
 269:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     lv_obj_t * obj_candidate = NULL;
 270:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     lv_dir_t dir_candidate = LV_DIR_NONE;
 271:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     int32_t scroll_limit = indev->scroll_limit;
 272:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
 273:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     /*Go until find a scrollable object in the current direction
 274:Drivers/lvgl/src/indev/lv_indev_scroll.c ****      *More precisely:
 275:Drivers/lvgl/src/indev/lv_indev_scroll.c ****      * 1. Check the pressed object and all of its ancestors and try to find an object which is scro
 276:Drivers/lvgl/src/indev/lv_indev_scroll.c ****      * 2. Scrollable means it has some content out of its area
 277:Drivers/lvgl/src/indev/lv_indev_scroll.c ****      * 3. If an object can be scrolled into the current direction then use it ("real match"")
 278:Drivers/lvgl/src/indev/lv_indev_scroll.c ****      * 4. If can be scrolled on the current axis (hor/ver) save it as candidate (at least show an e
 279:Drivers/lvgl/src/indev/lv_indev_scroll.c ****      * 5. Use the last candidate. Always the "deepest" parent or the object from point 3*/
 280:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     lv_obj_t * obj_act = indev->pointer.act_obj;
 281:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
 282:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     /*Decide if it's a horizontal or vertical scroll*/
 283:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     bool hor_en = false;
 284:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     bool ver_en = false;
 285:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     indev->pointer.scroll_sum.x += indev->pointer.vect.x;
 286:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     indev->pointer.scroll_sum.y += indev->pointer.vect.y;
 287:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
 288:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     while(obj_act) {
 289:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         /*Get the transformed scroll_sum with this object*/
 290:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         int16_t angle = 0;
 291:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         int32_t scale_x = 256;
 292:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         int32_t scale_y = 256;
 293:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         lv_point_t pivot = { 0, 0 };
 294:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         lv_obj_t * parent = obj_act;
 295:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         while(parent) {
 296:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             angle += lv_obj_get_style_transform_rotation(parent, LV_PART_MAIN);
 297:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             int32_t zoom_act_x = lv_obj_get_style_transform_scale_x_safe(parent, LV_PART_MAIN);
 298:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             int32_t zoom_act_y = lv_obj_get_style_transform_scale_y_safe(parent, LV_PART_MAIN);
 299:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             scale_x = (scale_x * zoom_act_x) >> 8;
 300:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             scale_y = (scale_y * zoom_act_y) >> 8;
 301:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             parent = lv_obj_get_parent(parent);
 302:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         }
 303:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
 304:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         if(scale_x == 0) {
 305:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             scale_x = 1;
 306:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         }
 307:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
 308:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         if(scale_y == 0) {
 309:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             scale_y = 1;
 310:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         }
 311:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
 312:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         lv_point_t obj_scroll_sum = indev->pointer.scroll_sum;
 313:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         if(angle != 0 || scale_x != LV_SCALE_NONE || scale_y != LV_SCALE_NONE) {
 314:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             angle = -angle;
 315:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             scale_x = (256 * 256) / scale_x;
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//ccspqae8.s 			page 7


 316:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             scale_y = (256 * 256) / scale_y;
 317:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             lv_point_transform(&obj_scroll_sum, angle, scale_x, scale_y, &pivot, false);
 318:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         }
 319:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
 320:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         if(LV_ABS(obj_scroll_sum.x) > LV_ABS(obj_scroll_sum.y)) {
 321:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             hor_en = true;
 322:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         }
 323:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         else {
 324:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             ver_en = true;
 325:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         }
 326:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
 327:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         if(lv_obj_has_flag(obj_act, LV_OBJ_FLAG_SCROLLABLE) == false) {
 328:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             /*If this object don't want to chain the scroll to the parent stop searching*/
 329:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             if(lv_obj_has_flag(obj_act, LV_OBJ_FLAG_SCROLL_CHAIN_HOR) == false && hor_en) break;
 330:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             if(lv_obj_has_flag(obj_act, LV_OBJ_FLAG_SCROLL_CHAIN_VER) == false && ver_en) break;
 331:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
 332:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             obj_act = lv_obj_get_parent(obj_act);
 333:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             continue;
 334:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         }
 335:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
 336:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         /*Consider both up-down or left/right scrollable according to the current direction*/
 337:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         bool up_en = ver_en;
 338:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         bool down_en = ver_en;
 339:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         bool left_en = hor_en;
 340:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         bool right_en = hor_en;
 341:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
 342:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         /*The object might have disabled some directions.*/
 343:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         lv_dir_t scroll_dir = lv_obj_get_scroll_dir(obj_act);
 344:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         if((scroll_dir & LV_DIR_LEFT) == 0) left_en = false;
 345:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         if((scroll_dir & LV_DIR_RIGHT) == 0) right_en = false;
 346:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         if((scroll_dir & LV_DIR_TOP) == 0) up_en = false;
 347:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         if((scroll_dir & LV_DIR_BOTTOM) == 0) down_en = false;
 348:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
 349:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         /*Horizontal scroll*/
 350:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         int32_t sl = 0;
 351:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         int32_t sr = 0;
 352:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         lv_scroll_snap_t snap_x = lv_obj_get_scroll_snap_x(obj_act);
 353:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         if(snap_x == LV_SCROLL_SNAP_NONE) {
 354:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             sl = lv_obj_get_scroll_left(obj_act);
 355:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             sr = lv_obj_get_scroll_right(obj_act);
 356:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         }
 357:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         else {
 358:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             bool has_start_snap;
 359:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             bool has_end_snap;
 360:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             has_more_snap_points(obj_act, LV_DIR_HOR, &has_start_snap, &has_end_snap);
 361:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
 362:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             /*Assume scrolling is there are more snap point
 363:Drivers/lvgl/src/indev/lv_indev_scroll.c ****              *Assumed scroll in if there are NO more nap points*/
 364:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             sl = has_start_snap ? 1 : -1;
 365:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             sr = has_end_snap ? 1 : -1;
 366:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         }
 367:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
 368:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         /*Vertical scroll*/
 369:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         int32_t st = 0;
 370:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         int32_t sb = 0;
 371:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         lv_scroll_snap_t snap_y = lv_obj_get_scroll_snap_y(obj_act);
 372:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         if(snap_y == LV_SCROLL_SNAP_NONE) {
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//ccspqae8.s 			page 8


 373:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             st = lv_obj_get_scroll_top(obj_act);
 374:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             sb = lv_obj_get_scroll_bottom(obj_act);
 375:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         }
 376:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         else {
 377:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             bool has_start_snap;
 378:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             bool has_end_snap;
 379:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             has_more_snap_points(obj_act, LV_DIR_VER, &has_start_snap, &has_end_snap);
 380:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
 381:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             /*Assume scrolling is there are more snap point
 382:Drivers/lvgl/src/indev/lv_indev_scroll.c ****              *Assumed scroll in if there are NO more nap points*/
 383:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             st = has_start_snap ? 1 : -1;
 384:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             sb = has_end_snap ? 1 : -1;
 385:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         }
 386:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
 387:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         /*If this object is scrollable into the current scroll direction then save it as a candidat
 388:Drivers/lvgl/src/indev/lv_indev_scroll.c ****          *It's important only to be scrollable on the current axis (hor/ver) because if the scroll
 389:Drivers/lvgl/src/indev/lv_indev_scroll.c ****          *is propagated to this object it can show at least elastic scroll effect.
 390:Drivers/lvgl/src/indev/lv_indev_scroll.c ****          *But if not hor/ver scrollable do not scroll it at all (so it's not a good candidate)*/
 391:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         if((st > 0 || sb > 0)  &&
 392:Drivers/lvgl/src/indev/lv_indev_scroll.c ****            ((up_en    && obj_scroll_sum.y >=   scroll_limit) ||
 393:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             (down_en  && obj_scroll_sum.y <= - scroll_limit))) {
 394:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             obj_candidate = obj_act;
 395:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             dir_candidate = LV_DIR_VER;
 396:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         }
 397:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
 398:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         if((sl > 0 || sr > 0)  &&
 399:Drivers/lvgl/src/indev/lv_indev_scroll.c ****            ((left_en   && obj_scroll_sum.x >=   scroll_limit) ||
 400:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             (right_en  && obj_scroll_sum.x <= - scroll_limit))) {
 401:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             obj_candidate = obj_act;
 402:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             dir_candidate = LV_DIR_HOR;
 403:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         }
 404:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
 405:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         if(st <= 0) up_en = false;
 406:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         if(sb <= 0) down_en = false;
 407:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         if(sl <= 0) left_en = false;
 408:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         if(sr <= 0) right_en = false;
 409:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
 410:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         /*If the object really can be scrolled into the current direction then use it.*/
 411:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         if((left_en  && obj_scroll_sum.x >=   scroll_limit) ||
 412:Drivers/lvgl/src/indev/lv_indev_scroll.c ****            (right_en && obj_scroll_sum.x <= - scroll_limit) ||
 413:Drivers/lvgl/src/indev/lv_indev_scroll.c ****            (up_en    && obj_scroll_sum.y >=   scroll_limit) ||
 414:Drivers/lvgl/src/indev/lv_indev_scroll.c ****            (down_en  && obj_scroll_sum.y <= - scroll_limit)) {
 415:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             indev->pointer.scroll_dir = hor_en ? LV_DIR_HOR : LV_DIR_VER;
 416:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             break;
 417:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         }
 418:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
 419:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         /*If this object don't want to chain the scroll to the parent stop searching*/
 420:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         if(lv_obj_has_flag(obj_act, LV_OBJ_FLAG_SCROLL_CHAIN_HOR) == false && hor_en) break;
 421:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         if(lv_obj_has_flag(obj_act, LV_OBJ_FLAG_SCROLL_CHAIN_VER) == false && ver_en) break;
