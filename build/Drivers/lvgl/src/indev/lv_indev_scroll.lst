  66:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     /*Set new position or scroll if the vector is not zero*/
  67:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     int16_t angle = 0;
  68:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     int16_t scale_x = 256;
  69:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     int16_t scale_y = 256;
  70:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     lv_obj_t * parent = scroll_obj;
  71:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     while(parent) {
  72:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         angle += lv_obj_get_style_transform_rotation(parent, LV_PART_MAIN);
  73:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         int32_t zoom_act_x = lv_obj_get_style_transform_scale_x_safe(parent, LV_PART_MAIN);
  74:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         int32_t zoom_act_y = lv_obj_get_style_transform_scale_y_safe(parent, LV_PART_MAIN);
  75:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         scale_x = (scale_x * zoom_act_x) >> 8;
  76:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         scale_y = (scale_y * zoom_act_y) >> 8;
  77:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         parent = lv_obj_get_parent(parent);
  78:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     }
