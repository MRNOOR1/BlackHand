 204:Drivers/lvgl/src/indev/lv_indev_scroll.c ****                 }
 205:Drivers/lvgl/src/indev/lv_indev_scroll.c ****                 else if(sb < 0) {
 206:Drivers/lvgl/src/indev/lv_indev_scroll.c ****                     lv_obj_scroll_by(scroll_obj, 0, -sb, LV_ANIM_ON);
 207:Drivers/lvgl/src/indev/lv_indev_scroll.c ****                     if(indev->reset_query) return;
 208:Drivers/lvgl/src/indev/lv_indev_scroll.c ****                 }
 209:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             }
 210:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         }
 211:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
 212:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         /*If horizontally scrollable and not controlled by snap*/
 213:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         if(align_x == LV_SCROLL_SNAP_NONE) {
 214:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             int32_t sl = lv_obj_get_scroll_left(scroll_obj);
 215:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             int32_t sr = lv_obj_get_scroll_right(scroll_obj);
 216:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             if(sl > 0 || sr > 0) {
 217:Drivers/lvgl/src/indev/lv_indev_scroll.c ****                 if(sl < 0) {
 218:Drivers/lvgl/src/indev/lv_indev_scroll.c ****                     lv_obj_scroll_by(scroll_obj, sl, 0, LV_ANIM_ON);
 219:Drivers/lvgl/src/indev/lv_indev_scroll.c ****                     if(indev->reset_query) return;
 220:Drivers/lvgl/src/indev/lv_indev_scroll.c ****                 }
 221:Drivers/lvgl/src/indev/lv_indev_scroll.c ****                 else if(sr < 0) {
 222:Drivers/lvgl/src/indev/lv_indev_scroll.c ****                     lv_obj_scroll_by(scroll_obj, -sr, 0, LV_ANIM_ON);
 223:Drivers/lvgl/src/indev/lv_indev_scroll.c ****                     if(indev->reset_query) return;
 224:Drivers/lvgl/src/indev/lv_indev_scroll.c ****                 }
 225:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             }
 226:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         }
 227:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
 228:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         lv_obj_send_event(scroll_obj, LV_EVENT_SCROLL_END, indev);
 229:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         if(indev->reset_query) return;
 230:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
 231:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         indev->pointer.scroll_dir = LV_DIR_NONE;
 232:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         indev->pointer.scroll_obj = NULL;
 233:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     }
