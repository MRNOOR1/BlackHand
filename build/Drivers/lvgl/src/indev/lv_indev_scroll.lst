 641:Drivers/lvgl/src/indev/lv_indev_scroll.c **** static int32_t elastic_diff(lv_obj_t * scroll_obj, int32_t diff, int32_t scroll_start, int32_t scro
 642:Drivers/lvgl/src/indev/lv_indev_scroll.c ****                             lv_dir_t dir)
 643:Drivers/lvgl/src/indev/lv_indev_scroll.c **** {
 644:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     if(diff == 0) return 0;
 645:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
 646:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     /*Scroll back to the edge if required*/
 647:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     if(!lv_obj_has_flag(scroll_obj, LV_OBJ_FLAG_SCROLL_ELASTIC)) {
 648:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         /*
 649:Drivers/lvgl/src/indev/lv_indev_scroll.c ****          * If the scrolling object does not set the `LV_OBJ_FLAG_SCROLL_ELASTIC` flag,
 650:Drivers/lvgl/src/indev/lv_indev_scroll.c ****          * make sure that `diff` will not cause the scroll to exceed the `start` or `end` boundary 
 651:Drivers/lvgl/src/indev/lv_indev_scroll.c ****          * If the content has exceeded the boundary due to external factors like `LV_SCROLL_SNAP_CE
 652:Drivers/lvgl/src/indev/lv_indev_scroll.c ****          * then respect the current position instead of going straight back to 0.
 653:Drivers/lvgl/src/indev/lv_indev_scroll.c ****          */
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//ccspqae8.s 			page 39


 654:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         const int32_t scroll_ended = diff > 0 ? scroll_start : scroll_end;
 655:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         if(scroll_ended <= 0) diff = 0;
 656:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         else if(scroll_ended - diff < 0) diff = scroll_ended;
 657:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     }
 658:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     /*Handle elastic scrolling*/
 659:Drivers/lvgl/src/indev/lv_indev_scroll.c ****     else {
 660:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
 661:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         lv_scroll_snap_t snap;
 662:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         snap = dir == LV_DIR_HOR ? lv_obj_get_scroll_snap_x(scroll_obj) : lv_obj_get_scroll_snap_y(
 663:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
 664:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         /*Without snapping just scale down the diff when scrolled out*/
 665:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         if(snap == LV_SCROLL_SNAP_NONE) {
 666:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             if(scroll_end < 0 || scroll_start < 0) {
 667:Drivers/lvgl/src/indev/lv_indev_scroll.c ****                 /*Rounding*/
 668:Drivers/lvgl/src/indev/lv_indev_scroll.c ****                 if(diff < 0) diff -= ELASTIC_SLOWNESS_FACTOR / 2;
 669:Drivers/lvgl/src/indev/lv_indev_scroll.c ****                 if(diff > 0) diff += ELASTIC_SLOWNESS_FACTOR / 2;
 670:Drivers/lvgl/src/indev/lv_indev_scroll.c ****                 return diff / ELASTIC_SLOWNESS_FACTOR;
 671:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             }
 672:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             else {
 673:Drivers/lvgl/src/indev/lv_indev_scroll.c ****                 return diff;
 674:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             }
 675:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         }
 676:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
 677:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         /*With snapping the widget is scrolled out if there are no more snap points
 678:Drivers/lvgl/src/indev/lv_indev_scroll.c ****          *at least in one direction (start or end)*/
 679:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         bool has_start_snap;
 680:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         bool has_end_snap;
 681:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         has_more_snap_points(scroll_obj, dir, &has_start_snap, &has_end_snap);
 682:Drivers/lvgl/src/indev/lv_indev_scroll.c **** 
 683:Drivers/lvgl/src/indev/lv_indev_scroll.c ****         if(!has_start_snap || !has_end_snap) {
 684:Drivers/lvgl/src/indev/lv_indev_scroll.c ****             /*Rounding*/
