 190:Drivers/lvgl/src/indev/lv_indev.c **** void indev_read_core(lv_indev_t * indev, lv_indev_data_t * data)
 191:Drivers/lvgl/src/indev/lv_indev.c **** {
 192:Drivers/lvgl/src/indev/lv_indev.c ****     LV_PROFILER_INDEV_BEGIN;
 193:Drivers/lvgl/src/indev/lv_indev.c ****     lv_memzero(data, sizeof(lv_indev_data_t));
 194:Drivers/lvgl/src/indev/lv_indev.c **** 
 195:Drivers/lvgl/src/indev/lv_indev.c ****     /* For touchpad sometimes users don't set the last pressed coordinate on release.
 196:Drivers/lvgl/src/indev/lv_indev.c ****      * So be sure a coordinates are initialized to the last point */
 197:Drivers/lvgl/src/indev/lv_indev.c ****     if(indev->type == LV_INDEV_TYPE_POINTER) {
 198:Drivers/lvgl/src/indev/lv_indev.c ****         data->point.x = indev->pointer.last_raw_point.x;
 199:Drivers/lvgl/src/indev/lv_indev.c ****         data->point.y = indev->pointer.last_raw_point.y;
 200:Drivers/lvgl/src/indev/lv_indev.c ****     }
 201:Drivers/lvgl/src/indev/lv_indev.c ****     /*Similarly set at least the last key in case of the user doesn't set it on release*/
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//ccG3e9Ml.s 			page 5


 202:Drivers/lvgl/src/indev/lv_indev.c ****     else if(indev->type == LV_INDEV_TYPE_KEYPAD) {
 203:Drivers/lvgl/src/indev/lv_indev.c ****         data->key = indev->keypad.last_key;
 204:Drivers/lvgl/src/indev/lv_indev.c ****     }
 205:Drivers/lvgl/src/indev/lv_indev.c ****     /*For compatibility assume that used button was enter (encoder push)*/
 206:Drivers/lvgl/src/indev/lv_indev.c ****     else if(indev->type == LV_INDEV_TYPE_ENCODER) {
 207:Drivers/lvgl/src/indev/lv_indev.c ****         data->key = LV_KEY_ENTER;
 208:Drivers/lvgl/src/indev/lv_indev.c ****     }
 209:Drivers/lvgl/src/indev/lv_indev.c **** 
 210:Drivers/lvgl/src/indev/lv_indev.c ****     if(indev->read_cb) {
 211:Drivers/lvgl/src/indev/lv_indev.c ****         LV_TRACE_INDEV("calling indev_read_cb");
 212:Drivers/lvgl/src/indev/lv_indev.c ****         indev->read_cb(indev, data);
 213:Drivers/lvgl/src/indev/lv_indev.c **** 
 214:Drivers/lvgl/src/indev/lv_indev.c ****         /*Set the time stamp to the current time is it was not set in the read_cb*/
 215:Drivers/lvgl/src/indev/lv_indev.c ****         if(data->timestamp == 0) data->timestamp = lv_tick_get();
 216:Drivers/lvgl/src/indev/lv_indev.c ****     }
 217:Drivers/lvgl/src/indev/lv_indev.c ****     else {
