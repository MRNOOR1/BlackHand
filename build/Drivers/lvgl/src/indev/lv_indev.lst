1774:Drivers/lvgl/src/indev/lv_indev.c ****         indev->pointer.gesture_sum.y = 0;
1775:Drivers/lvgl/src/indev/lv_indev.c ****     }
1776:Drivers/lvgl/src/indev/lv_indev.c **** 
1777:Drivers/lvgl/src/indev/lv_indev.c ****     /*Count the movement by gesture*/
