1753:Drivers/lvgl/src/indev/lv_indev.c **** /**
1754:Drivers/lvgl/src/indev/lv_indev.c **** * Handle the gesture of indev_proc_p->pointer.act_obj
1755:Drivers/lvgl/src/indev/lv_indev.c **** * @param indev pointer to an input device state
1756:Drivers/lvgl/src/indev/lv_indev.c **** */
1757:Drivers/lvgl/src/indev/lv_indev.c **** void indev_gesture(lv_indev_t * indev)
1758:Drivers/lvgl/src/indev/lv_indev.c **** {
1759:Drivers/lvgl/src/indev/lv_indev.c ****     if(indev->pointer.scroll_obj) return;
1760:Drivers/lvgl/src/indev/lv_indev.c ****     if(indev->pointer.gesture_sent) return;
1761:Drivers/lvgl/src/indev/lv_indev.c **** 
1762:Drivers/lvgl/src/indev/lv_indev.c ****     lv_obj_t * gesture_obj = indev->pointer.act_obj;
