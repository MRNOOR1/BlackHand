1744:Drivers/lvgl/src/indev/lv_indev.c ****         }
1745:Drivers/lvgl/src/indev/lv_indev.c ****         else {
1746:Drivers/lvgl/src/indev/lv_indev.c ****             lv_obj_send_event(indev_obj_act, LV_EVENT_FOCUSED, indev_act);
1747:Drivers/lvgl/src/indev/lv_indev.c ****             if(indev_reset_check(indev)) return;
1748:Drivers/lvgl/src/indev/lv_indev.c ****         }
1749:Drivers/lvgl/src/indev/lv_indev.c ****     }
1750:Drivers/lvgl/src/indev/lv_indev.c ****     indev->pointer.last_pressed = indev_obj_act;
