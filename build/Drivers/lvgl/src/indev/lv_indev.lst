1771:Drivers/lvgl/src/indev/lv_indev.c ****     if((LV_ABS(indev->pointer.vect.x) < indev_act->gesture_min_velocity) &&
1772:Drivers/lvgl/src/indev/lv_indev.c ****        (LV_ABS(indev->pointer.vect.y) < indev_act->gesture_min_velocity)) {
