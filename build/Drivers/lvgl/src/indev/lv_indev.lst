1782:Drivers/lvgl/src/indev/lv_indev.c ****        (LV_ABS(indev->pointer.gesture_sum.y) > indev_act->gesture_limit)) {
1783:Drivers/lvgl/src/indev/lv_indev.c **** 
1784:Drivers/lvgl/src/indev/lv_indev.c ****         indev->pointer.gesture_sent = 1;
1785:Drivers/lvgl/src/indev/lv_indev.c **** 
1786:Drivers/lvgl/src/indev/lv_indev.c ****         if(LV_ABS(indev->pointer.gesture_sum.x) > LV_ABS(indev->pointer.gesture_sum.y)) {
