1689:Drivers/lvgl/src/indev/lv_indev.c **** static void indev_click_focus(lv_indev_t * indev)
1690:Drivers/lvgl/src/indev/lv_indev.c **** {
1691:Drivers/lvgl/src/indev/lv_indev.c ****     /*Handle click focus*/
1692:Drivers/lvgl/src/indev/lv_indev.c ****     if(lv_obj_has_flag(indev_obj_act, LV_OBJ_FLAG_CLICK_FOCUSABLE) == false) {
1693:Drivers/lvgl/src/indev/lv_indev.c ****         return;
1694:Drivers/lvgl/src/indev/lv_indev.c ****     }
1695:Drivers/lvgl/src/indev/lv_indev.c **** 
1696:Drivers/lvgl/src/indev/lv_indev.c ****     lv_group_t * g_act = lv_obj_get_group(indev_obj_act);
1697:Drivers/lvgl/src/indev/lv_indev.c ****     lv_group_t * g_prev = indev->pointer.last_pressed ? lv_obj_get_group(indev->pointer.last_presse
1698:Drivers/lvgl/src/indev/lv_indev.c **** 
1699:Drivers/lvgl/src/indev/lv_indev.c ****     /*If both the last and act. obj. are in the same group (or have no group)*/
1700:Drivers/lvgl/src/indev/lv_indev.c ****     if(g_act == g_prev) {
1701:Drivers/lvgl/src/indev/lv_indev.c ****         /*The objects are in a group*/
1702:Drivers/lvgl/src/indev/lv_indev.c ****         if(g_act) {
1703:Drivers/lvgl/src/indev/lv_indev.c ****             lv_group_focus_obj(indev_obj_act);
1704:Drivers/lvgl/src/indev/lv_indev.c ****             if(indev_reset_check(indev)) return;
1705:Drivers/lvgl/src/indev/lv_indev.c ****         }
1706:Drivers/lvgl/src/indev/lv_indev.c ****         /*The object are not in group*/
1707:Drivers/lvgl/src/indev/lv_indev.c ****         else {
1708:Drivers/lvgl/src/indev/lv_indev.c ****             if(indev->pointer.last_pressed != indev_obj_act) {
1709:Drivers/lvgl/src/indev/lv_indev.c ****                 lv_obj_send_event(indev->pointer.last_pressed, LV_EVENT_DEFOCUSED, indev_act);
1710:Drivers/lvgl/src/indev/lv_indev.c ****                 if(indev_reset_check(indev)) return;
1711:Drivers/lvgl/src/indev/lv_indev.c **** 
1712:Drivers/lvgl/src/indev/lv_indev.c ****                 lv_obj_send_event(indev_obj_act, LV_EVENT_FOCUSED, indev_act);
1713:Drivers/lvgl/src/indev/lv_indev.c ****                 if(indev_reset_check(indev)) return;
1714:Drivers/lvgl/src/indev/lv_indev.c ****             }
1715:Drivers/lvgl/src/indev/lv_indev.c ****         }
1716:Drivers/lvgl/src/indev/lv_indev.c ****     }
1717:Drivers/lvgl/src/indev/lv_indev.c ****     /*The object are not in the same group (in different groups or one has no group)*/
1718:Drivers/lvgl/src/indev/lv_indev.c ****     else {
1719:Drivers/lvgl/src/indev/lv_indev.c ****         /*If the prev. obj. is not in a group then defocus it.*/
1720:Drivers/lvgl/src/indev/lv_indev.c ****         if(g_prev == NULL && indev->pointer.last_pressed) {
1721:Drivers/lvgl/src/indev/lv_indev.c ****             lv_obj_send_event(indev->pointer.last_pressed, LV_EVENT_DEFOCUSED, indev_act);
1722:Drivers/lvgl/src/indev/lv_indev.c ****             if(indev_reset_check(indev)) return;
1723:Drivers/lvgl/src/indev/lv_indev.c ****         }
1724:Drivers/lvgl/src/indev/lv_indev.c ****         /*Focus on a non-group object*/
1725:Drivers/lvgl/src/indev/lv_indev.c ****         else {
1726:Drivers/lvgl/src/indev/lv_indev.c ****             if(indev->pointer.last_pressed) {
1727:Drivers/lvgl/src/indev/lv_indev.c ****                 /*If the prev. object also wasn't in a group defocus it*/
1728:Drivers/lvgl/src/indev/lv_indev.c ****                 if(g_prev == NULL) {
1729:Drivers/lvgl/src/indev/lv_indev.c ****                     lv_obj_send_event(indev->pointer.last_pressed, LV_EVENT_DEFOCUSED, indev_act);
1730:Drivers/lvgl/src/indev/lv_indev.c ****                     if(indev_reset_check(indev)) return;
1731:Drivers/lvgl/src/indev/lv_indev.c ****                 }
1732:Drivers/lvgl/src/indev/lv_indev.c ****                 /*If the prev. object also was in a group at least "LEAVE" it instead of defocus*/
1733:Drivers/lvgl/src/indev/lv_indev.c ****                 else {
1734:Drivers/lvgl/src/indev/lv_indev.c ****                     lv_obj_send_event(indev->pointer.last_pressed, LV_EVENT_LEAVE, indev_act);
1735:Drivers/lvgl/src/indev/lv_indev.c ****                     if(indev_reset_check(indev)) return;
1736:Drivers/lvgl/src/indev/lv_indev.c ****                 }
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//ccG3e9Ml.s 			page 33


1737:Drivers/lvgl/src/indev/lv_indev.c ****             }
1738:Drivers/lvgl/src/indev/lv_indev.c ****         }
1739:Drivers/lvgl/src/indev/lv_indev.c **** 
1740:Drivers/lvgl/src/indev/lv_indev.c ****         /*Focus to the act. in its group*/
1741:Drivers/lvgl/src/indev/lv_indev.c ****         if(g_act) {
1742:Drivers/lvgl/src/indev/lv_indev.c ****             lv_group_focus_obj(indev_obj_act);
