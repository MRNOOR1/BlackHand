 603:Drivers/lvgl/src/indev/lv_indev.c **** lv_obj_t * lv_indev_search_obj(lv_obj_t * obj, lv_point_t * point)
 604:Drivers/lvgl/src/indev/lv_indev.c **** {
 605:Drivers/lvgl/src/indev/lv_indev.c ****     lv_obj_t * found_p = NULL;
 606:Drivers/lvgl/src/indev/lv_indev.c **** 
 607:Drivers/lvgl/src/indev/lv_indev.c ****     /*If this obj is hidden the children are hidden too so return immediately*/
 608:Drivers/lvgl/src/indev/lv_indev.c ****     if(lv_obj_has_flag(obj, LV_OBJ_FLAG_HIDDEN)) return NULL;
 609:Drivers/lvgl/src/indev/lv_indev.c **** 
 610:Drivers/lvgl/src/indev/lv_indev.c ****     lv_point_t p_trans = *point;
 611:Drivers/lvgl/src/indev/lv_indev.c ****     lv_obj_transform_point(obj, &p_trans, LV_OBJ_POINT_TRANSFORM_FLAG_INVERSE);
 612:Drivers/lvgl/src/indev/lv_indev.c **** 
 613:Drivers/lvgl/src/indev/lv_indev.c ****     bool hit_test_ok = lv_obj_hit_test(obj, &p_trans);
 614:Drivers/lvgl/src/indev/lv_indev.c **** 
 615:Drivers/lvgl/src/indev/lv_indev.c ****     /*If the point is on this object check its children too*/
 616:Drivers/lvgl/src/indev/lv_indev.c ****     lv_area_t obj_coords = obj->coords;
 617:Drivers/lvgl/src/indev/lv_indev.c ****     if(lv_obj_has_flag(obj, LV_OBJ_FLAG_OVERFLOW_VISIBLE)) {
 618:Drivers/lvgl/src/indev/lv_indev.c ****         int32_t ext_draw_size = lv_obj_get_ext_draw_size(obj);
 619:Drivers/lvgl/src/indev/lv_indev.c ****         lv_area_increase(&obj_coords, ext_draw_size, ext_draw_size);
 620:Drivers/lvgl/src/indev/lv_indev.c ****     }
 621:Drivers/lvgl/src/indev/lv_indev.c ****     if(lv_area_is_point_on(&obj_coords, &p_trans, 0)) {
 622:Drivers/lvgl/src/indev/lv_indev.c ****         int32_t i;
 623:Drivers/lvgl/src/indev/lv_indev.c ****         uint32_t child_cnt = lv_obj_get_child_count(obj);
 624:Drivers/lvgl/src/indev/lv_indev.c **** 
 625:Drivers/lvgl/src/indev/lv_indev.c ****         /*If a child matches use it*/
 626:Drivers/lvgl/src/indev/lv_indev.c ****         for(i = child_cnt - 1; i >= 0; i--) {
 627:Drivers/lvgl/src/indev/lv_indev.c ****             lv_obj_t * child = obj->spec_attr->children[i];
 628:Drivers/lvgl/src/indev/lv_indev.c ****             found_p = lv_indev_search_obj(child, &p_trans);
 629:Drivers/lvgl/src/indev/lv_indev.c ****             if(found_p) return found_p;
 630:Drivers/lvgl/src/indev/lv_indev.c ****         }
 631:Drivers/lvgl/src/indev/lv_indev.c ****     }
 632:Drivers/lvgl/src/indev/lv_indev.c **** 
 633:Drivers/lvgl/src/indev/lv_indev.c ****     /*If not return earlier for a clicked child and this obj's hittest was ok use it
 634:Drivers/lvgl/src/indev/lv_indev.c ****      *else return NULL*/
 635:Drivers/lvgl/src/indev/lv_indev.c ****     if(hit_test_ok) return obj;
 636:Drivers/lvgl/src/indev/lv_indev.c ****     else return NULL;
 637:Drivers/lvgl/src/indev/lv_indev.c **** }
