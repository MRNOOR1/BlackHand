 595:Drivers/lvgl/src/indev/lv_indev.c ****         else if(mode == LV_INDEV_MODE_TIMER) {
 596:Drivers/lvgl/src/indev/lv_indev.c ****             /* use default timer mode*/
 597:Drivers/lvgl/src/indev/lv_indev.c ****             lv_timer_set_cb(indev->read_timer, lv_indev_read_timer_cb);
 598:Drivers/lvgl/src/indev/lv_indev.c ****             lv_timer_resume(indev->read_timer);
 599:Drivers/lvgl/src/indev/lv_indev.c ****         }
 600:Drivers/lvgl/src/indev/lv_indev.c ****     }
