 229:Drivers/lvgl/src/indev/lv_indev.c **** void lv_indev_read(lv_indev_t * indev)
 230:Drivers/lvgl/src/indev/lv_indev.c **** {
 231:Drivers/lvgl/src/indev/lv_indev.c ****     if(indev == NULL) return;
 232:Drivers/lvgl/src/indev/lv_indev.c **** 
 233:Drivers/lvgl/src/indev/lv_indev.c ****     LV_TRACE_INDEV("begin");
 234:Drivers/lvgl/src/indev/lv_indev.c **** 
 235:Drivers/lvgl/src/indev/lv_indev.c ****     indev_act = indev;
 236:Drivers/lvgl/src/indev/lv_indev.c **** 
 237:Drivers/lvgl/src/indev/lv_indev.c ****     /*Read and process all indevs*/
 238:Drivers/lvgl/src/indev/lv_indev.c ****     if(indev->disp == NULL) return; /*Not assigned to any displays*/
 239:Drivers/lvgl/src/indev/lv_indev.c **** 
 240:Drivers/lvgl/src/indev/lv_indev.c ****     /*Handle reset query before processing the point*/
 241:Drivers/lvgl/src/indev/lv_indev.c ****     indev_proc_reset_query_handler(indev);
 242:Drivers/lvgl/src/indev/lv_indev.c **** 
 243:Drivers/lvgl/src/indev/lv_indev.c ****     if(indev->enabled == 0) return;
 244:Drivers/lvgl/src/indev/lv_indev.c ****     if(indev->disp->prev_scr != NULL) {
 245:Drivers/lvgl/src/indev/lv_indev.c ****         LV_TRACE_INDEV("input blocked while screen animation active");
 246:Drivers/lvgl/src/indev/lv_indev.c ****         return;
 247:Drivers/lvgl/src/indev/lv_indev.c ****     }
 248:Drivers/lvgl/src/indev/lv_indev.c **** 
 249:Drivers/lvgl/src/indev/lv_indev.c ****     LV_PROFILER_INDEV_BEGIN;
 250:Drivers/lvgl/src/indev/lv_indev.c **** 
 251:Drivers/lvgl/src/indev/lv_indev.c ****     bool continue_reading;
 252:Drivers/lvgl/src/indev/lv_indev.c ****     lv_indev_data_t data;
 253:Drivers/lvgl/src/indev/lv_indev.c **** 
 254:Drivers/lvgl/src/indev/lv_indev.c ****     do {
 255:Drivers/lvgl/src/indev/lv_indev.c ****         /*Read the data*/
 256:Drivers/lvgl/src/indev/lv_indev.c ****         indev_read_core(indev, &data);
 257:Drivers/lvgl/src/indev/lv_indev.c ****         continue_reading = indev->mode != LV_INDEV_MODE_EVENT && data.continue_reading;
 258:Drivers/lvgl/src/indev/lv_indev.c **** 
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//ccG3e9Ml.s 			page 6


 259:Drivers/lvgl/src/indev/lv_indev.c ****         /*The active object might be deleted even in the read function*/
 260:Drivers/lvgl/src/indev/lv_indev.c ****         indev_proc_reset_query_handler(indev);
 261:Drivers/lvgl/src/indev/lv_indev.c ****         indev_obj_act = NULL;
 262:Drivers/lvgl/src/indev/lv_indev.c **** 
 263:Drivers/lvgl/src/indev/lv_indev.c ****         indev->state = data.state;
 264:Drivers/lvgl/src/indev/lv_indev.c **** 
 265:Drivers/lvgl/src/indev/lv_indev.c ****         /*Save the last activity time*/
 266:Drivers/lvgl/src/indev/lv_indev.c ****         indev->timestamp = data.timestamp;
 267:Drivers/lvgl/src/indev/lv_indev.c ****         if(indev->state == LV_INDEV_STATE_PRESSED) {
 268:Drivers/lvgl/src/indev/lv_indev.c ****             indev->disp->last_activity_time = data.timestamp;
 269:Drivers/lvgl/src/indev/lv_indev.c ****         }
 270:Drivers/lvgl/src/indev/lv_indev.c ****         else if(indev->type == LV_INDEV_TYPE_ENCODER && data.enc_diff) {
 271:Drivers/lvgl/src/indev/lv_indev.c ****             indev->disp->last_activity_time = data.timestamp;
 272:Drivers/lvgl/src/indev/lv_indev.c ****         }
 273:Drivers/lvgl/src/indev/lv_indev.c **** 
 274:Drivers/lvgl/src/indev/lv_indev.c ****         if(indev->type == LV_INDEV_TYPE_POINTER) {
 275:Drivers/lvgl/src/indev/lv_indev.c ****             indev_pointer_proc(indev, &data);
 276:Drivers/lvgl/src/indev/lv_indev.c ****         }
 277:Drivers/lvgl/src/indev/lv_indev.c ****         else if(indev->type == LV_INDEV_TYPE_KEYPAD) {
 278:Drivers/lvgl/src/indev/lv_indev.c ****             indev_keypad_proc(indev, &data);
 279:Drivers/lvgl/src/indev/lv_indev.c ****         }
 280:Drivers/lvgl/src/indev/lv_indev.c ****         else if(indev->type == LV_INDEV_TYPE_ENCODER) {
 281:Drivers/lvgl/src/indev/lv_indev.c ****             indev_encoder_proc(indev, &data);
 282:Drivers/lvgl/src/indev/lv_indev.c ****         }
 283:Drivers/lvgl/src/indev/lv_indev.c ****         else if(indev->type == LV_INDEV_TYPE_BUTTON) {
 284:Drivers/lvgl/src/indev/lv_indev.c ****             indev_button_proc(indev, &data);
 285:Drivers/lvgl/src/indev/lv_indev.c ****         }
 286:Drivers/lvgl/src/indev/lv_indev.c ****         /*Handle reset query if it happened in during processing*/
 287:Drivers/lvgl/src/indev/lv_indev.c ****         indev_proc_reset_query_handler(indev);
 288:Drivers/lvgl/src/indev/lv_indev.c ****     } while(continue_reading);
 289:Drivers/lvgl/src/indev/lv_indev.c **** 
 290:Drivers/lvgl/src/indev/lv_indev.c ****     /*End of indev processing, so no act indev*/
 291:Drivers/lvgl/src/indev/lv_indev.c ****     indev_act     = NULL;
 292:Drivers/lvgl/src/indev/lv_indev.c ****     indev_obj_act = NULL;
 293:Drivers/lvgl/src/indev/lv_indev.c **** 
 294:Drivers/lvgl/src/indev/lv_indev.c ****     LV_TRACE_INDEV("finished");
 295:Drivers/lvgl/src/indev/lv_indev.c ****     LV_PROFILER_INDEV_END;
 296:Drivers/lvgl/src/indev/lv_indev.c **** }
