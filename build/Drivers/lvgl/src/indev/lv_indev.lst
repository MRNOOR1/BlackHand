1791:Drivers/lvgl/src/indev/lv_indev.c ****         }
1792:Drivers/lvgl/src/indev/lv_indev.c ****         else {
1793:Drivers/lvgl/src/indev/lv_indev.c ****             if(indev->pointer.gesture_sum.y > 0)
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//ccG3e9Ml.s 			page 34


1794:Drivers/lvgl/src/indev/lv_indev.c ****                 indev->pointer.gesture_dir = LV_DIR_BOTTOM;
1795:Drivers/lvgl/src/indev/lv_indev.c ****             else
1796:Drivers/lvgl/src/indev/lv_indev.c ****                 indev->pointer.gesture_dir = LV_DIR_TOP;
1797:Drivers/lvgl/src/indev/lv_indev.c ****         }
1798:Drivers/lvgl/src/indev/lv_indev.c **** 
1799:Drivers/lvgl/src/indev/lv_indev.c ****         lv_obj_send_event(gesture_obj, LV_EVENT_GESTURE, indev_act);
1800:Drivers/lvgl/src/indev/lv_indev.c ****         if(indev_reset_check(indev)) return;
1801:Drivers/lvgl/src/indev/lv_indev.c **** 
