  99:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c ****        *delayMilliseconds = 0; // clear any old valid
 100:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c ****     if (pGIF->GIFFile.iPos >= pGIF->GIFFile.iSize-1) // no more data exists
 101:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c ****     {
 102:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c ****         (*pGIF->pfnSeek)(&pGIF->GIFFile, 0); // seek to start
 103:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c ****     }
 104:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c ****     if (GIFParseInfo(pGIF, 0))
 105:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c ****     {
 106:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c ****         pGIF->pUser = pUser;
