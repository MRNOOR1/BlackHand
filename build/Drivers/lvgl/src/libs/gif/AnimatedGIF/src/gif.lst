1107:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** 
1108:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** //
1109:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** // DecodeLZWTurbo
1110:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** //
1111:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** // Theory of operation:
1112:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** //
1113:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** // The 'traditional' LZW decoder maintains a dictionary with a linked list of codes.
1114:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** // These codes build into longer chains as more data is decoded. To output the pixels,
1115:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** // the linked list is traversed backwards from the last node to the first, then these
1116:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** // pixels are copied in reverse order to the output bitmap.
1117:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** //
1118:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** // My decoder takes a different approach. The output image becomes the dictionary and
1119:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** // the tables keep track of where in the output image the 'run' begins and its length.
1120:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** // ** NB **
1121:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** // These tables cannot be 16-bit values because a single dictionary's output can be
1122:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** // bigger than 64K
1123:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** //
1124:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** // I also work with the compressed data differently. Most decoders wind their way through
1125:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** // the chunked data by constantly checking if the current chunk has run out of data. I
1126:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** // take a different approach since modern machines have plenty of memory - I 'de-chunk'
1127:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** // the data first so that the inner loop can just decode as fast as possible. I also keep
1128:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** // a set of codes in a 64-bit local variable to minimize memory reads.
1129:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** //
1130:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** // These 2 changes result in a much faster decoder. For poorly compressed images, the
1131:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** // speed gain is about 2.5x compared to giflib. For well compressed images (long runs)
1132:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** // the speed can be as much as 30x faster. This is because it doesn't have to walk
1133:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** // backwards through the linked list of codes when outputting pixels. It also doesn't
1134:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** // have to copy pixels in reverse order, then unwind them.
1135:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** //
1136:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** static int DecodeLZWTurbo(GIFIMAGE *pImage, int iOptions)
