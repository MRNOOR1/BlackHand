 219:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** //
 220:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** // Initialize a GIF file and callback access from a file on SD or memory
 221:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** // returns 1 for success, 0 for failure
 222:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** // Fills in the canvas size of the GIFIMAGE structure
 223:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** //
 224:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** static int GIFInit(GIFIMAGE *pGIF)
 225:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** {
 226:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c ****     pGIF->GIFFile.iPos = 0; // start at beginning of file
 227:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c ****     if (!GIFParseInfo(pGIF, 1)) // gather info for the first frame
 228:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c ****        return 0; // something went wrong; not a GIF file?
 229:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c ****     (*pGIF->pfnSeek)(&pGIF->GIFFile, 0); // seek back to start of the file
 230:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c ****     if (pGIF->iCanvasWidth > MAX_WIDTH || pGIF->iCanvasHeight > 32767) { // too big or corrupt
 231:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c ****         pGIF->iError = GIF_TOO_WIDE;
 232:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c ****         return 0;
 233:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c ****     }
 234:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c ****   return 1;
 235:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** } /* GIFInit() */
