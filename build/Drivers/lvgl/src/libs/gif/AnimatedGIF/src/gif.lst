 108:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c ****             return 0;
 109:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c ****         if (pGIF->pTurboBuffer) { // the presence of the Turbo buffer indicates Turbo mode
 110:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c ****             rc = DecodeLZWTurbo(pGIF, 0);
 111:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c ****         } else {
 112:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c ****             rc = DecodeLZW(pGIF, 0);
 113:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c ****         }
 114:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c ****         if (rc != 0) // problem
 115:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c ****             return 0;
 116:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c ****     }
 117:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c ****     else
 118:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c ****     {
 119:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c ****         return 0; // error parsing the frame info, we may be at the end of the file
 120:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c ****     }
 121:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c ****     // Return 1 for more frames or 0 if this was the last frame
 122:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c ****     if (delayMilliseconds) // if not NULL, return the frame delay time
 123:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c ****         *delayMilliseconds = pGIF->iFrameDelay;
