 216:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** // The following functions are written in plain C and have no
 217:Drivers/lvgl/src/libs/gif/AnimatedGIF/src/gif.c **** // 3rd party dependencies, not even the C runtime library
