 406:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c **** static lv_cache_entry_t * get_possible_victim(lv_cache_sc_da_t * da, size_t index)
 407:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c **** {
 408:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****     LV_ASSERT(index < da->cache.size);
 409:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c **** 
 410:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****     void * da_entry;
 411:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****     lv_cache_entry_t * cache_entry;
 412:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****     get_entry(da, index, &da_entry, &cache_entry);
 413:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c **** 
 414:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****     const uint8_t sec_chance = has_second_chance(cache_entry);
 415:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****     const int32_t refs = lv_cache_entry_get_ref(cache_entry);
 416:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c **** 
 417:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****     if(sec_chance == 0 && refs == 0) {
 418:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****         return cache_entry;
 419:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****     }
 420:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****     if(sec_chance == 0 && refs > 0) {
 421:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****         LV_LOG_INFO(
 422:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****             "Entry %zu should be evicted but it's still referenced %" LV_PRId32
 423:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****             " times\n",
 424:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****             index, refs);
 425:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****         return NULL;
 426:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****     }
 427:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c **** 
 428:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****     /*Remove its second chance*/
 429:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****     set_second_chance(cache_entry, false);
 430:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****     return NULL;
 431:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c **** }
 432:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c **** 
 433:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c **** static lv_cache_entry_t * get_victim_cb(lv_cache_t * cache, void * user_data)
 434:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c **** {
 435:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****     LV_UNUSED(user_data);
 436:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c **** 
 437:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****     lv_cache_sc_da_t * da = (lv_cache_sc_da_t *)cache;
 438:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c **** 
 439:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****     LV_ASSERT_NULL(da);
 440:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****     /*
 441:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****          * We iterate twice to handle the complexity introduced by reference counting
 442:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****          * in the second chance algorithm:
 443:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****          *
 444:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****          * First iteration: Clear second chance bits and look for victims (entries with
 445:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****          * sec_chance=0 AND refs=0). Some entries may have sec_chance=0 but refs>0,
 446:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****          * making them unavailable for eviction despite being marked for removal.
 447:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****          *
 448:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****          * Second iteration: Now that all second chance bits are cleared from the first
 449:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****          * pass, we can find entries that are truly available for eviction (refs=0).
 450:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****          * We can't assume the first entry will be the victim after the first round
 451:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****          * because reference counts may prevent eviction of otherwise eligible entries.
 452:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****          *
 453:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****          * This ensures we give all entries a proper second chance while respecting
 454:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****          * active references that prevent immediate eviction.
 455:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****          */
 456:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****     for(size_t i = 0; i < 2; ++i) {
 457:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****         for(size_t j = 0; j < da->cache.size; ++j) {
 458:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****             lv_cache_entry_t * victim = get_possible_victim(da, j);
 459:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****             if(victim) {
 460:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****                 return victim;
 461:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****             }
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//cclDKaGf.s 			page 11


 462:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****         }
 463:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****     }
 464:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c ****     return NULL;
 465:Drivers/lvgl/src/misc/cache/class/lv_cache_sc_da.c **** }
