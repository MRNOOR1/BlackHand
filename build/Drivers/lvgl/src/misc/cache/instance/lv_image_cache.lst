 123:Drivers/lvgl/src/misc/cache/instance/lv_image_cache.c **** inline static lv_cache_compare_res_t image_cache_common_compare(const void * lhs_src, lv_image_src_
 124:Drivers/lvgl/src/misc/cache/instance/lv_image_cache.c ****                                                                 const void * rhs_src, lv_image_src_
 125:Drivers/lvgl/src/misc/cache/instance/lv_image_cache.c **** {
 126:Drivers/lvgl/src/misc/cache/instance/lv_image_cache.c ****     if(lhs_src_type == rhs_src_type) {
 127:Drivers/lvgl/src/misc/cache/instance/lv_image_cache.c ****         if(lhs_src_type == LV_IMAGE_SRC_FILE) {
 128:Drivers/lvgl/src/misc/cache/instance/lv_image_cache.c ****             int32_t cmp_res = lv_strcmp(lhs_src, rhs_src);
 129:Drivers/lvgl/src/misc/cache/instance/lv_image_cache.c ****             if(cmp_res != 0) {
 130:Drivers/lvgl/src/misc/cache/instance/lv_image_cache.c ****                 return cmp_res > 0 ? 1 : -1;
 131:Drivers/lvgl/src/misc/cache/instance/lv_image_cache.c ****             }
 132:Drivers/lvgl/src/misc/cache/instance/lv_image_cache.c ****         }
 133:Drivers/lvgl/src/misc/cache/instance/lv_image_cache.c ****         else if(lhs_src_type == LV_IMAGE_SRC_VARIABLE) {
 134:Drivers/lvgl/src/misc/cache/instance/lv_image_cache.c ****             if(lhs_src != rhs_src) {
 135:Drivers/lvgl/src/misc/cache/instance/lv_image_cache.c ****                 return lhs_src > rhs_src ? 1 : -1;
 136:Drivers/lvgl/src/misc/cache/instance/lv_image_cache.c ****             }
 137:Drivers/lvgl/src/misc/cache/instance/lv_image_cache.c ****         }
 138:Drivers/lvgl/src/misc/cache/instance/lv_image_cache.c ****         return 0;
 139:Drivers/lvgl/src/misc/cache/instance/lv_image_cache.c ****     }
 140:Drivers/lvgl/src/misc/cache/instance/lv_image_cache.c ****     return lhs_src_type > rhs_src_type ? 1 : -1;
 141:Drivers/lvgl/src/misc/cache/instance/lv_image_cache.c **** }
