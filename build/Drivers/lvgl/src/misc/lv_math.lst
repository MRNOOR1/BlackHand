  52:Drivers/lvgl/src/misc/lv_math.c **** int32_t LV_ATTRIBUTE_FAST_MEM lv_trigo_sin(int16_t angle)
  53:Drivers/lvgl/src/misc/lv_math.c **** {
  54:Drivers/lvgl/src/misc/lv_math.c ****     int32_t ret = 0;
  55:Drivers/lvgl/src/misc/lv_math.c ****     while(angle < 0) angle += 360;
  56:Drivers/lvgl/src/misc/lv_math.c ****     while(angle >= 360) angle -= 360;
  57:Drivers/lvgl/src/misc/lv_math.c **** 
  58:Drivers/lvgl/src/misc/lv_math.c ****     if(angle < 90) {
  59:Drivers/lvgl/src/misc/lv_math.c ****         ret = sin0_90_table[angle];
  60:Drivers/lvgl/src/misc/lv_math.c ****     }
  61:Drivers/lvgl/src/misc/lv_math.c ****     else if(angle >= 90 && angle < 180) {
  62:Drivers/lvgl/src/misc/lv_math.c ****         angle = 180 - angle;
  63:Drivers/lvgl/src/misc/lv_math.c ****         ret   = sin0_90_table[angle];
  64:Drivers/lvgl/src/misc/lv_math.c ****     }
  65:Drivers/lvgl/src/misc/lv_math.c ****     else if(angle >= 180 && angle < 270) {
  66:Drivers/lvgl/src/misc/lv_math.c ****         angle = angle - 180;
  67:Drivers/lvgl/src/misc/lv_math.c ****         ret   = -sin0_90_table[angle];
  68:Drivers/lvgl/src/misc/lv_math.c ****     }
  69:Drivers/lvgl/src/misc/lv_math.c ****     else {   /*angle >=270*/
  70:Drivers/lvgl/src/misc/lv_math.c ****         angle = 360 - angle;
  71:Drivers/lvgl/src/misc/lv_math.c ****         ret   = -sin0_90_table[angle];
  72:Drivers/lvgl/src/misc/lv_math.c ****     }
  73:Drivers/lvgl/src/misc/lv_math.c **** 
  74:Drivers/lvgl/src/misc/lv_math.c ****     if(ret == 32767) return 32768;
  75:Drivers/lvgl/src/misc/lv_math.c ****     else if(ret == -32767) return -32768;
  76:Drivers/lvgl/src/misc/lv_math.c ****     else return ret;
  77:Drivers/lvgl/src/misc/lv_math.c **** }
