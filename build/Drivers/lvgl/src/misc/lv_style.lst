 372:Drivers/lvgl/src/misc/lv_style.h **** /**
 373:Drivers/lvgl/src/misc/lv_style.h ****  * Copy all properties of a style to an other.
 374:Drivers/lvgl/src/misc/lv_style.h ****  * It has the same affect callying the same `lv_set_style_...`
 375:Drivers/lvgl/src/misc/lv_style.h ****  * functions on both styles.
 376:Drivers/lvgl/src/misc/lv_style.h ****  * It means new memory will be allocated to store the properties in
 377:Drivers/lvgl/src/misc/lv_style.h ****  * the destination style.
 378:Drivers/lvgl/src/misc/lv_style.h ****  * After the copy the destination style is fully independent of the source
 379:Drivers/lvgl/src/misc/lv_style.h ****  * and source can removed without affecting the destination style.
 380:Drivers/lvgl/src/misc/lv_style.h ****  * @param dst   the destination to copy into (can not the a constant style)
 381:Drivers/lvgl/src/misc/lv_style.h ****  * @param src   the source style to copy from.
 382:Drivers/lvgl/src/misc/lv_style.h ****  */
 383:Drivers/lvgl/src/misc/lv_style.h **** void lv_style_copy(lv_style_t * dst, const lv_style_t * src);
 384:Drivers/lvgl/src/misc/lv_style.h **** 
 385:Drivers/lvgl/src/misc/lv_style.h **** /**
 386:Drivers/lvgl/src/misc/lv_style.h ****  * Copy all properties of a style to an other without resetting the dst style.
 387:Drivers/lvgl/src/misc/lv_style.h ****  * It has the same effect as calling the same `lv_set_style_...`
 388:Drivers/lvgl/src/misc/lv_style.h ****  * functions on both styles.
 389:Drivers/lvgl/src/misc/lv_style.h ****  * It means new memory will be allocated to store the properties in
 390:Drivers/lvgl/src/misc/lv_style.h ****  * the destination style.
 391:Drivers/lvgl/src/misc/lv_style.h ****  * After the copy the destination style is fully independent of the source
 392:Drivers/lvgl/src/misc/lv_style.h ****  * and source can removed without affecting the destination style.
 393:Drivers/lvgl/src/misc/lv_style.h ****  * @param dst   the destination to copy into (cannot be a constant style)
 394:Drivers/lvgl/src/misc/lv_style.h ****  * @param src   the source style to copy from.
 395:Drivers/lvgl/src/misc/lv_style.h ****  */
 396:Drivers/lvgl/src/misc/lv_style.h **** void lv_style_merge(lv_style_t * dst, const lv_style_t * src);
 397:Drivers/lvgl/src/misc/lv_style.h **** 
