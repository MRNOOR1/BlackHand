 399:Drivers/lvgl/src/misc/lv_style.h **** /**
 400:Drivers/lvgl/src/misc/lv_style.h ****  * Check if a style is constant
 401:Drivers/lvgl/src/misc/lv_style.h ****  * @param style     pointer to a style
 402:Drivers/lvgl/src/misc/lv_style.h ****  * @return          true: the style is constant
 403:Drivers/lvgl/src/misc/lv_style.h ****  */
 404:Drivers/lvgl/src/misc/lv_style.h **** static inline bool lv_style_is_const(const lv_style_t * style)
 405:Drivers/lvgl/src/misc/lv_style.h **** {
 406:Drivers/lvgl/src/misc/lv_style.h ****     if(style->prop_cnt == 255) return true;
 407:Drivers/lvgl/src/misc/lv_style.h ****     return false;
 408:Drivers/lvgl/src/misc/lv_style.h **** }
 409:Drivers/lvgl/src/misc/lv_style.h **** 
