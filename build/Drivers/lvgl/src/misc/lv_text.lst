 233:Drivers/lvgl/src/misc/lv_text.c **** 
 234:Drivers/lvgl/src/misc/lv_text.c ****     uint32_t i = 0, i_next = 0, i_next_next = 0;  /*Iterating index into txt*/
 235:Drivers/lvgl/src/misc/lv_text.c ****     uint32_t letter = 0;      /*Letter at i*/
 236:Drivers/lvgl/src/misc/lv_text.c ****     uint32_t letter_next = 0; /*Letter at i_next*/
 237:Drivers/lvgl/src/misc/lv_text.c ****     int32_t letter_w;
