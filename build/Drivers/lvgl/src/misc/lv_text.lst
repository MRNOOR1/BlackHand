 193:Drivers/lvgl/src/misc/lv_text.c **** /**
 194:Drivers/lvgl/src/misc/lv_text.c ****  * Get the next word of text. A word is delimited by break characters.
 195:Drivers/lvgl/src/misc/lv_text.c ****  *
 196:Drivers/lvgl/src/misc/lv_text.c ****  * If the word cannot fit in the max_width space, obey LV_TXT_LINE_BREAK_LONG_* rules.
 197:Drivers/lvgl/src/misc/lv_text.c ****  *
 198:Drivers/lvgl/src/misc/lv_text.c ****  * If the next word cannot fit anything, return 0.
 199:Drivers/lvgl/src/misc/lv_text.c ****  *
 200:Drivers/lvgl/src/misc/lv_text.c ****  * If the first character is a break character, returns the next index.
 201:Drivers/lvgl/src/misc/lv_text.c ****  *
 202:Drivers/lvgl/src/misc/lv_text.c ****  * Example calls from lv_text_get_next_line() assuming sufficient max_width and
 203:Drivers/lvgl/src/misc/lv_text.c ****  * txt = "Test text\n"
 204:Drivers/lvgl/src/misc/lv_text.c ****  *        0123456789
 205:Drivers/lvgl/src/misc/lv_text.c ****  *
 206:Drivers/lvgl/src/misc/lv_text.c ****  * Calls would be as follows:
 207:Drivers/lvgl/src/misc/lv_text.c ****  *     1. Return i=4, pointing at breakchar ' ', for the string "Test"
 208:Drivers/lvgl/src/misc/lv_text.c ****  *     2. Return i=5, since i=4 was a breakchar.
 209:Drivers/lvgl/src/misc/lv_text.c ****  *     3. Return i=9, pointing at breakchar '\n'
 210:Drivers/lvgl/src/misc/lv_text.c ****  *     4. Parenting lv_text_get_next_line() would detect subsequent '\0'
 211:Drivers/lvgl/src/misc/lv_text.c ****  *
 212:Drivers/lvgl/src/misc/lv_text.c ****  * TODO: Returned word_w_ptr may overestimate the returned word's width when
 213:Drivers/lvgl/src/misc/lv_text.c ****  * max_width is reached. In current usage, this has no impact.
 214:Drivers/lvgl/src/misc/lv_text.c ****  *
 215:Drivers/lvgl/src/misc/lv_text.c ****  * @param txt a '\0' terminated string
 216:Drivers/lvgl/src/misc/lv_text.c ****  * @param font pointer to a font
 217:Drivers/lvgl/src/misc/lv_text.c ****  * @param letter_space letter space
 218:Drivers/lvgl/src/misc/lv_text.c ****  * @param max_width max width of the text (break the lines to fit this size). Set COORD_MAX to avoi
 219:Drivers/lvgl/src/misc/lv_text.c ****  * @param flags settings for the text from 'txt_flag_type' enum
 220:Drivers/lvgl/src/misc/lv_text.c ****  * @param[out] word_w_ptr width (in pixels) of the parsed word. May be NULL.
 221:Drivers/lvgl/src/misc/lv_text.c ****  * @param cmd_state Pointer to a lv_text_cmd_state_t variable which stored the current state of com
 222:Drivers/lvgl/src/misc/lv_text.c ****  * @return the index of the first char of the next word (in byte index not letter index. With UTF-8
 223:Drivers/lvgl/src/misc/lv_text.c ****  */
 224:Drivers/lvgl/src/misc/lv_text.c **** static uint32_t lv_text_get_next_word(const char * txt, const lv_font_t * font,
 225:Drivers/lvgl/src/misc/lv_text.c ****                                       int32_t letter_space, int32_t max_width,
 226:Drivers/lvgl/src/misc/lv_text.c ****                                       lv_text_flag_t flag, uint32_t * word_w_ptr,
 227:Drivers/lvgl/src/misc/lv_text.c ****                                       lv_text_cmd_state_t * cmd_state)
 228:Drivers/lvgl/src/misc/lv_text.c **** {
 229:Drivers/lvgl/src/misc/lv_text.c ****     if(txt == NULL || txt[0] == '\0') return 0;
 230:Drivers/lvgl/src/misc/lv_text.c ****     if(font == NULL) return 0;
 231:Drivers/lvgl/src/misc/lv_text.c **** 
 232:Drivers/lvgl/src/misc/lv_text.c ****     if(flag & LV_TEXT_FLAG_EXPAND) max_width = LV_COORD_MAX;
