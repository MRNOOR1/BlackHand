 146:Drivers/lvgl/src/misc/lv_text_private.h **** static inline bool lv_text_is_break_char(uint32_t letter)
 147:Drivers/lvgl/src/misc/lv_text_private.h **** {
 148:Drivers/lvgl/src/misc/lv_text_private.h ****     uint8_t i;
