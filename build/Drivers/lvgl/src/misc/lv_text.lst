 490:Drivers/lvgl/src/misc/lv_text.c ****     uint32_t i;
 491:Drivers/lvgl/src/misc/lv_text.c ****     for(i = pos; i <= old_len - len; i++) {
 492:Drivers/lvgl/src/misc/lv_text.c ****         txt[i] = txt[i + len];
 493:Drivers/lvgl/src/misc/lv_text.c ****     }
