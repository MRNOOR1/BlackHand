 603:Drivers/lvgl/src/misc/lv_text.c **** /**
 604:Drivers/lvgl/src/misc/lv_text.c ****  * Convert a wide character, e.g. 'Á' little endian to be UTF-8 compatible
 605:Drivers/lvgl/src/misc/lv_text.c ****  * @param c a wide character or a  Little endian number
 606:Drivers/lvgl/src/misc/lv_text.c ****  * @return `c` in big endian
 607:Drivers/lvgl/src/misc/lv_text.c ****  */
 608:Drivers/lvgl/src/misc/lv_text.c **** static uint32_t lv_text_utf8_conv_wc(uint32_t c)
 609:Drivers/lvgl/src/misc/lv_text.c **** {
 610:Drivers/lvgl/src/misc/lv_text.c **** #if LV_BIG_ENDIAN_SYSTEM == 0
 611:Drivers/lvgl/src/misc/lv_text.c ****     /*Swap the bytes (UTF-8 is big endian, but the MCUs are little endian)*/
 612:Drivers/lvgl/src/misc/lv_text.c ****     if((c & 0x80) != 0) {
 613:Drivers/lvgl/src/misc/lv_text.c ****         uint32_t swapped;
 614:Drivers/lvgl/src/misc/lv_text.c ****         uint8_t c8[4];
 615:Drivers/lvgl/src/misc/lv_text.c ****         lv_memcpy(c8, &c, 4);
 616:Drivers/lvgl/src/misc/lv_text.c ****         swapped = (c8[0] << 24) + (c8[1] << 16) + (c8[2] << 8) + (c8[3]);
 617:Drivers/lvgl/src/misc/lv_text.c ****         uint8_t i;
 618:Drivers/lvgl/src/misc/lv_text.c ****         for(i = 0; i < 4; i++) {
 619:Drivers/lvgl/src/misc/lv_text.c ****             if((swapped & 0xFF) == 0)
 620:Drivers/lvgl/src/misc/lv_text.c ****                 swapped = (swapped >> 8); /*Ignore leading zeros (they were in the end originally)*
 621:Drivers/lvgl/src/misc/lv_text.c ****         }
 622:Drivers/lvgl/src/misc/lv_text.c ****         c = swapped;
 623:Drivers/lvgl/src/misc/lv_text.c ****     }
 624:Drivers/lvgl/src/misc/lv_text.c **** #endif
 625:Drivers/lvgl/src/misc/lv_text.c ****     return c;
 626:Drivers/lvgl/src/misc/lv_text.c **** }
