 241:Drivers/lvgl/src/misc/lv_text.c ****     uint32_t break_letter_count = 0; /*Number of characters up to the long word break point*/
 242:Drivers/lvgl/src/misc/lv_text.c **** 
 243:Drivers/lvgl/src/misc/lv_text.c ****     letter = lv_text_encoded_next(txt, &i_next);
 244:Drivers/lvgl/src/misc/lv_text.c ****     i_next_next = i_next;
 245:Drivers/lvgl/src/misc/lv_text.c **** 
 246:Drivers/lvgl/src/misc/lv_text.c ****     /*Obtain the full word, regardless if it fits or not in max_width*/
 247:Drivers/lvgl/src/misc/lv_text.c ****     while(txt[i] != '\0') {
 248:Drivers/lvgl/src/misc/lv_text.c ****         letter_next = lv_text_encoded_next(txt, &i_next_next);
 249:Drivers/lvgl/src/misc/lv_text.c ****         word_len++;
 250:Drivers/lvgl/src/misc/lv_text.c **** 
 251:Drivers/lvgl/src/misc/lv_text.c ****         /*Handle the recolor command*/
 252:Drivers/lvgl/src/misc/lv_text.c ****         if((flag & LV_TEXT_FLAG_RECOLOR) != 0) {
