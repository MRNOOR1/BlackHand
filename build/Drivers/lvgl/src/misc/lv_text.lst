 150:Drivers/lvgl/src/misc/lv_text_private.h **** 
 151:Drivers/lvgl/src/misc/lv_text_private.h ****     /*Compare the letter to TXT_BREAK_CHARS*/
 152:Drivers/lvgl/src/misc/lv_text_private.h ****     for(i = 0; LV_TXT_BREAK_CHARS[i] != '\0'; i++) {
 153:Drivers/lvgl/src/misc/lv_text_private.h ****         if(letter == (uint32_t)LV_TXT_BREAK_CHARS[i]) {
 154:Drivers/lvgl/src/misc/lv_text_private.h ****             ret = true; /*If match then it is break char*/
 155:Drivers/lvgl/src/misc/lv_text_private.h ****             break;
 156:Drivers/lvgl/src/misc/lv_text_private.h ****         }
 157:Drivers/lvgl/src/misc/lv_text_private.h ****     }
 158:Drivers/lvgl/src/misc/lv_text_private.h **** 
 159:Drivers/lvgl/src/misc/lv_text_private.h ****     return ret;
 160:Drivers/lvgl/src/misc/lv_text_private.h **** }
