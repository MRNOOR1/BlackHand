 294:Drivers/lvgl/src/misc/lv_text.c ****         if(word_w_ptr != NULL && break_index == NO_BREAK_FOUND) *word_w_ptr = cur_w;
 295:Drivers/lvgl/src/misc/lv_text.c **** 
 296:Drivers/lvgl/src/misc/lv_text.c ****         i = i_next;
 297:Drivers/lvgl/src/misc/lv_text.c ****         i_next = i_next_next;
 298:Drivers/lvgl/src/misc/lv_text.c ****         letter = letter_next;
 299:Drivers/lvgl/src/misc/lv_text.c ****     }
