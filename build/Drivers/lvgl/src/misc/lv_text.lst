 254:Drivers/lvgl/src/misc/lv_text.c ****                 i = i_next;
 255:Drivers/lvgl/src/misc/lv_text.c ****                 i_next = i_next_next;
 256:Drivers/lvgl/src/misc/lv_text.c ****                 letter = letter_next;
 257:Drivers/lvgl/src/misc/lv_text.c ****                 continue;   /*Skip the letter if it is part of a command*/
 258:Drivers/lvgl/src/misc/lv_text.c ****             }
 259:Drivers/lvgl/src/misc/lv_text.c ****         }
 260:Drivers/lvgl/src/misc/lv_text.c **** 
 261:Drivers/lvgl/src/misc/lv_text.c ****         letter_w = lv_font_get_glyph_width(font, letter, letter_next);
 262:Drivers/lvgl/src/misc/lv_text.c ****         cur_w += letter_w;
 263:Drivers/lvgl/src/misc/lv_text.c **** 
 264:Drivers/lvgl/src/misc/lv_text.c ****         if(letter_w > 0) {
 265:Drivers/lvgl/src/misc/lv_text.c ****             cur_w += letter_space;
 266:Drivers/lvgl/src/misc/lv_text.c ****         }
 267:Drivers/lvgl/src/misc/lv_text.c **** 
 268:Drivers/lvgl/src/misc/lv_text.c ****         /*Test if this character fits within max_width*/
 269:Drivers/lvgl/src/misc/lv_text.c ****         if(break_index == NO_BREAK_FOUND && (cur_w - letter_space) > max_width) {
 270:Drivers/lvgl/src/misc/lv_text.c ****             break_index = i;
 271:Drivers/lvgl/src/misc/lv_text.c ****             break_letter_count = word_len - 1;
 272:Drivers/lvgl/src/misc/lv_text.c ****             if(flag & LV_TEXT_FLAG_BREAK_ALL) {
 273:Drivers/lvgl/src/misc/lv_text.c ****                 break;
 274:Drivers/lvgl/src/misc/lv_text.c ****             }
 275:Drivers/lvgl/src/misc/lv_text.c ****             /*break_index is now pointing at the character that doesn't fit*/
 276:Drivers/lvgl/src/misc/lv_text.c ****         }
 277:Drivers/lvgl/src/misc/lv_text.c **** 
 278:Drivers/lvgl/src/misc/lv_text.c ****         /*Check for new line chars and breakchars*/
 279:Drivers/lvgl/src/misc/lv_text.c ****         if(letter == '\n' || letter == '\r' || lv_text_is_break_char(letter)) {
 280:Drivers/lvgl/src/misc/lv_text.c ****             /*Update the output width on the first character if it fits.
