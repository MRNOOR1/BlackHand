 271:Drivers/lvgl/src/misc/lv_anim.c **** uint32_t lv_anim_speed_to_time(uint32_t speed, int32_t start, int32_t end)
 272:Drivers/lvgl/src/misc/lv_anim.c **** {
 273:Drivers/lvgl/src/misc/lv_anim.c ****     uint32_t d = LV_ABS(start - end);
 274:Drivers/lvgl/src/misc/lv_anim.c ****     uint32_t time = (d * 1000) / speed;
 275:Drivers/lvgl/src/misc/lv_anim.c **** 
 276:Drivers/lvgl/src/misc/lv_anim.c ****     time = time == 0 ? 1 : time;
 277:Drivers/lvgl/src/misc/lv_anim.c **** 
 278:Drivers/lvgl/src/misc/lv_anim.c ****     return time;
 279:Drivers/lvgl/src/misc/lv_anim.c **** }
