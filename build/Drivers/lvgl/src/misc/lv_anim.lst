 522:Drivers/lvgl/src/misc/lv_anim.c **** uint32_t lv_anim_resolve_speed(uint32_t speed_or_time, int32_t start, int32_t end)
 523:Drivers/lvgl/src/misc/lv_anim.c **** {
 524:Drivers/lvgl/src/misc/lv_anim.c ****     /*It was a simple time*/
 525:Drivers/lvgl/src/misc/lv_anim.c ****     if((speed_or_time & LV_ANIM_SPEED_MASK) == 0) return speed_or_time;
 526:Drivers/lvgl/src/misc/lv_anim.c **** 
 527:Drivers/lvgl/src/misc/lv_anim.c ****     uint32_t d    = LV_ABS(start - end);
 528:Drivers/lvgl/src/misc/lv_anim.c ****     uint32_t speed = speed_or_time & 0x3FF;
 529:Drivers/lvgl/src/misc/lv_anim.c ****     uint32_t time = (d * 100) / speed; /*Speed is in 10 units per sec*/
