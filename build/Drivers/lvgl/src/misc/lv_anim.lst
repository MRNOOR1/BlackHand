 257:Drivers/lvgl/src/misc/lv_anim.c ****     /*Lower the resolution to fit the 0.1023 range*/
 258:Drivers/lvgl/src/misc/lv_anim.c ****     speed = (speed + 5) / 10;
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//cc5tALs0.s 			page 6


 259:Drivers/lvgl/src/misc/lv_anim.c ****     min_time = (min_time + 5) / 10;
 260:Drivers/lvgl/src/misc/lv_anim.c ****     max_time = (max_time + 5) / 10;
 261:Drivers/lvgl/src/misc/lv_anim.c **** 
 262:Drivers/lvgl/src/misc/lv_anim.c ****     return LV_ANIM_SPEED_MASK + (max_time << 20) + (min_time << 10) + speed;
 263:Drivers/lvgl/src/misc/lv_anim.c **** 
 264:Drivers/lvgl/src/misc/lv_anim.c **** }
