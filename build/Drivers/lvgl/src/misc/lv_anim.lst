 811:Drivers/lvgl/src/misc/lv_anim.c ****     while(a != NULL) {
 812:Drivers/lvgl/src/misc/lv_anim.c ****         bool del = false;
 813:Drivers/lvgl/src/misc/lv_anim.c ****         /*We can't test for custom_exec_cb equality because in the MicroPython binding
 814:Drivers/lvgl/src/misc/lv_anim.c ****          *a wrapper callback is used here an the real callback data is stored in the `user_data`.
 815:Drivers/lvgl/src/misc/lv_anim.c ****          *Therefore equality check would remove all animations.*/
 816:Drivers/lvgl/src/misc/lv_anim.c ****         if(a != a_current &&
 817:Drivers/lvgl/src/misc/lv_anim.c ****            (a->act_time >= 0 || a->early_apply) &&
 818:Drivers/lvgl/src/misc/lv_anim.c ****            (a->var == a_current->var) &&
 819:Drivers/lvgl/src/misc/lv_anim.c ****            ((a->exec_cb && a->exec_cb == a_current->exec_cb)
 820:Drivers/lvgl/src/misc/lv_anim.c ****             /*|| (a->custom_exec_cb && a->custom_exec_cb == a_current->custom_exec_cb)*/)) {
 821:Drivers/lvgl/src/misc/lv_anim.c ****             lv_ll_remove(anim_ll_p, a);
 822:Drivers/lvgl/src/misc/lv_anim.c ****             if(a->deleted_cb != NULL) a->deleted_cb(a);
 823:Drivers/lvgl/src/misc/lv_anim.c **** #if LV_USE_EXT_DATA
 824:Drivers/lvgl/src/misc/lv_anim.c ****             if(a->ext_data.free_cb) {
 825:Drivers/lvgl/src/misc/lv_anim.c ****                 a->ext_data.free_cb(a->ext_data.data);
 826:Drivers/lvgl/src/misc/lv_anim.c ****                 a->ext_data.data = NULL;
 827:Drivers/lvgl/src/misc/lv_anim.c ****             }
 828:Drivers/lvgl/src/misc/lv_anim.c **** #endif
 829:Drivers/lvgl/src/misc/lv_anim.c ****             lv_free(a);
