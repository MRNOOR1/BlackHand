 831:Drivers/lvgl/src/misc/lv_anim.c ****             anim_mark_list_change();
 832:Drivers/lvgl/src/misc/lv_anim.c **** 
 833:Drivers/lvgl/src/misc/lv_anim.c ****             del_any = true;
 834:Drivers/lvgl/src/misc/lv_anim.c ****             del = true;
 835:Drivers/lvgl/src/misc/lv_anim.c ****         }
 836:Drivers/lvgl/src/misc/lv_anim.c **** 
 837:Drivers/lvgl/src/misc/lv_anim.c ****         /*Always start from the head on delete, because we don't know
