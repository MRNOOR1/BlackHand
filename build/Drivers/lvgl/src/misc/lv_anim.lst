 286:Drivers/lvgl/src/misc/lv_anim.c **** int32_t lv_anim_path_linear(const lv_anim_t * a)
 287:Drivers/lvgl/src/misc/lv_anim.c **** {
 288:Drivers/lvgl/src/misc/lv_anim.c ****     /*Calculate the current step*/
 289:Drivers/lvgl/src/misc/lv_anim.c ****     int32_t step = lv_map(a->act_time, 0, a->duration, 0, LV_ANIM_RESOLUTION);
 290:Drivers/lvgl/src/misc/lv_anim.c **** 
 291:Drivers/lvgl/src/misc/lv_anim.c ****     /*Get the new value which will be proportional to `step`
 292:Drivers/lvgl/src/misc/lv_anim.c ****      *and the `start` and `end` values*/
 293:Drivers/lvgl/src/misc/lv_anim.c ****     int32_t new_value;
 294:Drivers/lvgl/src/misc/lv_anim.c ****     new_value = step * (a->end_value - a->start_value);
 295:Drivers/lvgl/src/misc/lv_anim.c ****     new_value = new_value >> LV_ANIM_RES_SHIFT;
 296:Drivers/lvgl/src/misc/lv_anim.c ****     new_value += a->start_value;
 297:Drivers/lvgl/src/misc/lv_anim.c **** 
 298:Drivers/lvgl/src/misc/lv_anim.c ****     return new_value;
 299:Drivers/lvgl/src/misc/lv_anim.c **** }
