 324:Drivers/lvgl/src/misc/lv_anim.c **** int32_t lv_anim_path_bounce(const lv_anim_t * a)
 325:Drivers/lvgl/src/misc/lv_anim.c **** {
 326:Drivers/lvgl/src/misc/lv_anim.c ****     /*Calculate the current step*/
 327:Drivers/lvgl/src/misc/lv_anim.c ****     int32_t t = lv_map(a->act_time, 0, a->duration, 0, LV_BEZIER_VAL_MAX);
 328:Drivers/lvgl/src/misc/lv_anim.c ****     int32_t diff = (a->end_value - a->start_value);
 329:Drivers/lvgl/src/misc/lv_anim.c **** 
 330:Drivers/lvgl/src/misc/lv_anim.c ****     /*3 bounces has 5 parts: 3 down and 2 up. One part is t / 5 long*/
 331:Drivers/lvgl/src/misc/lv_anim.c **** 
 332:Drivers/lvgl/src/misc/lv_anim.c ****     if(t < 408) {
 333:Drivers/lvgl/src/misc/lv_anim.c ****         /*Go down*/
 334:Drivers/lvgl/src/misc/lv_anim.c ****         t = (t * 2500) >> LV_BEZIER_VAL_SHIFT; /*[0..1024] range*/
 335:Drivers/lvgl/src/misc/lv_anim.c ****         t = LV_BEZIER_VAL_MAX - t;
 336:Drivers/lvgl/src/misc/lv_anim.c ****     }
 337:Drivers/lvgl/src/misc/lv_anim.c ****     else if(t >= 408 && t < 614) {
 338:Drivers/lvgl/src/misc/lv_anim.c ****         /*First bounce back*/
 339:Drivers/lvgl/src/misc/lv_anim.c ****         t -= 408;
 340:Drivers/lvgl/src/misc/lv_anim.c ****         t    = t * 5; /*to [0..1024] range*/
 341:Drivers/lvgl/src/misc/lv_anim.c ****         diff = diff / 20;
 342:Drivers/lvgl/src/misc/lv_anim.c ****     }
 343:Drivers/lvgl/src/misc/lv_anim.c ****     else if(t >= 614 && t < 819) {
 344:Drivers/lvgl/src/misc/lv_anim.c ****         /*Fall back*/
 345:Drivers/lvgl/src/misc/lv_anim.c ****         t -= 614;
 346:Drivers/lvgl/src/misc/lv_anim.c ****         t    = t * 5; /*to [0..1024] range*/
 347:Drivers/lvgl/src/misc/lv_anim.c ****         t    = LV_BEZIER_VAL_MAX - t;
 348:Drivers/lvgl/src/misc/lv_anim.c ****         diff = diff / 20;
 349:Drivers/lvgl/src/misc/lv_anim.c ****     }
 350:Drivers/lvgl/src/misc/lv_anim.c ****     else if(t >= 819 && t < 921) {
 351:Drivers/lvgl/src/misc/lv_anim.c ****         /*Second bounce back*/
 352:Drivers/lvgl/src/misc/lv_anim.c ****         t -= 819;
 353:Drivers/lvgl/src/misc/lv_anim.c ****         t    = t * 10; /*to [0..1024] range*/
 354:Drivers/lvgl/src/misc/lv_anim.c ****         diff = diff / 40;
 355:Drivers/lvgl/src/misc/lv_anim.c ****     }
 356:Drivers/lvgl/src/misc/lv_anim.c ****     else if(t >= 921 && t <= LV_BEZIER_VAL_MAX) {
 357:Drivers/lvgl/src/misc/lv_anim.c ****         /*Fall back*/
 358:Drivers/lvgl/src/misc/lv_anim.c ****         t -= 921;
 359:Drivers/lvgl/src/misc/lv_anim.c ****         t    = t * 10; /*to [0..1024] range*/
 360:Drivers/lvgl/src/misc/lv_anim.c ****         t    = LV_BEZIER_VAL_MAX - t;
 361:Drivers/lvgl/src/misc/lv_anim.c ****         diff = diff / 40;
 362:Drivers/lvgl/src/misc/lv_anim.c ****     }
 363:Drivers/lvgl/src/misc/lv_anim.c **** 
 364:Drivers/lvgl/src/misc/lv_anim.c ****     if(t > LV_BEZIER_VAL_MAX) t = LV_BEZIER_VAL_MAX;
 365:Drivers/lvgl/src/misc/lv_anim.c ****     if(t < 0) t = 0;
 366:Drivers/lvgl/src/misc/lv_anim.c ****     int32_t step = lv_bezier3(t, 0, 500, 800, LV_BEZIER_VAL_MAX);
 367:Drivers/lvgl/src/misc/lv_anim.c **** 
 368:Drivers/lvgl/src/misc/lv_anim.c ****     int32_t new_value;
 369:Drivers/lvgl/src/misc/lv_anim.c ****     new_value = step * diff;
 370:Drivers/lvgl/src/misc/lv_anim.c ****     new_value = new_value >> LV_BEZIER_VAL_SHIFT;
 371:Drivers/lvgl/src/misc/lv_anim.c ****     new_value = a->end_value - new_value;
 372:Drivers/lvgl/src/misc/lv_anim.c **** 
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//cc5tALs0.s 			page 8


 373:Drivers/lvgl/src/misc/lv_anim.c ****     return new_value;
 374:Drivers/lvgl/src/misc/lv_anim.c **** }
 375:Drivers/lvgl/src/misc/lv_anim.c **** 
 376:Drivers/lvgl/src/misc/lv_anim.c **** int32_t lv_anim_path_step(const lv_anim_t * a)
 377:Drivers/lvgl/src/misc/lv_anim.c **** {
 378:Drivers/lvgl/src/misc/lv_anim.c ****     if(a->act_time >= a->duration)
 379:Drivers/lvgl/src/misc/lv_anim.c ****         return a->end_value;
 380:Drivers/lvgl/src/misc/lv_anim.c ****     else
 381:Drivers/lvgl/src/misc/lv_anim.c ****         return a->start_value;
 382:Drivers/lvgl/src/misc/lv_anim.c **** }
