 686:Drivers/lvgl/src/misc/lv_anim.c ****     /*Delete animation if
 687:Drivers/lvgl/src/misc/lv_anim.c ****      * - no repeat left and no reverse play scheduled (simple one shot animation); or
 688:Drivers/lvgl/src/misc/lv_anim.c ****      * - no repeat, reverse play enabled (reverse_duration != 0) and reverse play is completed. */
 689:Drivers/lvgl/src/misc/lv_anim.c ****     if(a->repeat_cnt == 0 && (a->reverse_duration == 0 || a->reverse_play_in_progress == 1)) {
 690:Drivers/lvgl/src/misc/lv_anim.c **** 
