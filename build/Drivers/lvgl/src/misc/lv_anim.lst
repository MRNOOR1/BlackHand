 532:Drivers/lvgl/src/misc/lv_anim.c **** 
 533:Drivers/lvgl/src/misc/lv_anim.c ****     return LV_CLAMP(min_time * 10, time, max_time * 10);
 534:Drivers/lvgl/src/misc/lv_anim.c **** }
