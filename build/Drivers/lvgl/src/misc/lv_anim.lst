 172:Drivers/lvgl/src/misc/lv_anim.c **** uint32_t lv_anim_get_playtime(const lv_anim_t * a)
 173:Drivers/lvgl/src/misc/lv_anim.c **** {
 174:Drivers/lvgl/src/misc/lv_anim.c ****     if(a->repeat_cnt == LV_ANIM_REPEAT_INFINITE) {
 175:Drivers/lvgl/src/misc/lv_anim.c ****         return LV_ANIM_PLAYTIME_INFINITE;
 176:Drivers/lvgl/src/misc/lv_anim.c ****     }
 177:Drivers/lvgl/src/misc/lv_anim.c **** 
 178:Drivers/lvgl/src/misc/lv_anim.c ****     uint32_t repeat_cnt = a->repeat_cnt;
 179:Drivers/lvgl/src/misc/lv_anim.c ****     if(repeat_cnt < 1) repeat_cnt = 1;
 180:Drivers/lvgl/src/misc/lv_anim.c **** 
 181:Drivers/lvgl/src/misc/lv_anim.c ****     uint32_t playtime = a->repeat_delay + a->duration + a->reverse_delay + a->reverse_duration;
 182:Drivers/lvgl/src/misc/lv_anim.c ****     playtime = playtime * repeat_cnt;
 183:Drivers/lvgl/src/misc/lv_anim.c ****     return playtime;
 184:Drivers/lvgl/src/misc/lv_anim.c **** }
