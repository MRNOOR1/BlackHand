 123:Drivers/lvgl/src/misc/lv_anim.c **** lv_anim_t * lv_anim_start(const lv_anim_t * a)
 124:Drivers/lvgl/src/misc/lv_anim.c **** {
 125:Drivers/lvgl/src/misc/lv_anim.c ****     LV_TRACE_ANIM("begin");
 126:Drivers/lvgl/src/misc/lv_anim.c **** 
 127:Drivers/lvgl/src/misc/lv_anim.c ****     /*Do not let two animations for the same 'var' with the same 'exec_cb'*/
 128:Drivers/lvgl/src/misc/lv_anim.c ****     if(a->early_apply && (a->exec_cb || a->custom_exec_cb)) {
 129:Drivers/lvgl/src/misc/lv_anim.c ****         remove_concurrent_anims(a);
 130:Drivers/lvgl/src/misc/lv_anim.c ****     }
 131:Drivers/lvgl/src/misc/lv_anim.c **** 
 132:Drivers/lvgl/src/misc/lv_anim.c ****     /*Add the new animation to the animation linked list*/
 133:Drivers/lvgl/src/misc/lv_anim.c ****     lv_anim_t * new_anim = lv_ll_ins_head(anim_ll_p);
 134:Drivers/lvgl/src/misc/lv_anim.c ****     LV_ASSERT_MALLOC(new_anim);
 135:Drivers/lvgl/src/misc/lv_anim.c ****     if(new_anim == NULL) return NULL;
 136:Drivers/lvgl/src/misc/lv_anim.c **** 
 137:Drivers/lvgl/src/misc/lv_anim.c ****     /*Initialize the animation descriptor*/
 138:Drivers/lvgl/src/misc/lv_anim.c ****     lv_memcpy(new_anim, a, sizeof(lv_anim_t));
 139:Drivers/lvgl/src/misc/lv_anim.c ****     if(a->var == a) new_anim->var = new_anim;
 140:Drivers/lvgl/src/misc/lv_anim.c ****     new_anim->run_round = state.anim_run_round;
 141:Drivers/lvgl/src/misc/lv_anim.c ****     new_anim->last_timer_run = lv_tick_get();
 142:Drivers/lvgl/src/misc/lv_anim.c ****     new_anim->is_paused = false;
 143:Drivers/lvgl/src/misc/lv_anim.c **** 
 144:Drivers/lvgl/src/misc/lv_anim.c ****     /*Set the start value*/
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//cc5tALs0.s 			page 4


 145:Drivers/lvgl/src/misc/lv_anim.c ****     if(new_anim->early_apply) {
 146:Drivers/lvgl/src/misc/lv_anim.c ****         if(new_anim->get_value_cb) {
 147:Drivers/lvgl/src/misc/lv_anim.c ****             int32_t v_ofs = new_anim->get_value_cb(new_anim);
 148:Drivers/lvgl/src/misc/lv_anim.c ****             new_anim->start_value += v_ofs;
 149:Drivers/lvgl/src/misc/lv_anim.c ****             new_anim->end_value += v_ofs;
 150:Drivers/lvgl/src/misc/lv_anim.c **** 
 151:Drivers/lvgl/src/misc/lv_anim.c ****         }
 152:Drivers/lvgl/src/misc/lv_anim.c **** 
 153:Drivers/lvgl/src/misc/lv_anim.c ****         resolve_time(new_anim);
 154:Drivers/lvgl/src/misc/lv_anim.c **** 
 155:Drivers/lvgl/src/misc/lv_anim.c ****         new_anim->current_value = new_anim->path_cb(new_anim);
 156:Drivers/lvgl/src/misc/lv_anim.c ****         if(new_anim->exec_cb) {
 157:Drivers/lvgl/src/misc/lv_anim.c ****             new_anim->exec_cb(new_anim->var, new_anim->current_value);
 158:Drivers/lvgl/src/misc/lv_anim.c ****         }
 159:Drivers/lvgl/src/misc/lv_anim.c ****         if(new_anim->custom_exec_cb) {
 160:Drivers/lvgl/src/misc/lv_anim.c ****             new_anim->custom_exec_cb(new_anim, new_anim->current_value);
 161:Drivers/lvgl/src/misc/lv_anim.c ****         }
 162:Drivers/lvgl/src/misc/lv_anim.c ****     }
 163:Drivers/lvgl/src/misc/lv_anim.c **** 
 164:Drivers/lvgl/src/misc/lv_anim.c ****     /*Creating an animation changed the linked list.
 165:Drivers/lvgl/src/misc/lv_anim.c ****      *It's important if it happens in a ready callback. (see `anim_timer`)*/
 166:Drivers/lvgl/src/misc/lv_anim.c ****     anim_mark_list_change();
 167:Drivers/lvgl/src/misc/lv_anim.c **** 
