 186:Drivers/lvgl/src/misc/lv_anim.c **** bool lv_anim_delete(void * var, lv_anim_exec_xcb_t exec_cb)
 187:Drivers/lvgl/src/misc/lv_anim.c **** {
 188:Drivers/lvgl/src/misc/lv_anim.c ****     lv_anim_t * a;
 189:Drivers/lvgl/src/misc/lv_anim.c ****     bool del_any = false;
 190:Drivers/lvgl/src/misc/lv_anim.c ****     a        = lv_ll_get_head(anim_ll_p);
 191:Drivers/lvgl/src/misc/lv_anim.c ****     while(a != NULL) {
 192:Drivers/lvgl/src/misc/lv_anim.c ****         bool del = false;
 193:Drivers/lvgl/src/misc/lv_anim.c ****         if((a->var == var || var == NULL) && (a->exec_cb == exec_cb || exec_cb == NULL)) {
 194:Drivers/lvgl/src/misc/lv_anim.c ****             remove_anim(a);
 195:Drivers/lvgl/src/misc/lv_anim.c ****             anim_mark_list_change(); /*Read by `anim_timer`. It need to know if a delete occurred i
 196:Drivers/lvgl/src/misc/lv_anim.c ****                                        the linked list*/
 197:Drivers/lvgl/src/misc/lv_anim.c ****             del_any = true;
 198:Drivers/lvgl/src/misc/lv_anim.c ****             del = true;
 199:Drivers/lvgl/src/misc/lv_anim.c ****         }
 200:Drivers/lvgl/src/misc/lv_anim.c **** 
 201:Drivers/lvgl/src/misc/lv_anim.c ****         /*Always start from the head on delete, because we don't know
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//cc5tALs0.s 			page 5


 202:Drivers/lvgl/src/misc/lv_anim.c ****          *how `anim_ll_p` was changes in `a->deleted_cb` */
 203:Drivers/lvgl/src/misc/lv_anim.c ****         a = del ? lv_ll_get_head(anim_ll_p) : lv_ll_get_next(anim_ll_p, a);
 204:Drivers/lvgl/src/misc/lv_anim.c ****     }
 205:Drivers/lvgl/src/misc/lv_anim.c **** 
 206:Drivers/lvgl/src/misc/lv_anim.c ****     return del_any;
 207:Drivers/lvgl/src/misc/lv_anim.c **** }
