 799:Drivers/lvgl/src/misc/lv_anim.c ****  * Remove animations which are animating the same var with the same exec_cb
 800:Drivers/lvgl/src/misc/lv_anim.c ****  * and they are already running or they have early_apply
 801:Drivers/lvgl/src/misc/lv_anim.c ****  * @param a_current     the current animation, use its var and exec_cb as reference to know what to
 802:Drivers/lvgl/src/misc/lv_anim.c ****  * @return              true: at least one animation was delete
 803:Drivers/lvgl/src/misc/lv_anim.c ****  */
 804:Drivers/lvgl/src/misc/lv_anim.c **** static bool remove_concurrent_anims(const lv_anim_t * a_current)
 805:Drivers/lvgl/src/misc/lv_anim.c **** {
 806:Drivers/lvgl/src/misc/lv_anim.c ****     if(a_current->exec_cb == NULL && a_current->custom_exec_cb == NULL) return false;
 807:Drivers/lvgl/src/misc/lv_anim.c **** 
