 679:Drivers/lvgl/src/misc/lv_anim.c **** static void anim_completed_handler(lv_anim_t * a)
 680:Drivers/lvgl/src/misc/lv_anim.c **** {
 681:Drivers/lvgl/src/misc/lv_anim.c ****     /*In the end of a forward anim decrement repeat cnt.*/
 682:Drivers/lvgl/src/misc/lv_anim.c ****     if(a->reverse_play_in_progress == 0 && a->repeat_cnt > 0 && a->repeat_cnt != LV_ANIM_REPEAT_INF
 683:Drivers/lvgl/src/misc/lv_anim.c ****         a->repeat_cnt--;
