 706:Drivers/lvgl/src/misc/lv_anim.c ****         lv_free(a);
 707:Drivers/lvgl/src/misc/lv_anim.c ****     }
 708:Drivers/lvgl/src/misc/lv_anim.c ****     /*If the animation is not deleted then restart it*/
 709:Drivers/lvgl/src/misc/lv_anim.c ****     else {
 710:Drivers/lvgl/src/misc/lv_anim.c ****         /*Restart the animation. If the time is over a little compensate it.*/
