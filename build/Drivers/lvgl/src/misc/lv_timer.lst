 384:Drivers/lvgl/src/misc/lv_timer.c **** /**
 385:Drivers/lvgl/src/misc/lv_timer.c ****  * Find out how much time remains before a timer must be run.
 386:Drivers/lvgl/src/misc/lv_timer.c ****  * @param timer pointer to lv_timer
 387:Drivers/lvgl/src/misc/lv_timer.c ****  * @return the time remaining, or 0 if it needs to be run again
 388:Drivers/lvgl/src/misc/lv_timer.c ****  */
 389:Drivers/lvgl/src/misc/lv_timer.c **** static uint32_t lv_timer_time_remaining(lv_timer_t * timer)
 390:Drivers/lvgl/src/misc/lv_timer.c **** {
 391:Drivers/lvgl/src/misc/lv_timer.c ****     /*Check if at least 'period' time elapsed*/
 392:Drivers/lvgl/src/misc/lv_timer.c ****     uint32_t elp = lv_tick_elaps(timer->last_run);
 393:Drivers/lvgl/src/misc/lv_timer.c ****     if(elp >= timer->period)
 394:Drivers/lvgl/src/misc/lv_timer.c ****         return 0;
 395:Drivers/lvgl/src/misc/lv_timer.c ****     return timer->period - elp;
 396:Drivers/lvgl/src/misc/lv_timer.c **** }
