 100:Drivers/lvgl/src/misc/lv_timer.c **** 
 101:Drivers/lvgl/src/misc/lv_timer.c ****         timer_active = lv_ll_get_head(timer_head);
 102:Drivers/lvgl/src/misc/lv_timer.c ****         while(timer_active) {
 103:Drivers/lvgl/src/misc/lv_timer.c ****             /*The timer might be deleted if it runs only once ('repeat_count = 1')
 104:Drivers/lvgl/src/misc/lv_timer.c ****              *So get next element until the current is surely valid*/
 105:Drivers/lvgl/src/misc/lv_timer.c ****             next = lv_ll_get_next(timer_head, timer_active);
 106:Drivers/lvgl/src/misc/lv_timer.c **** 
 107:Drivers/lvgl/src/misc/lv_timer.c ****             if(lv_timer_exec(timer_active)) {
 108:Drivers/lvgl/src/misc/lv_timer.c ****                 /*If a timer was created or deleted then this or the next item might be corrupted*/
 109:Drivers/lvgl/src/misc/lv_timer.c ****                 if(state_p->timer_created || state_p->timer_deleted) {
 110:Drivers/lvgl/src/misc/lv_timer.c ****                     LV_TRACE_TIMER("Start from the first timer again because a timer was created or
 111:Drivers/lvgl/src/misc/lv_timer.c ****                     break;
 112:Drivers/lvgl/src/misc/lv_timer.c ****                 }
 113:Drivers/lvgl/src/misc/lv_timer.c ****             }
 114:Drivers/lvgl/src/misc/lv_timer.c **** 
 115:Drivers/lvgl/src/misc/lv_timer.c ****             timer_active = next; /*Load the next timer*/
 116:Drivers/lvgl/src/misc/lv_timer.c ****         }
 117:Drivers/lvgl/src/misc/lv_timer.c ****     } while(timer_active);
 118:Drivers/lvgl/src/misc/lv_timer.c **** 
 119:Drivers/lvgl/src/misc/lv_timer.c ****     uint32_t time_until_next = LV_NO_TIMER_READY;
 120:Drivers/lvgl/src/misc/lv_timer.c ****     next = lv_ll_get_head(timer_head);
 121:Drivers/lvgl/src/misc/lv_timer.c ****     while(next) {
 122:Drivers/lvgl/src/misc/lv_timer.c ****         if(!next->paused) {
 123:Drivers/lvgl/src/misc/lv_timer.c ****             uint32_t delay = lv_timer_time_remaining(next);
 124:Drivers/lvgl/src/misc/lv_timer.c ****             if(delay < time_until_next)
 125:Drivers/lvgl/src/misc/lv_timer.c ****                 time_until_next = delay;
 126:Drivers/lvgl/src/misc/lv_timer.c ****         }
 127:Drivers/lvgl/src/misc/lv_timer.c **** 
 128:Drivers/lvgl/src/misc/lv_timer.c ****         next = lv_ll_get_next(timer_head, next); /*Find the next timer*/
 129:Drivers/lvgl/src/misc/lv_timer.c ****     }
 130:Drivers/lvgl/src/misc/lv_timer.c **** 
 131:Drivers/lvgl/src/misc/lv_timer.c ****     state_p->busy_time += lv_tick_elaps(handler_start);
 132:Drivers/lvgl/src/misc/lv_timer.c ****     uint32_t idle_period_time = lv_tick_elaps(state_p->idle_period_start);
 133:Drivers/lvgl/src/misc/lv_timer.c ****     if(idle_period_time >= IDLE_MEAS_PERIOD) {
 134:Drivers/lvgl/src/misc/lv_timer.c ****         state_p->idle_last         = (state_p->busy_time * 100) / idle_period_time;  /*Calculate th
 135:Drivers/lvgl/src/misc/lv_timer.c ****         state_p->idle_last         = state_p->idle_last > 100 ? 0 : 100 - state_p->idle_last; /*But
 136:Drivers/lvgl/src/misc/lv_timer.c ****         state_p->busy_time         = 0;
 137:Drivers/lvgl/src/misc/lv_timer.c ****         state_p->idle_period_start = lv_tick_get();
 138:Drivers/lvgl/src/misc/lv_timer.c ****     }
