  93:Drivers/lvgl/src/misc/lv_timer.c ****     /*Run all timer from the list*/
  94:Drivers/lvgl/src/misc/lv_timer.c ****     lv_timer_t * next;
  95:Drivers/lvgl/src/misc/lv_timer.c ****     lv_timer_t * timer_active;
  96:Drivers/lvgl/src/misc/lv_timer.c ****     lv_ll_t * timer_head = timer_ll_p;
  97:Drivers/lvgl/src/misc/lv_timer.c ****     do {
  98:Drivers/lvgl/src/misc/lv_timer.c ****         state_p->timer_deleted             = false;
