 332:Drivers/lvgl/src/misc/lv_timer.c **** /**
 333:Drivers/lvgl/src/misc/lv_timer.c ****  * Execute timer if its remaining time is zero
 334:Drivers/lvgl/src/misc/lv_timer.c ****  * @param timer pointer to lv_timer
 335:Drivers/lvgl/src/misc/lv_timer.c ****  * @return true: execute, false: not executed
 336:Drivers/lvgl/src/misc/lv_timer.c ****  */
 337:Drivers/lvgl/src/misc/lv_timer.c **** static bool lv_timer_exec(lv_timer_t * timer)
 338:Drivers/lvgl/src/misc/lv_timer.c **** {
 339:Drivers/lvgl/src/misc/lv_timer.c ****     if(timer->paused) return false;
 340:Drivers/lvgl/src/misc/lv_timer.c **** 
 341:Drivers/lvgl/src/misc/lv_timer.c ****     bool exec = false;
 342:Drivers/lvgl/src/misc/lv_timer.c ****     if(lv_timer_time_remaining(timer) == 0) {
 343:Drivers/lvgl/src/misc/lv_timer.c ****         /* Decrement the repeat count before executing the timer_cb.
 344:Drivers/lvgl/src/misc/lv_timer.c ****          * If any timer is deleted `if(timer->repeat_count == 0)` is not executed below
 345:Drivers/lvgl/src/misc/lv_timer.c ****          * but at least the repeat count is zero and the timer can be deleted in the next round*/
 346:Drivers/lvgl/src/misc/lv_timer.c ****         int32_t original_repeat_count = timer->repeat_count;
 347:Drivers/lvgl/src/misc/lv_timer.c ****         if(timer->repeat_count > 0) timer->repeat_count--;
 348:Drivers/lvgl/src/misc/lv_timer.c ****         timer->last_run = lv_tick_get();
 349:Drivers/lvgl/src/misc/lv_timer.c ****         LV_TRACE_TIMER("calling timer callback: %p", *((void **)&timer->timer_cb));
 350:Drivers/lvgl/src/misc/lv_timer.c **** 
 351:Drivers/lvgl/src/misc/lv_timer.c ****         if(timer->timer_cb && original_repeat_count != 0) {
 352:Drivers/lvgl/src/misc/lv_timer.c ****             LV_PROFILER_TIMER_BEGIN_TAG("timer_cb");
 353:Drivers/lvgl/src/misc/lv_timer.c ****             timer->timer_cb(timer);
 354:Drivers/lvgl/src/misc/lv_timer.c ****             LV_PROFILER_TIMER_END_TAG("timer_cb");
 355:Drivers/lvgl/src/misc/lv_timer.c ****         }
 356:Drivers/lvgl/src/misc/lv_timer.c **** 
 357:Drivers/lvgl/src/misc/lv_timer.c ****         if(!state.timer_deleted) {
 358:Drivers/lvgl/src/misc/lv_timer.c ****             LV_TRACE_TIMER("timer callback %p finished", *((void **)&timer->timer_cb));
 359:Drivers/lvgl/src/misc/lv_timer.c ****         }
 360:Drivers/lvgl/src/misc/lv_timer.c ****         else {
 361:Drivers/lvgl/src/misc/lv_timer.c ****             LV_TRACE_TIMER("timer callback finished");
 362:Drivers/lvgl/src/misc/lv_timer.c ****         }
 363:Drivers/lvgl/src/misc/lv_timer.c **** 
 364:Drivers/lvgl/src/misc/lv_timer.c ****         LV_ASSERT_MEM_INTEGRITY();
 365:Drivers/lvgl/src/misc/lv_timer.c ****         exec = true;
 366:Drivers/lvgl/src/misc/lv_timer.c ****     }
 367:Drivers/lvgl/src/misc/lv_timer.c **** 
 368:Drivers/lvgl/src/misc/lv_timer.c ****     if(state.timer_deleted == false) { /*The timer might be deleted by itself as well*/
 369:Drivers/lvgl/src/misc/lv_timer.c ****         if(timer->repeat_count == 0) { /*The repeat count is over, delete the timer*/
 370:Drivers/lvgl/src/misc/lv_timer.c ****             if(timer->auto_delete) {
 371:Drivers/lvgl/src/misc/lv_timer.c ****                 LV_TRACE_TIMER("deleting timer with %p callback because the repeat count is over", 
 372:Drivers/lvgl/src/misc/lv_timer.c ****                 lv_timer_delete(timer);
 373:Drivers/lvgl/src/misc/lv_timer.c ****             }
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//cckyXFEd.s 			page 8


 374:Drivers/lvgl/src/misc/lv_timer.c ****             else {
 375:Drivers/lvgl/src/misc/lv_timer.c ****                 LV_TRACE_TIMER("pausing timer with %p callback because the repeat count is over", *
 376:Drivers/lvgl/src/misc/lv_timer.c ****                 lv_timer_pause(timer);
 377:Drivers/lvgl/src/misc/lv_timer.c ****             }
 378:Drivers/lvgl/src/misc/lv_timer.c ****         }
 379:Drivers/lvgl/src/misc/lv_timer.c ****     }
 380:Drivers/lvgl/src/misc/lv_timer.c **** 
 381:Drivers/lvgl/src/misc/lv_timer.c ****     return exec;
 382:Drivers/lvgl/src/misc/lv_timer.c **** }
