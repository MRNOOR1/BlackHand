  94:Drivers/lvgl/src/misc/lv_area.c **** bool lv_area_intersect(lv_area_t * res_p, const lv_area_t * a1_p, const lv_area_t * a2_p)
  95:Drivers/lvgl/src/misc/lv_area.c **** {
  96:Drivers/lvgl/src/misc/lv_area.c ****     /*Get the smaller area from 'a1_p' and 'a2_p'*/
  97:Drivers/lvgl/src/misc/lv_area.c ****     res_p->x1 = LV_MAX(a1_p->x1, a2_p->x1);
  98:Drivers/lvgl/src/misc/lv_area.c ****     res_p->y1 = LV_MAX(a1_p->y1, a2_p->y1);
  99:Drivers/lvgl/src/misc/lv_area.c ****     res_p->x2 = LV_MIN(a1_p->x2, a2_p->x2);
 100:Drivers/lvgl/src/misc/lv_area.c ****     res_p->y2 = LV_MIN(a1_p->y2, a2_p->y2);
 101:Drivers/lvgl/src/misc/lv_area.c **** 
 102:Drivers/lvgl/src/misc/lv_area.c ****     /*If x1 or y1 greater than x2 or y2 then the areas union is empty*/
 103:Drivers/lvgl/src/misc/lv_area.c ****     bool union_ok = true;
 104:Drivers/lvgl/src/misc/lv_area.c ****     if((res_p->x1 > res_p->x2) || (res_p->y1 > res_p->y2)) {
 105:Drivers/lvgl/src/misc/lv_area.c ****         union_ok = false;
 106:Drivers/lvgl/src/misc/lv_area.c ****     }
 107:Drivers/lvgl/src/misc/lv_area.c **** 
 108:Drivers/lvgl/src/misc/lv_area.c ****     return union_ok;
 109:Drivers/lvgl/src/misc/lv_area.c **** }
