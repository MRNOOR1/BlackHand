 176:Drivers/lvgl/src/misc/lv_area.c **** void lv_area_join(lv_area_t * a_res_p, const lv_area_t * a1_p, const lv_area_t * a2_p)
 177:Drivers/lvgl/src/misc/lv_area.c **** {
 178:Drivers/lvgl/src/misc/lv_area.c ****     a_res_p->x1 = LV_MIN(a1_p->x1, a2_p->x1);
 179:Drivers/lvgl/src/misc/lv_area.c ****     a_res_p->y1 = LV_MIN(a1_p->y1, a2_p->y1);
 180:Drivers/lvgl/src/misc/lv_area.c ****     a_res_p->x2 = LV_MAX(a1_p->x2, a2_p->x2);
 181:Drivers/lvgl/src/misc/lv_area.c ****     a_res_p->y2 = LV_MAX(a1_p->y2, a2_p->y2);
 182:Drivers/lvgl/src/misc/lv_area.c **** }
