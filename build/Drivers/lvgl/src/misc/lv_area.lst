 184:Drivers/lvgl/src/misc/lv_area.c **** bool lv_area_is_point_on(const lv_area_t * a_p, const lv_point_t * p_p, int32_t radius)
 185:Drivers/lvgl/src/misc/lv_area.c **** {
 186:Drivers/lvgl/src/misc/lv_area.c ****     /*First check the basic area*/
 187:Drivers/lvgl/src/misc/lv_area.c ****     bool is_on_rect = false;
 188:Drivers/lvgl/src/misc/lv_area.c ****     if((p_p->x >= a_p->x1 && p_p->x <= a_p->x2) && ((p_p->y >= a_p->y1 && p_p->y <= a_p->y2))) {
 189:Drivers/lvgl/src/misc/lv_area.c ****         is_on_rect = true;
 190:Drivers/lvgl/src/misc/lv_area.c ****     }
 191:Drivers/lvgl/src/misc/lv_area.c ****     if(!is_on_rect)
 192:Drivers/lvgl/src/misc/lv_area.c ****         return false;
 193:Drivers/lvgl/src/misc/lv_area.c ****     /*Now handle potential rounded rectangles*/
 194:Drivers/lvgl/src/misc/lv_area.c ****     if(radius <= 0) {
 195:Drivers/lvgl/src/misc/lv_area.c ****         /*No radius, it is within the rectangle*/
 196:Drivers/lvgl/src/misc/lv_area.c ****         return true;
 197:Drivers/lvgl/src/misc/lv_area.c ****     }
 198:Drivers/lvgl/src/misc/lv_area.c ****     int32_t w = lv_area_get_width(a_p) / 2;
 199:Drivers/lvgl/src/misc/lv_area.c ****     int32_t h = lv_area_get_height(a_p) / 2;
 200:Drivers/lvgl/src/misc/lv_area.c ****     int32_t max_radius = LV_MIN(w, h);
 201:Drivers/lvgl/src/misc/lv_area.c ****     if(radius > max_radius)
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//ccfwYGJo.s 			page 5


 202:Drivers/lvgl/src/misc/lv_area.c ****         radius = max_radius;
 203:Drivers/lvgl/src/misc/lv_area.c **** 
 204:Drivers/lvgl/src/misc/lv_area.c ****     /*Check if it's in one of the corners*/
 205:Drivers/lvgl/src/misc/lv_area.c ****     lv_area_t corner_area;
 206:Drivers/lvgl/src/misc/lv_area.c ****     /*Top left*/
 207:Drivers/lvgl/src/misc/lv_area.c ****     corner_area.x1 = a_p->x1;
 208:Drivers/lvgl/src/misc/lv_area.c ****     corner_area.x2 = a_p->x1 + radius;
 209:Drivers/lvgl/src/misc/lv_area.c ****     corner_area.y1 = a_p->y1;
 210:Drivers/lvgl/src/misc/lv_area.c ****     corner_area.y2 = a_p->y1 + radius;
 211:Drivers/lvgl/src/misc/lv_area.c ****     if(lv_area_is_point_on(&corner_area, p_p, 0)) {
 212:Drivers/lvgl/src/misc/lv_area.c ****         corner_area.x2 += radius;
 213:Drivers/lvgl/src/misc/lv_area.c ****         corner_area.y2 += radius;
 214:Drivers/lvgl/src/misc/lv_area.c ****         return lv_point_within_circle(&corner_area, p_p);
 215:Drivers/lvgl/src/misc/lv_area.c ****     }
 216:Drivers/lvgl/src/misc/lv_area.c ****     /*Bottom left*/
 217:Drivers/lvgl/src/misc/lv_area.c ****     corner_area.y1 = a_p->y2 - radius;
 218:Drivers/lvgl/src/misc/lv_area.c ****     corner_area.y2 = a_p->y2;
 219:Drivers/lvgl/src/misc/lv_area.c ****     if(lv_area_is_point_on(&corner_area, p_p, 0)) {
 220:Drivers/lvgl/src/misc/lv_area.c ****         corner_area.x2 += radius;
 221:Drivers/lvgl/src/misc/lv_area.c ****         corner_area.y1 -= radius;
 222:Drivers/lvgl/src/misc/lv_area.c ****         return lv_point_within_circle(&corner_area, p_p);
 223:Drivers/lvgl/src/misc/lv_area.c ****     }
 224:Drivers/lvgl/src/misc/lv_area.c ****     /*Bottom right*/
 225:Drivers/lvgl/src/misc/lv_area.c ****     corner_area.x1 = a_p->x2 - radius;
 226:Drivers/lvgl/src/misc/lv_area.c ****     corner_area.x2 = a_p->x2;
 227:Drivers/lvgl/src/misc/lv_area.c ****     if(lv_area_is_point_on(&corner_area, p_p, 0)) {
 228:Drivers/lvgl/src/misc/lv_area.c ****         corner_area.x1 -= radius;
 229:Drivers/lvgl/src/misc/lv_area.c ****         corner_area.y1 -= radius;
 230:Drivers/lvgl/src/misc/lv_area.c ****         return lv_point_within_circle(&corner_area, p_p);
 231:Drivers/lvgl/src/misc/lv_area.c ****     }
 232:Drivers/lvgl/src/misc/lv_area.c ****     /*Top right*/
 233:Drivers/lvgl/src/misc/lv_area.c ****     corner_area.y1 = a_p->y1;
 234:Drivers/lvgl/src/misc/lv_area.c ****     corner_area.y2 = a_p->y1 + radius;
 235:Drivers/lvgl/src/misc/lv_area.c ****     if(lv_area_is_point_on(&corner_area, p_p, 0)) {
 236:Drivers/lvgl/src/misc/lv_area.c ****         corner_area.x1 -= radius;
 237:Drivers/lvgl/src/misc/lv_area.c ****         corner_area.y2 += radius;
