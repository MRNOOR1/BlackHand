 443:Drivers/lvgl/src/misc/lv_area.c **** void lv_point_transform(lv_point_t * point, int32_t angle, int32_t scale_x, int32_t scale_y, const 
 444:Drivers/lvgl/src/misc/lv_area.c ****                         bool zoom_first)
 445:Drivers/lvgl/src/misc/lv_area.c **** {
 446:Drivers/lvgl/src/misc/lv_area.c ****     lv_point_array_transform(point, 1, angle, scale_x, scale_y, pivot, zoom_first);
 447:Drivers/lvgl/src/misc/lv_area.c **** }
 448:Drivers/lvgl/src/misc/lv_area.c **** 
 449:Drivers/lvgl/src/misc/lv_area.c **** void lv_point_array_transform(lv_point_t * points, size_t count, int32_t angle, int32_t scale_x, in
 450:Drivers/lvgl/src/misc/lv_area.c ****                               const lv_point_t * pivot,
 451:Drivers/lvgl/src/misc/lv_area.c ****                               bool zoom_first)
 452:Drivers/lvgl/src/misc/lv_area.c **** {
 453:Drivers/lvgl/src/misc/lv_area.c ****     if(angle == 0 && scale_x == 256 && scale_y == 256) {
 454:Drivers/lvgl/src/misc/lv_area.c ****         return;
 455:Drivers/lvgl/src/misc/lv_area.c ****     }
 456:Drivers/lvgl/src/misc/lv_area.c ****     uint32_t i;
 457:Drivers/lvgl/src/misc/lv_area.c ****     for(i = 0; i < count; i++) {
 458:Drivers/lvgl/src/misc/lv_area.c ****         points[i].x -= pivot->x;
 459:Drivers/lvgl/src/misc/lv_area.c ****         points[i].y -= pivot->y;
 460:Drivers/lvgl/src/misc/lv_area.c **** 
 461:Drivers/lvgl/src/misc/lv_area.c ****     }
 462:Drivers/lvgl/src/misc/lv_area.c **** 
 463:Drivers/lvgl/src/misc/lv_area.c ****     if(angle == 0) {
 464:Drivers/lvgl/src/misc/lv_area.c ****         for(i = 0; i < count; i++) {
 465:Drivers/lvgl/src/misc/lv_area.c ****             points[i].x = (((int32_t)(points[i].x) * scale_x) >> 8) + pivot->x;
 466:Drivers/lvgl/src/misc/lv_area.c ****             points[i].y = (((int32_t)(points[i].y) * scale_y) >> 8) + pivot->y;
 467:Drivers/lvgl/src/misc/lv_area.c ****         }
 468:Drivers/lvgl/src/misc/lv_area.c ****         return;
 469:Drivers/lvgl/src/misc/lv_area.c ****     }
 470:Drivers/lvgl/src/misc/lv_area.c **** 
 471:Drivers/lvgl/src/misc/lv_area.c ****     int32_t angle_limited = angle;
 472:Drivers/lvgl/src/misc/lv_area.c ****     if(angle_limited > 3600) angle_limited -= 3600;
 473:Drivers/lvgl/src/misc/lv_area.c ****     if(angle_limited < 0) angle_limited += 3600;
 474:Drivers/lvgl/src/misc/lv_area.c **** 
 475:Drivers/lvgl/src/misc/lv_area.c ****     int32_t angle_low = angle_limited / 10;
 476:Drivers/lvgl/src/misc/lv_area.c ****     int32_t angle_high = angle_low + 1;
 477:Drivers/lvgl/src/misc/lv_area.c ****     int32_t angle_rem = angle_limited  - (angle_low * 10);
 478:Drivers/lvgl/src/misc/lv_area.c **** 
 479:Drivers/lvgl/src/misc/lv_area.c ****     int32_t s1 = lv_trigo_sin(angle_low);
 480:Drivers/lvgl/src/misc/lv_area.c ****     int32_t s2 = lv_trigo_sin(angle_high);
 481:Drivers/lvgl/src/misc/lv_area.c **** 
 482:Drivers/lvgl/src/misc/lv_area.c ****     int32_t c1 = lv_trigo_sin(angle_low + 90);
 483:Drivers/lvgl/src/misc/lv_area.c ****     int32_t c2 = lv_trigo_sin(angle_high + 90);
 484:Drivers/lvgl/src/misc/lv_area.c **** 
 485:Drivers/lvgl/src/misc/lv_area.c ****     int32_t sinma = (s1 * (10 - angle_rem) + s2 * angle_rem) / 10;
 486:Drivers/lvgl/src/misc/lv_area.c ****     sinma = sinma >> (LV_TRIGO_SHIFT - LV_TRANSFORM_TRIGO_SHIFT);
