 111:Drivers/lvgl/src/misc/lv_area.c **** int8_t lv_area_diff(lv_area_t res_p[], const lv_area_t * a1_p, const lv_area_t * a2_p)
 112:Drivers/lvgl/src/misc/lv_area.c **** {
 113:Drivers/lvgl/src/misc/lv_area.c ****     /*Areas have no common parts*/
 114:Drivers/lvgl/src/misc/lv_area.c ****     if(!lv_area_is_on(a1_p, a2_p)) return -1;
 115:Drivers/lvgl/src/misc/lv_area.c **** 
 116:Drivers/lvgl/src/misc/lv_area.c ****     /*No remaining areas after removing common parts*/
 117:Drivers/lvgl/src/misc/lv_area.c ****     if(lv_area_is_in(a1_p, a2_p, 0)) return 0;
 118:Drivers/lvgl/src/misc/lv_area.c **** 
 119:Drivers/lvgl/src/misc/lv_area.c ****     /*Result counter*/
 120:Drivers/lvgl/src/misc/lv_area.c ****     int8_t res_c = 0;
 121:Drivers/lvgl/src/misc/lv_area.c **** 
 122:Drivers/lvgl/src/misc/lv_area.c ****     /*Get required information*/
 123:Drivers/lvgl/src/misc/lv_area.c ****     lv_area_t n;
 124:Drivers/lvgl/src/misc/lv_area.c ****     int32_t a1_w = lv_area_get_width(a1_p) - 1;
 125:Drivers/lvgl/src/misc/lv_area.c ****     int32_t a1_h = lv_area_get_height(a1_p) - 1;
 126:Drivers/lvgl/src/misc/lv_area.c **** 
 127:Drivers/lvgl/src/misc/lv_area.c ****     /*Compute top rectangle*/
 128:Drivers/lvgl/src/misc/lv_area.c ****     int32_t th = a2_p->y1 - a1_p->y1;
 129:Drivers/lvgl/src/misc/lv_area.c ****     if(th > 0) {
 130:Drivers/lvgl/src/misc/lv_area.c ****         n.x1 = a1_p->x1;
 131:Drivers/lvgl/src/misc/lv_area.c ****         n.y1 = a1_p->y1;
 132:Drivers/lvgl/src/misc/lv_area.c ****         n.x2 = a1_p->x2;
 133:Drivers/lvgl/src/misc/lv_area.c ****         n.y2 = a1_p->y1 + th - 1;
 134:Drivers/lvgl/src/misc/lv_area.c ****         res_p[res_c++] = n;
 135:Drivers/lvgl/src/misc/lv_area.c ****     }
 136:Drivers/lvgl/src/misc/lv_area.c **** 
 137:Drivers/lvgl/src/misc/lv_area.c ****     /*Compute the bottom rectangle*/
 138:Drivers/lvgl/src/misc/lv_area.c ****     int32_t bh = a1_h - (a2_p->y2 - a1_p->y1);
 139:Drivers/lvgl/src/misc/lv_area.c ****     if(bh > 0 && a2_p->y2 < a1_p->y2) {
 140:Drivers/lvgl/src/misc/lv_area.c ****         n.x1 = a1_p->x1;
 141:Drivers/lvgl/src/misc/lv_area.c ****         n.y1 = a2_p->y2 + 1;
 142:Drivers/lvgl/src/misc/lv_area.c ****         n.x2 = a1_p->x2;
 143:Drivers/lvgl/src/misc/lv_area.c ****         n.y2 = a2_p->y2 + bh;
 144:Drivers/lvgl/src/misc/lv_area.c ****         res_p[res_c++] = n;
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//ccfwYGJo.s 			page 4


 145:Drivers/lvgl/src/misc/lv_area.c ****     }
 146:Drivers/lvgl/src/misc/lv_area.c **** 
 147:Drivers/lvgl/src/misc/lv_area.c ****     /*Compute side height*/
 148:Drivers/lvgl/src/misc/lv_area.c ****     int32_t y1 = a2_p->y1 > a1_p->y1 ? a2_p->y1 : a1_p->y1;
 149:Drivers/lvgl/src/misc/lv_area.c ****     int32_t y2 = a2_p->y2 < a1_p->y2 ? a2_p->y2 : a1_p->y2;
 150:Drivers/lvgl/src/misc/lv_area.c ****     int32_t sh = y2 - y1;
 151:Drivers/lvgl/src/misc/lv_area.c **** 
 152:Drivers/lvgl/src/misc/lv_area.c ****     /*Compute the left rectangle*/
 153:Drivers/lvgl/src/misc/lv_area.c ****     int32_t lw = a2_p->x1 - a1_p->x1;
 154:Drivers/lvgl/src/misc/lv_area.c ****     if(lw > 0 && sh >= 0) {
 155:Drivers/lvgl/src/misc/lv_area.c ****         n.x1 = a1_p->x1;
 156:Drivers/lvgl/src/misc/lv_area.c ****         n.y1 = y1;
 157:Drivers/lvgl/src/misc/lv_area.c ****         n.x2 = a1_p->x1 + lw - 1;
 158:Drivers/lvgl/src/misc/lv_area.c ****         n.y2 = y1 + sh;
 159:Drivers/lvgl/src/misc/lv_area.c ****         res_p[res_c++] = n;
 160:Drivers/lvgl/src/misc/lv_area.c ****     }
 161:Drivers/lvgl/src/misc/lv_area.c **** 
 162:Drivers/lvgl/src/misc/lv_area.c ****     /*Compute the right rectangle*/
 163:Drivers/lvgl/src/misc/lv_area.c ****     int32_t rw = a1_w - (a2_p->x2 - a1_p->x1);
 164:Drivers/lvgl/src/misc/lv_area.c ****     if(rw > 0 && sh >= 0) {
 165:Drivers/lvgl/src/misc/lv_area.c ****         n.x1 = a2_p->x2 + 1;
 166:Drivers/lvgl/src/misc/lv_area.c ****         n.y1 = y1;
 167:Drivers/lvgl/src/misc/lv_area.c ****         n.x2 = a2_p->x2 + rw;
 168:Drivers/lvgl/src/misc/lv_area.c ****         n.y2 = y1 + sh;
 169:Drivers/lvgl/src/misc/lv_area.c ****         res_p[res_c++] = n;
 170:Drivers/lvgl/src/misc/lv_area.c ****     }
 171:Drivers/lvgl/src/misc/lv_area.c **** 
 172:Drivers/lvgl/src/misc/lv_area.c ****     //Return number of results
 173:Drivers/lvgl/src/misc/lv_area.c ****     return res_c;
 174:Drivers/lvgl/src/misc/lv_area.c **** }
