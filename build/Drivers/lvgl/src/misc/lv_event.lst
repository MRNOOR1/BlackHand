 441:Drivers/lvgl/src/misc/lv_event.c **** static void cleanup_event_list_core(lv_array_t * array)
 442:Drivers/lvgl/src/misc/lv_event.c **** {
 443:Drivers/lvgl/src/misc/lv_event.c ****     const uint32_t size = lv_array_size(array);
 444:Drivers/lvgl/src/misc/lv_event.c ****     uint32_t kept_count = 0;
 445:Drivers/lvgl/src/misc/lv_event.c ****     for(uint32_t i = 0; i < size; i++) {
 446:Drivers/lvgl/src/misc/lv_event.c ****         lv_event_dsc_t ** dsc_i = lv_array_at(array, i);
 447:Drivers/lvgl/src/misc/lv_event.c ****         lv_event_dsc_t ** dsc_kept = lv_array_at(array, kept_count);
 448:Drivers/lvgl/src/misc/lv_event.c ****         if(event_is_marked_deleting(*dsc_i)) lv_free(*dsc_i);
 449:Drivers/lvgl/src/misc/lv_event.c ****         else {
 450:Drivers/lvgl/src/misc/lv_event.c ****             *dsc_kept = *dsc_i;
 451:Drivers/lvgl/src/misc/lv_event.c ****             kept_count++;
 452:Drivers/lvgl/src/misc/lv_event.c ****         }
 453:Drivers/lvgl/src/misc/lv_event.c ****     }
 454:Drivers/lvgl/src/misc/lv_event.c **** 
 455:Drivers/lvgl/src/misc/lv_event.c ****     if(kept_count == 0) lv_array_deinit(array);
 456:Drivers/lvgl/src/misc/lv_event.c ****     else lv_array_resize(array, kept_count);
 457:Drivers/lvgl/src/misc/lv_event.c **** }
