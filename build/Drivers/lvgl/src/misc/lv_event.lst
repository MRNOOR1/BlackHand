 108:Drivers/lvgl/src/misc/lv_event.c **** lv_result_t lv_event_send(lv_event_list_t * list, lv_event_t * e, bool preprocess)
 109:Drivers/lvgl/src/misc/lv_event.c **** {
 110:Drivers/lvgl/src/misc/lv_event.c ****     if(list == NULL) return LV_RESULT_OK;
 111:Drivers/lvgl/src/misc/lv_event.c ****     if(e->deleted) return LV_RESULT_INVALID;
 112:Drivers/lvgl/src/misc/lv_event.c **** 
 113:Drivers/lvgl/src/misc/lv_event.c ****     /* When obj is deleted in its own event, it will cause the `list->array` header to be released,
 114:Drivers/lvgl/src/misc/lv_event.c ****      * but the content still exists, which leads to memory leakage.
 115:Drivers/lvgl/src/misc/lv_event.c ****      * Therefore, back up the header in advance,
 116:Drivers/lvgl/src/misc/lv_event.c ****      * which can strive to release the memory and prevent used-after-free. */
 117:Drivers/lvgl/src/misc/lv_event.c ****     lv_array_t back_array_head = list->array;
 118:Drivers/lvgl/src/misc/lv_event.c **** 
 119:Drivers/lvgl/src/misc/lv_event.c ****     /* Dealing with the problem of nested event deletion event */
 120:Drivers/lvgl/src/misc/lv_event.c ****     const bool is_traversing = list->is_traversing;
 121:Drivers/lvgl/src/misc/lv_event.c ****     list->is_traversing = true;
 122:Drivers/lvgl/src/misc/lv_event.c **** 
 123:Drivers/lvgl/src/misc/lv_event.c ****     lv_result_t res = LV_RESULT_OK;
 124:Drivers/lvgl/src/misc/lv_event.c ****     const uint32_t size = event_array_size(list);
 125:Drivers/lvgl/src/misc/lv_event.c ****     for(uint32_t i = 0; i < size && !e->deleted; i++) {
 126:Drivers/lvgl/src/misc/lv_event.c ****         lv_event_dsc_t * dsc = *event_array_at(list, i);
 127:Drivers/lvgl/src/misc/lv_event.c ****         if(dsc->cb == NULL) continue;
 128:Drivers/lvgl/src/misc/lv_event.c ****         if(event_is_marked_deleting(dsc)) continue;
 129:Drivers/lvgl/src/misc/lv_event.c ****         const bool is_preprocessed = (dsc->filter & LV_EVENT_PREPROCESS) != 0;
 130:Drivers/lvgl/src/misc/lv_event.c ****         if(is_preprocessed != preprocess) continue;
 131:Drivers/lvgl/src/misc/lv_event.c ****         lv_event_code_t filter = dsc->filter & ~LV_EVENT_PREPROCESS;
 132:Drivers/lvgl/src/misc/lv_event.c ****         if(filter == LV_EVENT_ALL || filter == e->code) {
 133:Drivers/lvgl/src/misc/lv_event.c ****             e->user_data = dsc->user_data;
 134:Drivers/lvgl/src/misc/lv_event.c **** #if LV_USE_EXT_DATA
 135:Drivers/lvgl/src/misc/lv_event.c ****             e->ext_data.data = dsc->ext_data.data;
 136:Drivers/lvgl/src/misc/lv_event.c **** #endif
 137:Drivers/lvgl/src/misc/lv_event.c ****             dsc->cb(e);
 138:Drivers/lvgl/src/misc/lv_event.c ****             if(e->stop_processing) break;
 139:Drivers/lvgl/src/misc/lv_event.c **** 
 140:Drivers/lvgl/src/misc/lv_event.c ****             /*Stop if the object is deleted*/
 141:Drivers/lvgl/src/misc/lv_event.c ****             if(e->deleted) {
 142:Drivers/lvgl/src/misc/lv_event.c ****                 res = LV_RESULT_INVALID;
 143:Drivers/lvgl/src/misc/lv_event.c ****                 break;
 144:Drivers/lvgl/src/misc/lv_event.c ****             }
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//cc8C6kZQ.s 			page 4


 145:Drivers/lvgl/src/misc/lv_event.c ****         }
 146:Drivers/lvgl/src/misc/lv_event.c ****     }
 147:Drivers/lvgl/src/misc/lv_event.c **** 
 148:Drivers/lvgl/src/misc/lv_event.c ****     if(is_traversing) return res;
 149:Drivers/lvgl/src/misc/lv_event.c **** 
 150:Drivers/lvgl/src/misc/lv_event.c ****     if(e->deleted) cleanup_event_list_core(&back_array_head);
 151:Drivers/lvgl/src/misc/lv_event.c ****     else {
 152:Drivers/lvgl/src/misc/lv_event.c ****         list->is_traversing = false;
 153:Drivers/lvgl/src/misc/lv_event.c ****         cleanup_event_list(list);
 154:Drivers/lvgl/src/misc/lv_event.c ****     }
 155:Drivers/lvgl/src/misc/lv_event.c **** 
 156:Drivers/lvgl/src/misc/lv_event.c ****     return res;
 157:Drivers/lvgl/src/misc/lv_event.c **** }
