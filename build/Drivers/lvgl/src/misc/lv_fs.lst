 162:Drivers/lvgl/src/misc/lv_fs.c **** lv_result_t lv_fs_get_buffer_from_path(lv_fs_path_ex_t * path, void ** buffer, uint32_t * size)
 163:Drivers/lvgl/src/misc/lv_fs.c **** {
 164:Drivers/lvgl/src/misc/lv_fs.c ****     LV_ASSERT_NULL(path);
 165:Drivers/lvgl/src/misc/lv_fs.c ****     LV_ASSERT_NULL(buffer);
 166:Drivers/lvgl/src/misc/lv_fs.c ****     LV_ASSERT_NULL(size);
 167:Drivers/lvgl/src/misc/lv_fs.c **** 
 168:Drivers/lvgl/src/misc/lv_fs.c ****     *size = 0;
 169:Drivers/lvgl/src/misc/lv_fs.c ****     *buffer = NULL;
 170:Drivers/lvgl/src/misc/lv_fs.c **** 
 171:Drivers/lvgl/src/misc/lv_fs.c ****     if(path->path[0] < 'A' || path->path[0] > 'Z') return LV_RESULT_INVALID;
 172:Drivers/lvgl/src/misc/lv_fs.c ****     if(path->path[1] != ':') return LV_RESULT_INVALID;
 173:Drivers/lvgl/src/misc/lv_fs.c **** 
 174:Drivers/lvgl/src/misc/lv_fs.c ****     uint32_t i;
 175:Drivers/lvgl/src/misc/lv_fs.c ****     lv_uintptr_t adr = 0;
 176:Drivers/lvgl/src/misc/lv_fs.c ****     for(i = 2; path->path[i] != '-' && path->path[i] != '\0' && i < sizeof(path->path); i++) {
 177:Drivers/lvgl/src/misc/lv_fs.c ****         adr = adr * 10;
 178:Drivers/lvgl/src/misc/lv_fs.c ****         adr += path->path[i] - '0';
 179:Drivers/lvgl/src/misc/lv_fs.c ****     }
 180:Drivers/lvgl/src/misc/lv_fs.c **** 
 181:Drivers/lvgl/src/misc/lv_fs.c ****     if(path->path[i] == '\0' || i == sizeof(path->path)) return LV_RESULT_INVALID;
 182:Drivers/lvgl/src/misc/lv_fs.c ****     i++; /*Skip '-'*/
 183:Drivers/lvgl/src/misc/lv_fs.c **** 
 184:Drivers/lvgl/src/misc/lv_fs.c ****     for(; path->path[i] != '.' && path->path[i] != '\0' && i < sizeof(path->path); i++) {
 185:Drivers/lvgl/src/misc/lv_fs.c ****         *size = (*size) * 10;
 186:Drivers/lvgl/src/misc/lv_fs.c ****         *size += path->path[i] - '0';
 187:Drivers/lvgl/src/misc/lv_fs.c ****     }
 188:Drivers/lvgl/src/misc/lv_fs.c **** 
 189:Drivers/lvgl/src/misc/lv_fs.c ****     *buffer = (void *)adr;
 190:Drivers/lvgl/src/misc/lv_fs.c **** 
 191:Drivers/lvgl/src/misc/lv_fs.c ****     return LV_RESULT_OK;
 192:Drivers/lvgl/src/misc/lv_fs.c **** }
