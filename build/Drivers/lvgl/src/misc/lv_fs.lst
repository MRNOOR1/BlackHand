 611:Drivers/lvgl/src/misc/lv_fs.c **** char * lv_fs_up(char * path)
 612:Drivers/lvgl/src/misc/lv_fs.c **** {
 613:Drivers/lvgl/src/misc/lv_fs.c ****     size_t len = lv_strlen(path);
 614:Drivers/lvgl/src/misc/lv_fs.c ****     if(len == 0) return path;
 615:Drivers/lvgl/src/misc/lv_fs.c **** 
 616:Drivers/lvgl/src/misc/lv_fs.c ****     len--; /*Go before the trailing '\0'*/
 617:Drivers/lvgl/src/misc/lv_fs.c **** 
 618:Drivers/lvgl/src/misc/lv_fs.c ****     /*Ignore trailing '/' or '\'*/
 619:Drivers/lvgl/src/misc/lv_fs.c ****     while(path[len] == '/' || path[len] == '\\') {
 620:Drivers/lvgl/src/misc/lv_fs.c ****         path[len] = '\0';
 621:Drivers/lvgl/src/misc/lv_fs.c ****         if(len > 0)
 622:Drivers/lvgl/src/misc/lv_fs.c ****             len--;
 623:Drivers/lvgl/src/misc/lv_fs.c ****         else
 624:Drivers/lvgl/src/misc/lv_fs.c ****             return path;
 625:Drivers/lvgl/src/misc/lv_fs.c ****     }
 626:Drivers/lvgl/src/misc/lv_fs.c **** 
 627:Drivers/lvgl/src/misc/lv_fs.c ****     size_t i;
 628:Drivers/lvgl/src/misc/lv_fs.c ****     for(i = len; i > 0; i--) {
 629:Drivers/lvgl/src/misc/lv_fs.c ****         if(path[i] == '/' || path[i] == '\\') break;
 630:Drivers/lvgl/src/misc/lv_fs.c ****     }
 631:Drivers/lvgl/src/misc/lv_fs.c **** 
 632:Drivers/lvgl/src/misc/lv_fs.c ****     if(i > 0) path[i] = '\0';
 633:Drivers/lvgl/src/misc/lv_fs.c **** 
 634:Drivers/lvgl/src/misc/lv_fs.c ****     return path;
 635:Drivers/lvgl/src/misc/lv_fs.c **** }
