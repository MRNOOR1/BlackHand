 724:Drivers/lvgl/src/misc/lv_fs.c **** static lv_fs_res_t lv_fs_read_cached(lv_fs_file_t * file_p, void * buf, uint32_t btr, uint32_t * br
 725:Drivers/lvgl/src/misc/lv_fs.c **** {
 726:Drivers/lvgl/src/misc/lv_fs.c ****     lv_fs_res_t res = LV_FS_RES_OK;
 727:Drivers/lvgl/src/misc/lv_fs.c ****     uint32_t file_position = file_p->cache->file_position;
 728:Drivers/lvgl/src/misc/lv_fs.c ****     uint32_t start = file_p->cache->start;
 729:Drivers/lvgl/src/misc/lv_fs.c ****     uint32_t end = file_p->cache->end;
 730:Drivers/lvgl/src/misc/lv_fs.c ****     char * buffer = file_p->cache->buffer;
 731:Drivers/lvgl/src/misc/lv_fs.c ****     uint32_t buffer_size = file_p->drv->cache_size;
 732:Drivers/lvgl/src/misc/lv_fs.c **** 
 733:Drivers/lvgl/src/misc/lv_fs.c ****     if(start <= file_position && file_position <= end) {
 734:Drivers/lvgl/src/misc/lv_fs.c ****         /* Data can be read from cache buffer */
 735:Drivers/lvgl/src/misc/lv_fs.c ****         uint32_t buffer_remaining_length = (uint32_t)end - file_position + 1;
 736:Drivers/lvgl/src/misc/lv_fs.c ****         uint32_t buffer_offset = (end - start) - buffer_remaining_length + 1;
 737:Drivers/lvgl/src/misc/lv_fs.c **** 
 738:Drivers/lvgl/src/misc/lv_fs.c ****         /* Do not allow reading beyond the actual memory block for memory-mapped files */
 739:Drivers/lvgl/src/misc/lv_fs.c ****         if(file_p->drv->cache_size == LV_FS_CACHE_FROM_BUFFER) {
 740:Drivers/lvgl/src/misc/lv_fs.c ****             if(btr > buffer_remaining_length)
 741:Drivers/lvgl/src/misc/lv_fs.c ****                 btr = buffer_remaining_length - 1;
 742:Drivers/lvgl/src/misc/lv_fs.c ****         }
 743:Drivers/lvgl/src/misc/lv_fs.c **** 
 744:Drivers/lvgl/src/misc/lv_fs.c ****         if(btr <= buffer_remaining_length) {
 745:Drivers/lvgl/src/misc/lv_fs.c ****             /*Data is in cache buffer, and buffer end not reached, no need to read from FS*/
 746:Drivers/lvgl/src/misc/lv_fs.c ****             lv_memcpy(buf, buffer + buffer_offset, btr);
 747:Drivers/lvgl/src/misc/lv_fs.c ****             *br = btr;
 748:Drivers/lvgl/src/misc/lv_fs.c ****         }
