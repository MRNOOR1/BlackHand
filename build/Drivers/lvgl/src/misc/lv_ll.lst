 181:Drivers/lvgl/src/misc/lv_ll.c **** void lv_ll_chg_list(lv_ll_t * ll_ori_p, lv_ll_t * ll_new_p, void * node, bool head)
 182:Drivers/lvgl/src/misc/lv_ll.c **** {
 183:Drivers/lvgl/src/misc/lv_ll.c ****     lv_ll_remove(ll_ori_p, node);
 184:Drivers/lvgl/src/misc/lv_ll.c **** 
 185:Drivers/lvgl/src/misc/lv_ll.c ****     if(head) {
 186:Drivers/lvgl/src/misc/lv_ll.c ****         /*Set node as head*/
 187:Drivers/lvgl/src/misc/lv_ll.c ****         node_set_prev(ll_new_p, node, NULL);
 188:Drivers/lvgl/src/misc/lv_ll.c ****         node_set_next(ll_new_p, node, ll_new_p->head);
 189:Drivers/lvgl/src/misc/lv_ll.c **** 
 190:Drivers/lvgl/src/misc/lv_ll.c ****         if(ll_new_p->head != NULL) { /*If there is old head then before it goes the new*/
 191:Drivers/lvgl/src/misc/lv_ll.c ****             node_set_prev(ll_new_p, ll_new_p->head, node);
 192:Drivers/lvgl/src/misc/lv_ll.c ****         }
 193:Drivers/lvgl/src/misc/lv_ll.c **** 
 194:Drivers/lvgl/src/misc/lv_ll.c ****         ll_new_p->head = node;       /*Set the new head in the dsc.*/
 195:Drivers/lvgl/src/misc/lv_ll.c ****         if(ll_new_p->tail == NULL) { /*If there is no tail (first node) set the tail too*/
 196:Drivers/lvgl/src/misc/lv_ll.c ****             ll_new_p->tail = node;
 197:Drivers/lvgl/src/misc/lv_ll.c ****         }
 198:Drivers/lvgl/src/misc/lv_ll.c ****     }
 199:Drivers/lvgl/src/misc/lv_ll.c ****     else {
 200:Drivers/lvgl/src/misc/lv_ll.c ****         /*Set node as tail*/
 201:Drivers/lvgl/src/misc/lv_ll.c ****         node_set_prev(ll_new_p, node, ll_new_p->tail);
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//cc1QUPW1.s 			page 5


 202:Drivers/lvgl/src/misc/lv_ll.c ****         node_set_next(ll_new_p, node, NULL);
 203:Drivers/lvgl/src/misc/lv_ll.c **** 
 204:Drivers/lvgl/src/misc/lv_ll.c ****         if(ll_new_p->tail != NULL) { /*If there is old tail then after it goes the new*/
 205:Drivers/lvgl/src/misc/lv_ll.c ****             node_set_next(ll_new_p, ll_new_p->tail, node);
 206:Drivers/lvgl/src/misc/lv_ll.c ****         }
 207:Drivers/lvgl/src/misc/lv_ll.c **** 
 208:Drivers/lvgl/src/misc/lv_ll.c ****         ll_new_p->tail = node;       /*Set the new tail in the dsc.*/
 209:Drivers/lvgl/src/misc/lv_ll.c ****         if(ll_new_p->head == NULL) { /*If there is no head (first node) set the head too*/
 210:Drivers/lvgl/src/misc/lv_ll.c ****             ll_new_p->head = node;
 211:Drivers/lvgl/src/misc/lv_ll.c ****         }
 212:Drivers/lvgl/src/misc/lv_ll.c ****     }
 213:Drivers/lvgl/src/misc/lv_ll.c **** }
