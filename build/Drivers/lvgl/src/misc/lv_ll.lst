 245:Drivers/lvgl/src/misc/lv_ll.c **** uint32_t lv_ll_get_len(const lv_ll_t * ll_p)
 246:Drivers/lvgl/src/misc/lv_ll.c **** {
 247:Drivers/lvgl/src/misc/lv_ll.c ****     uint32_t len = 0;
