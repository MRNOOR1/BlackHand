 227:Drivers/lvgl/src/misc/lv_ll.c **** void * lv_ll_get_next(const lv_ll_t * ll_p, const void * n_act)
 228:Drivers/lvgl/src/misc/lv_ll.c **** {
 229:Drivers/lvgl/src/misc/lv_ll.c ****     /*Pointer to the next node is stored in the end of this node.
 230:Drivers/lvgl/src/misc/lv_ll.c ****      *Go there and return the address found there*/
