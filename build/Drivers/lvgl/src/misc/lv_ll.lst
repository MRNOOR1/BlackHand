 237:Drivers/lvgl/src/misc/lv_ll.c **** {
 238:Drivers/lvgl/src/misc/lv_ll.c ****     /*Pointer to the prev. node is stored in the end of this node.
 239:Drivers/lvgl/src/misc/lv_ll.c ****      *Go there and return the address found there*/
 240:Drivers/lvgl/src/misc/lv_ll.c ****     const lv_ll_node_t * n_act_d = n_act;
 241:Drivers/lvgl/src/misc/lv_ll.c ****     n_act_d += LL_PREV_P_OFFSET(ll_p);
