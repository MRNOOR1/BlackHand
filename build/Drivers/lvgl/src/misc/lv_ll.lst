 256:Drivers/lvgl/src/misc/lv_ll.c **** 
 257:Drivers/lvgl/src/misc/lv_ll.c **** void lv_ll_move_before(lv_ll_t * ll_p, void * n_act, void * n_after)
 258:Drivers/lvgl/src/misc/lv_ll.c **** {
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//cc1QUPW1.s 			page 6


 259:Drivers/lvgl/src/misc/lv_ll.c ****     if(n_act == n_after) return; /*Can't move before itself*/
 260:Drivers/lvgl/src/misc/lv_ll.c **** 
 261:Drivers/lvgl/src/misc/lv_ll.c ****     void * n_before;
 262:Drivers/lvgl/src/misc/lv_ll.c ****     if(n_after != NULL)
 263:Drivers/lvgl/src/misc/lv_ll.c ****         n_before = lv_ll_get_prev(ll_p, n_after);
 264:Drivers/lvgl/src/misc/lv_ll.c ****     else
 265:Drivers/lvgl/src/misc/lv_ll.c ****         n_before = lv_ll_get_tail(ll_p); /*if `n_after` is NULL `n_act` should be the new tail*/
 266:Drivers/lvgl/src/misc/lv_ll.c **** 
 267:Drivers/lvgl/src/misc/lv_ll.c ****     if(n_act == n_before) return; /*Already before `n_after`*/
 268:Drivers/lvgl/src/misc/lv_ll.c **** 
 269:Drivers/lvgl/src/misc/lv_ll.c ****     /*It's much easier to remove from the list and add again*/
 270:Drivers/lvgl/src/misc/lv_ll.c ****     lv_ll_remove(ll_p, n_act);
 271:Drivers/lvgl/src/misc/lv_ll.c **** 
 272:Drivers/lvgl/src/misc/lv_ll.c ****     /*Add again by setting the prev. and next nodes*/
 273:Drivers/lvgl/src/misc/lv_ll.c ****     node_set_next(ll_p, n_before, n_act);
 274:Drivers/lvgl/src/misc/lv_ll.c ****     node_set_prev(ll_p, n_act, n_before);
 275:Drivers/lvgl/src/misc/lv_ll.c ****     node_set_prev(ll_p, n_after, n_act);
 276:Drivers/lvgl/src/misc/lv_ll.c ****     node_set_next(ll_p, n_act, n_after);
 277:Drivers/lvgl/src/misc/lv_ll.c **** 
 278:Drivers/lvgl/src/misc/lv_ll.c ****     /*If `n_act` was moved before NULL then it become the new tail*/
 279:Drivers/lvgl/src/misc/lv_ll.c ****     if(n_after == NULL) ll_p->tail = n_act;
 280:Drivers/lvgl/src/misc/lv_ll.c **** 
 281:Drivers/lvgl/src/misc/lv_ll.c ****     /*If `n_act` was moved before `NULL` then it's the new head*/
 282:Drivers/lvgl/src/misc/lv_ll.c ****     if(n_before == NULL) ll_p->head = n_act;
 283:Drivers/lvgl/src/misc/lv_ll.c **** }
 284:Drivers/lvgl/src/misc/lv_ll.c **** 
 285:Drivers/lvgl/src/misc/lv_ll.c **** bool lv_ll_is_empty(lv_ll_t * ll_p)
 286:Drivers/lvgl/src/misc/lv_ll.c **** {
 287:Drivers/lvgl/src/misc/lv_ll.c ****     if(ll_p == NULL) return true;
 288:Drivers/lvgl/src/misc/lv_ll.c **** 
 289:Drivers/lvgl/src/misc/lv_ll.c ****     if(ll_p->head == NULL && ll_p->tail == NULL) return true;
 290:Drivers/lvgl/src/misc/lv_ll.c **** 
 291:Drivers/lvgl/src/misc/lv_ll.c ****     return false;
 292:Drivers/lvgl/src/misc/lv_ll.c **** }
