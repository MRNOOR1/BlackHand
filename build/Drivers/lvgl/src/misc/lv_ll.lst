 160:Drivers/lvgl/src/misc/lv_ll.c **** void lv_ll_clear_custom(lv_ll_t * ll_p, void(*cleanup)(void *))
 161:Drivers/lvgl/src/misc/lv_ll.c **** {
 162:Drivers/lvgl/src/misc/lv_ll.c ****     void * i;
 163:Drivers/lvgl/src/misc/lv_ll.c ****     void * i_next;
 164:Drivers/lvgl/src/misc/lv_ll.c **** 
 165:Drivers/lvgl/src/misc/lv_ll.c ****     i      = lv_ll_get_head(ll_p);
 166:Drivers/lvgl/src/misc/lv_ll.c ****     i_next = NULL;
 167:Drivers/lvgl/src/misc/lv_ll.c **** 
 168:Drivers/lvgl/src/misc/lv_ll.c ****     while(i != NULL) {
 169:Drivers/lvgl/src/misc/lv_ll.c ****         i_next = lv_ll_get_next(ll_p, i);
 170:Drivers/lvgl/src/misc/lv_ll.c ****         if(cleanup == NULL) {
 171:Drivers/lvgl/src/misc/lv_ll.c ****             lv_ll_remove(ll_p, i);
 172:Drivers/lvgl/src/misc/lv_ll.c ****             lv_free(i);
 173:Drivers/lvgl/src/misc/lv_ll.c ****         }
 174:Drivers/lvgl/src/misc/lv_ll.c ****         else {
 175:Drivers/lvgl/src/misc/lv_ll.c ****             cleanup(i);
 176:Drivers/lvgl/src/misc/lv_ll.c ****         }
 177:Drivers/lvgl/src/misc/lv_ll.c ****         i = i_next;
 178:Drivers/lvgl/src/misc/lv_ll.c ****     }
 179:Drivers/lvgl/src/misc/lv_ll.c **** }
