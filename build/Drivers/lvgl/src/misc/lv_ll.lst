  42:Drivers/lvgl/src/misc/lv_ll.c **** void lv_ll_init(lv_ll_t * ll_p, uint32_t node_size)
  43:Drivers/lvgl/src/misc/lv_ll.c **** {
  44:Drivers/lvgl/src/misc/lv_ll.c ****     ll_p->head = NULL;
  45:Drivers/lvgl/src/misc/lv_ll.c ****     ll_p->tail = NULL;
  46:Drivers/lvgl/src/misc/lv_ll.c **** #ifdef LV_ARCH_64
  47:Drivers/lvgl/src/misc/lv_ll.c ****     /*Round the size up to 8*/
  48:Drivers/lvgl/src/misc/lv_ll.c ****     node_size = (node_size + 7) & (~0x7);
  49:Drivers/lvgl/src/misc/lv_ll.c **** #else
  50:Drivers/lvgl/src/misc/lv_ll.c ****     /*Round the size up to 4*/
  51:Drivers/lvgl/src/misc/lv_ll.c ****     node_size = (node_size + 3) & (~0x3);
  52:Drivers/lvgl/src/misc/lv_ll.c **** #endif
  53:Drivers/lvgl/src/misc/lv_ll.c **** 
  54:Drivers/lvgl/src/misc/lv_ll.c ****     ll_p->n_size = node_size;
  55:Drivers/lvgl/src/misc/lv_ll.c **** }
  56:Drivers/lvgl/src/misc/lv_ll.c **** 
  57:Drivers/lvgl/src/misc/lv_ll.c **** void * lv_ll_ins_head(lv_ll_t * ll_p)
  58:Drivers/lvgl/src/misc/lv_ll.c **** {
  59:Drivers/lvgl/src/misc/lv_ll.c ****     lv_ll_node_t * n_new;
  60:Drivers/lvgl/src/misc/lv_ll.c **** 
  61:Drivers/lvgl/src/misc/lv_ll.c ****     n_new = lv_malloc(ll_p->n_size + LL_NODE_META_SIZE);
  62:Drivers/lvgl/src/misc/lv_ll.c **** 
  63:Drivers/lvgl/src/misc/lv_ll.c ****     if(n_new != NULL) {
  64:Drivers/lvgl/src/misc/lv_ll.c ****         node_set_prev(ll_p, n_new, NULL);       /*No prev. before the new head*/
  65:Drivers/lvgl/src/misc/lv_ll.c ****         node_set_next(ll_p, n_new, ll_p->head); /*After new comes the old head*/
  66:Drivers/lvgl/src/misc/lv_ll.c **** 
  67:Drivers/lvgl/src/misc/lv_ll.c ****         if(ll_p->head != NULL) { /*If there is old head then before it goes the new*/
  68:Drivers/lvgl/src/misc/lv_ll.c ****             node_set_prev(ll_p, ll_p->head, n_new);
  69:Drivers/lvgl/src/misc/lv_ll.c ****         }
  70:Drivers/lvgl/src/misc/lv_ll.c **** 
  71:Drivers/lvgl/src/misc/lv_ll.c ****         ll_p->head = n_new;      /*Set the new head in the dsc.*/
  72:Drivers/lvgl/src/misc/lv_ll.c ****         if(ll_p->tail == NULL) { /*If there is no tail (1. node) set the tail too*/
  73:Drivers/lvgl/src/misc/lv_ll.c ****             ll_p->tail = n_new;
  74:Drivers/lvgl/src/misc/lv_ll.c ****         }
  75:Drivers/lvgl/src/misc/lv_ll.c ****     }
  76:Drivers/lvgl/src/misc/lv_ll.c **** 
  77:Drivers/lvgl/src/misc/lv_ll.c ****     return n_new;
  78:Drivers/lvgl/src/misc/lv_ll.c **** }
  79:Drivers/lvgl/src/misc/lv_ll.c **** 
  80:Drivers/lvgl/src/misc/lv_ll.c **** void * lv_ll_ins_prev(lv_ll_t * ll_p, void * n_act)
  81:Drivers/lvgl/src/misc/lv_ll.c **** {
  82:Drivers/lvgl/src/misc/lv_ll.c ****     lv_ll_node_t * n_new;
  83:Drivers/lvgl/src/misc/lv_ll.c **** 
  84:Drivers/lvgl/src/misc/lv_ll.c ****     if(NULL == ll_p || NULL == n_act) return NULL;
  85:Drivers/lvgl/src/misc/lv_ll.c **** 
  86:Drivers/lvgl/src/misc/lv_ll.c ****     if(lv_ll_get_head(ll_p) == n_act) {
  87:Drivers/lvgl/src/misc/lv_ll.c ****         n_new = lv_ll_ins_head(ll_p);
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//cc1QUPW1.s 			page 3


  88:Drivers/lvgl/src/misc/lv_ll.c ****         if(n_new == NULL) return NULL;
  89:Drivers/lvgl/src/misc/lv_ll.c ****     }
  90:Drivers/lvgl/src/misc/lv_ll.c ****     else {
  91:Drivers/lvgl/src/misc/lv_ll.c ****         n_new = lv_malloc(ll_p->n_size + LL_NODE_META_SIZE);
  92:Drivers/lvgl/src/misc/lv_ll.c ****         if(n_new == NULL) return NULL;
  93:Drivers/lvgl/src/misc/lv_ll.c **** 
  94:Drivers/lvgl/src/misc/lv_ll.c ****         lv_ll_node_t * n_prev;
  95:Drivers/lvgl/src/misc/lv_ll.c ****         n_prev = lv_ll_get_prev(ll_p, n_act);
  96:Drivers/lvgl/src/misc/lv_ll.c ****         node_set_next(ll_p, n_prev, n_new);
  97:Drivers/lvgl/src/misc/lv_ll.c ****         node_set_prev(ll_p, n_new, n_prev);
  98:Drivers/lvgl/src/misc/lv_ll.c ****         node_set_prev(ll_p, n_act, n_new);
  99:Drivers/lvgl/src/misc/lv_ll.c ****         node_set_next(ll_p, n_new, n_act);
 100:Drivers/lvgl/src/misc/lv_ll.c ****     }
 101:Drivers/lvgl/src/misc/lv_ll.c **** 
 102:Drivers/lvgl/src/misc/lv_ll.c ****     return n_new;
 103:Drivers/lvgl/src/misc/lv_ll.c **** }
 104:Drivers/lvgl/src/misc/lv_ll.c **** 
 105:Drivers/lvgl/src/misc/lv_ll.c **** void * lv_ll_ins_tail(lv_ll_t * ll_p)
 106:Drivers/lvgl/src/misc/lv_ll.c **** {
 107:Drivers/lvgl/src/misc/lv_ll.c ****     lv_ll_node_t * n_new;
 108:Drivers/lvgl/src/misc/lv_ll.c **** 
 109:Drivers/lvgl/src/misc/lv_ll.c ****     n_new = lv_malloc(ll_p->n_size + LL_NODE_META_SIZE);
 110:Drivers/lvgl/src/misc/lv_ll.c **** 
 111:Drivers/lvgl/src/misc/lv_ll.c ****     if(n_new != NULL) {
 112:Drivers/lvgl/src/misc/lv_ll.c ****         node_set_next(ll_p, n_new, NULL);       /*No next after the new tail*/
 113:Drivers/lvgl/src/misc/lv_ll.c ****         node_set_prev(ll_p, n_new, ll_p->tail); /*The prev. before new is the old tail*/
 114:Drivers/lvgl/src/misc/lv_ll.c ****         if(ll_p->tail != NULL) {                /*If there is old tail then the new comes after it*
 115:Drivers/lvgl/src/misc/lv_ll.c ****             node_set_next(ll_p, ll_p->tail, n_new);
 116:Drivers/lvgl/src/misc/lv_ll.c ****         }
 117:Drivers/lvgl/src/misc/lv_ll.c **** 
 118:Drivers/lvgl/src/misc/lv_ll.c ****         ll_p->tail = n_new;      /*Set the new tail in the dsc.*/
 119:Drivers/lvgl/src/misc/lv_ll.c ****         if(ll_p->head == NULL) { /*If there is no head (1. node) set the head too*/
 120:Drivers/lvgl/src/misc/lv_ll.c ****             ll_p->head = n_new;
 121:Drivers/lvgl/src/misc/lv_ll.c ****         }
 122:Drivers/lvgl/src/misc/lv_ll.c ****     }
 123:Drivers/lvgl/src/misc/lv_ll.c **** 
 124:Drivers/lvgl/src/misc/lv_ll.c ****     return n_new;
 125:Drivers/lvgl/src/misc/lv_ll.c **** }
 126:Drivers/lvgl/src/misc/lv_ll.c **** 
 127:Drivers/lvgl/src/misc/lv_ll.c **** void lv_ll_remove(lv_ll_t * ll_p, void * node_p)
 128:Drivers/lvgl/src/misc/lv_ll.c **** {
 129:Drivers/lvgl/src/misc/lv_ll.c ****     if(ll_p == NULL) return;
 130:Drivers/lvgl/src/misc/lv_ll.c **** 
 131:Drivers/lvgl/src/misc/lv_ll.c ****     if(lv_ll_get_head(ll_p) == node_p) {
 132:Drivers/lvgl/src/misc/lv_ll.c ****         /*The new head will be the node after 'node_p'*/
 133:Drivers/lvgl/src/misc/lv_ll.c ****         ll_p->head = lv_ll_get_next(ll_p, node_p);
 134:Drivers/lvgl/src/misc/lv_ll.c ****         if(ll_p->head == NULL) {
 135:Drivers/lvgl/src/misc/lv_ll.c ****             ll_p->tail = NULL;
 136:Drivers/lvgl/src/misc/lv_ll.c ****         }
 137:Drivers/lvgl/src/misc/lv_ll.c ****         else {
 138:Drivers/lvgl/src/misc/lv_ll.c ****             node_set_prev(ll_p, ll_p->head, NULL);
 139:Drivers/lvgl/src/misc/lv_ll.c ****         }
 140:Drivers/lvgl/src/misc/lv_ll.c ****     }
 141:Drivers/lvgl/src/misc/lv_ll.c ****     else if(lv_ll_get_tail(ll_p) == node_p) {
 142:Drivers/lvgl/src/misc/lv_ll.c ****         /*The new tail will be the node before 'node_p'*/
 143:Drivers/lvgl/src/misc/lv_ll.c ****         ll_p->tail = lv_ll_get_prev(ll_p, node_p);
 144:Drivers/lvgl/src/misc/lv_ll.c ****         if(ll_p->tail == NULL) {
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//cc1QUPW1.s 			page 4


 145:Drivers/lvgl/src/misc/lv_ll.c ****             ll_p->head = NULL;
 146:Drivers/lvgl/src/misc/lv_ll.c ****         }
 147:Drivers/lvgl/src/misc/lv_ll.c ****         else {
 148:Drivers/lvgl/src/misc/lv_ll.c ****             node_set_next(ll_p, ll_p->tail, NULL);
 149:Drivers/lvgl/src/misc/lv_ll.c ****         }
 150:Drivers/lvgl/src/misc/lv_ll.c ****     }
 151:Drivers/lvgl/src/misc/lv_ll.c ****     else {
 152:Drivers/lvgl/src/misc/lv_ll.c ****         lv_ll_node_t * n_prev = lv_ll_get_prev(ll_p, node_p);
 153:Drivers/lvgl/src/misc/lv_ll.c ****         lv_ll_node_t * n_next = lv_ll_get_next(ll_p, node_p);
 154:Drivers/lvgl/src/misc/lv_ll.c **** 
 155:Drivers/lvgl/src/misc/lv_ll.c ****         node_set_next(ll_p, n_prev, n_next);
 156:Drivers/lvgl/src/misc/lv_ll.c ****         node_set_prev(ll_p, n_next, n_prev);
 157:Drivers/lvgl/src/misc/lv_ll.c ****     }
 158:Drivers/lvgl/src/misc/lv_ll.c **** }
