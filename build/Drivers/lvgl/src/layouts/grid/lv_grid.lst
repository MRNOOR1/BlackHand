 287:Drivers/lvgl/src/layouts/grid/lv_grid.c ****         col_templ = get_col_dsc(parent);
 288:Drivers/lvgl/src/layouts/grid/lv_grid.c ****         if(col_templ == NULL) {
 289:Drivers/lvgl/src/layouts/grid/lv_grid.c ****             LV_LOG_WARN("No col descriptor found even on the parent");
 290:Drivers/lvgl/src/layouts/grid/lv_grid.c ****             return LV_RESULT_INVALID;
 291:Drivers/lvgl/src/layouts/grid/lv_grid.c ****         }
 292:Drivers/lvgl/src/layouts/grid/lv_grid.c **** 
 293:Drivers/lvgl/src/layouts/grid/lv_grid.c ****         int32_t pos = get_col_pos(cont);
 294:Drivers/lvgl/src/layouts/grid/lv_grid.c ****         int32_t span = get_col_span(cont);
 295:Drivers/lvgl/src/layouts/grid/lv_grid.c **** 
 296:Drivers/lvgl/src/layouts/grid/lv_grid.c ****         int32_t * col_templ_sub = lv_malloc(sizeof(int32_t) * (span + 1));
 297:Drivers/lvgl/src/layouts/grid/lv_grid.c ****         lv_memcpy(col_templ_sub, &col_templ[pos], sizeof(int32_t) * span);
 298:Drivers/lvgl/src/layouts/grid/lv_grid.c ****         col_templ_sub[span] = LV_GRID_TEMPLATE_LAST;
 299:Drivers/lvgl/src/layouts/grid/lv_grid.c ****         col_templ = col_templ_sub;
 300:Drivers/lvgl/src/layouts/grid/lv_grid.c ****         subgrid = true;
 301:Drivers/lvgl/src/layouts/grid/lv_grid.c ****     }
 302:Drivers/lvgl/src/layouts/grid/lv_grid.c **** 
 303:Drivers/lvgl/src/layouts/grid/lv_grid.c ****     int32_t cont_w = lv_obj_get_content_width(cont);
 304:Drivers/lvgl/src/layouts/grid/lv_grid.c **** 
 305:Drivers/lvgl/src/layouts/grid/lv_grid.c ****     c->col_num = count_tracks(col_templ);
 306:Drivers/lvgl/src/layouts/grid/lv_grid.c ****     c->x = lv_malloc(sizeof(int32_t) * c->col_num);
 307:Drivers/lvgl/src/layouts/grid/lv_grid.c ****     c->w = lv_malloc(sizeof(int32_t) * c->col_num);
 308:Drivers/lvgl/src/layouts/grid/lv_grid.c **** 
 309:Drivers/lvgl/src/layouts/grid/lv_grid.c ****     /*Set sizes for CONTENT cells*/
 310:Drivers/lvgl/src/layouts/grid/lv_grid.c ****     uint32_t i;
 311:Drivers/lvgl/src/layouts/grid/lv_grid.c ****     for(i = 0; i < c->col_num; i++) {
 312:Drivers/lvgl/src/layouts/grid/lv_grid.c ****         int32_t size = LV_COORD_MIN;
 313:Drivers/lvgl/src/layouts/grid/lv_grid.c ****         if(IS_CONTENT(col_templ[i])) {
 314:Drivers/lvgl/src/layouts/grid/lv_grid.c ****             /*Check the size of children of this cell*/
 315:Drivers/lvgl/src/layouts/grid/lv_grid.c ****             uint32_t ci;
