 316:Drivers/lvgl/src/layouts/grid/lv_grid.c ****             for(ci = 0; ci < lv_obj_get_child_count(cont); ci++) {
 317:Drivers/lvgl/src/layouts/grid/lv_grid.c ****                 lv_obj_t * item = lv_obj_get_child(cont, ci);
 318:Drivers/lvgl/src/layouts/grid/lv_grid.c ****                 if(lv_obj_has_flag_any(item, LV_OBJ_FLAG_IGNORE_LAYOUT | LV_OBJ_FLAG_HIDDEN | LV_OB
 319:Drivers/lvgl/src/layouts/grid/lv_grid.c ****                 uint32_t col_span = get_col_span(item);
 320:Drivers/lvgl/src/layouts/grid/lv_grid.c ****                 if(col_span != 1) continue;
 321:Drivers/lvgl/src/layouts/grid/lv_grid.c **** 
 322:Drivers/lvgl/src/layouts/grid/lv_grid.c ****                 uint32_t col_pos = get_col_pos(item);
 323:Drivers/lvgl/src/layouts/grid/lv_grid.c ****                 if(col_pos != i) continue;
 324:Drivers/lvgl/src/layouts/grid/lv_grid.c **** 
 325:Drivers/lvgl/src/layouts/grid/lv_grid.c ****                 size = LV_MAX(size, lv_obj_get_width(item));
 326:Drivers/lvgl/src/layouts/grid/lv_grid.c ****             }
 327:Drivers/lvgl/src/layouts/grid/lv_grid.c ****             if(size >= 0) c->w[i] = size;
 328:Drivers/lvgl/src/layouts/grid/lv_grid.c ****             else c->w[i] = 0;
 329:Drivers/lvgl/src/layouts/grid/lv_grid.c ****         }
 330:Drivers/lvgl/src/layouts/grid/lv_grid.c ****     }
 331:Drivers/lvgl/src/layouts/grid/lv_grid.c **** 
 332:Drivers/lvgl/src/layouts/grid/lv_grid.c ****     uint32_t col_fr_cnt = 0;
 333:Drivers/lvgl/src/layouts/grid/lv_grid.c ****     int32_t grid_w = 0;
 334:Drivers/lvgl/src/layouts/grid/lv_grid.c **** 
 335:Drivers/lvgl/src/layouts/grid/lv_grid.c ****     for(i = 0; i < c->col_num; i++) {
 336:Drivers/lvgl/src/layouts/grid/lv_grid.c ****         int32_t x = col_templ[i];
 337:Drivers/lvgl/src/layouts/grid/lv_grid.c ****         if(IS_FR(x)) {
 338:Drivers/lvgl/src/layouts/grid/lv_grid.c ****             col_fr_cnt += GET_FR(x);
 339:Drivers/lvgl/src/layouts/grid/lv_grid.c ****         }
 340:Drivers/lvgl/src/layouts/grid/lv_grid.c ****         else if(IS_CONTENT(x)) {
 341:Drivers/lvgl/src/layouts/grid/lv_grid.c ****             grid_w += c->w[i];
 342:Drivers/lvgl/src/layouts/grid/lv_grid.c ****         }
 343:Drivers/lvgl/src/layouts/grid/lv_grid.c ****         else {
 344:Drivers/lvgl/src/layouts/grid/lv_grid.c ****             c->w[i] = x;
 345:Drivers/lvgl/src/layouts/grid/lv_grid.c ****             grid_w += x;
 346:Drivers/lvgl/src/layouts/grid/lv_grid.c ****         }
 347:Drivers/lvgl/src/layouts/grid/lv_grid.c ****     }
 348:Drivers/lvgl/src/layouts/grid/lv_grid.c **** 
 349:Drivers/lvgl/src/layouts/grid/lv_grid.c ****     int32_t col_gap = lv_obj_get_style_pad_column(cont, LV_PART_MAIN);
 350:Drivers/lvgl/src/layouts/grid/lv_grid.c ****     cont_w -= col_gap * (c->col_num - 1);
 351:Drivers/lvgl/src/layouts/grid/lv_grid.c ****     int32_t free_w = cont_w - grid_w;
 352:Drivers/lvgl/src/layouts/grid/lv_grid.c ****     if(free_w < 0) free_w = 0;
 353:Drivers/lvgl/src/layouts/grid/lv_grid.c **** 
 354:Drivers/lvgl/src/layouts/grid/lv_grid.c ****     for(i = 0; i < c->col_num && col_fr_cnt; i++) {
 355:Drivers/lvgl/src/layouts/grid/lv_grid.c ****         int32_t x = col_templ[i];
 356:Drivers/lvgl/src/layouts/grid/lv_grid.c ****         if(IS_FR(x)) {
 357:Drivers/lvgl/src/layouts/grid/lv_grid.c ****             int32_t f = GET_FR(x);
 358:Drivers/lvgl/src/layouts/grid/lv_grid.c ****             c->w[i] = lv_div_round_closest(free_w * f, col_fr_cnt);
 359:Drivers/lvgl/src/layouts/grid/lv_grid.c ****             /*By updating remaining fr and width, we ensure f == col_fr_cnt
 360:Drivers/lvgl/src/layouts/grid/lv_grid.c ****              *in the last loop iteration. That means the last iteration will
 361:Drivers/lvgl/src/layouts/grid/lv_grid.c ****              *not have rounding errors and use all remaining space.*/
 362:Drivers/lvgl/src/layouts/grid/lv_grid.c ****             col_fr_cnt -= f;
 363:Drivers/lvgl/src/layouts/grid/lv_grid.c ****             free_w -= c->w[i];
 364:Drivers/lvgl/src/layouts/grid/lv_grid.c ****         }
 365:Drivers/lvgl/src/layouts/grid/lv_grid.c ****     }
 366:Drivers/lvgl/src/layouts/grid/lv_grid.c **** 
 367:Drivers/lvgl/src/layouts/grid/lv_grid.c ****     if(subgrid) {
