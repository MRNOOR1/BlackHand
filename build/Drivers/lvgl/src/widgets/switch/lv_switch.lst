 224:Drivers/lvgl/src/widgets/switch/lv_switch.c ****             break;
 225:Drivers/lvgl/src/widgets/switch/lv_switch.c ****         case LV_SWITCH_ORIENTATION_AUTO:
 226:Drivers/lvgl/src/widgets/switch/lv_switch.c ****         default:
 227:Drivers/lvgl/src/widgets/switch/lv_switch.c ****             hor = (switch_w >= switch_h);
 228:Drivers/lvgl/src/widgets/switch/lv_switch.c ****             break;
 229:Drivers/lvgl/src/widgets/switch/lv_switch.c ****     }
 230:Drivers/lvgl/src/widgets/switch/lv_switch.c **** 
