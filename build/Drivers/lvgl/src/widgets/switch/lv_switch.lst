 216:Drivers/lvgl/src/widgets/switch/lv_switch.c ****     bool hor = false;
 217:Drivers/lvgl/src/widgets/switch/lv_switch.c **** 
 218:Drivers/lvgl/src/widgets/switch/lv_switch.c ****     switch(sw->orientation) {
 219:Drivers/lvgl/src/widgets/switch/lv_switch.c ****         case LV_SWITCH_ORIENTATION_HORIZONTAL:
 220:Drivers/lvgl/src/widgets/switch/lv_switch.c ****             hor = true;
 221:Drivers/lvgl/src/widgets/switch/lv_switch.c ****             break;
 222:Drivers/lvgl/src/widgets/switch/lv_switch.c ****         case LV_SWITCH_ORIENTATION_VERTICAL:
