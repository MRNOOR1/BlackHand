 210:Drivers/lvgl/src/widgets/switch/lv_switch.c ****     /*Draw the knob*/
 211:Drivers/lvgl/src/widgets/switch/lv_switch.c ****     lv_area_t knob_area;
 212:Drivers/lvgl/src/widgets/switch/lv_switch.c ****     lv_area_copy(&knob_area, &obj->coords);
