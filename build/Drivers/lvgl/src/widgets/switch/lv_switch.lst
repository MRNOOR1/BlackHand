 151:Drivers/lvgl/src/widgets/switch/lv_switch.c **** {
 152:Drivers/lvgl/src/widgets/switch/lv_switch.c ****     LV_UNUSED(class_p);
 153:Drivers/lvgl/src/widgets/switch/lv_switch.c **** 
 154:Drivers/lvgl/src/widgets/switch/lv_switch.c ****     lv_result_t res;
 155:Drivers/lvgl/src/widgets/switch/lv_switch.c **** 
 156:Drivers/lvgl/src/widgets/switch/lv_switch.c ****     /*Call the ancestor's event handler*/
 157:Drivers/lvgl/src/widgets/switch/lv_switch.c ****     res = lv_obj_event_base(MY_CLASS, e);
 158:Drivers/lvgl/src/widgets/switch/lv_switch.c ****     if(res != LV_RESULT_OK) return;
 159:Drivers/lvgl/src/widgets/switch/lv_switch.c **** 
 160:Drivers/lvgl/src/widgets/switch/lv_switch.c ****     lv_event_code_t code = lv_event_get_code(e);
 161:Drivers/lvgl/src/widgets/switch/lv_switch.c ****     lv_obj_t * obj = lv_event_get_current_target(e);
 162:Drivers/lvgl/src/widgets/switch/lv_switch.c **** 
 163:Drivers/lvgl/src/widgets/switch/lv_switch.c ****     if(code == LV_EVENT_REFR_EXT_DRAW_SIZE) {
 164:Drivers/lvgl/src/widgets/switch/lv_switch.c ****         int32_t knob_left = lv_obj_get_style_pad_left(obj,   LV_PART_KNOB);
 165:Drivers/lvgl/src/widgets/switch/lv_switch.c ****         int32_t knob_right = lv_obj_get_style_pad_right(obj,  LV_PART_KNOB);
 166:Drivers/lvgl/src/widgets/switch/lv_switch.c ****         int32_t knob_top = lv_obj_get_style_pad_top(obj,    LV_PART_KNOB);
 167:Drivers/lvgl/src/widgets/switch/lv_switch.c ****         int32_t knob_bottom = lv_obj_get_style_pad_bottom(obj, LV_PART_KNOB);
 168:Drivers/lvgl/src/widgets/switch/lv_switch.c **** 
 169:Drivers/lvgl/src/widgets/switch/lv_switch.c ****         /*The smaller size is the knob diameter*/
 170:Drivers/lvgl/src/widgets/switch/lv_switch.c ****         int32_t knob_size = LV_MAX4(knob_left, knob_right, knob_bottom, knob_top);
 171:Drivers/lvgl/src/widgets/switch/lv_switch.c ****         knob_size += LV_SWITCH_KNOB_EXT_AREA_CORRECTION;
 172:Drivers/lvgl/src/widgets/switch/lv_switch.c ****         knob_size += lv_obj_calculate_ext_draw_size(obj, LV_PART_KNOB);
 173:Drivers/lvgl/src/widgets/switch/lv_switch.c **** 
 174:Drivers/lvgl/src/widgets/switch/lv_switch.c ****         int32_t * s = lv_event_get_param(e);
 175:Drivers/lvgl/src/widgets/switch/lv_switch.c ****         *s = LV_MAX(*s, knob_size);
 176:Drivers/lvgl/src/widgets/switch/lv_switch.c ****         *s = LV_MAX(*s, lv_obj_calculate_ext_draw_size(obj, LV_PART_INDICATOR));
 177:Drivers/lvgl/src/widgets/switch/lv_switch.c ****     }
 178:Drivers/lvgl/src/widgets/switch/lv_switch.c ****     else if(code == LV_EVENT_STATE_CHANGED) {
 179:Drivers/lvgl/src/widgets/switch/lv_switch.c ****         lv_state_t prev_state = lv_event_get_prev_state(e);
 180:Drivers/lvgl/src/widgets/switch/lv_switch.c ****         lv_state_t diff = prev_state ^ lv_obj_get_state(obj);
 181:Drivers/lvgl/src/widgets/switch/lv_switch.c **** 
 182:Drivers/lvgl/src/widgets/switch/lv_switch.c ****         if(diff & LV_STATE_CHECKED) {
 183:Drivers/lvgl/src/widgets/switch/lv_switch.c ****             lv_switch_trigger_anim(obj);
 184:Drivers/lvgl/src/widgets/switch/lv_switch.c ****             lv_obj_invalidate(obj);
 185:Drivers/lvgl/src/widgets/switch/lv_switch.c ****         }
 186:Drivers/lvgl/src/widgets/switch/lv_switch.c ****     }
 187:Drivers/lvgl/src/widgets/switch/lv_switch.c ****     else if(code == LV_EVENT_DRAW_MAIN) {
 188:Drivers/lvgl/src/widgets/switch/lv_switch.c ****         draw_main(e);
 189:Drivers/lvgl/src/widgets/switch/lv_switch.c ****     }
 190:Drivers/lvgl/src/widgets/switch/lv_switch.c **** }
