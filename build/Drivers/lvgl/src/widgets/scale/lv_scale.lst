 693:Drivers/lvgl/src/widgets/scale/lv_scale.c ****             }
 694:Drivers/lvgl/src/widgets/scale/lv_scale.c ****             else {
 695:Drivers/lvgl/src/widgets/scale/lv_scale.c ****                 scale_draw_indicator(obj, event);
 696:Drivers/lvgl/src/widgets/scale/lv_scale.c ****                 scale_draw_main(obj, event);
 697:Drivers/lvgl/src/widgets/scale/lv_scale.c ****             }
 698:Drivers/lvgl/src/widgets/scale/lv_scale.c ****         }
 699:Drivers/lvgl/src/widgets/scale/lv_scale.c ****     }
 700:Drivers/lvgl/src/widgets/scale/lv_scale.c ****     if(event_code == LV_EVENT_DRAW_POST) {
 701:Drivers/lvgl/src/widgets/scale/lv_scale.c ****         if(scale->post_draw == true) {
 702:Drivers/lvgl/src/widgets/scale/lv_scale.c ****             scale_find_section_tick_idx(obj);
 703:Drivers/lvgl/src/widgets/scale/lv_scale.c ****             scale_calculate_main_compensation(obj);
 704:Drivers/lvgl/src/widgets/scale/lv_scale.c **** 
 705:Drivers/lvgl/src/widgets/scale/lv_scale.c ****             if(scale->draw_ticks_on_top) {
