 672:Drivers/lvgl/src/widgets/scale/lv_scale.c **** static void lv_scale_event(const lv_obj_class_t * class_p, lv_event_t * event)
 673:Drivers/lvgl/src/widgets/scale/lv_scale.c **** {
 674:Drivers/lvgl/src/widgets/scale/lv_scale.c ****     LV_UNUSED(class_p);
 675:Drivers/lvgl/src/widgets/scale/lv_scale.c **** 
 676:Drivers/lvgl/src/widgets/scale/lv_scale.c ****     /*Call the ancestor's event handler*/
 677:Drivers/lvgl/src/widgets/scale/lv_scale.c ****     lv_result_t res = lv_obj_event_base(MY_CLASS, event);
 678:Drivers/lvgl/src/widgets/scale/lv_scale.c ****     if(res != LV_RESULT_OK) return;
 679:Drivers/lvgl/src/widgets/scale/lv_scale.c **** 
 680:Drivers/lvgl/src/widgets/scale/lv_scale.c ****     lv_event_code_t event_code = lv_event_get_code(event);
