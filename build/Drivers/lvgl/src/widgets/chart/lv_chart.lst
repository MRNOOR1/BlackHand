 935:Drivers/lvgl/src/widgets/chart/lv_chart.c ****                 if(chart->type == LV_CHART_TYPE_LINE) draw_series_line(obj, layer);
 936:Drivers/lvgl/src/widgets/chart/lv_chart.c ****                 else if(chart->type == LV_CHART_TYPE_BAR) draw_series_bar(obj, layer);
 937:Drivers/lvgl/src/widgets/chart/lv_chart.c ****                 else if(chart->type == LV_CHART_TYPE_STACKED) draw_series_stacked(obj, layer);
 938:Drivers/lvgl/src/widgets/chart/lv_chart.c ****                 else if(chart->type == LV_CHART_TYPE_SCATTER) draw_series_scatter(obj, layer);
 939:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             }
 940:Drivers/lvgl/src/widgets/chart/lv_chart.c **** 
 941:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             draw_cursors(obj, layer);
 942:Drivers/lvgl/src/widgets/chart/lv_chart.c **** 
