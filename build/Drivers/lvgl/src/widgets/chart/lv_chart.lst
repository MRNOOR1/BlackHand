 887:Drivers/lvgl/src/widgets/chart/lv_chart.c **** static void lv_chart_event(const lv_obj_class_t * class_p, lv_event_t * e)
 888:Drivers/lvgl/src/widgets/chart/lv_chart.c **** {
 889:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     LV_UNUSED(class_p);
 890:Drivers/lvgl/src/widgets/chart/lv_chart.c **** 
 891:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     /*Call the ancestor's event handler*/
 892:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     lv_result_t res;
 893:Drivers/lvgl/src/widgets/chart/lv_chart.c **** 
 894:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     res = lv_obj_event_base(MY_CLASS, e);
 895:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     if(res != LV_RESULT_OK) return;
 896:Drivers/lvgl/src/widgets/chart/lv_chart.c **** 
 897:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     lv_event_code_t code = lv_event_get_code(e);
 898:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     lv_obj_t * obj = lv_event_get_current_target(e);
 899:Drivers/lvgl/src/widgets/chart/lv_chart.c **** 
 900:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     lv_chart_t * chart  = (lv_chart_t *)obj;
 901:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     if(code == LV_EVENT_PRESSED) {
 902:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         lv_indev_t * indev = lv_indev_active();
 903:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         lv_point_t p;
 904:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         lv_indev_get_point(indev, &p);
 905:Drivers/lvgl/src/widgets/chart/lv_chart.c **** 
 906:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         p.x -= obj->coords.x1;
 907:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         uint32_t id = get_index_from_x(obj, p.x + lv_obj_get_scroll_left(obj));
 908:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         if(id != (uint32_t)chart->pressed_point_id) {
 909:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             invalidate_point(obj, id);
 910:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             invalidate_point(obj, chart->pressed_point_id);
 911:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             chart->pressed_point_id = id;
 912:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             lv_obj_send_event(obj, LV_EVENT_VALUE_CHANGED, NULL);
 913:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         }
 914:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     }
 915:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     else if(code == LV_EVENT_RELEASED) {
 916:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         invalidate_point(obj, chart->pressed_point_id);
 917:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         chart->pressed_point_id = LV_CHART_POINT_NONE;
 918:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     }
 919:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     else if(code == LV_EVENT_DRAW_MAIN) {
 920:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         lv_layer_t * layer = lv_event_get_layer(e);
 921:Drivers/lvgl/src/widgets/chart/lv_chart.c **** 
 922:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         lv_area_t ext_coords;
 923:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         lv_obj_get_coords(obj, &ext_coords);
 924:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         int32_t ext_draw_size = lv_obj_get_ext_draw_size(obj);
 925:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         lv_area_increase(&ext_coords, ext_draw_size, ext_draw_size);
 926:Drivers/lvgl/src/widgets/chart/lv_chart.c **** 
 927:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         lv_area_t clip_area;
 928:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         if(lv_area_intersect(&clip_area, &ext_coords, &layer->_clip_area)) {
 929:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             const lv_area_t clip_area_ori = layer->_clip_area;
 930:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             layer->_clip_area = clip_area;
 931:Drivers/lvgl/src/widgets/chart/lv_chart.c **** 
 932:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             draw_div_lines(obj, layer);
