 166:Drivers/lvgl/src/widgets/chart/lv_chart.c **** void lv_chart_set_axis_min_value(lv_obj_t * obj, lv_chart_axis_t axis, int32_t min)
 167:Drivers/lvgl/src/widgets/chart/lv_chart.c **** {
 168:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     LV_ASSERT_OBJ(obj, MY_CLASS);
 169:Drivers/lvgl/src/widgets/chart/lv_chart.c **** 
 170:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     lv_chart_t * chart  = (lv_chart_t *)obj;
 171:Drivers/lvgl/src/widgets/chart/lv_chart.c **** 
 172:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     switch(axis) {
 173:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         case LV_CHART_AXIS_PRIMARY_Y:
 174:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             if(chart->ymin[0] == min) return;
 175:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             chart->ymin[0] = min;
 176:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             break;
 177:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         case LV_CHART_AXIS_SECONDARY_Y:
 178:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             if(chart->ymin[1] == min) return;
 179:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             chart->ymin[1] = min;
 180:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             break;
 181:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         case LV_CHART_AXIS_PRIMARY_X:
 182:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             if(chart->xmin[0] == min) return;
 183:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             chart->xmin[0] = min;
 184:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             break;
 185:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         case LV_CHART_AXIS_SECONDARY_X:
 186:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             if(chart->xmin[1] == min) return;
 187:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             chart->xmin[1] = min;
 188:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             break;
 189:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         default:
 190:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             LV_LOG_WARN("Invalid axis: %d", axis);
 191:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             return;
 192:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     }
 193:Drivers/lvgl/src/widgets/chart/lv_chart.c **** 
 194:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     lv_chart_refresh(obj);
 195:Drivers/lvgl/src/widgets/chart/lv_chart.c **** }
