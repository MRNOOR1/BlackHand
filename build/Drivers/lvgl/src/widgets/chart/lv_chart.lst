 327:Drivers/lvgl/src/widgets/chart/lv_chart.c **** void lv_chart_get_point_pos_by_id(lv_obj_t * obj, lv_chart_series_t * ser, uint32_t id, lv_point_t 
 328:Drivers/lvgl/src/widgets/chart/lv_chart.c **** {
 329:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     LV_ASSERT_NULL(obj);
 330:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     LV_ASSERT_NULL(ser);
 331:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     LV_ASSERT_OBJ(obj, MY_CLASS);
 332:Drivers/lvgl/src/widgets/chart/lv_chart.c **** 
 333:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     lv_chart_t * chart  = (lv_chart_t *)obj;
 334:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     if(id >= chart->point_cnt) {
 335:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         LV_LOG_WARN("Invalid index: %"LV_PRIu32, id);
 336:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         p_out->x = 0;
 337:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         p_out->y = 0;
 338:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         return;
 339:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     }
 340:Drivers/lvgl/src/widgets/chart/lv_chart.c **** 
 341:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     int32_t w = lv_obj_get_content_width(obj);
 342:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     int32_t h = lv_obj_get_content_height(obj);
 343:Drivers/lvgl/src/widgets/chart/lv_chart.c **** 
 344:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     if(chart->type == LV_CHART_TYPE_LINE) {
 345:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         if(chart->point_cnt > 1) {
 346:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             p_out->x = (w * id) / (chart->point_cnt - 1);
 347:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         }
 348:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         else {
 349:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             p_out->x = 0;
 350:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         }
 351:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         int32_t temp_y = value_to_y(obj, ser, ser->y_points[id], h);
 352:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         p_out->y = h - temp_y;
 353:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     }
 354:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     else if(chart->type == LV_CHART_TYPE_SCATTER) {
 355:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         p_out->x = lv_map(ser->x_points[id], chart->xmin[ser->x_axis_sec], chart->xmax[ser->x_axis_
 356:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         int32_t temp_y = value_to_y(obj, ser, ser->y_points[id], h);
 357:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         p_out->y = h - temp_y;
 358:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     }
 359:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     else if(chart->type == LV_CHART_TYPE_BAR) {
 360:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         uint32_t ser_cnt = lv_ll_get_len(&chart->series_ll);
 361:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         int32_t ser_gap = lv_obj_get_style_pad_column(obj, LV_PART_ITEMS);
 362:Drivers/lvgl/src/widgets/chart/lv_chart.c **** 
 363:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         /*Gap between the columns on adjacent X ticks*/
 364:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         int32_t block_gap = lv_obj_get_style_pad_column(obj, LV_PART_MAIN);
 365:Drivers/lvgl/src/widgets/chart/lv_chart.c **** 
 366:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         int32_t block_w = (w - ((chart->point_cnt - 1) * block_gap)) / chart->point_cnt;
 367:Drivers/lvgl/src/widgets/chart/lv_chart.c **** 
 368:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         if(chart->point_cnt > 1) {
 369:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             p_out->x = (int32_t)((int32_t)(w - block_w) * id) / (chart->point_cnt - 1);
 370:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         }
 371:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         else {
 372:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             p_out->x = 0;
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//cceI3mMD.s 			page 8


 373:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         }
 374:Drivers/lvgl/src/widgets/chart/lv_chart.c **** 
 375:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         lv_chart_series_t * ser_i = NULL;
 376:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         uint32_t ser_idx = 0;
 377:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         LV_LL_READ(&chart->series_ll, ser_i) {
 378:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             if(ser_i == ser) break;
 379:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             ser_idx++;
 380:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         }
 381:Drivers/lvgl/src/widgets/chart/lv_chart.c **** 
 382:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         p_out->x = (int32_t)((int32_t)(w + block_gap) * id) / chart->point_cnt;
 383:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         if(ser_cnt > 0) {
 384:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             p_out->x += block_w * ser_idx / ser_cnt;
 385:Drivers/lvgl/src/widgets/chart/lv_chart.c **** 
 386:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             int32_t col_w = (block_w - (ser_gap * (ser_cnt - 1))) / ser_cnt;
 387:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             p_out->x += col_w / 2;
 388:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         }
 389:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         else {
 390:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             LV_LOG_WARN("bar chart series count is zero");
 391:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         }
 392:Drivers/lvgl/src/widgets/chart/lv_chart.c **** 
 393:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         int32_t temp_y = value_to_y(obj, ser, ser->y_points[id], h);
 394:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         p_out->y = h - temp_y;
 395:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     }
 396:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     else if(chart->type == LV_CHART_TYPE_STACKED) {
 397:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         /*Gap between the columns on adjacent X ticks*/
 398:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         int32_t block_gap = lv_obj_get_style_pad_column(obj, LV_PART_MAIN);
 399:Drivers/lvgl/src/widgets/chart/lv_chart.c **** 
 400:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         int32_t block_w = (w - ((chart->point_cnt - 1) * block_gap)) / chart->point_cnt;
 401:Drivers/lvgl/src/widgets/chart/lv_chart.c **** 
 402:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         if(chart->point_cnt > 1) {
 403:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             p_out->x = (int32_t)((int32_t)(w - block_w) * id) / (chart->point_cnt - 1);
 404:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         }
 405:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         else {
 406:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             p_out->x = 0;
 407:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         }
 408:Drivers/lvgl/src/widgets/chart/lv_chart.c **** 
 409:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         p_out->x += block_w / 2;
 410:Drivers/lvgl/src/widgets/chart/lv_chart.c **** 
 411:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         int32_t v_sum = 0;
 412:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         lv_chart_series_t * s;
 413:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         LV_LL_READ(&chart->series_ll, s) {
 414:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             if(s->hidden) continue;
 415:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             int32_t start_point = chart->update_mode == LV_CHART_UPDATE_MODE_SHIFT ? s->start_point
 416:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             int32_t p_act = (start_point + id) % chart->point_cnt;
 417:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             int32_t v_act = s->y_points[p_act];
 418:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             if(s->y_points[p_act] == LV_CHART_POINT_NONE) continue;
 419:Drivers/lvgl/src/widgets/chart/lv_chart.c **** 
 420:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             /* Skip negative values in stacked charts. Negative values are not supported
 421:Drivers/lvgl/src/widgets/chart/lv_chart.c ****              * in stacked charts as they cannot be visually represented in the stacking logic. */
 422:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             if(v_act <= 0) {
 423:Drivers/lvgl/src/widgets/chart/lv_chart.c ****                 LV_LOG_WARN("Stacked chart doesn't support negative values.");
 424:Drivers/lvgl/src/widgets/chart/lv_chart.c ****                 continue;
 425:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             }
 426:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             v_sum += v_act;
 427:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             if(s == ser) break;
 428:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         }
 429:Drivers/lvgl/src/widgets/chart/lv_chart.c **** 
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//cceI3mMD.s 			page 9


 430:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         int32_t temp_y = value_to_y(obj, ser, v_sum, h);
 431:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         p_out->y = h - temp_y;
 432:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     }
 433:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     /*LV_CHART_TYPE_NONE*/
 434:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     else {
 435:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         p_out->x = 0;
 436:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         p_out->y = 0;
