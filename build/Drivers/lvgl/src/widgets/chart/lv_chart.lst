 114:Drivers/lvgl/src/widgets/chart/lv_chart.c **** {
 115:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     LV_ASSERT_OBJ(obj, MY_CLASS);
 116:Drivers/lvgl/src/widgets/chart/lv_chart.c **** 
 117:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     lv_chart_t * chart  = (lv_chart_t *)obj;
 118:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     if(chart->type == type) return;
 119:Drivers/lvgl/src/widgets/chart/lv_chart.c **** 
 120:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     if(chart->type == LV_CHART_TYPE_SCATTER) {
 121:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         lv_chart_series_t * ser;
 122:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         LV_LL_READ_BACK(&chart->series_ll, ser) {
 123:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             lv_free(ser->x_points);
 124:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             ser->x_points = NULL;
 125:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         }
 126:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     }
 127:Drivers/lvgl/src/widgets/chart/lv_chart.c **** 
 128:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     if(type == LV_CHART_TYPE_SCATTER) {
 129:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         lv_chart_series_t * ser;
 130:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         LV_LL_READ_BACK(&chart->series_ll, ser) {
 131:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             ser->x_points = lv_malloc(sizeof(int32_t) * chart->point_cnt);
 132:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             LV_ASSERT_MALLOC(ser->x_points);
 133:Drivers/lvgl/src/widgets/chart/lv_chart.c ****             if(ser->x_points == NULL) return;
 134:Drivers/lvgl/src/widgets/chart/lv_chart.c ****         }
 135:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     }
 136:Drivers/lvgl/src/widgets/chart/lv_chart.c **** 
 137:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     chart->type = type;
 138:Drivers/lvgl/src/widgets/chart/lv_chart.c **** 
 139:Drivers/lvgl/src/widgets/chart/lv_chart.c ****     lv_chart_refresh(obj);
 140:Drivers/lvgl/src/widgets/chart/lv_chart.c **** }
