 116:Drivers/lvgl/src/widgets/led/lv_led.c **** void lv_led_toggle(lv_obj_t * obj)
 117:Drivers/lvgl/src/widgets/led/lv_led.c **** {
 118:Drivers/lvgl/src/widgets/led/lv_led.c ****     uint8_t bright = lv_led_get_brightness(obj);
 119:Drivers/lvgl/src/widgets/led/lv_led.c ****     if(bright > (LV_LED_BRIGHT_MIN + LV_LED_BRIGHT_MAX) >> 1)
 120:Drivers/lvgl/src/widgets/led/lv_led.c ****         lv_led_off(obj);
 121:Drivers/lvgl/src/widgets/led/lv_led.c ****     else
 122:Drivers/lvgl/src/widgets/led/lv_led.c ****         lv_led_on(obj);
 123:Drivers/lvgl/src/widgets/led/lv_led.c **** }
