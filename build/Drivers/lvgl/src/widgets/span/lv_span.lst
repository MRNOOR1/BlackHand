 554:Drivers/lvgl/src/widgets/span/lv_span.c ****         uint32_t j = 0;
 555:Drivers/lvgl/src/widgets/span/lv_span.c ****         const char * cur_txt = cur_span->txt;
 556:Drivers/lvgl/src/widgets/span/lv_span.c ****         span_text_check(&cur_txt);
 557:Drivers/lvgl/src/widgets/span/lv_span.c ****         while(cur_txt[j] != '\0') {
