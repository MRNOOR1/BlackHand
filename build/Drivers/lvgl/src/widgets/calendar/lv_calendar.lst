 410:Drivers/lvgl/src/widgets/calendar/lv_calendar.c **** /**
 411:Drivers/lvgl/src/widgets/calendar/lv_calendar.c ****  * Get the number of days in a month
 412:Drivers/lvgl/src/widgets/calendar/lv_calendar.c ****  * @param year a year
 413:Drivers/lvgl/src/widgets/calendar/lv_calendar.c ****  * @param month a month. The range is basically [1..12] but [-11..0] or [13..24] is also
 414:Drivers/lvgl/src/widgets/calendar/lv_calendar.c ****  *              supported to handle next/prev. year
 415:Drivers/lvgl/src/widgets/calendar/lv_calendar.c ****  * @return [28..31]
 416:Drivers/lvgl/src/widgets/calendar/lv_calendar.c ****  */
 417:Drivers/lvgl/src/widgets/calendar/lv_calendar.c **** static uint8_t get_month_length(int32_t year, int32_t month)
 418:Drivers/lvgl/src/widgets/calendar/lv_calendar.c **** {
 419:Drivers/lvgl/src/widgets/calendar/lv_calendar.c ****     month--;
 420:Drivers/lvgl/src/widgets/calendar/lv_calendar.c ****     if(month < 0) {
 421:Drivers/lvgl/src/widgets/calendar/lv_calendar.c ****         year--;             /*Already in the previous year (won't be less than -12 to skip a whole 
 422:Drivers/lvgl/src/widgets/calendar/lv_calendar.c ****         month = 12 + month; /*`month` is negative, the result will be < 12*/
 423:Drivers/lvgl/src/widgets/calendar/lv_calendar.c ****     }
 424:Drivers/lvgl/src/widgets/calendar/lv_calendar.c ****     if(month >= 12) {
 425:Drivers/lvgl/src/widgets/calendar/lv_calendar.c ****         year++;
 426:Drivers/lvgl/src/widgets/calendar/lv_calendar.c ****         month -= 12;
 427:Drivers/lvgl/src/widgets/calendar/lv_calendar.c ****     }
 428:Drivers/lvgl/src/widgets/calendar/lv_calendar.c **** 
 429:Drivers/lvgl/src/widgets/calendar/lv_calendar.c ****     /*month == 1 is february*/
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//ccZZ70SA.s 			page 9


 430:Drivers/lvgl/src/widgets/calendar/lv_calendar.c ****     return (month == 1) ? (28 + is_leap_year(year)) : 31 - month % 7 % 2;
 431:Drivers/lvgl/src/widgets/calendar/lv_calendar.c **** }
 432:Drivers/lvgl/src/widgets/calendar/lv_calendar.c **** 
