 269:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     /* ensure the angle is in the range [0, 360) */
 270:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     while(rotation < 0) rotation += 360;
