 236:Drivers/lvgl/src/widgets/arc/lv_arc.c **** void lv_arc_set_bg_end_angle(lv_obj_t * obj, lv_value_precise_t end)
 237:Drivers/lvgl/src/widgets/arc/lv_arc.c **** {
 238:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     LV_ASSERT_OBJ(obj, MY_CLASS);
 239:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     lv_arc_t * arc = (lv_arc_t *)obj;
 240:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 241:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     if(end > 360) end -= 360;
 242:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 243:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     lv_value_precise_t old_delta = arc->bg_angle_end - arc->bg_angle_start;
 244:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     lv_value_precise_t new_delta = end - arc->bg_angle_start;
 245:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 246:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     if(old_delta < 0) old_delta = 360 + old_delta;
 247:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     if(new_delta < 0) new_delta = 360 + new_delta;
 248:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 249:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     if(LV_ABS(new_delta - old_delta) > 180)  lv_obj_invalidate(obj);
 250:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     else if(new_delta < old_delta) inv_arc_area(obj, end, arc->bg_angle_end, LV_PART_MAIN);
 251:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     else if(old_delta < new_delta) inv_arc_area(obj, arc->bg_angle_end, end, LV_PART_MAIN);
 252:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 253:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     arc->bg_angle_end = end;
 254:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 255:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     value_update(obj);
 256:Drivers/lvgl/src/widgets/arc/lv_arc.c **** }
