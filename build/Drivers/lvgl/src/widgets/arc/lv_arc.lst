 214:Drivers/lvgl/src/widgets/arc/lv_arc.c **** void lv_arc_set_bg_start_angle(lv_obj_t * obj, lv_value_precise_t start)
 215:Drivers/lvgl/src/widgets/arc/lv_arc.c **** {
 216:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     LV_ASSERT_OBJ(obj, MY_CLASS);
 217:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     lv_arc_t * arc = (lv_arc_t *)obj;
 218:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 219:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     if(start > 360) start -= 360;
 220:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 221:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     lv_value_precise_t old_delta = arc->bg_angle_end - arc->bg_angle_start;
 222:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     lv_value_precise_t new_delta = arc->bg_angle_end - start;
 223:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 224:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     if(old_delta < 0) old_delta = 360 + old_delta;
 225:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     if(new_delta < 0) new_delta = 360 + new_delta;
 226:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 227:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     if(LV_ABS(new_delta - old_delta) > 180)  lv_obj_invalidate(obj);
 228:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     else if(new_delta < old_delta) inv_arc_area(obj, arc->bg_angle_start, start, LV_PART_MAIN);
 229:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     else if(old_delta < new_delta) inv_arc_area(obj, start, arc->bg_angle_start, LV_PART_MAIN);
 230:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 231:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     arc->bg_angle_start = start;
