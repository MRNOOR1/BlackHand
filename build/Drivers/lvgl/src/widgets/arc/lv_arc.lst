 161:Drivers/lvgl/src/widgets/arc/lv_arc.c **** void lv_arc_set_start_angle(lv_obj_t * obj, lv_value_precise_t start)
 162:Drivers/lvgl/src/widgets/arc/lv_arc.c **** {
 163:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     LV_ASSERT_OBJ(obj, MY_CLASS);
 164:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     lv_arc_t * arc = (lv_arc_t *)obj;
 165:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 166:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     if(start > 360) start -= 360;
 167:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 168:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     lv_value_precise_t old_delta = arc->indic_angle_end - arc->indic_angle_start;
 169:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     lv_value_precise_t new_delta = arc->indic_angle_end - start;
 170:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 171:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     if(old_delta < 0) old_delta = 360 + old_delta;
 172:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     if(new_delta < 0) new_delta = 360 + new_delta;
 173:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 174:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     if(LV_ABS(new_delta - old_delta) > 180)  lv_obj_invalidate(obj);
 175:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     else if(new_delta < old_delta) inv_arc_area(obj, arc->indic_angle_start, start, LV_PART_INDICAT
 176:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     else if(old_delta < new_delta) inv_arc_area(obj, start, arc->indic_angle_start, LV_PART_INDICAT
 177:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 178:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     inv_knob_area(obj);
 179:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 180:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     arc->indic_angle_start = start;
 181:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 182:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     inv_knob_area(obj);
 183:Drivers/lvgl/src/widgets/arc/lv_arc.c **** }
 184:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 185:Drivers/lvgl/src/widgets/arc/lv_arc.c **** void lv_arc_set_end_angle(lv_obj_t * obj, lv_value_precise_t end)
 186:Drivers/lvgl/src/widgets/arc/lv_arc.c **** {
 187:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     LV_ASSERT_OBJ(obj, MY_CLASS);
 188:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     lv_arc_t * arc = (lv_arc_t *)obj;
 189:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     if(end > 360) end -= 360;
 190:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 191:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     lv_value_precise_t old_delta = arc->indic_angle_end - arc->indic_angle_start;
 192:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     lv_value_precise_t new_delta = end - arc->indic_angle_start;
 193:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 194:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     if(old_delta < 0) old_delta = 360 + old_delta;
 195:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     if(new_delta < 0) new_delta = 360 + new_delta;
 196:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 197:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     if(LV_ABS(new_delta - old_delta) > 180)  lv_obj_invalidate(obj);
 198:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     else if(new_delta < old_delta) inv_arc_area(obj, end, arc->indic_angle_end, LV_PART_INDICATOR);
 199:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     else if(old_delta < new_delta) inv_arc_area(obj, arc->indic_angle_end, end, LV_PART_INDICATOR);
 200:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 201:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     inv_knob_area(obj);
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//ccdsoqIm.s 			page 5


 202:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 203:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     arc->indic_angle_end = end;
 204:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 205:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     inv_knob_area(obj);
 206:Drivers/lvgl/src/widgets/arc/lv_arc.c **** }
