 277:Drivers/lvgl/src/widgets/arc/lv_arc.c **** void lv_arc_set_mode(lv_obj_t * obj, lv_arc_mode_t type)
 278:Drivers/lvgl/src/widgets/arc/lv_arc.c **** {
 279:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     LV_ASSERT_OBJ(obj, MY_CLASS);
 280:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     lv_arc_t * arc = (lv_arc_t *)obj;
 281:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 282:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     int32_t val = arc->value;
 283:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 284:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     arc->type = type;
 285:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     arc->value = -1; /** Force set_value handling*/
 286:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 287:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     lv_value_precise_t bg_midpoint, bg_end = arc->bg_angle_end;
 288:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     if(arc->bg_angle_end < arc->bg_angle_start) bg_end = arc->bg_angle_end + 360;
 289:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 290:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     switch(arc->type) {
 291:Drivers/lvgl/src/widgets/arc/lv_arc.c ****         case LV_ARC_MODE_SYMMETRICAL:
 292:Drivers/lvgl/src/widgets/arc/lv_arc.c ****             bg_midpoint = (arc->bg_angle_start + bg_end) / 2;
 293:Drivers/lvgl/src/widgets/arc/lv_arc.c ****             lv_arc_set_start_angle(obj, bg_midpoint);
 294:Drivers/lvgl/src/widgets/arc/lv_arc.c ****             lv_arc_set_end_angle(obj, bg_midpoint);
 295:Drivers/lvgl/src/widgets/arc/lv_arc.c ****             break;
 296:Drivers/lvgl/src/widgets/arc/lv_arc.c ****         case LV_ARC_MODE_REVERSE:
 297:Drivers/lvgl/src/widgets/arc/lv_arc.c ****             lv_arc_set_end_angle(obj, arc->bg_angle_end);
 298:Drivers/lvgl/src/widgets/arc/lv_arc.c ****             break;
 299:Drivers/lvgl/src/widgets/arc/lv_arc.c ****         default: /** LV_ARC_TYPE_NORMAL*/
 300:Drivers/lvgl/src/widgets/arc/lv_arc.c ****             lv_arc_set_start_angle(obj, arc->bg_angle_start);
 301:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     }
 302:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 303:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     lv_arc_set_value(obj, val);
 304:Drivers/lvgl/src/widgets/arc/lv_arc.c **** }
