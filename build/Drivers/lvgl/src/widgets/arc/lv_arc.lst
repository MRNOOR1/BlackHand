 306:Drivers/lvgl/src/widgets/arc/lv_arc.c **** void lv_arc_set_value(lv_obj_t * obj, int32_t value)
 307:Drivers/lvgl/src/widgets/arc/lv_arc.c **** {
 308:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     LV_ASSERT_OBJ(obj, MY_CLASS);
 309:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     lv_arc_t * arc = (lv_arc_t *)obj;
 310:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 311:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     if(arc->value == value) return;
 312:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 313:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     int32_t new_value;
 314:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     new_value = value > arc->max_value ? arc->max_value : value;
 315:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     new_value = new_value < arc->min_value ? arc->min_value : new_value;
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//ccdsoqIm.s 			page 7


 316:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 317:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     if(arc->value == new_value) return;
 318:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     arc->value = new_value;
 319:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 320:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     value_update(obj);
 321:Drivers/lvgl/src/widgets/arc/lv_arc.c **** }
 322:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 323:Drivers/lvgl/src/widgets/arc/lv_arc.c **** void lv_arc_set_range(lv_obj_t * obj, int32_t min, int32_t max)
 324:Drivers/lvgl/src/widgets/arc/lv_arc.c **** {
 325:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     LV_ASSERT_OBJ(obj, MY_CLASS);
 326:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     lv_arc_t * arc = (lv_arc_t *)obj;
 327:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 328:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     if(arc->min_value == min && arc->max_value == max) return;
 329:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 330:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     arc->min_value = min;
 331:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     arc->max_value = max;
 332:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 333:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     if(arc->value < min) {
 334:Drivers/lvgl/src/widgets/arc/lv_arc.c ****         arc->value = min;
 335:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     }
 336:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     if(arc->value > max) {
 337:Drivers/lvgl/src/widgets/arc/lv_arc.c ****         arc->value = max;
 338:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     }
 339:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 340:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     value_update(obj); /*value has changed relative to the new range*/
 341:Drivers/lvgl/src/widgets/arc/lv_arc.c **** }
 342:Drivers/lvgl/src/widgets/arc/lv_arc.c **** 
 343:Drivers/lvgl/src/widgets/arc/lv_arc.c **** void lv_arc_set_min_value(lv_obj_t * obj, int32_t min)
 344:Drivers/lvgl/src/widgets/arc/lv_arc.c **** {
 345:Drivers/lvgl/src/widgets/arc/lv_arc.c ****     lv_arc_set_range(obj, min, lv_arc_get_max_value(obj));
 346:Drivers/lvgl/src/widgets/arc/lv_arc.c **** }
