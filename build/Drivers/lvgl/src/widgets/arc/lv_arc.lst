1045:Drivers/lvgl/src/widgets/arc/lv_arc.c **** /**
1046:Drivers/lvgl/src/widgets/arc/lv_arc.c ****  * Check if angle is within arc background bounds
1047:Drivers/lvgl/src/widgets/arc/lv_arc.c ****  *
1048:Drivers/lvgl/src/widgets/arc/lv_arc.c ****  * In order to avoid unexpected value update of the arc value when the user clicks
1049:Drivers/lvgl/src/widgets/arc/lv_arc.c ****  * outside of the arc background we need to check if the angle (of the clicked point)
1050:Drivers/lvgl/src/widgets/arc/lv_arc.c ****  * is within the bounds of the background.
1051:Drivers/lvgl/src/widgets/arc/lv_arc.c ****  *
1052:Drivers/lvgl/src/widgets/arc/lv_arc.c ****  * A tolerance (extra room) also should be taken into consideration.
1053:Drivers/lvgl/src/widgets/arc/lv_arc.c ****  *
1054:Drivers/lvgl/src/widgets/arc/lv_arc.c ****  * E.g. Arc with start angle of 0° and end angle of 90°, the background is only visible in
1055:Drivers/lvgl/src/widgets/arc/lv_arc.c ****  * that range, from 90° to 360° the background is invisible. Click in 150° should not update
1056:Drivers/lvgl/src/widgets/arc/lv_arc.c ****  * the arc value, click within the arc angle range should.
1057:Drivers/lvgl/src/widgets/arc/lv_arc.c ****  *
1058:Drivers/lvgl/src/widgets/arc/lv_arc.c ****  * IMPORTANT NOTE: angle is always relative to bg_angle_start, e.g. if bg_angle_start is 30
1059:Drivers/lvgl/src/widgets/arc/lv_arc.c ****  * and we click a bit to the left, angle is 10, not the expected 40.
1060:Drivers/lvgl/src/widgets/arc/lv_arc.c ****  *
1061:Drivers/lvgl/src/widgets/arc/lv_arc.c ****  * @param obj   Pointer to lv_arc
1062:Drivers/lvgl/src/widgets/arc/lv_arc.c ****  * @param angle Angle to be checked. Is 0<=angle<=360 and relative to bg_angle_start
1063:Drivers/lvgl/src/widgets/arc/lv_arc.c ****  * @param tolerance_deg Tolerance
1064:Drivers/lvgl/src/widgets/arc/lv_arc.c ****  *
1065:Drivers/lvgl/src/widgets/arc/lv_arc.c ****  * @return true if angle is within arc background bounds, false otherwise
1066:Drivers/lvgl/src/widgets/arc/lv_arc.c ****  */
1067:Drivers/lvgl/src/widgets/arc/lv_arc.c **** static bool lv_arc_angle_within_bg_bounds(lv_obj_t * obj, const lv_value_precise_t angle,
1068:Drivers/lvgl/src/widgets/arc/lv_arc.c ****                                           const lv_value_precise_t tolerance_deg)
