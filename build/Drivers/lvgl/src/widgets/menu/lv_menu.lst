 395:Drivers/lvgl/src/widgets/menu/lv_menu.c **** void lv_menu_set_load_page_event(lv_obj_t * menu, lv_obj_t * obj, lv_obj_t * page)
 396:Drivers/lvgl/src/widgets/menu/lv_menu.c **** {
 397:Drivers/lvgl/src/widgets/menu/lv_menu.c ****     LV_ASSERT_OBJ(menu, MY_CLASS);
 398:Drivers/lvgl/src/widgets/menu/lv_menu.c **** 
 399:Drivers/lvgl/src/widgets/menu/lv_menu.c ****     lv_obj_add_flag(obj, LV_OBJ_FLAG_CLICKABLE);
 400:Drivers/lvgl/src/widgets/menu/lv_menu.c ****     lv_obj_remove_flag(obj, LV_OBJ_FLAG_SCROLLABLE);
 401:Drivers/lvgl/src/widgets/menu/lv_menu.c ****     lv_obj_add_flag(obj, LV_OBJ_FLAG_SCROLL_ON_FOCUS);
 402:Drivers/lvgl/src/widgets/menu/lv_menu.c **** 
 403:Drivers/lvgl/src/widgets/menu/lv_menu.c ****     /* Remove old event */
 404:Drivers/lvgl/src/widgets/menu/lv_menu.c ****     uint32_t i;
 405:Drivers/lvgl/src/widgets/menu/lv_menu.c ****     uint32_t event_cnt = lv_obj_get_event_count(obj);
 406:Drivers/lvgl/src/widgets/menu/lv_menu.c ****     for(i = 0; i < event_cnt; i++) {
 407:Drivers/lvgl/src/widgets/menu/lv_menu.c ****         lv_event_dsc_t * event_dsc = lv_obj_get_event_dsc(obj, i);
 408:Drivers/lvgl/src/widgets/menu/lv_menu.c ****         if(lv_event_dsc_get_cb(event_dsc) == lv_menu_load_page_event_cb) {
 409:Drivers/lvgl/src/widgets/menu/lv_menu.c ****             /* Free the old event data */
 410:Drivers/lvgl/src/widgets/menu/lv_menu.c ****             lv_menu_load_page_event_data_t * old_event_data = lv_event_dsc_get_user_data(event_dsc)
 411:Drivers/lvgl/src/widgets/menu/lv_menu.c ****             lv_obj_remove_event(obj, i);
 412:Drivers/lvgl/src/widgets/menu/lv_menu.c ****             /* Also remove the corresponding DELETE event callback */
 413:Drivers/lvgl/src/widgets/menu/lv_menu.c ****             event_cnt = lv_obj_get_event_count(obj);
 414:Drivers/lvgl/src/widgets/menu/lv_menu.c ****             for(uint32_t j = 0; j < event_cnt; j++) {
 415:Drivers/lvgl/src/widgets/menu/lv_menu.c ****                 lv_event_dsc_t * del_dsc = lv_obj_get_event_dsc(obj, j);
 416:Drivers/lvgl/src/widgets/menu/lv_menu.c ****                 if(lv_event_dsc_get_cb(del_dsc) == lv_menu_obj_delete_event_cb &&
 417:Drivers/lvgl/src/widgets/menu/lv_menu.c ****                    lv_event_dsc_get_user_data(del_dsc) == old_event_data) {
 418:Drivers/lvgl/src/widgets/menu/lv_menu.c ****                     lv_obj_remove_event(obj, j);
 419:Drivers/lvgl/src/widgets/menu/lv_menu.c ****                     break;
 420:Drivers/lvgl/src/widgets/menu/lv_menu.c ****                 }
 421:Drivers/lvgl/src/widgets/menu/lv_menu.c ****             }
 422:Drivers/lvgl/src/widgets/menu/lv_menu.c ****             lv_free(old_event_data);
 423:Drivers/lvgl/src/widgets/menu/lv_menu.c ****             break;
 424:Drivers/lvgl/src/widgets/menu/lv_menu.c ****         }
 425:Drivers/lvgl/src/widgets/menu/lv_menu.c ****     }
 426:Drivers/lvgl/src/widgets/menu/lv_menu.c **** 
 427:Drivers/lvgl/src/widgets/menu/lv_menu.c ****     lv_menu_load_page_event_data_t * event_data = lv_malloc(sizeof(lv_menu_load_page_event_data_t))
 428:Drivers/lvgl/src/widgets/menu/lv_menu.c ****     event_data->menu = menu;
 429:Drivers/lvgl/src/widgets/menu/lv_menu.c ****     event_data->page = page;
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//ccA33RQ9.s 			page 9


 430:Drivers/lvgl/src/widgets/menu/lv_menu.c **** 
 431:Drivers/lvgl/src/widgets/menu/lv_menu.c ****     lv_obj_add_event_cb(obj, lv_menu_load_page_event_cb, LV_EVENT_CLICKED, event_data);
 432:Drivers/lvgl/src/widgets/menu/lv_menu.c ****     lv_obj_add_event_cb(obj, lv_menu_obj_delete_event_cb, LV_EVENT_DELETE, event_data);
 433:Drivers/lvgl/src/widgets/menu/lv_menu.c **** }
