 820:Drivers/lvgl/src/widgets/menu/lv_menu.c **** static void lv_menu_back_event_cb(lv_event_t * e)
 821:Drivers/lvgl/src/widgets/menu/lv_menu.c **** {
 822:Drivers/lvgl/src/widgets/menu/lv_menu.c ****     lv_event_code_t code = lv_event_get_code(e);
 823:Drivers/lvgl/src/widgets/menu/lv_menu.c ****     /* LV_EVENT_CLICKED */
 824:Drivers/lvgl/src/widgets/menu/lv_menu.c ****     if(code == LV_EVENT_CLICKED) {
 825:Drivers/lvgl/src/widgets/menu/lv_menu.c ****         lv_obj_t * obj = lv_event_get_current_target(e);
 826:Drivers/lvgl/src/widgets/menu/lv_menu.c ****         lv_menu_t * menu = (lv_menu_t *)lv_event_get_user_data(e);
 827:Drivers/lvgl/src/widgets/menu/lv_menu.c **** 
 828:Drivers/lvgl/src/widgets/menu/lv_menu.c ****         if(!(obj == menu->main_header_back_btn || obj == menu->sidebar_header_back_btn)) return;
 829:Drivers/lvgl/src/widgets/menu/lv_menu.c **** 
 830:Drivers/lvgl/src/widgets/menu/lv_menu.c ****         menu->prev_depth = menu->cur_depth; /* Save the previous value for user event handler */
 831:Drivers/lvgl/src/widgets/menu/lv_menu.c **** 
 832:Drivers/lvgl/src/widgets/menu/lv_menu.c ****         if(lv_menu_back_button_is_root((lv_obj_t *)menu, obj)) return;
 833:Drivers/lvgl/src/widgets/menu/lv_menu.c **** 
 834:Drivers/lvgl/src/widgets/menu/lv_menu.c ****         lv_ll_t * history_ll = &(menu->history_ll);
 835:Drivers/lvgl/src/widgets/menu/lv_menu.c **** 
 836:Drivers/lvgl/src/widgets/menu/lv_menu.c ****         /* The current menu */
 837:Drivers/lvgl/src/widgets/menu/lv_menu.c ****         lv_menu_history_t * act_hist = lv_ll_get_head(history_ll);
 838:Drivers/lvgl/src/widgets/menu/lv_menu.c **** 
 839:Drivers/lvgl/src/widgets/menu/lv_menu.c ****         /* The previous menu */
 840:Drivers/lvgl/src/widgets/menu/lv_menu.c ****         lv_menu_history_t * prev_hist = lv_ll_get_next(history_ll, act_hist);
 841:Drivers/lvgl/src/widgets/menu/lv_menu.c **** 
 842:Drivers/lvgl/src/widgets/menu/lv_menu.c ****         if(prev_hist != NULL) {
 843:Drivers/lvgl/src/widgets/menu/lv_menu.c ****             /* Previous menu exists */
 844:Drivers/lvgl/src/widgets/menu/lv_menu.c ****             /* Delete the current item from the history */
 845:Drivers/lvgl/src/widgets/menu/lv_menu.c ****             lv_ll_remove(history_ll, act_hist);
 846:Drivers/lvgl/src/widgets/menu/lv_menu.c ****             lv_free(act_hist);
 847:Drivers/lvgl/src/widgets/menu/lv_menu.c ****             menu->cur_depth--;
 848:Drivers/lvgl/src/widgets/menu/lv_menu.c ****             /* Create the previous menu.
 849:Drivers/lvgl/src/widgets/menu/lv_menu.c ****             *  Remove it from the history because `lv_menu_set_page` will add it again */
 850:Drivers/lvgl/src/widgets/menu/lv_menu.c ****             lv_ll_remove(history_ll, prev_hist);
 851:Drivers/lvgl/src/widgets/menu/lv_menu.c ****             menu->cur_depth--;
 852:Drivers/lvgl/src/widgets/menu/lv_menu.c ****             lv_menu_set_page(&(menu->obj), prev_hist->page);
 853:Drivers/lvgl/src/widgets/menu/lv_menu.c **** 
 854:Drivers/lvgl/src/widgets/menu/lv_menu.c ****             lv_free(prev_hist);
 855:Drivers/lvgl/src/widgets/menu/lv_menu.c ****         }
 856:Drivers/lvgl/src/widgets/menu/lv_menu.c ****     }
 857:Drivers/lvgl/src/widgets/menu/lv_menu.c **** }
