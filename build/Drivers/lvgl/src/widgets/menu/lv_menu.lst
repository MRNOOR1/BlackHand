 202:Drivers/lvgl/src/widgets/menu/lv_menu.c **** 
 203:Drivers/lvgl/src/widgets/menu/lv_menu.c ****     lv_menu_t * menu = (lv_menu_t *)obj;
 204:Drivers/lvgl/src/widgets/menu/lv_menu.c ****     lv_ll_t * history_ll = &(menu->history_ll);
 205:Drivers/lvgl/src/widgets/menu/lv_menu.c **** 
 206:Drivers/lvgl/src/widgets/menu/lv_menu.c ****     /* The current menu */
 207:Drivers/lvgl/src/widgets/menu/lv_menu.c ****     lv_menu_history_t * act_hist = lv_ll_get_head(history_ll);
 208:Drivers/lvgl/src/widgets/menu/lv_menu.c **** 
 209:Drivers/lvgl/src/widgets/menu/lv_menu.c ****     lv_obj_t * page = NULL;
 210:Drivers/lvgl/src/widgets/menu/lv_menu.c **** 
 211:Drivers/lvgl/src/widgets/menu/lv_menu.c ****     if(act_hist != NULL) {
 212:Drivers/lvgl/src/widgets/menu/lv_menu.c ****         page = act_hist->page;
 213:Drivers/lvgl/src/widgets/menu/lv_menu.c ****         /* Delete the current item from the history */
 214:Drivers/lvgl/src/widgets/menu/lv_menu.c ****         lv_ll_remove(history_ll, act_hist);
 215:Drivers/lvgl/src/widgets/menu/lv_menu.c ****         lv_free(act_hist);
 216:Drivers/lvgl/src/widgets/menu/lv_menu.c ****         menu->cur_depth--;
 217:Drivers/lvgl/src/widgets/menu/lv_menu.c ****     }
 218:Drivers/lvgl/src/widgets/menu/lv_menu.c **** 
