 202:Drivers/lvgl/src/widgets/label/lv_label.c ****     if(!new_tag) {
 203:Drivers/lvgl/src/widgets/label/lv_label.c ****         LV_LOG_WARN("Failed to allocate memory for new tag");
 204:Drivers/lvgl/src/widgets/label/lv_label.c ****         return;
 205:Drivers/lvgl/src/widgets/label/lv_label.c ****     }
 206:Drivers/lvgl/src/widgets/label/lv_label.c ****     if(label->translation_tag) {
 207:Drivers/lvgl/src/widgets/label/lv_label.c ****         lv_free(label->translation_tag);
 208:Drivers/lvgl/src/widgets/label/lv_label.c ****     }
 209:Drivers/lvgl/src/widgets/label/lv_label.c ****     label->translation_tag = new_tag;
 210:Drivers/lvgl/src/widgets/label/lv_label.c ****     set_text_internal(obj, lv_tr(tag));
 211:Drivers/lvgl/src/widgets/label/lv_label.c **** }
