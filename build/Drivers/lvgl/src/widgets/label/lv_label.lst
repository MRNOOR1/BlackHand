 145:Drivers/lvgl/src/widgets/label/lv_label.c **** 
 146:Drivers/lvgl/src/widgets/label/lv_label.c **** void lv_label_set_text_vfmt(lv_obj_t * obj, const char * fmt, va_list args)
 147:Drivers/lvgl/src/widgets/label/lv_label.c **** {
 148:Drivers/lvgl/src/widgets/label/lv_label.c ****     LV_ASSERT_OBJ(obj, MY_CLASS);
 149:Drivers/lvgl/src/widgets/label/lv_label.c ****     LV_ASSERT_NULL(fmt);
 150:Drivers/lvgl/src/widgets/label/lv_label.c **** 
 151:Drivers/lvgl/src/widgets/label/lv_label.c ****     remove_translation_tag(obj);
 152:Drivers/lvgl/src/widgets/label/lv_label.c ****     lv_label_t * label = (lv_label_t *)obj;
 153:Drivers/lvgl/src/widgets/label/lv_label.c **** 
 154:Drivers/lvgl/src/widgets/label/lv_label.c ****     lv_label_revert_dots(obj);
 155:Drivers/lvgl/src/widgets/label/lv_label.c **** 
 156:Drivers/lvgl/src/widgets/label/lv_label.c ****     /*If text is NULL then refresh*/
 157:Drivers/lvgl/src/widgets/label/lv_label.c ****     if(fmt == NULL) {
 158:Drivers/lvgl/src/widgets/label/lv_label.c ****         lv_label_mark_need_refr_text(obj);
 159:Drivers/lvgl/src/widgets/label/lv_label.c ****         return;
 160:Drivers/lvgl/src/widgets/label/lv_label.c ****     }
 161:Drivers/lvgl/src/widgets/label/lv_label.c **** 
 162:Drivers/lvgl/src/widgets/label/lv_label.c ****     if(label->text != NULL && label->static_txt == 0) {
 163:Drivers/lvgl/src/widgets/label/lv_label.c ****         lv_free(label->text);
 164:Drivers/lvgl/src/widgets/label/lv_label.c ****         label->text = NULL;
 165:Drivers/lvgl/src/widgets/label/lv_label.c ****     }
 166:Drivers/lvgl/src/widgets/label/lv_label.c **** 
 167:Drivers/lvgl/src/widgets/label/lv_label.c ****     label->text = lv_text_set_text_vfmt(fmt, args);
 168:Drivers/lvgl/src/widgets/label/lv_label.c ****     label->static_txt = 0; /*Now the text is dynamically allocated*/
 169:Drivers/lvgl/src/widgets/label/lv_label.c **** 
 170:Drivers/lvgl/src/widgets/label/lv_label.c ****     lv_label_mark_need_refr_text(obj);
 171:Drivers/lvgl/src/widgets/label/lv_label.c **** }
 172:Drivers/lvgl/src/widgets/label/lv_label.c **** 
 173:Drivers/lvgl/src/widgets/label/lv_label.c **** void lv_label_set_text_static(lv_obj_t * obj, const char * text)
 174:Drivers/lvgl/src/widgets/label/lv_label.c **** {
 175:Drivers/lvgl/src/widgets/label/lv_label.c ****     LV_ASSERT_OBJ(obj, MY_CLASS);
 176:Drivers/lvgl/src/widgets/label/lv_label.c ****     lv_label_t * label = (lv_label_t *)obj;
 177:Drivers/lvgl/src/widgets/label/lv_label.c **** 
 178:Drivers/lvgl/src/widgets/label/lv_label.c ****     remove_translation_tag(obj);
 179:Drivers/lvgl/src/widgets/label/lv_label.c ****     if(label->static_txt == 0 && label->text != NULL) {
 180:Drivers/lvgl/src/widgets/label/lv_label.c ****         lv_free(label->text);
 181:Drivers/lvgl/src/widgets/label/lv_label.c ****         label->text = NULL;
 182:Drivers/lvgl/src/widgets/label/lv_label.c ****     }
 183:Drivers/lvgl/src/widgets/label/lv_label.c **** 
 184:Drivers/lvgl/src/widgets/label/lv_label.c ****     if(text != NULL) {
 185:Drivers/lvgl/src/widgets/label/lv_label.c ****         label->static_txt = 1;
 186:Drivers/lvgl/src/widgets/label/lv_label.c ****         label->text       = (char *)text;
 187:Drivers/lvgl/src/widgets/label/lv_label.c ****     }
 188:Drivers/lvgl/src/widgets/label/lv_label.c **** 
 189:Drivers/lvgl/src/widgets/label/lv_label.c ****     lv_label_mark_need_refr_text(obj);
 190:Drivers/lvgl/src/widgets/label/lv_label.c **** }
