 207:Drivers/lvgl/src/widgets/canvas/lv_canvas.c **** lv_color32_t lv_canvas_get_px(lv_obj_t * obj, int32_t x, int32_t y)
 208:Drivers/lvgl/src/widgets/canvas/lv_canvas.c **** {
 209:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****     LV_ASSERT_OBJ(obj, MY_CLASS);
 210:Drivers/lvgl/src/widgets/canvas/lv_canvas.c **** 
 211:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****     lv_color32_t ret = { 0 };
 212:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****     lv_canvas_t * canvas = (lv_canvas_t *)obj;
 213:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****     if(canvas->draw_buf == NULL) return ret;
 214:Drivers/lvgl/src/widgets/canvas/lv_canvas.c **** 
 215:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****     lv_image_header_t * header = &canvas->draw_buf->header;
 216:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****     const uint8_t * px = lv_draw_buf_goto_xy(canvas->draw_buf, x, y);
 217:Drivers/lvgl/src/widgets/canvas/lv_canvas.c **** 
 218:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****     switch(header->cf) {
 219:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****         case LV_COLOR_FORMAT_ARGB8888:
 220:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****             ret = *(lv_color32_t *)px;
 221:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****             break;
 222:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****         case LV_COLOR_FORMAT_RGB888:
 223:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****         case LV_COLOR_FORMAT_XRGB8888:
 224:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****             ret.red = px[2];
 225:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****             ret.green = px[1];
 226:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****             ret.blue = px[0];
 227:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****             ret.alpha = 0xFF;
 228:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****             break;
 229:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****         case LV_COLOR_FORMAT_RGB565: {
 230:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****                 lv_color16_t * c16 = (lv_color16_t *) px;
 231:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****                 ret.red = (c16[0].red * 2106) >> 8;  /*To make it rounded*/
 232:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****                 ret.green = (c16[0].green * 1037) >> 8;
 233:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****                 ret.blue = (c16[0].blue * 2106) >> 8;
 234:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****                 ret.alpha = 0xFF;
 235:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****                 break;
