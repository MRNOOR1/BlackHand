 111:Drivers/lvgl/src/widgets/canvas/lv_canvas.c **** void lv_canvas_set_px(lv_obj_t * obj, int32_t x, int32_t y, lv_color_t color, lv_opa_t opa)
 112:Drivers/lvgl/src/widgets/canvas/lv_canvas.c **** {
 113:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****     LV_ASSERT_OBJ(obj, MY_CLASS);
 114:Drivers/lvgl/src/widgets/canvas/lv_canvas.c **** 
 115:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****     lv_canvas_t * canvas = (lv_canvas_t *)obj;
 116:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****     lv_draw_buf_t * draw_buf = canvas->draw_buf;
 117:Drivers/lvgl/src/widgets/canvas/lv_canvas.c **** 
 118:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****     lv_color_format_t cf = draw_buf->header.cf;
 119:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****     uint8_t * data = lv_draw_buf_goto_xy(draw_buf, x, y);
 120:Drivers/lvgl/src/widgets/canvas/lv_canvas.c **** 
 121:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****     if(LV_COLOR_FORMAT_IS_INDEXED(cf)) {
 122:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****         uint8_t shift;
 123:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****         uint8_t c_int = color.blue;
 124:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****         switch(cf) {
 125:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****             case LV_COLOR_FORMAT_I1:
 126:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****                 shift = 7 - (x & 0x7);
 127:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****                 break;
 128:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****             case LV_COLOR_FORMAT_I2:
 129:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****                 shift = 6 - 2 * (x & 0x3);
 130:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****                 break;
 131:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****             case LV_COLOR_FORMAT_I4:
 132:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****                 shift = 4 - 4 * (x & 0x1);
 133:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****                 break;
 134:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****             case LV_COLOR_FORMAT_I8:
 135:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****                 /*Indexed8 format is a easy case, process and return.*/
 136:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****                 shift = 0;
 137:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****                 *data = c_int;
 138:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****             default:
 139:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****                 return;
 140:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****         }
 141:Drivers/lvgl/src/widgets/canvas/lv_canvas.c **** 
 142:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****         uint8_t bpp = lv_color_format_get_bpp(cf);
 143:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****         uint8_t mask = (1 << bpp) - 1;
 144:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****         c_int &= mask;
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//cc0QvDW4.s 			page 4


 145:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****         *data = (*data & ~(mask << shift)) | (c_int << shift);
 146:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****     }
 147:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****     else if(cf == LV_COLOR_FORMAT_L8) {
 148:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****         *data = lv_color_luminance(color);
 149:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****     }
 150:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****     else if(cf == LV_COLOR_FORMAT_A8) {
 151:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****         *data = opa;
 152:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****     }
 153:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****     else if(cf == LV_COLOR_FORMAT_RGB565) {
 154:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****         lv_color16_t * buf = (lv_color16_t *)data;
 155:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****         buf->red = color.red >> 3;
 156:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****         buf->green = color.green >> 2;
 157:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****         buf->blue = color.blue >> 3;
 158:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****     }
 159:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****     else if(cf == LV_COLOR_FORMAT_RGB888) {
 160:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****         data[2] = color.red;
 161:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****         data[1] = color.green;
 162:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****         data[0] = color.blue;
 163:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****     }
 164:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****     else if(cf == LV_COLOR_FORMAT_XRGB8888) {
 165:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****         data[2] = color.red;
 166:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****         data[1] = color.green;
 167:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****         data[0] = color.blue;
 168:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****         data[3] = 0xFF;
 169:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****     }
 170:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****     else if(cf == LV_COLOR_FORMAT_ARGB8888) {
 171:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****         lv_color32_t * buf = (lv_color32_t *)data;
 172:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****         buf->red = color.red;
 173:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****         buf->green = color.green;
 174:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****         buf->blue = color.blue;
 175:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****         buf->alpha = opa;
 176:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****     }
 177:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****     else if(cf == LV_COLOR_FORMAT_AL88) {
 178:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****         lv_color16a_t * buf = (lv_color16a_t *)data;
 179:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****         buf->lumi = lv_color_luminance(color);
 180:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****         buf->alpha = 255;
 181:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****     }
 182:Drivers/lvgl/src/widgets/canvas/lv_canvas.c ****     lv_obj_invalidate(obj);
 183:Drivers/lvgl/src/widgets/canvas/lv_canvas.c **** }
