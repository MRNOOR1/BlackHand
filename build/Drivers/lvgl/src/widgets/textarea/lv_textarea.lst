 220:Drivers/lvgl/src/widgets/textarea/lv_textarea.c ****     if(res != LV_RESULT_OK) return;
 221:Drivers/lvgl/src/widgets/textarea/lv_textarea.c **** 
 222:Drivers/lvgl/src/widgets/textarea/lv_textarea.c ****     uint32_t c_uni = lv_text_encoded_next((const char *)&c2, NULL);
 223:Drivers/lvgl/src/widgets/textarea/lv_textarea.c **** 
 224:Drivers/lvgl/src/widgets/textarea/lv_textarea.c ****     if(char_is_accepted(obj, c_uni) == false) {
 225:Drivers/lvgl/src/widgets/textarea/lv_textarea.c ****         LV_LOG_INFO("Character is not accepted by the text area (too long text or not in the accept
 226:Drivers/lvgl/src/widgets/textarea/lv_textarea.c ****         return;
