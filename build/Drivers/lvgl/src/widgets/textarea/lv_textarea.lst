 202:Drivers/lvgl/src/widgets/textarea/lv_textarea.c ****     const char * letter_buf = (char *)&u32_buf;
 203:Drivers/lvgl/src/widgets/textarea/lv_textarea.c **** 
 204:Drivers/lvgl/src/widgets/textarea/lv_textarea.c ****     uint32_t c2 = c;
 205:Drivers/lvgl/src/widgets/textarea/lv_textarea.c **** #if LV_BIG_ENDIAN_SYSTEM
 206:Drivers/lvgl/src/widgets/textarea/lv_textarea.c ****     if(c != 0) while(*letter_buf == 0) ++letter_buf;
 207:Drivers/lvgl/src/widgets/textarea/lv_textarea.c **** 
 208:Drivers/lvgl/src/widgets/textarea/lv_textarea.c ****     /*The byte order may or may not need to be swapped here to get correct c_uni below,
 209:Drivers/lvgl/src/widgets/textarea/lv_textarea.c ****       since lv_textarea_add_text is ordering bytes correctly before calling lv_textarea_add_char.
 210:Drivers/lvgl/src/widgets/textarea/lv_textarea.c ****       Assume swapping is needed if MSB is zero. May not be foolproof. */
 211:Drivers/lvgl/src/widgets/textarea/lv_textarea.c ****     if((c != 0) && ((c & 0xff000000) == 0)) {
 212:Drivers/lvgl/src/widgets/textarea/lv_textarea.c ****         c2 = ((c >> 24) & 0xff) | /*move byte 3 to byte 0*/
 213:Drivers/lvgl/src/widgets/textarea/lv_textarea.c ****              ((c << 8) & 0xff0000) | /*move byte 1 to byte 2*/
 214:Drivers/lvgl/src/widgets/textarea/lv_textarea.c ****              ((c >> 8) & 0xff00) | /*move byte 2 to byte 1*/
 215:Drivers/lvgl/src/widgets/textarea/lv_textarea.c ****              ((c << 24) & 0xff000000); /*byte 0 to byte 3*/
 216:Drivers/lvgl/src/widgets/textarea/lv_textarea.c ****     }
 217:Drivers/lvgl/src/widgets/textarea/lv_textarea.c **** #endif
 218:Drivers/lvgl/src/widgets/textarea/lv_textarea.c **** 
