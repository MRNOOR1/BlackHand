 930:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c **** static void invalidate_button_area(const lv_obj_t * obj, uint32_t btn_idx)
 931:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c **** {
 932:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     if(btn_idx == LV_BUTTONMATRIX_BUTTON_NONE) return;
 933:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c **** 
 934:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     lv_area_t btn_area;
 935:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     lv_area_t obj_area;
 936:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c **** 
 937:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     lv_buttonmatrix_t * btnm = (lv_buttonmatrix_t *)obj;
 938:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     if(btn_idx >= btnm->btn_cnt) return;
 939:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c **** 
 940:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     lv_area_copy(&btn_area, &btnm->button_areas[btn_idx]);
 941:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     lv_obj_get_coords(obj, &obj_area);
 942:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c **** 
 943:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     /*The buttons might have outline and shadow so make the invalidation larger with the gaps betwe
 944:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****      *It assumes that the outline or shadow is smaller than the gaps*/
 945:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     int32_t row_gap = lv_obj_get_style_pad_row(obj, LV_PART_MAIN);
 946:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     int32_t col_gap = lv_obj_get_style_pad_column(obj, LV_PART_MAIN);
 947:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c **** 
 948:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     /*Be sure to have a minimal extra space if row/col_gap is small*/
 949:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     int32_t dpi = lv_display_get_dpi(lv_obj_get_display(obj));
 950:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     row_gap = LV_MAX(row_gap, dpi / 10);
 951:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     col_gap = LV_MAX(col_gap, dpi / 10);
 952:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c **** 
 953:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     /*Convert relative coordinates to absolute*/
 954:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     btn_area.x1 += obj_area.x1 - row_gap;
 955:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     btn_area.y1 += obj_area.y1 - col_gap;
 956:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     btn_area.x2 += obj_area.x1 + row_gap;
 957:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     btn_area.y2 += obj_area.y1 + col_gap;
 958:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c **** 
 959:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     if((btn_idx == btnm->btn_id_sel) && (btnm->ctrl_bits[btn_idx] & LV_BUTTONMATRIX_CTRL_POPOVER)) 
 960:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****         /*Push up the upper boundary of the btn area to also invalidate the popover*/
 961:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****         btn_area.y1 -= lv_area_get_height(&btn_area);
 962:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     }
 963:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c **** 
 964:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     lv_obj_invalidate_area(obj, &btn_area);
 965:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c **** }
