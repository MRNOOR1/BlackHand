 973:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c **** static void make_one_button_checked(lv_obj_t * obj, uint32_t btn_idx)
 974:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c **** {
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//ccmUKZBE.s 			page 22


 975:Drivers/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     /*Save whether the button was toggled*/
