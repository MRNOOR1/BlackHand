 457:Drivers/lvgl/src/widgets/roller/lv_roller.c ****                 }
 458:Drivers/lvgl/src/widgets/roller/lv_roller.c ****             }
 459:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         }
 460:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         else {
 461:Drivers/lvgl/src/widgets/roller/lv_roller.c ****             /*Save the current value. Used to revert this
 462:Drivers/lvgl/src/widgets/roller/lv_roller.c ****              *state if ENTER won't be pressed*/
 463:Drivers/lvgl/src/widgets/roller/lv_roller.c ****             roller->sel_opt_id_ori = roller->sel_opt_id;
 464:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         }
 465:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     }
