 435:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     }
 436:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     else if(code == LV_EVENT_RELEASED || code == LV_EVENT_PRESS_LOST) {
 437:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         if(roller->option_cnt <= 1) return;
 438:Drivers/lvgl/src/widgets/roller/lv_roller.c **** 
 439:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         release_handler(obj);
 440:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     }
 441:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     else if(code == LV_EVENT_FOCUSED) {
 442:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         lv_group_t * g             = lv_obj_get_group(obj);
 443:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         lv_indev_type_t indev_type = lv_indev_get_type(lv_indev_active());
