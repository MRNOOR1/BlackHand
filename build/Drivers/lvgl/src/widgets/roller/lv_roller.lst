 399:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         lv_point_t * p = lv_event_get_param(e);
 400:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         p->x = get_selected_label_width(obj);
 401:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     }
 402:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     else if(code == LV_EVENT_STYLE_CHANGED) {
 403:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         lv_obj_t * label = get_label(obj);
 404:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         /*Be sure the label's style is updated before processing the roller*/
 405:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         if(label) lv_obj_send_event(label, LV_EVENT_STYLE_CHANGED, NULL);
 406:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         lv_obj_refresh_self_size(obj);
 407:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         refr_position(obj, LV_ANIM_OFF);
 408:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     }
 409:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     else if(code == LV_EVENT_SIZE_CHANGED) {
 410:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         refr_position(obj, LV_ANIM_OFF);
 411:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     }
 412:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     else if(code == LV_EVENT_PRESSED) {
 413:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         if(roller->option_cnt <= 1) return;
 414:Drivers/lvgl/src/widgets/roller/lv_roller.c **** 
 415:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         roller->moved = 0;
 416:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         lv_anim_delete(get_label(obj), set_y_anim);
 417:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     }
 418:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     else if(code == LV_EVENT_CLICKED) {
 419:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         if(roller->moved == 1) {
 420:Drivers/lvgl/src/widgets/roller/lv_roller.c ****             lv_event_stop_processing(e);
 421:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         }
 422:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     }
 423:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     else if(code == LV_EVENT_PRESSING) {
