 186:Drivers/lvgl/src/widgets/roller/lv_roller.c **** void lv_roller_set_selected(lv_obj_t * obj, uint32_t sel_opt, lv_anim_enable_t anim)
 187:Drivers/lvgl/src/widgets/roller/lv_roller.c **** {
 188:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     LV_ASSERT_OBJ(obj, MY_CLASS);
 189:Drivers/lvgl/src/widgets/roller/lv_roller.c **** 
 190:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     /*Set the value even if it's the same as the current value because
 191:Drivers/lvgl/src/widgets/roller/lv_roller.c ****      *if moving to the next option with an animation which was just deleted in the PRESS Call the a
 192:Drivers/lvgl/src/widgets/roller/lv_roller.c ****      *nothing will continue the animation.*/
 193:Drivers/lvgl/src/widgets/roller/lv_roller.c **** 
 194:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     lv_roller_t * roller = (lv_roller_t *)obj;
 195:Drivers/lvgl/src/widgets/roller/lv_roller.c **** 
 196:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     /*In infinite mode interpret the new ID relative to the currently visible "page"*/
 197:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     if(roller->mode == LV_ROLLER_MODE_INFINITE) {
 198:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         uint32_t real_option_cnt = roller->option_cnt / roller->inf_page_cnt;
 199:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         uint32_t current_page = roller->sel_opt_id / real_option_cnt;
 200:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         /*Set by the user to e.g. 0, 1, 2, 3...
 201:Drivers/lvgl/src/widgets/roller/lv_roller.c ****          *Upscale the value to the current page*/
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//ccr7QAwq.s 			page 5


 202:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         if(sel_opt < real_option_cnt) {
 203:Drivers/lvgl/src/widgets/roller/lv_roller.c ****             uint32_t act_opt = roller->sel_opt_id - current_page * real_option_cnt;
 204:Drivers/lvgl/src/widgets/roller/lv_roller.c ****             int32_t sel_opt_signed = sel_opt;
 205:Drivers/lvgl/src/widgets/roller/lv_roller.c ****             /*Huge jump? Probably from last to first or first to last option.*/
 206:Drivers/lvgl/src/widgets/roller/lv_roller.c ****             if((uint32_t)LV_ABS((int16_t)(act_opt - sel_opt)) > real_option_cnt / 2) {
 207:Drivers/lvgl/src/widgets/roller/lv_roller.c ****                 if(act_opt > sel_opt) sel_opt_signed += real_option_cnt;
 208:Drivers/lvgl/src/widgets/roller/lv_roller.c ****                 else sel_opt_signed -= real_option_cnt;
 209:Drivers/lvgl/src/widgets/roller/lv_roller.c ****             }
 210:Drivers/lvgl/src/widgets/roller/lv_roller.c ****             sel_opt = sel_opt_signed + real_option_cnt * current_page;
 211:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         }
 212:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     }
 213:Drivers/lvgl/src/widgets/roller/lv_roller.c **** 
 214:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     roller->sel_opt_id     = sel_opt < roller->option_cnt ? sel_opt : roller->option_cnt - 1;
 215:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     roller->sel_opt_id_ori = roller->sel_opt_id;
 216:Drivers/lvgl/src/widgets/roller/lv_roller.c **** 
 217:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     refr_position(obj, anim);
 218:Drivers/lvgl/src/widgets/roller/lv_roller.c **** }
