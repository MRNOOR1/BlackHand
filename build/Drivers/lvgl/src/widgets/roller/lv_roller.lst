 130:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     lv_obj_t * label = get_label(obj);
 131:Drivers/lvgl/src/widgets/roller/lv_roller.c **** 
 132:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     roller->sel_opt_id     = 0;
 133:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     roller->sel_opt_id_ori = 0;
 134:Drivers/lvgl/src/widgets/roller/lv_roller.c **** 
 135:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     /*Count the '\n'-s to determine the number of options*/
 136:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     roller->option_cnt = 0;
 137:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     uint32_t cnt;
 138:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     for(cnt = 0; options[cnt] != '\0'; cnt++) {
 139:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         if(options[cnt] == '\n') roller->option_cnt++;
 140:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     }
 141:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     roller->option_cnt++; /*Last option has no `\n`*/
 142:Drivers/lvgl/src/widgets/roller/lv_roller.c **** 
 143:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     if(mode == LV_ROLLER_MODE_NORMAL) {
 144:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         roller->mode = LV_ROLLER_MODE_NORMAL;
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//ccr7QAwq.s 			page 4


 145:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         lv_label_set_text(label, options);
 146:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     }
 147:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     else {
 148:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         roller->mode = LV_ROLLER_MODE_INFINITE;
 149:Drivers/lvgl/src/widgets/roller/lv_roller.c **** 
 150:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         const lv_font_t * font = lv_obj_get_style_text_font(obj, LV_PART_MAIN);
 151:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         int32_t normal_h = roller->option_cnt * (lv_font_get_line_height(font) + lv_obj_get_style_t
 152:Drivers/lvgl/src/widgets/roller/lv_roller.c ****                                                                                                    
 153:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         roller->inf_page_cnt = LV_CLAMP(3, EXTRA_INF_SIZE / normal_h, 15);
 154:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         if(!(roller->inf_page_cnt & 1)) roller->inf_page_cnt++;   /*Make it odd*/
 155:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         LV_LOG_INFO("Using %" LV_PRIu32 " pages to make the roller look infinite", roller->inf_page
 156:Drivers/lvgl/src/widgets/roller/lv_roller.c **** 
 157:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         size_t opt_len = lv_strlen(options) + 1; /*+1 to add '\n' after option lists*/
 158:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         size_t opt_extra_len = opt_len * roller->inf_page_cnt;
 159:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         if(opt_extra_len == 0) {
 160:Drivers/lvgl/src/widgets/roller/lv_roller.c ****             /*Prevent write overflow*/
 161:Drivers/lvgl/src/widgets/roller/lv_roller.c ****             opt_extra_len = 1;
 162:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         }
 163:Drivers/lvgl/src/widgets/roller/lv_roller.c **** 
 164:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         char * opt_extra = lv_malloc(opt_extra_len);
 165:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         uint32_t i;
 166:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         for(i = 0; i < roller->inf_page_cnt; i++) {
 167:Drivers/lvgl/src/widgets/roller/lv_roller.c ****             lv_strcpy(&opt_extra[opt_len * i], options);
 168:Drivers/lvgl/src/widgets/roller/lv_roller.c ****             opt_extra[opt_len * (i + 1) - 1] = '\n';
 169:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         }
 170:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         opt_extra[opt_extra_len - 1] = '\0';
 171:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         lv_label_set_text(label, opt_extra);
 172:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         lv_free(opt_extra);
 173:Drivers/lvgl/src/widgets/roller/lv_roller.c **** 
 174:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         roller->sel_opt_id = ((roller->inf_page_cnt / 2) + 0) * roller->option_cnt;
 175:Drivers/lvgl/src/widgets/roller/lv_roller.c **** 
 176:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         roller->option_cnt = roller->option_cnt * roller->inf_page_cnt;
 177:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         inf_normalize(obj);
 178:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     }
 179:Drivers/lvgl/src/widgets/roller/lv_roller.c **** 
