 220:Drivers/lvgl/src/widgets/roller/lv_roller.c **** bool lv_roller_set_selected_str(lv_obj_t * obj, const char * sel_opt, lv_anim_enable_t anim)
 221:Drivers/lvgl/src/widgets/roller/lv_roller.c **** {
