 327:Drivers/lvgl/src/widgets/roller/lv_roller.c **** lv_result_t lv_roller_get_option_str(const lv_obj_t * obj, uint32_t option, char * buf, uint32_t bu
 328:Drivers/lvgl/src/widgets/roller/lv_roller.c **** {
 329:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     LV_ASSERT_OBJ(obj, MY_CLASS);
 330:Drivers/lvgl/src/widgets/roller/lv_roller.c **** 
 331:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     lv_obj_t * label = get_label(obj);
 332:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     uint32_t i;
 333:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     uint32_t line        = 0;
 334:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     const char * opt_txt = lv_label_get_text(label);
 335:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     size_t txt_len     = lv_strlen(opt_txt);
 336:Drivers/lvgl/src/widgets/roller/lv_roller.c **** 
 337:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     for(i = 0; i < txt_len && line != option; i++) {
 338:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         if(opt_txt[i] == '\n') line++;
 339:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     }
 340:Drivers/lvgl/src/widgets/roller/lv_roller.c **** 
 341:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     if(line != option) {
 342:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         return LV_RESULT_INVALID;
 343:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     }
 344:Drivers/lvgl/src/widgets/roller/lv_roller.c **** 
 345:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     uint32_t c;
 346:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     for(c = 0; i < txt_len && opt_txt[i] != '\n'; c++, i++) {
 347:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         if(buf_size && c >= buf_size - 1) {
 348:Drivers/lvgl/src/widgets/roller/lv_roller.c ****             LV_LOG_WARN("the buffer was too small");
 349:Drivers/lvgl/src/widgets/roller/lv_roller.c ****             break;
 350:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         }
 351:Drivers/lvgl/src/widgets/roller/lv_roller.c ****         buf[c] = opt_txt[i];
 352:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     }
 353:Drivers/lvgl/src/widgets/roller/lv_roller.c **** 
 354:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     buf[c] = '\0';
 355:Drivers/lvgl/src/widgets/roller/lv_roller.c ****     return LV_RESULT_OK;
 356:Drivers/lvgl/src/widgets/roller/lv_roller.c **** }
