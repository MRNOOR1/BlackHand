  99:Drivers/lvgl/src/widgets/arclabel/lv_arclabel.c **** void lv_arclabel_set_text(lv_obj_t * obj, const char * text)
 100:Drivers/lvgl/src/widgets/arclabel/lv_arclabel.c **** {
 101:Drivers/lvgl/src/widgets/arclabel/lv_arclabel.c ****     LV_ASSERT_OBJ(obj, MY_CLASS);
 102:Drivers/lvgl/src/widgets/arclabel/lv_arclabel.c ****     lv_arclabel_t * arclabel = (lv_arclabel_t *)obj;
 103:Drivers/lvgl/src/widgets/arclabel/lv_arclabel.c **** 
 104:Drivers/lvgl/src/widgets/arclabel/lv_arclabel.c ****     /*If text is NULL then just refresh with the current text*/
 105:Drivers/lvgl/src/widgets/arclabel/lv_arclabel.c ****     if(text == NULL) text = arclabel->text;
 106:Drivers/lvgl/src/widgets/arclabel/lv_arclabel.c **** 
 107:Drivers/lvgl/src/widgets/arclabel/lv_arclabel.c ****     const size_t text_len = lv_strlen(text) + 1;
 108:Drivers/lvgl/src/widgets/arclabel/lv_arclabel.c **** 
 109:Drivers/lvgl/src/widgets/arclabel/lv_arclabel.c ****     /*If set its own text then reallocate it (maybe its size changed)*/
 110:Drivers/lvgl/src/widgets/arclabel/lv_arclabel.c ****     if(arclabel->text == text && arclabel->static_txt == 0) {
 111:Drivers/lvgl/src/widgets/arclabel/lv_arclabel.c ****         arclabel->text = lv_realloc(arclabel->text, text_len);
 112:Drivers/lvgl/src/widgets/arclabel/lv_arclabel.c ****         LV_ASSERT_MALLOC(arclabel->text);
 113:Drivers/lvgl/src/widgets/arclabel/lv_arclabel.c ****         if(arclabel->text == NULL) return;
 114:Drivers/lvgl/src/widgets/arclabel/lv_arclabel.c ****     }
 115:Drivers/lvgl/src/widgets/arclabel/lv_arclabel.c ****     else {
 116:Drivers/lvgl/src/widgets/arclabel/lv_arclabel.c ****         /*Free the old text*/
 117:Drivers/lvgl/src/widgets/arclabel/lv_arclabel.c ****         if(arclabel->text != NULL && arclabel->static_txt == 0) {
 118:Drivers/lvgl/src/widgets/arclabel/lv_arclabel.c ****             lv_free(arclabel->text);
 119:Drivers/lvgl/src/widgets/arclabel/lv_arclabel.c ****             arclabel->text = NULL;
 120:Drivers/lvgl/src/widgets/arclabel/lv_arclabel.c ****         }
 121:Drivers/lvgl/src/widgets/arclabel/lv_arclabel.c **** 
 122:Drivers/lvgl/src/widgets/arclabel/lv_arclabel.c ****         arclabel->text = lv_malloc(text_len);
 123:Drivers/lvgl/src/widgets/arclabel/lv_arclabel.c ****         LV_ASSERT_MALLOC(arclabel->text);
 124:Drivers/lvgl/src/widgets/arclabel/lv_arclabel.c ****         if(arclabel->text == NULL) return;
 125:Drivers/lvgl/src/widgets/arclabel/lv_arclabel.c **** 
 126:Drivers/lvgl/src/widgets/arclabel/lv_arclabel.c ****         lv_strcpy(arclabel->text, text);
 127:Drivers/lvgl/src/widgets/arclabel/lv_arclabel.c **** 
 128:Drivers/lvgl/src/widgets/arclabel/lv_arclabel.c ****         /*Now the text is dynamically allocated*/
 129:Drivers/lvgl/src/widgets/arclabel/lv_arclabel.c ****         arclabel->static_txt = 0;
 130:Drivers/lvgl/src/widgets/arclabel/lv_arclabel.c ****     }
 131:Drivers/lvgl/src/widgets/arclabel/lv_arclabel.c **** 
 132:Drivers/lvgl/src/widgets/arclabel/lv_arclabel.c ****     lv_obj_invalidate(obj);
 133:Drivers/lvgl/src/widgets/arclabel/lv_arclabel.c **** }
