 474:Drivers/lvgl/src/widgets/bar/lv_bar.c ****     /* An area with width 0 is {x1 = 0 x2 = -1} so subtracting 1 from `anim_cur_value_x` causes...
 475:Drivers/lvgl/src/widgets/bar/lv_bar.c ****      *     anim_start_value_x = 0   anim_cur_value_x = 0   to be {x1 = 0 x2 = -1  } which is width 
 476:Drivers/lvgl/src/widgets/bar/lv_bar.c ****      *     anim_start_value_x = 0   anim_cur_value_x = 300 to be {x1 = 0 x2 =  299} which is width 
 477:Drivers/lvgl/src/widgets/bar/lv_bar.c ****      */
 478:Drivers/lvgl/src/widgets/bar/lv_bar.c ****     anim_cur_value_x -= 1;
 479:Drivers/lvgl/src/widgets/bar/lv_bar.c **** 
 480:Drivers/lvgl/src/widgets/bar/lv_bar.c ****     if(reversed) {
 481:Drivers/lvgl/src/widgets/bar/lv_bar.c ****         /*Swap axes*/
 482:Drivers/lvgl/src/widgets/bar/lv_bar.c ****         int32_t * tmp;
 483:Drivers/lvgl/src/widgets/bar/lv_bar.c ****         tmp = axis1;
 484:Drivers/lvgl/src/widgets/bar/lv_bar.c ****         axis1 = axis2;
 485:Drivers/lvgl/src/widgets/bar/lv_bar.c ****         axis2 = tmp;
 486:Drivers/lvgl/src/widgets/bar/lv_bar.c ****         anim_cur_value_x = -anim_cur_value_x;
