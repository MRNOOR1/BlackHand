 511:Drivers/lvgl/src/widgets/bar/lv_bar.c **** 
 512:Drivers/lvgl/src/widgets/bar/lv_bar.c ****             if(*axis2 > zero) {
 513:Drivers/lvgl/src/widgets/bar/lv_bar.c ****                 *right = *axis2;
 514:Drivers/lvgl/src/widgets/bar/lv_bar.c ****                 *left = zero;
 515:Drivers/lvgl/src/widgets/bar/lv_bar.c ****             }
 516:Drivers/lvgl/src/widgets/bar/lv_bar.c ****             else {
 517:Drivers/lvgl/src/widgets/bar/lv_bar.c ****                 *left = *axis2;
