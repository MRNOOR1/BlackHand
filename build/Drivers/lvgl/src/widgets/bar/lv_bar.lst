 175:Drivers/lvgl/src/widgets/bar/lv_bar.c **** void lv_bar_set_range(lv_obj_t * obj, int32_t min, int32_t max)
 176:Drivers/lvgl/src/widgets/bar/lv_bar.c **** {
 177:Drivers/lvgl/src/widgets/bar/lv_bar.c ****     LV_ASSERT_OBJ(obj, MY_CLASS);
 178:Drivers/lvgl/src/widgets/bar/lv_bar.c **** 
 179:Drivers/lvgl/src/widgets/bar/lv_bar.c ****     lv_bar_t * bar = (lv_bar_t *)obj;
 180:Drivers/lvgl/src/widgets/bar/lv_bar.c **** 
 181:Drivers/lvgl/src/widgets/bar/lv_bar.c ****     bar->val_reversed = min > max;
 182:Drivers/lvgl/src/widgets/bar/lv_bar.c **** 
 183:Drivers/lvgl/src/widgets/bar/lv_bar.c ****     int32_t real_min = bar->val_reversed ? max : min;
 184:Drivers/lvgl/src/widgets/bar/lv_bar.c ****     int32_t real_max = bar->val_reversed ? min : max;
 185:Drivers/lvgl/src/widgets/bar/lv_bar.c ****     if(bar->min_value == real_min && bar->max_value == real_max) return;
 186:Drivers/lvgl/src/widgets/bar/lv_bar.c **** 
 187:Drivers/lvgl/src/widgets/bar/lv_bar.c ****     bar->max_value = real_max;
 188:Drivers/lvgl/src/widgets/bar/lv_bar.c ****     bar->min_value = real_min;
 189:Drivers/lvgl/src/widgets/bar/lv_bar.c **** 
 190:Drivers/lvgl/src/widgets/bar/lv_bar.c ****     if(lv_bar_get_mode(obj) != LV_BAR_MODE_RANGE)
 191:Drivers/lvgl/src/widgets/bar/lv_bar.c ****         bar->start_value = real_min;
 192:Drivers/lvgl/src/widgets/bar/lv_bar.c **** 
 193:Drivers/lvgl/src/widgets/bar/lv_bar.c ****     if(bar->cur_value > real_max) {
 194:Drivers/lvgl/src/widgets/bar/lv_bar.c ****         bar->cur_value = real_max;
 195:Drivers/lvgl/src/widgets/bar/lv_bar.c ****         lv_bar_set_value(obj, bar->cur_value, LV_ANIM_OFF);
 196:Drivers/lvgl/src/widgets/bar/lv_bar.c ****     }
 197:Drivers/lvgl/src/widgets/bar/lv_bar.c ****     if(bar->cur_value < real_min) {
 198:Drivers/lvgl/src/widgets/bar/lv_bar.c ****         bar->cur_value = real_min;
 199:Drivers/lvgl/src/widgets/bar/lv_bar.c ****         lv_bar_set_value(obj, bar->cur_value, LV_ANIM_OFF);
 200:Drivers/lvgl/src/widgets/bar/lv_bar.c ****     }
 201:Drivers/lvgl/src/widgets/bar/lv_bar.c **** 
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//cchuAKlx.s 			page 5


 202:Drivers/lvgl/src/widgets/bar/lv_bar.c ****     lv_obj_invalidate(obj);
 203:Drivers/lvgl/src/widgets/bar/lv_bar.c **** }
