 157:Drivers/lvgl/src/widgets/bar/lv_bar.c **** void lv_bar_set_start_value(lv_obj_t * obj, int32_t value, lv_anim_enable_t anim)
 158:Drivers/lvgl/src/widgets/bar/lv_bar.c **** {
 159:Drivers/lvgl/src/widgets/bar/lv_bar.c ****     LV_ASSERT_OBJ(obj, MY_CLASS);
 160:Drivers/lvgl/src/widgets/bar/lv_bar.c **** 
 161:Drivers/lvgl/src/widgets/bar/lv_bar.c ****     lv_bar_t * bar = (lv_bar_t *)obj;
 162:Drivers/lvgl/src/widgets/bar/lv_bar.c **** 
 163:Drivers/lvgl/src/widgets/bar/lv_bar.c ****     if(bar->mode != LV_BAR_MODE_RANGE) {
 164:Drivers/lvgl/src/widgets/bar/lv_bar.c ****         return;
 165:Drivers/lvgl/src/widgets/bar/lv_bar.c ****     }
 166:Drivers/lvgl/src/widgets/bar/lv_bar.c **** 
 167:Drivers/lvgl/src/widgets/bar/lv_bar.c ****     value = LV_CLAMP(bar->min_value, value, bar->max_value);
 168:Drivers/lvgl/src/widgets/bar/lv_bar.c ****     value = value > bar->cur_value ? bar->cur_value : value; /*Can't be greater than the right valu
 169:Drivers/lvgl/src/widgets/bar/lv_bar.c **** 
 170:Drivers/lvgl/src/widgets/bar/lv_bar.c ****     if(bar->start_value == value) return;
 171:Drivers/lvgl/src/widgets/bar/lv_bar.c **** 
 172:Drivers/lvgl/src/widgets/bar/lv_bar.c ****     lv_bar_set_value_with_anim(obj, value, &bar->start_value, &bar->start_value_anim, anim);
 173:Drivers/lvgl/src/widgets/bar/lv_bar.c **** }
