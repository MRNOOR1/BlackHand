 490:Drivers/lvgl/src/widgets/bar/lv_bar.c ****     /*Set the indicator length*/
 491:Drivers/lvgl/src/widgets/bar/lv_bar.c ****     if(hor) {
 492:Drivers/lvgl/src/widgets/bar/lv_bar.c ****         *axis2 = *axis1 + anim_cur_value_x;
 493:Drivers/lvgl/src/widgets/bar/lv_bar.c ****         *axis1 += anim_start_value_x;
 494:Drivers/lvgl/src/widgets/bar/lv_bar.c ****     }
 495:Drivers/lvgl/src/widgets/bar/lv_bar.c ****     else {
 496:Drivers/lvgl/src/widgets/bar/lv_bar.c ****         *axis1 = *axis2 - anim_cur_value_x;
 497:Drivers/lvgl/src/widgets/bar/lv_bar.c ****         *axis2 -= anim_start_value_x;
 498:Drivers/lvgl/src/widgets/bar/lv_bar.c ****     }
 499:Drivers/lvgl/src/widgets/bar/lv_bar.c **** 
 500:Drivers/lvgl/src/widgets/bar/lv_bar.c ****     if(sym) {
 501:Drivers/lvgl/src/widgets/bar/lv_bar.c ****         int32_t zero, shift;
