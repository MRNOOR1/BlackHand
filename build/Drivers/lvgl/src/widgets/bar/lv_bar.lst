 570:Drivers/lvgl/src/widgets/bar/lv_bar.c ****     /*Cases:
 571:Drivers/lvgl/src/widgets/bar/lv_bar.c ****      * Simple:
 572:Drivers/lvgl/src/widgets/bar/lv_bar.c ****      *   - indicator area is the same or smaller then the bg
 573:Drivers/lvgl/src/widgets/bar/lv_bar.c ****      *   - indicator has the same or larger radius than the bg
 574:Drivers/lvgl/src/widgets/bar/lv_bar.c ****      *   - what to do? just draw the indicator
 575:Drivers/lvgl/src/widgets/bar/lv_bar.c ****      * Radius issue:
 576:Drivers/lvgl/src/widgets/bar/lv_bar.c ****      *   - indicator area is the same or smaller then bg
 577:Drivers/lvgl/src/widgets/bar/lv_bar.c ****      *   - indicator has smaller radius than the bg and the indicator overflows on the corners
 578:Drivers/lvgl/src/widgets/bar/lv_bar.c ****      *   - what to do? draw the indicator on a layer and clip to bg radius
 579:Drivers/lvgl/src/widgets/bar/lv_bar.c ****      * Larger indicator:
 580:Drivers/lvgl/src/widgets/bar/lv_bar.c ****      *   - indicator area is the larger then the bg
 581:Drivers/lvgl/src/widgets/bar/lv_bar.c ****      *   - radius doesn't matter
 582:Drivers/lvgl/src/widgets/bar/lv_bar.c ****      *   - shadow doesn't matter
 583:Drivers/lvgl/src/widgets/bar/lv_bar.c ****      *   - what to do? just draw the indicator
 584:Drivers/lvgl/src/widgets/bar/lv_bar.c ****      * Shadow:
 585:Drivers/lvgl/src/widgets/bar/lv_bar.c ****      *   - indicator area is the same or smaller then the bg
 586:Drivers/lvgl/src/widgets/bar/lv_bar.c ****      *   - indicator has the same or larger radius than the bg (shadow needs to be drawn on strange
 587:Drivers/lvgl/src/widgets/bar/lv_bar.c ****      *   - what to do? don't draw the shadow if the indicator is too small has strange shape
 588:Drivers/lvgl/src/widgets/bar/lv_bar.c ****      * Gradient:
 589:Drivers/lvgl/src/widgets/bar/lv_bar.c ****      *   - the indicator has a gradient
 590:Drivers/lvgl/src/widgets/bar/lv_bar.c ****      *   - what to do? draw it on a bg sized layer clip the indicator are from the gradient
 591:Drivers/lvgl/src/widgets/bar/lv_bar.c ****      *
 592:Drivers/lvgl/src/widgets/bar/lv_bar.c ****      */
 593:Drivers/lvgl/src/widgets/bar/lv_bar.c **** 
 594:Drivers/lvgl/src/widgets/bar/lv_bar.c ****     bool mask_needed = false;
 595:Drivers/lvgl/src/widgets/bar/lv_bar.c ****     if(hor && draw_rect_dsc.bg_grad.dir == LV_GRAD_DIR_HOR) mask_needed = true;
 596:Drivers/lvgl/src/widgets/bar/lv_bar.c ****     else if(!hor && draw_rect_dsc.bg_grad.dir == LV_GRAD_DIR_VER) mask_needed = true;
 597:Drivers/lvgl/src/widgets/bar/lv_bar.c **** 
