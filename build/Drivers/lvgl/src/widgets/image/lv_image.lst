 147:Drivers/lvgl/src/widgets/image/lv_image.c **** 
 148:Drivers/lvgl/src/widgets/image/lv_image.c **** void lv_image_set_src(lv_obj_t * obj, const void * src)
 149:Drivers/lvgl/src/widgets/image/lv_image.c **** {
 150:Drivers/lvgl/src/widgets/image/lv_image.c ****     LV_ASSERT_OBJ(obj, MY_CLASS);
 151:Drivers/lvgl/src/widgets/image/lv_image.c **** 
 152:Drivers/lvgl/src/widgets/image/lv_image.c ****     lv_obj_invalidate(obj);
 153:Drivers/lvgl/src/widgets/image/lv_image.c **** 
 154:Drivers/lvgl/src/widgets/image/lv_image.c ****     lv_image_src_t src_type = lv_image_src_get_type(src);
 155:Drivers/lvgl/src/widgets/image/lv_image.c ****     lv_image_t * img = (lv_image_t *)obj;
 156:Drivers/lvgl/src/widgets/image/lv_image.c **** 
 157:Drivers/lvgl/src/widgets/image/lv_image.c **** #if LV_USE_LOG && LV_LOG_LEVEL <= LV_LOG_LEVEL_INFO
 158:Drivers/lvgl/src/widgets/image/lv_image.c ****     switch(src_type) {
 159:Drivers/lvgl/src/widgets/image/lv_image.c ****         case LV_IMAGE_SRC_FILE:
 160:Drivers/lvgl/src/widgets/image/lv_image.c ****             LV_LOG_TRACE("`LV_IMAGE_SRC_FILE` type found");
 161:Drivers/lvgl/src/widgets/image/lv_image.c ****             break;
 162:Drivers/lvgl/src/widgets/image/lv_image.c ****         case LV_IMAGE_SRC_VARIABLE:
 163:Drivers/lvgl/src/widgets/image/lv_image.c ****             LV_LOG_TRACE("`LV_IMAGE_SRC_VARIABLE` type found");
 164:Drivers/lvgl/src/widgets/image/lv_image.c ****             break;
 165:Drivers/lvgl/src/widgets/image/lv_image.c ****         case LV_IMAGE_SRC_SYMBOL:
 166:Drivers/lvgl/src/widgets/image/lv_image.c ****             LV_LOG_TRACE("`LV_IMAGE_SRC_SYMBOL` type found");
 167:Drivers/lvgl/src/widgets/image/lv_image.c ****             break;
 168:Drivers/lvgl/src/widgets/image/lv_image.c ****         default:
 169:Drivers/lvgl/src/widgets/image/lv_image.c ****             LV_LOG_WARN("unknown type");
 170:Drivers/lvgl/src/widgets/image/lv_image.c ****     }
 171:Drivers/lvgl/src/widgets/image/lv_image.c **** #endif
 172:Drivers/lvgl/src/widgets/image/lv_image.c **** 
 173:Drivers/lvgl/src/widgets/image/lv_image.c ****     /*If the new source type is unknown free the memories of the old source*/
 174:Drivers/lvgl/src/widgets/image/lv_image.c ****     if(src_type == LV_IMAGE_SRC_UNKNOWN) {
 175:Drivers/lvgl/src/widgets/image/lv_image.c ****         if(src) LV_LOG_WARN("unknown image type");
 176:Drivers/lvgl/src/widgets/image/lv_image.c ****         reset_image_attributes(obj);
 177:Drivers/lvgl/src/widgets/image/lv_image.c ****         return;
 178:Drivers/lvgl/src/widgets/image/lv_image.c ****     }
 179:Drivers/lvgl/src/widgets/image/lv_image.c **** 
 180:Drivers/lvgl/src/widgets/image/lv_image.c ****     lv_image_header_t header;
 181:Drivers/lvgl/src/widgets/image/lv_image.c ****     lv_result_t res = lv_image_decoder_get_info(src, &header);
 182:Drivers/lvgl/src/widgets/image/lv_image.c ****     if(res != LV_RESULT_OK) {
 183:Drivers/lvgl/src/widgets/image/lv_image.c ****         if(src_type == LV_IMAGE_SRC_FILE) {
 184:Drivers/lvgl/src/widgets/image/lv_image.c ****             LV_LOG_WARN("failed to get image info: %s", (const char *)src);
 185:Drivers/lvgl/src/widgets/image/lv_image.c ****         }
 186:Drivers/lvgl/src/widgets/image/lv_image.c ****         else {
 187:Drivers/lvgl/src/widgets/image/lv_image.c ****             LV_LOG_WARN("failed to get image info: %p", src);
 188:Drivers/lvgl/src/widgets/image/lv_image.c ****         }
 189:Drivers/lvgl/src/widgets/image/lv_image.c ****         reset_image_attributes(obj);
 190:Drivers/lvgl/src/widgets/image/lv_image.c ****         return;
 191:Drivers/lvgl/src/widgets/image/lv_image.c ****     }
 192:Drivers/lvgl/src/widgets/image/lv_image.c **** 
 193:Drivers/lvgl/src/widgets/image/lv_image.c ****     /*Save the source*/
 194:Drivers/lvgl/src/widgets/image/lv_image.c ****     if(src_type == LV_IMAGE_SRC_VARIABLE) {
 195:Drivers/lvgl/src/widgets/image/lv_image.c ****         if(header.flags & LV_IMAGE_FLAGS_ALLOCATED) {
 196:Drivers/lvgl/src/widgets/image/lv_image.c ****             lv_draw_buf_t * buf = (lv_draw_buf_t *)src;
 197:Drivers/lvgl/src/widgets/image/lv_image.c ****             if(!buf->unaligned_data || !buf->handlers) {
 198:Drivers/lvgl/src/widgets/image/lv_image.c ****                 LV_LOG_ERROR("Invalid draw buffer, unaligned_data: %p, handlers: %p",
 199:Drivers/lvgl/src/widgets/image/lv_image.c ****                              buf->unaligned_data, (void *)buf->handlers);
 200:Drivers/lvgl/src/widgets/image/lv_image.c ****                 return;
 201:Drivers/lvgl/src/widgets/image/lv_image.c ****             }
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//ccePDbYF.s 			page 5


 202:Drivers/lvgl/src/widgets/image/lv_image.c ****         }
 203:Drivers/lvgl/src/widgets/image/lv_image.c **** 
 204:Drivers/lvgl/src/widgets/image/lv_image.c ****         /*If memory was allocated because of the previous `src_type` then free it*/
 205:Drivers/lvgl/src/widgets/image/lv_image.c ****         if(img->src_type == LV_IMAGE_SRC_FILE || img->src_type == LV_IMAGE_SRC_SYMBOL) {
 206:Drivers/lvgl/src/widgets/image/lv_image.c ****             lv_free((void *)img->src);
 207:Drivers/lvgl/src/widgets/image/lv_image.c ****         }
 208:Drivers/lvgl/src/widgets/image/lv_image.c ****         img->src = src;
 209:Drivers/lvgl/src/widgets/image/lv_image.c ****     }
 210:Drivers/lvgl/src/widgets/image/lv_image.c ****     else if(src_type == LV_IMAGE_SRC_FILE || src_type == LV_IMAGE_SRC_SYMBOL) {
 211:Drivers/lvgl/src/widgets/image/lv_image.c ****         /*If the new and the old src are the same then it was only a refresh.*/
 212:Drivers/lvgl/src/widgets/image/lv_image.c ****         if(img->src != src) {
 213:Drivers/lvgl/src/widgets/image/lv_image.c ****             const void * old_src = NULL;
 214:Drivers/lvgl/src/widgets/image/lv_image.c ****             /*If memory was allocated because of the previous `src_type` then save its pointer and 
 215:Drivers/lvgl/src/widgets/image/lv_image.c ****              *It's important to allocate first to be sure the new data will be on a new address.
 216:Drivers/lvgl/src/widgets/image/lv_image.c ****              *Else `img_cache` wouldn't see the change in source.*/
 217:Drivers/lvgl/src/widgets/image/lv_image.c ****             if(img->src_type == LV_IMAGE_SRC_FILE || img->src_type == LV_IMAGE_SRC_SYMBOL) {
 218:Drivers/lvgl/src/widgets/image/lv_image.c ****                 old_src = img->src;
 219:Drivers/lvgl/src/widgets/image/lv_image.c ****             }
 220:Drivers/lvgl/src/widgets/image/lv_image.c ****             char * new_str = lv_strdup(src);
 221:Drivers/lvgl/src/widgets/image/lv_image.c ****             LV_ASSERT_MALLOC(new_str);
 222:Drivers/lvgl/src/widgets/image/lv_image.c ****             if(new_str == NULL) return;
 223:Drivers/lvgl/src/widgets/image/lv_image.c ****             img->src = new_str;
 224:Drivers/lvgl/src/widgets/image/lv_image.c **** 
 225:Drivers/lvgl/src/widgets/image/lv_image.c ****             if(old_src) lv_free((void *)old_src);
 226:Drivers/lvgl/src/widgets/image/lv_image.c ****         }
 227:Drivers/lvgl/src/widgets/image/lv_image.c ****     }
 228:Drivers/lvgl/src/widgets/image/lv_image.c **** 
 229:Drivers/lvgl/src/widgets/image/lv_image.c ****     if(src_type == LV_IMAGE_SRC_SYMBOL) {
 230:Drivers/lvgl/src/widgets/image/lv_image.c ****         /*`lv_image_dsc_get_info` couldn't set the width and height of a font so set it here*/
 231:Drivers/lvgl/src/widgets/image/lv_image.c ****         const lv_font_t * font = lv_obj_get_style_text_font(obj, LV_PART_MAIN);
