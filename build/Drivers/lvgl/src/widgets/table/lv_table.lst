 108:Drivers/lvgl/src/widgets/table/lv_table.c **** void lv_table_set_cell_value(lv_obj_t * obj, uint32_t row, uint32_t col, const char * txt)
 109:Drivers/lvgl/src/widgets/table/lv_table.c **** {
 110:Drivers/lvgl/src/widgets/table/lv_table.c ****     LV_ASSERT_OBJ(obj, MY_CLASS);
 111:Drivers/lvgl/src/widgets/table/lv_table.c ****     LV_ASSERT_NULL(txt);
 112:Drivers/lvgl/src/widgets/table/lv_table.c **** 
 113:Drivers/lvgl/src/widgets/table/lv_table.c ****     lv_table_t * table = (lv_table_t *)obj;
 114:Drivers/lvgl/src/widgets/table/lv_table.c **** 
 115:Drivers/lvgl/src/widgets/table/lv_table.c ****     /*Auto expand*/
 116:Drivers/lvgl/src/widgets/table/lv_table.c ****     if(col >= table->col_cnt) lv_table_set_column_count(obj, col + 1);
 117:Drivers/lvgl/src/widgets/table/lv_table.c ****     if(row >= table->row_cnt) lv_table_set_row_count(obj, row + 1);
 118:Drivers/lvgl/src/widgets/table/lv_table.c **** 
 119:Drivers/lvgl/src/widgets/table/lv_table.c ****     uint32_t cell = row * table->col_cnt + col;
 120:Drivers/lvgl/src/widgets/table/lv_table.c ****     lv_table_cell_ctrl_t ctrl = 0;
 121:Drivers/lvgl/src/widgets/table/lv_table.c **** 
 122:Drivers/lvgl/src/widgets/table/lv_table.c ****     /*Save the control byte*/
 123:Drivers/lvgl/src/widgets/table/lv_table.c ****     if(table->cell_data[cell]) ctrl = table->cell_data[cell]->ctrl;
 124:Drivers/lvgl/src/widgets/table/lv_table.c **** 
 125:Drivers/lvgl/src/widgets/table/lv_table.c ****     void * user_data = NULL;
 126:Drivers/lvgl/src/widgets/table/lv_table.c **** 
 127:Drivers/lvgl/src/widgets/table/lv_table.c ****     /*Save the user data*/
 128:Drivers/lvgl/src/widgets/table/lv_table.c ****     if(table->cell_data[cell]) user_data = table->cell_data[cell]->user_data;
 129:Drivers/lvgl/src/widgets/table/lv_table.c **** 
 130:Drivers/lvgl/src/widgets/table/lv_table.c ****     size_t to_allocate = get_cell_txt_len(txt);
 131:Drivers/lvgl/src/widgets/table/lv_table.c **** 
 132:Drivers/lvgl/src/widgets/table/lv_table.c ****     table->cell_data[cell] = lv_realloc(table->cell_data[cell], to_allocate);
 133:Drivers/lvgl/src/widgets/table/lv_table.c ****     LV_ASSERT_MALLOC(table->cell_data[cell]);
 134:Drivers/lvgl/src/widgets/table/lv_table.c ****     if(table->cell_data[cell] == NULL) return;
 135:Drivers/lvgl/src/widgets/table/lv_table.c **** 
 136:Drivers/lvgl/src/widgets/table/lv_table.c ****     copy_cell_txt(table->cell_data[cell], txt);
 137:Drivers/lvgl/src/widgets/table/lv_table.c **** 
 138:Drivers/lvgl/src/widgets/table/lv_table.c ****     table->cell_data[cell]->ctrl = ctrl;
 139:Drivers/lvgl/src/widgets/table/lv_table.c ****     table->cell_data[cell]->user_data = user_data;
 140:Drivers/lvgl/src/widgets/table/lv_table.c ****     refr_cell_size(obj, row, col);
 141:Drivers/lvgl/src/widgets/table/lv_table.c **** }
