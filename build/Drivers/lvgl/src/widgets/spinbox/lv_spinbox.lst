 142:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c **** void lv_spinbox_set_digit_format(lv_obj_t * obj, uint32_t digit_count, uint32_t sep_pos)
 143:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c **** {
 144:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****     LV_ASSERT_OBJ(obj, MY_CLASS);
 145:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****     lv_spinbox_t * spinbox = (lv_spinbox_t *)obj;
 146:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c **** 
 147:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****     if(digit_count > LV_SPINBOX_MAX_DIGIT_COUNT) digit_count = LV_SPINBOX_MAX_DIGIT_COUNT;
 148:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c **** 
 149:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****     if(sep_pos >= digit_count) sep_pos = 0;
 150:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c **** 
 151:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****     if(digit_count < LV_SPINBOX_MAX_DIGIT_COUNT) {
 152:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****         const int64_t max_val = lv_pow(10, digit_count);
 153:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****         if(spinbox->range_max > max_val - 1) spinbox->range_max = max_val - 1;
 154:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****         if(spinbox->range_min < -max_val  + 1) spinbox->range_min = -max_val  + 1;
 155:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****     }
 156:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c **** 
 157:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****     spinbox->digit_count   = digit_count;
 158:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****     spinbox->dec_point_pos = sep_pos;
 159:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c **** 
 160:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****     lv_spinbox_updatevalue(obj);
 161:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c **** }
