 344:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c **** void lv_spinbox_increment(lv_obj_t * obj)
 345:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c **** {
 346:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****     LV_ASSERT_OBJ(obj, MY_CLASS);
 347:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****     lv_spinbox_t * spinbox = (lv_spinbox_t *)obj;
 348:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c **** 
 349:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****     int32_t v = spinbox->value;
 350:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****     /* Special mode when zero crossing. E.g -3+10 should be 3, not 7.
 351:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****      * Pretend we are on -7 now.*/
 352:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****     if((spinbox->value < 0) && (spinbox->value + spinbox->step) > 0) {
 353:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****         v = -(spinbox->step + spinbox->value);
 354:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****     }
 355:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c **** 
 356:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****     if(v + spinbox->step <= spinbox->range_max) {
 357:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****         v += spinbox->step;
 358:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****     }
 359:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****     else {
 360:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****         /*Rollover?*/
 361:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****         if((spinbox->rollover) && (spinbox->value == spinbox->range_max))
 362:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****             v = spinbox->range_min;
 363:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****         else
 364:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****             v = spinbox->range_max;
 365:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****     }
 366:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c **** 
 367:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****     if(v != spinbox->value) {
 368:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****         spinbox->value = v;
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//ccg13GvY.s 			page 8


 369:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****         lv_spinbox_updatevalue(obj);
 370:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****     }
 371:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c **** }
 372:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c **** 
 373:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c **** void lv_spinbox_decrement(lv_obj_t * obj)
 374:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c **** {
 375:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****     LV_ASSERT_OBJ(obj, MY_CLASS);
 376:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****     lv_spinbox_t * spinbox = (lv_spinbox_t *)obj;
 377:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c **** 
 378:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****     int32_t v = spinbox->value;
 379:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****     /* Special mode when zero crossing. E.g 3-10 should be -3, not -7.
 380:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****      * Pretend we are on 7 now.*/
 381:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****     if((spinbox->value > 0) && (spinbox->value - spinbox->step) < 0) {
 382:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****         v = spinbox->step - spinbox->value;
 383:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****     }
 384:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c **** 
 385:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****     if(v - spinbox->step >= spinbox->range_min) {
 386:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****         v -= spinbox->step;
 387:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****     }
 388:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****     else {
 389:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****         /*Rollover?*/
 390:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****         if((spinbox->rollover) && (spinbox->value == spinbox->range_min))
 391:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****             v = spinbox->range_max;
 392:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****         else
 393:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****             v = spinbox->range_min;
 394:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****     }
 395:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c **** 
 396:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****     if(v != spinbox->value) {
 397:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****         spinbox->value = v;
 398:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****         lv_spinbox_updatevalue(obj);
 399:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c ****     }
 400:Drivers/lvgl/src/widgets/spinbox/lv_spinbox.c **** }
