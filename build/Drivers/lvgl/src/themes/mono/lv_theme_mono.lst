 184:Drivers/lvgl/src/themes/mono/lv_theme_mono.c **** lv_theme_t * lv_theme_mono_init(lv_display_t * disp, bool dark_bg, const lv_font_t * font)
 185:Drivers/lvgl/src/themes/mono/lv_theme_mono.c **** {
 186:Drivers/lvgl/src/themes/mono/lv_theme_mono.c ****     /*This trick is required only to avoid the garbage collection of
 187:Drivers/lvgl/src/themes/mono/lv_theme_mono.c ****      *styles' data if LVGL is used in a binding (e.g. MicroPython)
 188:Drivers/lvgl/src/themes/mono/lv_theme_mono.c ****      *In a general case styles could be in a simple `static lv_style_t my_style...` variables*/
 189:Drivers/lvgl/src/themes/mono/lv_theme_mono.c ****     if(!lv_theme_mono_is_inited()) {
 190:Drivers/lvgl/src/themes/mono/lv_theme_mono.c ****         theme_def = lv_malloc_zeroed(sizeof(my_theme_t));
 191:Drivers/lvgl/src/themes/mono/lv_theme_mono.c ****         LV_ASSERT_MALLOC(theme_def);
 192:Drivers/lvgl/src/themes/mono/lv_theme_mono.c ****     }
 193:Drivers/lvgl/src/themes/mono/lv_theme_mono.c **** 
 194:Drivers/lvgl/src/themes/mono/lv_theme_mono.c ****     my_theme_t * theme = theme_def;
 195:Drivers/lvgl/src/themes/mono/lv_theme_mono.c **** 
 196:Drivers/lvgl/src/themes/mono/lv_theme_mono.c ****     theme->base.disp = disp;
