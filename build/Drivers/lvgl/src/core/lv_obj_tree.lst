  94:Drivers/lvgl/src/core/lv_obj_tree.c **** void lv_obj_clean(lv_obj_t * obj)
  95:Drivers/lvgl/src/core/lv_obj_tree.c **** {
  96:Drivers/lvgl/src/core/lv_obj_tree.c ****     LV_LOG_TRACE("begin (clean %p)", (void *)obj);
