 281:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 282:Drivers/lvgl/src/core/lv_obj_tree.c ****     lv_obj_invalidate(parent);
 283:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 284:Drivers/lvgl/src/core/lv_obj_tree.c ****     if(parent != parent2) {
 285:Drivers/lvgl/src/core/lv_obj_tree.c ****         lv_obj_invalidate(parent2);
 286:Drivers/lvgl/src/core/lv_obj_tree.c ****     }
 287:Drivers/lvgl/src/core/lv_obj_tree.c ****     lv_group_swap_obj(obj1, obj2);
