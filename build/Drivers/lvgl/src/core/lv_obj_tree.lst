 484:Drivers/lvgl/src/core/lv_obj_tree.c ****             lv_obj_t * child = lv_obj_get_child(parent, i);
 485:Drivers/lvgl/src/core/lv_obj_tree.c ****             /*All siblings older siblings are checked, craft the name of this widget*/
 486:Drivers/lvgl/src/core/lv_obj_tree.c ****             if(child == obj) {
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//cc9Gd54N.s 			page 10


 487:Drivers/lvgl/src/core/lv_obj_tree.c ****                 char num_buf[8];
 488:Drivers/lvgl/src/core/lv_obj_tree.c ****                 size_t num_len;
 489:Drivers/lvgl/src/core/lv_obj_tree.c ****                 num_len = lv_snprintf(num_buf, sizeof(num_buf), "%d", cnt);
 490:Drivers/lvgl/src/core/lv_obj_tree.c ****                 /*Is there enough space for the name and the index?*/
 491:Drivers/lvgl/src/core/lv_obj_tree.c ****                 if(buf_size > name_len + num_len) {
 492:Drivers/lvgl/src/core/lv_obj_tree.c ****                     /*E.g. buf = "some_name_", so trim the # from the end*/
 493:Drivers/lvgl/src/core/lv_obj_tree.c ****                     lv_strncpy(buf, name, name_len - 1);
 494:Drivers/lvgl/src/core/lv_obj_tree.c ****                     lv_strcpy(&buf[name_len - 1], num_buf);
 495:Drivers/lvgl/src/core/lv_obj_tree.c ****                 }
 496:Drivers/lvgl/src/core/lv_obj_tree.c ****                 else {
 497:Drivers/lvgl/src/core/lv_obj_tree.c ****                     /*Use the name as it is as a fallback*/
 498:Drivers/lvgl/src/core/lv_obj_tree.c ****                     lv_strlcpy(buf, obj->spec_attr->name, buf_size);
 499:Drivers/lvgl/src/core/lv_obj_tree.c ****                 }
 500:Drivers/lvgl/src/core/lv_obj_tree.c ****                 break;
 501:Drivers/lvgl/src/core/lv_obj_tree.c ****             }
 502:Drivers/lvgl/src/core/lv_obj_tree.c ****             /*Check the older siblings. IF they start with the same name count them*/
 503:Drivers/lvgl/src/core/lv_obj_tree.c ****             else {
 504:Drivers/lvgl/src/core/lv_obj_tree.c ****                 const char * child_name = lv_obj_get_name(child);
 505:Drivers/lvgl/src/core/lv_obj_tree.c ****                 if(child_name == NULL) {
 506:Drivers/lvgl/src/core/lv_obj_tree.c ****                     /*If the name we are looking for start with the child's class name
 507:Drivers/lvgl/src/core/lv_obj_tree.c ****                      *increment the index. E.g. <class_name>_#*/
 508:Drivers/lvgl/src/core/lv_obj_tree.c ****                     size_t class_name_len = lv_strlen(child->class_p->name);
 509:Drivers/lvgl/src/core/lv_obj_tree.c ****                     if(name_len > 3 && class_name_len == name_len - 2 &&
 510:Drivers/lvgl/src/core/lv_obj_tree.c ****                        lv_strncmp(child->class_p->name, name, class_name_len) == 0) {
 511:Drivers/lvgl/src/core/lv_obj_tree.c ****                         cnt++;
 512:Drivers/lvgl/src/core/lv_obj_tree.c ****                     }
 513:Drivers/lvgl/src/core/lv_obj_tree.c ****                 }
 514:Drivers/lvgl/src/core/lv_obj_tree.c ****                 /*The name is set, check if it's e.g. <some_name>#*/
 515:Drivers/lvgl/src/core/lv_obj_tree.c ****                 else {
 516:Drivers/lvgl/src/core/lv_obj_tree.c ****                     if(lv_strcmp(child->spec_attr->name, name) == 0) {
 517:Drivers/lvgl/src/core/lv_obj_tree.c ****                         cnt++;
 518:Drivers/lvgl/src/core/lv_obj_tree.c ****                     }
 519:Drivers/lvgl/src/core/lv_obj_tree.c ****                 }
 520:Drivers/lvgl/src/core/lv_obj_tree.c ****             }
 521:Drivers/lvgl/src/core/lv_obj_tree.c ****         }
 522:Drivers/lvgl/src/core/lv_obj_tree.c ****     }
 523:Drivers/lvgl/src/core/lv_obj_tree.c ****     else {
 524:Drivers/lvgl/src/core/lv_obj_tree.c ****         /*Just use the set name*/
 525:Drivers/lvgl/src/core/lv_obj_tree.c ****         lv_strlcpy(buf, obj->spec_attr->name, buf_size);
 526:Drivers/lvgl/src/core/lv_obj_tree.c ****     }
 527:Drivers/lvgl/src/core/lv_obj_tree.c **** }
