 208:Drivers/lvgl/src/core/lv_obj_tree.c **** void lv_obj_move_to_index(lv_obj_t * obj, int32_t index)
 209:Drivers/lvgl/src/core/lv_obj_tree.c **** {
 210:Drivers/lvgl/src/core/lv_obj_tree.c ****     LV_ASSERT_OBJ(obj, MY_CLASS);
 211:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 212:Drivers/lvgl/src/core/lv_obj_tree.c ****     /* Check parent validity */
 213:Drivers/lvgl/src/core/lv_obj_tree.c ****     lv_obj_t * parent = lv_obj_get_parent(obj);
 214:Drivers/lvgl/src/core/lv_obj_tree.c ****     if(!parent) {
 215:Drivers/lvgl/src/core/lv_obj_tree.c ****         LV_LOG_WARN("parent is NULL");
 216:Drivers/lvgl/src/core/lv_obj_tree.c ****         return;
 217:Drivers/lvgl/src/core/lv_obj_tree.c ****     }
 218:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 219:Drivers/lvgl/src/core/lv_obj_tree.c ****     const uint32_t parent_child_count = lv_obj_get_child_count(parent);
 220:Drivers/lvgl/src/core/lv_obj_tree.c ****     /* old_index only can be 0 or greater, this point cannot be reached if the parent is not null *
 221:Drivers/lvgl/src/core/lv_obj_tree.c ****     const int32_t old_index = lv_obj_get_index(obj);
 222:Drivers/lvgl/src/core/lv_obj_tree.c ****     LV_ASSERT(0 <= old_index);
 223:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 224:Drivers/lvgl/src/core/lv_obj_tree.c ****     if(index < 0) {
 225:Drivers/lvgl/src/core/lv_obj_tree.c ****         index += parent_child_count;
 226:Drivers/lvgl/src/core/lv_obj_tree.c ****     }
 227:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 228:Drivers/lvgl/src/core/lv_obj_tree.c ****     /* Index was negative and the absolute value is greater than parent child count */
 229:Drivers/lvgl/src/core/lv_obj_tree.c ****     if((index < 0)
 230:Drivers/lvgl/src/core/lv_obj_tree.c ****        /* Index is same or bigger than parent child count */
 231:Drivers/lvgl/src/core/lv_obj_tree.c ****        || (index >= (int32_t) parent_child_count)
 232:Drivers/lvgl/src/core/lv_obj_tree.c ****        /* If both previous and new index are the same */
 233:Drivers/lvgl/src/core/lv_obj_tree.c ****        || (index == old_index)) {
 234:Drivers/lvgl/src/core/lv_obj_tree.c **** 
