 529:Drivers/lvgl/src/core/lv_obj_tree.c **** lv_obj_t * lv_obj_get_child_by_name(const lv_obj_t * parent, const char * path)
 530:Drivers/lvgl/src/core/lv_obj_tree.c **** {
 531:Drivers/lvgl/src/core/lv_obj_tree.c ****     LV_ASSERT_OBJ(parent, MY_CLASS);
 532:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 533:Drivers/lvgl/src/core/lv_obj_tree.c ****     if(parent == NULL || parent->spec_attr == NULL || path == NULL) return NULL;
 534:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 535:Drivers/lvgl/src/core/lv_obj_tree.c ****     while(*path) {
 536:Drivers/lvgl/src/core/lv_obj_tree.c ****         const char * segment = path;
 537:Drivers/lvgl/src/core/lv_obj_tree.c ****         uint32_t len = 0;
 538:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 539:Drivers/lvgl/src/core/lv_obj_tree.c ****         /* Calculate the length of the current segment */
 540:Drivers/lvgl/src/core/lv_obj_tree.c ****         while(path[len] && path[len] != '/')
 541:Drivers/lvgl/src/core/lv_obj_tree.c ****             len++;
 542:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 543:Drivers/lvgl/src/core/lv_obj_tree.c ****         /* Look for a child whose resolved name exactly matches the segment */
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//cc9Gd54N.s 			page 11


 544:Drivers/lvgl/src/core/lv_obj_tree.c ****         lv_obj_t * child = find_by_name_direct(parent, segment, len);
 545:Drivers/lvgl/src/core/lv_obj_tree.c ****         if(!child) return NULL; /*Segment not found*/
 546:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 547:Drivers/lvgl/src/core/lv_obj_tree.c ****         /* Advance to the next segment */
 548:Drivers/lvgl/src/core/lv_obj_tree.c ****         path += len;
 549:Drivers/lvgl/src/core/lv_obj_tree.c ****         if(*path == '/') path++; /* Skip the '/' */
 550:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 551:Drivers/lvgl/src/core/lv_obj_tree.c ****         /* If there is no further segment, we've found the target child */
 552:Drivers/lvgl/src/core/lv_obj_tree.c ****         if(*path == '\0') return child;
 553:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 554:Drivers/lvgl/src/core/lv_obj_tree.c ****         parent = child;
 555:Drivers/lvgl/src/core/lv_obj_tree.c ****     }
 556:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 557:Drivers/lvgl/src/core/lv_obj_tree.c ****     return NULL;
 558:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 559:Drivers/lvgl/src/core/lv_obj_tree.c **** }
 560:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 561:Drivers/lvgl/src/core/lv_obj_tree.c **** lv_obj_t * lv_obj_find_by_name(const lv_obj_t * parent, const char * name)
 562:Drivers/lvgl/src/core/lv_obj_tree.c **** {
 563:Drivers/lvgl/src/core/lv_obj_tree.c ****     if(parent == NULL) parent = lv_display_get_screen_active(NULL);
 564:Drivers/lvgl/src/core/lv_obj_tree.c ****     if(parent == NULL) return NULL;
 565:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 566:Drivers/lvgl/src/core/lv_obj_tree.c ****     lv_obj_t * child = find_by_name_direct(parent, name, UINT16_MAX);
 567:Drivers/lvgl/src/core/lv_obj_tree.c ****     if(child) return child;
 568:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 569:Drivers/lvgl/src/core/lv_obj_tree.c ****     /*Search children recursively*/
 570:Drivers/lvgl/src/core/lv_obj_tree.c ****     uint32_t child_cnt = lv_obj_get_child_count(parent);
 571:Drivers/lvgl/src/core/lv_obj_tree.c ****     uint32_t i;
 572:Drivers/lvgl/src/core/lv_obj_tree.c ****     for(i = 0; i < child_cnt; i++) {
 573:Drivers/lvgl/src/core/lv_obj_tree.c ****         child = parent->spec_attr->children[i];
 574:Drivers/lvgl/src/core/lv_obj_tree.c ****         lv_obj_t * found = lv_obj_find_by_name(child, name);
 575:Drivers/lvgl/src/core/lv_obj_tree.c ****         if(found != NULL) return found;
 576:Drivers/lvgl/src/core/lv_obj_tree.c ****     }
 577:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 578:Drivers/lvgl/src/core/lv_obj_tree.c ****     return NULL;
 579:Drivers/lvgl/src/core/lv_obj_tree.c **** }
 580:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 581:Drivers/lvgl/src/core/lv_obj_tree.c **** #endif /*LV_USE_OBJ_NAME*/
