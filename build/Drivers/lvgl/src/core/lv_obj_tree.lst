 600:Drivers/lvgl/src/core/lv_obj_tree.c **** int32_t lv_obj_get_index_by_type(const lv_obj_t * obj, const lv_obj_class_t * class_p)
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//cc9Gd54N.s 			page 12


 601:Drivers/lvgl/src/core/lv_obj_tree.c **** {
