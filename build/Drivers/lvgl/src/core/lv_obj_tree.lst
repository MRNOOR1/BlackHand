 100:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 101:Drivers/lvgl/src/core/lv_obj_tree.c ****     uint32_t cnt = lv_obj_get_child_count(obj);
 102:Drivers/lvgl/src/core/lv_obj_tree.c ****     lv_obj_t * child = lv_obj_get_first_not_deleting_child(obj);
 103:Drivers/lvgl/src/core/lv_obj_tree.c ****     while(child) {
 104:Drivers/lvgl/src/core/lv_obj_tree.c ****         obj_delete_core(child);
 105:Drivers/lvgl/src/core/lv_obj_tree.c ****         child = lv_obj_get_first_not_deleting_child(obj);
 106:Drivers/lvgl/src/core/lv_obj_tree.c ****     }
