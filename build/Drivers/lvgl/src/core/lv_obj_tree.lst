 583:Drivers/lvgl/src/core/lv_obj_tree.c **** int32_t lv_obj_get_index(const lv_obj_t * obj)
 584:Drivers/lvgl/src/core/lv_obj_tree.c **** {
 585:Drivers/lvgl/src/core/lv_obj_tree.c ****     LV_ASSERT_OBJ(obj, MY_CLASS);
 586:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 587:Drivers/lvgl/src/core/lv_obj_tree.c ****     lv_obj_t * parent = lv_obj_get_parent(obj);
 588:Drivers/lvgl/src/core/lv_obj_tree.c ****     if(parent == NULL) return -1;
 589:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 590:Drivers/lvgl/src/core/lv_obj_tree.c ****     int32_t i = 0;
 591:Drivers/lvgl/src/core/lv_obj_tree.c ****     for(i = 0; i < parent->spec_attr->child_cnt; i++) {
 592:Drivers/lvgl/src/core/lv_obj_tree.c ****         if(parent->spec_attr->children[i] == obj) return i;
 593:Drivers/lvgl/src/core/lv_obj_tree.c ****     }
 594:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 595:Drivers/lvgl/src/core/lv_obj_tree.c ****     /*Shouldn't reach this point*/
 596:Drivers/lvgl/src/core/lv_obj_tree.c ****     LV_ASSERT(0);
 597:Drivers/lvgl/src/core/lv_obj_tree.c ****     return -1;
 598:Drivers/lvgl/src/core/lv_obj_tree.c **** }
