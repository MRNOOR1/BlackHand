 110:Drivers/lvgl/src/core/lv_obj_tree.c ****         obj->spec_attr->scroll.x = 0;
 111:Drivers/lvgl/src/core/lv_obj_tree.c ****         obj->spec_attr->scroll.y = 0;
 112:Drivers/lvgl/src/core/lv_obj_tree.c ****     }
 113:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 114:Drivers/lvgl/src/core/lv_obj_tree.c ****     if(lv_obj_get_child_count(obj) < cnt) {
 115:Drivers/lvgl/src/core/lv_obj_tree.c ****         lv_obj_send_event(obj, LV_EVENT_CHILD_CHANGED, NULL);
 116:Drivers/lvgl/src/core/lv_obj_tree.c ****         lv_obj_send_event(obj, LV_EVENT_CHILD_DELETED, NULL);
 117:Drivers/lvgl/src/core/lv_obj_tree.c ****     }
 118:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 119:Drivers/lvgl/src/core/lv_obj_tree.c ****     LV_ASSERT_MEM_INTEGRITY();
