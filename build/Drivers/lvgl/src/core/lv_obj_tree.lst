 654:Drivers/lvgl/src/core/lv_obj_tree.c **** static void obj_indev_reset(lv_indev_t * indev, lv_obj_t * obj)
 655:Drivers/lvgl/src/core/lv_obj_tree.c **** {
 656:Drivers/lvgl/src/core/lv_obj_tree.c ****     /* If the input device is already in the release state,
 657:Drivers/lvgl/src/core/lv_obj_tree.c ****      * there is no need to wait for the input device to be released
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//cc9Gd54N.s 			page 13


 658:Drivers/lvgl/src/core/lv_obj_tree.c ****      */
 659:Drivers/lvgl/src/core/lv_obj_tree.c ****     if(lv_indev_get_state(indev) != LV_INDEV_STATE_RELEASED) {
 660:Drivers/lvgl/src/core/lv_obj_tree.c ****         /*Wait for release to avoid accidentally triggering other obj to be clicked*/
 661:Drivers/lvgl/src/core/lv_obj_tree.c ****         lv_indev_wait_release(indev);
 662:Drivers/lvgl/src/core/lv_obj_tree.c ****     }
 663:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 664:Drivers/lvgl/src/core/lv_obj_tree.c ****     /*Reset the input device*/
 665:Drivers/lvgl/src/core/lv_obj_tree.c ****     lv_indev_reset(indev, obj);
 666:Drivers/lvgl/src/core/lv_obj_tree.c **** }
 667:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 668:Drivers/lvgl/src/core/lv_obj_tree.c **** static void obj_delete_core(lv_obj_t * obj)
 669:Drivers/lvgl/src/core/lv_obj_tree.c **** {
 670:Drivers/lvgl/src/core/lv_obj_tree.c ****     if(obj->is_deleting)
 671:Drivers/lvgl/src/core/lv_obj_tree.c ****         return;
 672:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 673:Drivers/lvgl/src/core/lv_obj_tree.c ****     obj->is_deleting = true;
 674:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 675:Drivers/lvgl/src/core/lv_obj_tree.c ****     /*Let the user free the resources used in `LV_EVENT_DELETE`*/
 676:Drivers/lvgl/src/core/lv_obj_tree.c ****     lv_result_t res = lv_obj_send_event(obj, LV_EVENT_DELETE, NULL);
 677:Drivers/lvgl/src/core/lv_obj_tree.c ****     if(res == LV_RESULT_INVALID) {
 678:Drivers/lvgl/src/core/lv_obj_tree.c ****         obj->is_deleting = false;
 679:Drivers/lvgl/src/core/lv_obj_tree.c ****         return;
 680:Drivers/lvgl/src/core/lv_obj_tree.c ****     }
 681:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 682:Drivers/lvgl/src/core/lv_obj_tree.c ****     /*Clean registered event_cb*/
 683:Drivers/lvgl/src/core/lv_obj_tree.c ****     if(obj->spec_attr) lv_event_remove_all(&(obj->spec_attr->event_list));
 684:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 685:Drivers/lvgl/src/core/lv_obj_tree.c ****     /*Recursively delete the children*/
 686:Drivers/lvgl/src/core/lv_obj_tree.c ****     lv_obj_t * child = lv_obj_get_child(obj, 0);
 687:Drivers/lvgl/src/core/lv_obj_tree.c ****     while(child) {
 688:Drivers/lvgl/src/core/lv_obj_tree.c ****         obj_delete_core(child);
 689:Drivers/lvgl/src/core/lv_obj_tree.c ****         child = lv_obj_get_child(obj, 0);
 690:Drivers/lvgl/src/core/lv_obj_tree.c ****     }
 691:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 692:Drivers/lvgl/src/core/lv_obj_tree.c ****     lv_group_t * group = lv_obj_get_group(obj);
 693:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 694:Drivers/lvgl/src/core/lv_obj_tree.c ****     /*Reset all input devices if the object to delete is used*/
 695:Drivers/lvgl/src/core/lv_obj_tree.c ****     lv_indev_t * indev = lv_indev_get_next(NULL);
 696:Drivers/lvgl/src/core/lv_obj_tree.c ****     while(indev) {
 697:Drivers/lvgl/src/core/lv_obj_tree.c ****         lv_indev_type_t indev_type = lv_indev_get_type(indev);
 698:Drivers/lvgl/src/core/lv_obj_tree.c ****         if(indev_type == LV_INDEV_TYPE_POINTER || indev_type == LV_INDEV_TYPE_BUTTON) {
 699:Drivers/lvgl/src/core/lv_obj_tree.c ****             if(indev->pointer.act_obj == obj || indev->pointer.scroll_obj == obj) {
 700:Drivers/lvgl/src/core/lv_obj_tree.c ****                 obj_indev_reset(indev, obj);
 701:Drivers/lvgl/src/core/lv_obj_tree.c ****             }
 702:Drivers/lvgl/src/core/lv_obj_tree.c ****             if(indev->pointer.last_pressed == obj) {
 703:Drivers/lvgl/src/core/lv_obj_tree.c ****                 indev->pointer.last_pressed = NULL;
 704:Drivers/lvgl/src/core/lv_obj_tree.c ****             }
 705:Drivers/lvgl/src/core/lv_obj_tree.c ****             if(indev->pointer.last_hovered == obj) {
 706:Drivers/lvgl/src/core/lv_obj_tree.c ****                 indev->pointer.last_hovered = NULL;
 707:Drivers/lvgl/src/core/lv_obj_tree.c ****             }
 708:Drivers/lvgl/src/core/lv_obj_tree.c ****         }
 709:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 710:Drivers/lvgl/src/core/lv_obj_tree.c ****         if(indev->group == group && obj == lv_indev_get_active_obj()) {
 711:Drivers/lvgl/src/core/lv_obj_tree.c ****             obj_indev_reset(indev, obj);
 712:Drivers/lvgl/src/core/lv_obj_tree.c ****         }
 713:Drivers/lvgl/src/core/lv_obj_tree.c ****         indev = lv_indev_get_next(indev);
 714:Drivers/lvgl/src/core/lv_obj_tree.c ****     }
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//cc9Gd54N.s 			page 14


 715:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 716:Drivers/lvgl/src/core/lv_obj_tree.c ****     /*Delete all pending async del-s*/
 717:Drivers/lvgl/src/core/lv_obj_tree.c ****     lv_result_t async_cancel_res = LV_RESULT_OK;
 718:Drivers/lvgl/src/core/lv_obj_tree.c ****     while(async_cancel_res == LV_RESULT_OK) {
 719:Drivers/lvgl/src/core/lv_obj_tree.c ****         async_cancel_res = lv_async_call_cancel(lv_obj_delete_async_cb, obj);
 720:Drivers/lvgl/src/core/lv_obj_tree.c ****     }
 721:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 722:Drivers/lvgl/src/core/lv_obj_tree.c ****     /*All children deleted. Now clean up the object specific data*/
 723:Drivers/lvgl/src/core/lv_obj_tree.c ****     lv_obj_destruct(obj);
 724:Drivers/lvgl/src/core/lv_obj_tree.c **** 
 725:Drivers/lvgl/src/core/lv_obj_tree.c ****     /*Remove the screen for the screen list*/
 726:Drivers/lvgl/src/core/lv_obj_tree.c ****     if(obj->parent == NULL) {
 727:Drivers/lvgl/src/core/lv_obj_tree.c ****         lv_display_t * disp = lv_obj_get_display(obj);
