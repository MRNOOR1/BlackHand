 180:Drivers/lvgl/src/core/lv_obj_scroll.c ****     int32_t space_right = lv_obj_get_style_space_right(obj, LV_PART_MAIN);
 181:Drivers/lvgl/src/core/lv_obj_scroll.c ****     int32_t space_left = lv_obj_get_style_space_left(obj, LV_PART_MAIN);
 182:Drivers/lvgl/src/core/lv_obj_scroll.c **** 
 183:Drivers/lvgl/src/core/lv_obj_scroll.c ****     int32_t child_res = 0;
 184:Drivers/lvgl/src/core/lv_obj_scroll.c **** 
 185:Drivers/lvgl/src/core/lv_obj_scroll.c ****     uint32_t i;
 186:Drivers/lvgl/src/core/lv_obj_scroll.c ****     int32_t x1 = LV_COORD_MAX;
 187:Drivers/lvgl/src/core/lv_obj_scroll.c ****     uint32_t child_cnt = lv_obj_get_child_count(obj);
 188:Drivers/lvgl/src/core/lv_obj_scroll.c ****     for(i = 0; i < child_cnt; i++) {
 189:Drivers/lvgl/src/core/lv_obj_scroll.c ****         const lv_obj_t * child = obj->spec_attr->children[i];
 190:Drivers/lvgl/src/core/lv_obj_scroll.c ****         if(lv_obj_has_flag_any(child,  LV_OBJ_FLAG_HIDDEN | LV_OBJ_FLAG_FLOATING)) continue;
 191:Drivers/lvgl/src/core/lv_obj_scroll.c **** 
 192:Drivers/lvgl/src/core/lv_obj_scroll.c ****         int32_t tmp_x = child->coords.x1 - lv_obj_get_style_margin_left(child, LV_PART_MAIN);
 193:Drivers/lvgl/src/core/lv_obj_scroll.c ****         x1 = LV_MIN(x1, tmp_x);
 194:Drivers/lvgl/src/core/lv_obj_scroll.c ****     }
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//cc2HRQKm.s 			page 26


 195:Drivers/lvgl/src/core/lv_obj_scroll.c **** 
 196:Drivers/lvgl/src/core/lv_obj_scroll.c ****     if(x1 != LV_COORD_MAX) {
 197:Drivers/lvgl/src/core/lv_obj_scroll.c ****         child_res = x1;
 198:Drivers/lvgl/src/core/lv_obj_scroll.c ****         child_res = (obj->coords.x1 + space_left) - child_res;
