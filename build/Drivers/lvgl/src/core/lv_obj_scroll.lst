 229:Drivers/lvgl/src/core/lv_obj_scroll.c **** 
 230:Drivers/lvgl/src/core/lv_obj_scroll.c ****         int32_t tmp_x = child->coords.x2 + lv_obj_get_style_margin_right(child, LV_PART_MAIN);
 231:Drivers/lvgl/src/core/lv_obj_scroll.c ****         child_res = LV_MAX(child_res, tmp_x);
 232:Drivers/lvgl/src/core/lv_obj_scroll.c ****     }
 233:Drivers/lvgl/src/core/lv_obj_scroll.c **** 
 234:Drivers/lvgl/src/core/lv_obj_scroll.c ****     int32_t space_right = lv_obj_get_style_space_right(obj, LV_PART_MAIN);
 235:Drivers/lvgl/src/core/lv_obj_scroll.c ****     int32_t space_left = lv_obj_get_style_space_left(obj, LV_PART_MAIN);
 236:Drivers/lvgl/src/core/lv_obj_scroll.c **** 
 237:Drivers/lvgl/src/core/lv_obj_scroll.c ****     if(child_res != LV_COORD_MIN) {
