 262:Drivers/lvgl/src/core/lv_obj_scroll.c **** void lv_obj_scroll_by_bounded(lv_obj_t * obj, int32_t dx, int32_t dy, lv_anim_enable_t anim_en)
 263:Drivers/lvgl/src/core/lv_obj_scroll.c **** {
 264:Drivers/lvgl/src/core/lv_obj_scroll.c ****     if(dx == 0 && dy == 0) return;
 265:Drivers/lvgl/src/core/lv_obj_scroll.c **** 
 266:Drivers/lvgl/src/core/lv_obj_scroll.c ****     /*We need to know the final sizes for bound check*/
 267:Drivers/lvgl/src/core/lv_obj_scroll.c ****     lv_obj_update_layout(obj);
 268:Drivers/lvgl/src/core/lv_obj_scroll.c **** 
 269:Drivers/lvgl/src/core/lv_obj_scroll.c ****     /*Don't let scroll more than naturally possible by the size of the content*/
 270:Drivers/lvgl/src/core/lv_obj_scroll.c ****     int32_t x_current = -lv_obj_get_scroll_x(obj);
 271:Drivers/lvgl/src/core/lv_obj_scroll.c ****     int32_t x_bounded = x_current + dx;
 272:Drivers/lvgl/src/core/lv_obj_scroll.c **** 
 273:Drivers/lvgl/src/core/lv_obj_scroll.c ****     if(lv_obj_get_style_base_dir(obj, LV_PART_MAIN) != LV_BASE_DIR_RTL) {
 274:Drivers/lvgl/src/core/lv_obj_scroll.c ****         if(x_bounded > 0) x_bounded = 0;
 275:Drivers/lvgl/src/core/lv_obj_scroll.c ****         if(x_bounded < 0) {
 276:Drivers/lvgl/src/core/lv_obj_scroll.c ****             int32_t  scroll_max = lv_obj_get_scroll_left(obj) + lv_obj_get_scroll_right(obj);
 277:Drivers/lvgl/src/core/lv_obj_scroll.c ****             if(scroll_max < 0) scroll_max = 0;
 278:Drivers/lvgl/src/core/lv_obj_scroll.c **** 
 279:Drivers/lvgl/src/core/lv_obj_scroll.c ****             if(x_bounded < -scroll_max) x_bounded = -scroll_max;
 280:Drivers/lvgl/src/core/lv_obj_scroll.c ****         }
 281:Drivers/lvgl/src/core/lv_obj_scroll.c ****     }
 282:Drivers/lvgl/src/core/lv_obj_scroll.c ****     else {
 283:Drivers/lvgl/src/core/lv_obj_scroll.c ****         if(x_bounded < 0) x_bounded = 0;
 284:Drivers/lvgl/src/core/lv_obj_scroll.c ****         if(x_bounded > 0) {
 285:Drivers/lvgl/src/core/lv_obj_scroll.c ****             int32_t  scroll_max = lv_obj_get_scroll_left(obj) + lv_obj_get_scroll_right(obj);
 286:Drivers/lvgl/src/core/lv_obj_scroll.c ****             if(scroll_max < 0) scroll_max = 0;
 287:Drivers/lvgl/src/core/lv_obj_scroll.c **** 
 288:Drivers/lvgl/src/core/lv_obj_scroll.c ****             if(x_bounded > scroll_max) x_bounded = scroll_max;
 289:Drivers/lvgl/src/core/lv_obj_scroll.c ****         }
 290:Drivers/lvgl/src/core/lv_obj_scroll.c ****     }
 291:Drivers/lvgl/src/core/lv_obj_scroll.c **** 
 292:Drivers/lvgl/src/core/lv_obj_scroll.c ****     /*Don't let scroll more than naturally possible by the size of the content*/
 293:Drivers/lvgl/src/core/lv_obj_scroll.c ****     int32_t y_current = -lv_obj_get_scroll_y(obj);
 294:Drivers/lvgl/src/core/lv_obj_scroll.c ****     int32_t y_bounded = y_current + dy;
 295:Drivers/lvgl/src/core/lv_obj_scroll.c **** 
 296:Drivers/lvgl/src/core/lv_obj_scroll.c ****     if(y_bounded > 0) y_bounded = 0;
 297:Drivers/lvgl/src/core/lv_obj_scroll.c ****     if(y_bounded < 0) {
 298:Drivers/lvgl/src/core/lv_obj_scroll.c ****         int32_t  scroll_max = lv_obj_get_scroll_top(obj) + lv_obj_get_scroll_bottom(obj);
 299:Drivers/lvgl/src/core/lv_obj_scroll.c ****         if(scroll_max < 0) scroll_max = 0;
 300:Drivers/lvgl/src/core/lv_obj_scroll.c ****         if(y_bounded < -scroll_max) y_bounded = -scroll_max;
 301:Drivers/lvgl/src/core/lv_obj_scroll.c ****     }
 302:Drivers/lvgl/src/core/lv_obj_scroll.c **** 
 303:Drivers/lvgl/src/core/lv_obj_scroll.c ****     dx = x_bounded - x_current;
 304:Drivers/lvgl/src/core/lv_obj_scroll.c ****     dy = y_bounded - y_current;
 305:Drivers/lvgl/src/core/lv_obj_scroll.c ****     if(dx || dy) {
 306:Drivers/lvgl/src/core/lv_obj_scroll.c ****         lv_obj_scroll_by(obj, dx, dy, anim_en);
 307:Drivers/lvgl/src/core/lv_obj_scroll.c ****     }
 308:Drivers/lvgl/src/core/lv_obj_scroll.c **** }
