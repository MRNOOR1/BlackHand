 310:Drivers/lvgl/src/core/lv_obj_scroll.c **** void lv_obj_scroll_by(lv_obj_t * obj, int32_t dx, int32_t dy, lv_anim_enable_t anim_en)
 311:Drivers/lvgl/src/core/lv_obj_scroll.c **** {
 312:Drivers/lvgl/src/core/lv_obj_scroll.c ****     if(dx == 0 && dy == 0) return;
 313:Drivers/lvgl/src/core/lv_obj_scroll.c ****     if(anim_en) {
 314:Drivers/lvgl/src/core/lv_obj_scroll.c ****         lv_display_t * d = lv_obj_get_display(obj);
 315:Drivers/lvgl/src/core/lv_obj_scroll.c ****         lv_anim_t a;
 316:Drivers/lvgl/src/core/lv_obj_scroll.c ****         lv_anim_init(&a);
 317:Drivers/lvgl/src/core/lv_obj_scroll.c ****         lv_anim_set_var(&a, obj);
 318:Drivers/lvgl/src/core/lv_obj_scroll.c ****         lv_anim_set_deleted_cb(&a, scroll_end_cb);
 319:Drivers/lvgl/src/core/lv_obj_scroll.c **** 
 320:Drivers/lvgl/src/core/lv_obj_scroll.c ****         if(dx) {
 321:Drivers/lvgl/src/core/lv_obj_scroll.c ****             uint32_t t = lv_anim_speed_clamped((lv_display_get_horizontal_resolution(d)) >> 1, SCRO
 322:Drivers/lvgl/src/core/lv_obj_scroll.c ****                                                SCROLL_ANIM_TIME_MAX);
 323:Drivers/lvgl/src/core/lv_obj_scroll.c ****             lv_anim_set_duration(&a, t);
 324:Drivers/lvgl/src/core/lv_obj_scroll.c ****             int32_t sx = lv_obj_get_scroll_x(obj);
 325:Drivers/lvgl/src/core/lv_obj_scroll.c ****             lv_anim_set_values(&a, -sx, -sx + dx);
 326:Drivers/lvgl/src/core/lv_obj_scroll.c ****             lv_anim_set_exec_cb(&a, scroll_x_anim);
 327:Drivers/lvgl/src/core/lv_obj_scroll.c ****             lv_anim_set_path_cb(&a, lv_anim_path_ease_out);
 328:Drivers/lvgl/src/core/lv_obj_scroll.c **** 
 329:Drivers/lvgl/src/core/lv_obj_scroll.c ****             lv_result_t res;
 330:Drivers/lvgl/src/core/lv_obj_scroll.c ****             res = lv_obj_send_event(obj, LV_EVENT_SCROLL_BEGIN, &a);
 331:Drivers/lvgl/src/core/lv_obj_scroll.c ****             if(res != LV_RESULT_OK) return;
 332:Drivers/lvgl/src/core/lv_obj_scroll.c ****             lv_anim_start(&a);
 333:Drivers/lvgl/src/core/lv_obj_scroll.c ****         }
 334:Drivers/lvgl/src/core/lv_obj_scroll.c **** 
 335:Drivers/lvgl/src/core/lv_obj_scroll.c ****         if(dy) {
 336:Drivers/lvgl/src/core/lv_obj_scroll.c ****             uint32_t t = lv_anim_speed_clamped((lv_display_get_vertical_resolution(d)) >> 1, SCROLL
 337:Drivers/lvgl/src/core/lv_obj_scroll.c ****                                                SCROLL_ANIM_TIME_MAX);
 338:Drivers/lvgl/src/core/lv_obj_scroll.c ****             lv_anim_set_duration(&a, t);
 339:Drivers/lvgl/src/core/lv_obj_scroll.c ****             int32_t sy = lv_obj_get_scroll_y(obj);
 340:Drivers/lvgl/src/core/lv_obj_scroll.c ****             lv_anim_set_values(&a, -sy, -sy + dy);
 341:Drivers/lvgl/src/core/lv_obj_scroll.c ****             lv_anim_set_exec_cb(&a,  scroll_y_anim);
 342:Drivers/lvgl/src/core/lv_obj_scroll.c ****             lv_anim_set_path_cb(&a, lv_anim_path_ease_out);
 343:Drivers/lvgl/src/core/lv_obj_scroll.c **** 
 344:Drivers/lvgl/src/core/lv_obj_scroll.c ****             lv_result_t res;
 345:Drivers/lvgl/src/core/lv_obj_scroll.c ****             res = lv_obj_send_event(obj, LV_EVENT_SCROLL_BEGIN, &a);
 346:Drivers/lvgl/src/core/lv_obj_scroll.c ****             if(res != LV_RESULT_OK) return;
 347:Drivers/lvgl/src/core/lv_obj_scroll.c ****             lv_anim_start(&a);
 348:Drivers/lvgl/src/core/lv_obj_scroll.c ****         }
 349:Drivers/lvgl/src/core/lv_obj_scroll.c ****     }
 350:Drivers/lvgl/src/core/lv_obj_scroll.c ****     else {
 351:Drivers/lvgl/src/core/lv_obj_scroll.c ****         /*Remove pending animations*/
 352:Drivers/lvgl/src/core/lv_obj_scroll.c ****         lv_anim_delete(obj, scroll_y_anim);
 353:Drivers/lvgl/src/core/lv_obj_scroll.c ****         lv_anim_delete(obj, scroll_x_anim);
