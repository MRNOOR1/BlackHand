 346:Drivers/lvgl/src/core/lv_obj_pos.c **** void lv_obj_update_layout(const lv_obj_t * obj)
 347:Drivers/lvgl/src/core/lv_obj_pos.c **** {
 348:Drivers/lvgl/src/core/lv_obj_pos.c ****     if(update_layout_mutex) {
 349:Drivers/lvgl/src/core/lv_obj_pos.c ****         LV_LOG_TRACE("Already running, returning");
 350:Drivers/lvgl/src/core/lv_obj_pos.c ****         return;
 351:Drivers/lvgl/src/core/lv_obj_pos.c ****     }
 352:Drivers/lvgl/src/core/lv_obj_pos.c ****     LV_PROFILER_LAYOUT_BEGIN;
 353:Drivers/lvgl/src/core/lv_obj_pos.c ****     update_layout_mutex = true;
 354:Drivers/lvgl/src/core/lv_obj_pos.c **** 
 355:Drivers/lvgl/src/core/lv_obj_pos.c ****     lv_obj_t * scr = lv_obj_get_screen(obj);
 356:Drivers/lvgl/src/core/lv_obj_pos.c ****     /*Repeat until there are no more layout invalidations*/
 357:Drivers/lvgl/src/core/lv_obj_pos.c ****     while(scr->scr_layout_inv) {
 358:Drivers/lvgl/src/core/lv_obj_pos.c ****         LV_LOG_TRACE("Layout update begin");
 359:Drivers/lvgl/src/core/lv_obj_pos.c ****         scr->scr_layout_inv = 0;
 360:Drivers/lvgl/src/core/lv_obj_pos.c ****         layout_update_core(scr);
 361:Drivers/lvgl/src/core/lv_obj_pos.c ****         LV_LOG_TRACE("Layout update end");
 362:Drivers/lvgl/src/core/lv_obj_pos.c ****     }
 363:Drivers/lvgl/src/core/lv_obj_pos.c **** 
 364:Drivers/lvgl/src/core/lv_obj_pos.c ****     lv_display_t * disp = lv_obj_get_display(scr);
 365:Drivers/lvgl/src/core/lv_obj_pos.c ****     lv_display_send_event(disp, LV_EVENT_UPDATE_LAYOUT_COMPLETED, NULL);
 366:Drivers/lvgl/src/core/lv_obj_pos.c ****     update_layout_mutex = false;
 367:Drivers/lvgl/src/core/lv_obj_pos.c ****     LV_PROFILER_LAYOUT_END;
 368:Drivers/lvgl/src/core/lv_obj_pos.c **** }
