 269:Drivers/lvgl/src/core/lv_refr.c **** lv_result_t lv_inv_area(lv_display_t * disp, const lv_area_t * area_p)
 270:Drivers/lvgl/src/core/lv_refr.c **** {
 271:Drivers/lvgl/src/core/lv_refr.c ****     if(!disp) disp = lv_display_get_default();
 272:Drivers/lvgl/src/core/lv_refr.c ****     if(!disp) return LV_RESULT_INVALID;
 273:Drivers/lvgl/src/core/lv_refr.c ****     if(!lv_display_is_invalidation_enabled(disp)) return LV_RESULT_INVALID;
 274:Drivers/lvgl/src/core/lv_refr.c **** 
 275:Drivers/lvgl/src/core/lv_refr.c ****     /**
 276:Drivers/lvgl/src/core/lv_refr.c ****      * There are two reasons for this issue:
 277:Drivers/lvgl/src/core/lv_refr.c ****      *  1.LVGL API is being used across threads, such as modifying widget properties in another thr
 278:Drivers/lvgl/src/core/lv_refr.c ****      *    or within an interrupt handler during the main thread rendering process.
 279:Drivers/lvgl/src/core/lv_refr.c ****      *  2.User-customized widget modify widget properties/styles again within the DRAW event.
 280:Drivers/lvgl/src/core/lv_refr.c ****      *
 281:Drivers/lvgl/src/core/lv_refr.c ****      * Therefore, ensure that LVGL is used in a single-threaded manner, or refer to
 282:Drivers/lvgl/src/core/lv_refr.c ****      * documentation: https://docs.lvgl.io/master/porting/os.html for proper locking mechanisms.
 283:Drivers/lvgl/src/core/lv_refr.c ****      * Additionally, ensure that only drawing-related tasks are performed within the DRAW event,
 284:Drivers/lvgl/src/core/lv_refr.c ****      * and move widget property/style modifications to other events.
 285:Drivers/lvgl/src/core/lv_refr.c ****      */
 286:Drivers/lvgl/src/core/lv_refr.c ****     LV_ASSERT_MSG(!disp->rendering_in_progress, "Invalidate area is not allowed during rendering.")
 287:Drivers/lvgl/src/core/lv_refr.c **** 
 288:Drivers/lvgl/src/core/lv_refr.c ****     /*Clear the invalidate buffer if the parameter is NULL*/
 289:Drivers/lvgl/src/core/lv_refr.c ****     if(area_p == NULL) {
 290:Drivers/lvgl/src/core/lv_refr.c ****         disp->inv_p = 0;
 291:Drivers/lvgl/src/core/lv_refr.c ****         return LV_RESULT_OK;
 292:Drivers/lvgl/src/core/lv_refr.c ****     }
 293:Drivers/lvgl/src/core/lv_refr.c **** 
 294:Drivers/lvgl/src/core/lv_refr.c ****     lv_area_t scr_area;
 295:Drivers/lvgl/src/core/lv_refr.c ****     scr_area.x1 = 0;
 296:Drivers/lvgl/src/core/lv_refr.c ****     scr_area.y1 = 0;
 297:Drivers/lvgl/src/core/lv_refr.c ****     scr_area.x2 = lv_display_get_horizontal_resolution(disp) - 1;
 298:Drivers/lvgl/src/core/lv_refr.c ****     scr_area.y2 = lv_display_get_vertical_resolution(disp) - 1;
 299:Drivers/lvgl/src/core/lv_refr.c **** 
 300:Drivers/lvgl/src/core/lv_refr.c ****     lv_area_t com_area;
 301:Drivers/lvgl/src/core/lv_refr.c ****     bool suc;
 302:Drivers/lvgl/src/core/lv_refr.c **** 
 303:Drivers/lvgl/src/core/lv_refr.c ****     suc = lv_area_intersect(&com_area, area_p, &scr_area);
 304:Drivers/lvgl/src/core/lv_refr.c ****     if(suc == false)  return LV_RESULT_INVALID; /*Out of the screen*/
 305:Drivers/lvgl/src/core/lv_refr.c **** 
 306:Drivers/lvgl/src/core/lv_refr.c ****     if(disp->color_format == LV_COLOR_FORMAT_I1) {
 307:Drivers/lvgl/src/core/lv_refr.c ****         /*Make sure that the X coordinates start and end on byte boundary.
 308:Drivers/lvgl/src/core/lv_refr.c ****          *E.g. convert 11;27 to 8;31*/
 309:Drivers/lvgl/src/core/lv_refr.c ****         com_area.x1 &= ~0x7; /*Round down: Nx8*/
 310:Drivers/lvgl/src/core/lv_refr.c ****         com_area.x2 |= 0x7;    /*Round up: Nx8 - 1*/
 311:Drivers/lvgl/src/core/lv_refr.c ****     }
 312:Drivers/lvgl/src/core/lv_refr.c **** 
 313:Drivers/lvgl/src/core/lv_refr.c ****     /*If there were at least 1 invalid area in full refresh mode, redraw the whole screen*/
 314:Drivers/lvgl/src/core/lv_refr.c ****     if(disp->render_mode == LV_DISPLAY_RENDER_MODE_FULL) {
 315:Drivers/lvgl/src/core/lv_refr.c ****         disp->inv_areas[0] = scr_area;
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//cceL6DBR.s 			page 7


 316:Drivers/lvgl/src/core/lv_refr.c ****         disp->inv_p = 1;
 317:Drivers/lvgl/src/core/lv_refr.c ****         lv_display_send_event(disp, LV_EVENT_REFR_REQUEST, NULL);
 318:Drivers/lvgl/src/core/lv_refr.c ****         return LV_RESULT_OK;
 319:Drivers/lvgl/src/core/lv_refr.c ****     }
 320:Drivers/lvgl/src/core/lv_refr.c **** 
 321:Drivers/lvgl/src/core/lv_refr.c ****     lv_result_t res = lv_display_send_event(disp, LV_EVENT_INVALIDATE_AREA, &com_area);
 322:Drivers/lvgl/src/core/lv_refr.c ****     if(res != LV_RESULT_OK) return LV_RESULT_INVALID;
 323:Drivers/lvgl/src/core/lv_refr.c **** 
 324:Drivers/lvgl/src/core/lv_refr.c ****     /*Save only if this area is not in one of the saved areas*/
 325:Drivers/lvgl/src/core/lv_refr.c ****     uint16_t i;
 326:Drivers/lvgl/src/core/lv_refr.c ****     for(i = 0; i < disp->inv_p; i++) {
 327:Drivers/lvgl/src/core/lv_refr.c ****         if(lv_area_is_in(&com_area, &disp->inv_areas[i], 0) != false) return LV_RESULT_OK;
 328:Drivers/lvgl/src/core/lv_refr.c ****     }
 329:Drivers/lvgl/src/core/lv_refr.c **** 
 330:Drivers/lvgl/src/core/lv_refr.c ****     /*Save the area*/
 331:Drivers/lvgl/src/core/lv_refr.c ****     lv_area_t * tmp_area_p = &com_area;
 332:Drivers/lvgl/src/core/lv_refr.c ****     if(disp->inv_p >= LV_INV_BUF_SIZE) { /*If no place for the area add the screen*/
 333:Drivers/lvgl/src/core/lv_refr.c ****         disp->inv_p = 0;
 334:Drivers/lvgl/src/core/lv_refr.c ****         tmp_area_p = &scr_area;
 335:Drivers/lvgl/src/core/lv_refr.c ****     }
 336:Drivers/lvgl/src/core/lv_refr.c ****     lv_area_copy(&disp->inv_areas[disp->inv_p], tmp_area_p);
 337:Drivers/lvgl/src/core/lv_refr.c ****     disp->inv_p++;
 338:Drivers/lvgl/src/core/lv_refr.c **** 
 339:Drivers/lvgl/src/core/lv_refr.c ****     lv_display_send_event(disp, LV_EVENT_REFR_REQUEST, NULL);
 340:Drivers/lvgl/src/core/lv_refr.c **** 
 341:Drivers/lvgl/src/core/lv_refr.c ****     return LV_RESULT_OK;
 342:Drivers/lvgl/src/core/lv_refr.c **** }
