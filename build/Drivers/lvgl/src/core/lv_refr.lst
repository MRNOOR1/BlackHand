 451:Drivers/lvgl/src/core/lv_refr.c **** /**
 452:Drivers/lvgl/src/core/lv_refr.c ****  * Search the most top object which fully covers an area
 453:Drivers/lvgl/src/core/lv_refr.c ****  * @param area_p pointer to an area
 454:Drivers/lvgl/src/core/lv_refr.c ****  * @param obj the first object to start the searching (typically a screen)
 455:Drivers/lvgl/src/core/lv_refr.c ****  * @return
 456:Drivers/lvgl/src/core/lv_refr.c ****  */
 457:Drivers/lvgl/src/core/lv_refr.c **** lv_obj_t * lv_refr_get_top_obj(const lv_area_t * area_p, lv_obj_t * obj)
 458:Drivers/lvgl/src/core/lv_refr.c **** {
 459:Drivers/lvgl/src/core/lv_refr.c ****     lv_obj_t * found_p = NULL;
 460:Drivers/lvgl/src/core/lv_refr.c **** 
 461:Drivers/lvgl/src/core/lv_refr.c ****     if(lv_area_is_in(area_p, &obj->coords, 0) == false) return NULL;
 462:Drivers/lvgl/src/core/lv_refr.c ****     if(lv_obj_has_flag(obj, LV_OBJ_FLAG_HIDDEN)) return NULL;
 463:Drivers/lvgl/src/core/lv_refr.c ****     if(lv_obj_get_layer_type(obj) != LV_LAYER_TYPE_NONE) return NULL;
 464:Drivers/lvgl/src/core/lv_refr.c ****     if(lv_obj_get_style_opa(obj, LV_PART_MAIN) < LV_OPA_MAX) return NULL;
 465:Drivers/lvgl/src/core/lv_refr.c **** 
 466:Drivers/lvgl/src/core/lv_refr.c ****     /*If this object is fully cover the draw area then check the children too*/
 467:Drivers/lvgl/src/core/lv_refr.c ****     lv_cover_check_info_t info;
 468:Drivers/lvgl/src/core/lv_refr.c ****     info.res = LV_COVER_RES_COVER;
 469:Drivers/lvgl/src/core/lv_refr.c ****     info.area = area_p;
 470:Drivers/lvgl/src/core/lv_refr.c ****     lv_obj_send_event(obj, LV_EVENT_COVER_CHECK, &info);
 471:Drivers/lvgl/src/core/lv_refr.c ****     if(info.res == LV_COVER_RES_MASKED) return NULL;
 472:Drivers/lvgl/src/core/lv_refr.c **** 
 473:Drivers/lvgl/src/core/lv_refr.c ****     int32_t i;
