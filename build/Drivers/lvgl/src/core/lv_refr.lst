1157:Drivers/lvgl/src/core/lv_refr.c ****         if(!lv_area_intersect(&inverse_clip_coords_for_obj, &inverse_clip_coords_for_obj, obj_draw_
1158:Drivers/lvgl/src/core/lv_refr.c ****             return LV_RESULT_INVALID;
