1077:Drivers/lvgl/src/core/lv_refr.c **** /**
1078:Drivers/lvgl/src/core/lv_refr.c ****  * Make the refreshing from an object. Draw all its children and the youngers too.
1079:Drivers/lvgl/src/core/lv_refr.c ****  * @param top_p pointer to an objects. Start the drawing from it.
1080:Drivers/lvgl/src/core/lv_refr.c ****  * @param mask_p pointer to an area, the objects will be drawn only here
1081:Drivers/lvgl/src/core/lv_refr.c ****  */
1082:Drivers/lvgl/src/core/lv_refr.c **** static void refr_obj_and_children(lv_layer_t * layer, lv_obj_t * top_obj)
1083:Drivers/lvgl/src/core/lv_refr.c **** {
1084:Drivers/lvgl/src/core/lv_refr.c ****     /*Normally always will be a top_obj (at least the screen)
1085:Drivers/lvgl/src/core/lv_refr.c ****      *but in special cases (e.g. if the screen has alpha) it won't.
1086:Drivers/lvgl/src/core/lv_refr.c ****      *In this case use the screen directly*/
1087:Drivers/lvgl/src/core/lv_refr.c ****     if(top_obj == NULL) top_obj = lv_display_get_screen_active(disp_refr);
1088:Drivers/lvgl/src/core/lv_refr.c ****     if(top_obj == NULL) return;  /*Shouldn't happen*/
1089:Drivers/lvgl/src/core/lv_refr.c **** 
1090:Drivers/lvgl/src/core/lv_refr.c ****     LV_PROFILER_REFR_BEGIN;
1091:Drivers/lvgl/src/core/lv_refr.c ****     /*Draw the 'younger' sibling objects because they can be on top_obj*/
1092:Drivers/lvgl/src/core/lv_refr.c ****     lv_obj_t * parent;
1093:Drivers/lvgl/src/core/lv_refr.c ****     lv_obj_t * border_p = top_obj;
1094:Drivers/lvgl/src/core/lv_refr.c **** 
1095:Drivers/lvgl/src/core/lv_refr.c ****     parent = lv_obj_get_parent(top_obj);
1096:Drivers/lvgl/src/core/lv_refr.c **** 
1097:Drivers/lvgl/src/core/lv_refr.c ****     /*Calculate the recolor before the parent*/
1098:Drivers/lvgl/src/core/lv_refr.c ****     if(parent) {
1099:Drivers/lvgl/src/core/lv_refr.c ****         layer->recolor = lv_obj_get_style_recolor_recursive(parent, LV_PART_MAIN);
1100:Drivers/lvgl/src/core/lv_refr.c ****     }
1101:Drivers/lvgl/src/core/lv_refr.c **** 
1102:Drivers/lvgl/src/core/lv_refr.c ****     /*Refresh the top object and its children*/
1103:Drivers/lvgl/src/core/lv_refr.c ****     lv_obj_refr(layer, top_obj);
1104:Drivers/lvgl/src/core/lv_refr.c **** 
1105:Drivers/lvgl/src/core/lv_refr.c ****     /*Do until not reach the screen*/
1106:Drivers/lvgl/src/core/lv_refr.c ****     while(parent != NULL) {
1107:Drivers/lvgl/src/core/lv_refr.c ****         bool go = false;
1108:Drivers/lvgl/src/core/lv_refr.c ****         uint32_t i;
1109:Drivers/lvgl/src/core/lv_refr.c ****         uint32_t child_cnt = lv_obj_get_child_count(parent);
1110:Drivers/lvgl/src/core/lv_refr.c ****         for(i = 0; i < child_cnt; i++) {
1111:Drivers/lvgl/src/core/lv_refr.c ****             lv_obj_t * child = parent->spec_attr->children[i];
1112:Drivers/lvgl/src/core/lv_refr.c ****             if(!go) {
1113:Drivers/lvgl/src/core/lv_refr.c ****                 if(child == border_p) go = true;
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//cceL6DBR.s 			page 21


1114:Drivers/lvgl/src/core/lv_refr.c ****             }
1115:Drivers/lvgl/src/core/lv_refr.c ****             else {
1116:Drivers/lvgl/src/core/lv_refr.c ****                 /*Refresh the objects*/
1117:Drivers/lvgl/src/core/lv_refr.c ****                 lv_obj_refr(layer, child);
1118:Drivers/lvgl/src/core/lv_refr.c ****             }
1119:Drivers/lvgl/src/core/lv_refr.c ****         }
1120:Drivers/lvgl/src/core/lv_refr.c **** 
1121:Drivers/lvgl/src/core/lv_refr.c ****         /*Call the post draw function of the parents of the to object*/
1122:Drivers/lvgl/src/core/lv_refr.c ****         lv_obj_send_event(parent, LV_EVENT_DRAW_POST_BEGIN, (void *)layer);
1123:Drivers/lvgl/src/core/lv_refr.c ****         lv_obj_send_event(parent, LV_EVENT_DRAW_POST, (void *)layer);
1124:Drivers/lvgl/src/core/lv_refr.c ****         lv_obj_send_event(parent, LV_EVENT_DRAW_POST_END, (void *)layer);
1125:Drivers/lvgl/src/core/lv_refr.c **** 
1126:Drivers/lvgl/src/core/lv_refr.c ****         /*The new border will be the last parents,
1127:Drivers/lvgl/src/core/lv_refr.c ****          *so the 'younger' brothers of parent will be refreshed*/
1128:Drivers/lvgl/src/core/lv_refr.c ****         border_p = parent;
1129:Drivers/lvgl/src/core/lv_refr.c ****         /*Go a level deeper*/
1130:Drivers/lvgl/src/core/lv_refr.c ****         parent = lv_obj_get_parent(parent);
1131:Drivers/lvgl/src/core/lv_refr.c ****     }
1132:Drivers/lvgl/src/core/lv_refr.c ****     LV_PROFILER_REFR_END;
1133:Drivers/lvgl/src/core/lv_refr.c **** }
