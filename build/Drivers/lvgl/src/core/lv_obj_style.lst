 800:Drivers/lvgl/src/core/lv_obj_style.c ****            obj->styles[i].selector == selector) {
 801:Drivers/lvgl/src/core/lv_obj_style.c ****             return (lv_style_t *)obj->styles[i].style;
 802:Drivers/lvgl/src/core/lv_obj_style.c ****         }
