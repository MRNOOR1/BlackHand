 411:Drivers/lvgl/src/core/../misc/lv_style.h **** /**
 412:Drivers/lvgl/src/core/../misc/lv_style.h ****  * Register a new style property for custom usage
 413:Drivers/lvgl/src/core/../misc/lv_style.h ****  * @return a new property ID, or LV_STYLE_PROP_INV if there are no more available.
 414:Drivers/lvgl/src/core/../misc/lv_style.h ****  *
 415:Drivers/lvgl/src/core/../misc/lv_style.h ****  * Example:
 416:Drivers/lvgl/src/core/../misc/lv_style.h ****  * @code
 417:Drivers/lvgl/src/core/../misc/lv_style.h ****  * lv_style_prop_t MY_PROP;
 418:Drivers/lvgl/src/core/../misc/lv_style.h ****  * static inline void lv_style_set_my_prop(lv_style_t * style, lv_color_t value) {
 419:Drivers/lvgl/src/core/../misc/lv_style.h ****  * lv_style_value_t v = {.color = value}; lv_style_set_prop(style, MY_PROP, v); }
 420:Drivers/lvgl/src/core/../misc/lv_style.h ****  *
 421:Drivers/lvgl/src/core/../misc/lv_style.h ****  * ...
 422:Drivers/lvgl/src/core/../misc/lv_style.h ****  * MY_PROP = lv_style_register_prop();
 423:Drivers/lvgl/src/core/../misc/lv_style.h ****  * ...
 424:Drivers/lvgl/src/core/../misc/lv_style.h ****  * lv_style_set_my_prop(&style1, lv_palette_main(LV_PALETTE_RED));
 425:Drivers/lvgl/src/core/../misc/lv_style.h ****  * @endcode
 426:Drivers/lvgl/src/core/../misc/lv_style.h ****  */
 427:Drivers/lvgl/src/core/../misc/lv_style.h **** lv_style_prop_t lv_style_register_prop(uint8_t flag);
 428:Drivers/lvgl/src/core/../misc/lv_style.h **** 
