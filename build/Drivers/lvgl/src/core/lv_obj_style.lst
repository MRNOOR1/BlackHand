 916:Drivers/lvgl/src/core/lv_obj_style.c **** /**
 917:Drivers/lvgl/src/core/lv_obj_style.c ****  * Refresh the style of all children of an object. (Called recursively)
 918:Drivers/lvgl/src/core/lv_obj_style.c ****  * @param style refresh objects only with this
 919:Drivers/lvgl/src/core/lv_obj_style.c ****  * @param obj pointer to an object
 920:Drivers/lvgl/src/core/lv_obj_style.c ****  */
 921:Drivers/lvgl/src/core/lv_obj_style.c **** static void report_style_change_core(void * style, lv_obj_t * obj)
 922:Drivers/lvgl/src/core/lv_obj_style.c **** {
 923:Drivers/lvgl/src/core/lv_obj_style.c ****     uint32_t i;
 924:Drivers/lvgl/src/core/lv_obj_style.c ****     for(i = 0; i < obj->style_cnt; i++) {
 925:Drivers/lvgl/src/core/lv_obj_style.c ****         if(style == NULL || obj->styles[i].style == style) {
 926:Drivers/lvgl/src/core/lv_obj_style.c ****             full_cache_refresh(obj, lv_obj_style_get_selector_part(obj->styles[i].selector));
 927:Drivers/lvgl/src/core/lv_obj_style.c ****             lv_obj_refresh_style(obj, LV_PART_ANY, LV_STYLE_PROP_ANY);
 928:Drivers/lvgl/src/core/lv_obj_style.c ****             break;
 929:Drivers/lvgl/src/core/lv_obj_style.c ****         }
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//ccYugLMm.s 			page 41


 930:Drivers/lvgl/src/core/lv_obj_style.c ****     }
 931:Drivers/lvgl/src/core/lv_obj_style.c **** 
 932:Drivers/lvgl/src/core/lv_obj_style.c ****     uint32_t child_cnt = lv_obj_get_child_count(obj);
 933:Drivers/lvgl/src/core/lv_obj_style.c ****     for(i = 0; i < child_cnt; i++) {
 934:Drivers/lvgl/src/core/lv_obj_style.c ****         report_style_change_core(style, obj->spec_attr->children[i]);
 935:Drivers/lvgl/src/core/lv_obj_style.c ****     }
 936:Drivers/lvgl/src/core/lv_obj_style.c **** }
 937:Drivers/lvgl/src/core/lv_obj_style.c **** 
 938:Drivers/lvgl/src/core/lv_obj_style.c **** /**
 939:Drivers/lvgl/src/core/lv_obj_style.c ****  * Recursively refresh the style of the children. Go deeper until a not NULL style is found
 940:Drivers/lvgl/src/core/lv_obj_style.c ****  * because the NULL styles are inherited from the parent
 941:Drivers/lvgl/src/core/lv_obj_style.c ****  * @param obj pointer to an object
 942:Drivers/lvgl/src/core/lv_obj_style.c ****  */
 943:Drivers/lvgl/src/core/lv_obj_style.c **** static void refresh_children_style(lv_obj_t * obj)
 944:Drivers/lvgl/src/core/lv_obj_style.c **** {
 945:Drivers/lvgl/src/core/lv_obj_style.c ****     uint32_t i;
 946:Drivers/lvgl/src/core/lv_obj_style.c ****     uint32_t child_cnt = lv_obj_get_child_count(obj);
 947:Drivers/lvgl/src/core/lv_obj_style.c ****     for(i = 0; i < child_cnt; i++) {
 948:Drivers/lvgl/src/core/lv_obj_style.c ****         lv_obj_t * child = obj->spec_attr->children[i];
 949:Drivers/lvgl/src/core/lv_obj_style.c ****         lv_obj_invalidate(child);
 950:Drivers/lvgl/src/core/lv_obj_style.c ****         lv_obj_send_event(child, LV_EVENT_STYLE_CHANGED, NULL);
 951:Drivers/lvgl/src/core/lv_obj_style.c ****         lv_obj_invalidate(child);
 952:Drivers/lvgl/src/core/lv_obj_style.c **** 
 953:Drivers/lvgl/src/core/lv_obj_style.c ****         refresh_children_style(child); /*Check children too*/
 954:Drivers/lvgl/src/core/lv_obj_style.c ****     }
 955:Drivers/lvgl/src/core/lv_obj_style.c **** }
 956:Drivers/lvgl/src/core/lv_obj_style.c **** 
 957:Drivers/lvgl/src/core/lv_obj_style.c **** /**
 958:Drivers/lvgl/src/core/lv_obj_style.c ****  * Remove the transition from object's part's property.
 959:Drivers/lvgl/src/core/lv_obj_style.c ****  * - Remove the transition from `lv_obj_style_trans_ll` and free it
 960:Drivers/lvgl/src/core/lv_obj_style.c ****  * - Delete pending transitions
 961:Drivers/lvgl/src/core/lv_obj_style.c ****  * @param obj pointer to an object which transition(s) should be removed
 962:Drivers/lvgl/src/core/lv_obj_style.c ****  * @param part a part of object or 0xFF to remove from all parts
 963:Drivers/lvgl/src/core/lv_obj_style.c ****  * @param prop a property or 0xFF to remove all properties
 964:Drivers/lvgl/src/core/lv_obj_style.c ****  * @param tr_limit delete transitions only "older" than this. `NULL` if not used
 965:Drivers/lvgl/src/core/lv_obj_style.c ****  */
 966:Drivers/lvgl/src/core/lv_obj_style.c **** static bool trans_delete(lv_obj_t * obj, lv_part_t part, lv_style_prop_t prop, trans_t * tr_limit)
 967:Drivers/lvgl/src/core/lv_obj_style.c **** {
 968:Drivers/lvgl/src/core/lv_obj_style.c ****     trans_t * tr;
 969:Drivers/lvgl/src/core/lv_obj_style.c ****     trans_t * tr_prev;
 970:Drivers/lvgl/src/core/lv_obj_style.c ****     bool removed = false;
 971:Drivers/lvgl/src/core/lv_obj_style.c ****     tr = lv_ll_get_tail(style_trans_ll_p);
 972:Drivers/lvgl/src/core/lv_obj_style.c ****     while(tr != NULL) {
 973:Drivers/lvgl/src/core/lv_obj_style.c ****         if(tr == tr_limit) break;
 974:Drivers/lvgl/src/core/lv_obj_style.c **** 
 975:Drivers/lvgl/src/core/lv_obj_style.c ****         /*'tr' might be deleted, so get the next object while 'tr' is valid*/
