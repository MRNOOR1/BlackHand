 253:Drivers/lvgl/src/core/lv_obj.c **** void lv_obj_add_flag(lv_obj_t * obj, lv_obj_flag_t f)
 254:Drivers/lvgl/src/core/lv_obj.c **** {
 255:Drivers/lvgl/src/core/lv_obj.c ****     LV_ASSERT_OBJ(obj, MY_CLASS);
 256:Drivers/lvgl/src/core/lv_obj.c ****     if(lv_obj_has_flag(obj, f)) /*Check if all flags are set*/
 257:Drivers/lvgl/src/core/lv_obj.c ****         return;
 258:Drivers/lvgl/src/core/lv_obj.c **** 
 259:Drivers/lvgl/src/core/lv_obj.c ****     bool was_on_layout = lv_obj_is_layout_positioned(obj);
 260:Drivers/lvgl/src/core/lv_obj.c **** 
 261:Drivers/lvgl/src/core/lv_obj.c ****     /* We must invalidate the area occupied by the object before we hide it as calls to invalidate 
 262:Drivers/lvgl/src/core/lv_obj.c ****     if(f & LV_OBJ_FLAG_HIDDEN) lv_obj_invalidate(obj);
 263:Drivers/lvgl/src/core/lv_obj.c **** 
 264:Drivers/lvgl/src/core/lv_obj.c ****     obj->flags |= f;
 265:Drivers/lvgl/src/core/lv_obj.c **** 
 266:Drivers/lvgl/src/core/lv_obj.c ****     if(f & LV_OBJ_FLAG_HIDDEN) {
 267:Drivers/lvgl/src/core/lv_obj.c ****         if(lv_obj_has_state(obj, LV_STATE_FOCUSED)) {
 268:Drivers/lvgl/src/core/lv_obj.c ****             lv_group_t * group = lv_obj_get_group(obj);
 269:Drivers/lvgl/src/core/lv_obj.c ****             if(group != NULL) {
 270:Drivers/lvgl/src/core/lv_obj.c ****                 lv_group_focus_next(group);
 271:Drivers/lvgl/src/core/lv_obj.c ****                 lv_obj_t * next_obj = lv_group_get_focused(group);
 272:Drivers/lvgl/src/core/lv_obj.c ****                 if(next_obj != NULL) {
 273:Drivers/lvgl/src/core/lv_obj.c ****                     lv_obj_invalidate(next_obj);
 274:Drivers/lvgl/src/core/lv_obj.c ****                 }
 275:Drivers/lvgl/src/core/lv_obj.c ****             }
 276:Drivers/lvgl/src/core/lv_obj.c ****         }
 277:Drivers/lvgl/src/core/lv_obj.c ****     }
 278:Drivers/lvgl/src/core/lv_obj.c **** 
 279:Drivers/lvgl/src/core/lv_obj.c ****     if((was_on_layout != lv_obj_is_layout_positioned(obj)) || (f & (LV_OBJ_FLAG_LAYOUT_1 |  LV_OBJ_
 280:Drivers/lvgl/src/core/lv_obj.c ****         lv_obj_mark_layout_as_dirty(lv_obj_get_parent(obj));
 281:Drivers/lvgl/src/core/lv_obj.c ****         lv_obj_mark_layout_as_dirty(obj);
 282:Drivers/lvgl/src/core/lv_obj.c ****     }
 283:Drivers/lvgl/src/core/lv_obj.c **** 
 284:Drivers/lvgl/src/core/lv_obj.c ****     if(f & LV_OBJ_FLAG_SCROLLABLE) {
 285:Drivers/lvgl/src/core/lv_obj.c ****         lv_area_t hor_area, ver_area;
 286:Drivers/lvgl/src/core/lv_obj.c ****         lv_obj_get_scrollbar_area(obj, &hor_area, &ver_area);
 287:Drivers/lvgl/src/core/lv_obj.c ****         lv_obj_invalidate_area(obj, &hor_area);
 288:Drivers/lvgl/src/core/lv_obj.c ****         lv_obj_invalidate_area(obj, &ver_area);
 289:Drivers/lvgl/src/core/lv_obj.c ****     }
 290:Drivers/lvgl/src/core/lv_obj.c **** }
