 555:Drivers/lvgl/src/core/lv_obj.c **** static void lv_obj_constructor(const lv_obj_class_t * class_p, lv_obj_t * obj)
 556:Drivers/lvgl/src/core/lv_obj.c **** {
 557:Drivers/lvgl/src/core/lv_obj.c ****     LV_UNUSED(class_p);
 558:Drivers/lvgl/src/core/lv_obj.c ****     LV_TRACE_OBJ_CREATE("begin");
 559:Drivers/lvgl/src/core/lv_obj.c **** 
 560:Drivers/lvgl/src/core/lv_obj.c ****     lv_obj_t * parent = obj->parent;
 561:Drivers/lvgl/src/core/lv_obj.c ****     if(parent) {
 562:Drivers/lvgl/src/core/lv_obj.c ****         int32_t sl = lv_obj_get_scroll_left(parent);
 563:Drivers/lvgl/src/core/lv_obj.c ****         int32_t st = lv_obj_get_scroll_top(parent);
 564:Drivers/lvgl/src/core/lv_obj.c **** 
 565:Drivers/lvgl/src/core/lv_obj.c ****         obj->coords.y1 = parent->coords.y1 + lv_obj_get_style_pad_top(parent, LV_PART_MAIN) - st;
 566:Drivers/lvgl/src/core/lv_obj.c ****         obj->coords.y2 = obj->coords.y1 - 1;
 567:Drivers/lvgl/src/core/lv_obj.c ****         obj->coords.x1  = parent->coords.x1 + lv_obj_get_style_pad_left(parent, LV_PART_MAIN) - sl;
 568:Drivers/lvgl/src/core/lv_obj.c ****         obj->coords.x2  = obj->coords.x1 - 1;
 569:Drivers/lvgl/src/core/lv_obj.c ****     }
 570:Drivers/lvgl/src/core/lv_obj.c **** 
 571:Drivers/lvgl/src/core/lv_obj.c ****     /*Set attributes*/
 572:Drivers/lvgl/src/core/lv_obj.c ****     obj->flags = LV_OBJ_FLAG_CLICKABLE;
 573:Drivers/lvgl/src/core/lv_obj.c ****     obj->flags |= LV_OBJ_FLAG_SNAPPABLE;
 574:Drivers/lvgl/src/core/lv_obj.c ****     if(parent) obj->flags |= LV_OBJ_FLAG_PRESS_LOCK;
 575:Drivers/lvgl/src/core/lv_obj.c ****     if(parent) obj->flags |= LV_OBJ_FLAG_SCROLL_CHAIN;
 576:Drivers/lvgl/src/core/lv_obj.c ****     obj->flags |= LV_OBJ_FLAG_CLICK_FOCUSABLE;
 577:Drivers/lvgl/src/core/lv_obj.c ****     obj->flags |= LV_OBJ_FLAG_SCROLLABLE;
