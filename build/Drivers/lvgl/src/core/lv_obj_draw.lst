 339:Drivers/lvgl/src/core/lv_obj_draw.c **** int32_t lv_obj_calculate_ext_draw_size(lv_obj_t * obj, lv_part_t part)
 340:Drivers/lvgl/src/core/lv_obj_draw.c **** {
 341:Drivers/lvgl/src/core/lv_obj_draw.c ****     LV_PROFILER_DRAW_BEGIN;
 342:Drivers/lvgl/src/core/lv_obj_draw.c ****     int32_t s = 0;
 343:Drivers/lvgl/src/core/lv_obj_draw.c **** 
 344:Drivers/lvgl/src/core/lv_obj_draw.c ****     int32_t sh_width = lv_obj_get_style_shadow_width(obj, part);
 345:Drivers/lvgl/src/core/lv_obj_draw.c ****     if(sh_width) {
 346:Drivers/lvgl/src/core/lv_obj_draw.c ****         lv_opa_t sh_opa = lv_obj_get_style_shadow_opa(obj, part);
 347:Drivers/lvgl/src/core/lv_obj_draw.c ****         if(sh_opa > LV_OPA_MIN) {
 348:Drivers/lvgl/src/core/lv_obj_draw.c ****             sh_width = sh_width / 2 + 1;    /*The blur adds only half width*/
 349:Drivers/lvgl/src/core/lv_obj_draw.c ****             sh_width += lv_obj_get_style_shadow_spread(obj, part);
 350:Drivers/lvgl/src/core/lv_obj_draw.c ****             int32_t sh_ofs_x = lv_obj_get_style_shadow_offset_x(obj, part);
 351:Drivers/lvgl/src/core/lv_obj_draw.c ****             int32_t sh_ofs_y = lv_obj_get_style_shadow_offset_y(obj, part);
 352:Drivers/lvgl/src/core/lv_obj_draw.c ****             sh_width += LV_MAX(LV_ABS(sh_ofs_x), LV_ABS(sh_ofs_y));
 353:Drivers/lvgl/src/core/lv_obj_draw.c ****             s = LV_MAX(s, sh_width);
 354:Drivers/lvgl/src/core/lv_obj_draw.c ****         }
 355:Drivers/lvgl/src/core/lv_obj_draw.c ****     }
 356:Drivers/lvgl/src/core/lv_obj_draw.c **** 
 357:Drivers/lvgl/src/core/lv_obj_draw.c ****     int32_t outline_width = lv_obj_get_style_outline_width(obj, part);
 358:Drivers/lvgl/src/core/lv_obj_draw.c ****     if(outline_width) {
 359:Drivers/lvgl/src/core/lv_obj_draw.c ****         lv_opa_t outline_opa = lv_obj_get_style_outline_opa(obj, part);
 360:Drivers/lvgl/src/core/lv_obj_draw.c ****         if(outline_opa > LV_OPA_MIN) {
 361:Drivers/lvgl/src/core/lv_obj_draw.c ****             int32_t outline_pad = lv_obj_get_style_outline_pad(obj, part);
 362:Drivers/lvgl/src/core/lv_obj_draw.c ****             s = LV_MAX(s, outline_pad + outline_width);
 363:Drivers/lvgl/src/core/lv_obj_draw.c ****         }
 364:Drivers/lvgl/src/core/lv_obj_draw.c ****     }
 365:Drivers/lvgl/src/core/lv_obj_draw.c **** 
 366:Drivers/lvgl/src/core/lv_obj_draw.c ****     int32_t w = lv_obj_get_style_transform_width(obj, part);
 367:Drivers/lvgl/src/core/lv_obj_draw.c ****     int32_t h = lv_obj_get_style_transform_height(obj, part);
 368:Drivers/lvgl/src/core/lv_obj_draw.c ****     int32_t wh = LV_MAX(w, h);
 369:Drivers/lvgl/src/core/lv_obj_draw.c ****     if(wh > 0) s += wh;
 370:Drivers/lvgl/src/core/lv_obj_draw.c **** 
 371:Drivers/lvgl/src/core/lv_obj_draw.c ****     LV_PROFILER_DRAW_END;
 372:Drivers/lvgl/src/core/lv_obj_draw.c ****     return s;
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//cckZJDG0.s 			page 8


 373:Drivers/lvgl/src/core/lv_obj_draw.c **** }
