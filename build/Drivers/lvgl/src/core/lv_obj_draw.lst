 375:Drivers/lvgl/src/core/lv_obj_draw.c **** void lv_obj_refresh_ext_draw_size(lv_obj_t * obj)
 376:Drivers/lvgl/src/core/lv_obj_draw.c **** {
 377:Drivers/lvgl/src/core/lv_obj_draw.c ****     LV_PROFILER_DRAW_BEGIN;
 378:Drivers/lvgl/src/core/lv_obj_draw.c ****     LV_ASSERT_OBJ(obj, MY_CLASS);
 379:Drivers/lvgl/src/core/lv_obj_draw.c **** 
 380:Drivers/lvgl/src/core/lv_obj_draw.c ****     int32_t s_old = lv_obj_get_ext_draw_size(obj);
 381:Drivers/lvgl/src/core/lv_obj_draw.c ****     int32_t s_new = 0;
 382:Drivers/lvgl/src/core/lv_obj_draw.c ****     lv_obj_send_event(obj, LV_EVENT_REFR_EXT_DRAW_SIZE, &s_new);
 383:Drivers/lvgl/src/core/lv_obj_draw.c **** 
 384:Drivers/lvgl/src/core/lv_obj_draw.c ****     /*Store the result if the special attrs already allocated*/
 385:Drivers/lvgl/src/core/lv_obj_draw.c ****     if(obj->spec_attr) {
 386:Drivers/lvgl/src/core/lv_obj_draw.c ****         obj->spec_attr->ext_draw_size = s_new;
 387:Drivers/lvgl/src/core/lv_obj_draw.c ****     }
 388:Drivers/lvgl/src/core/lv_obj_draw.c ****     /*Allocate spec. attrs. only if the result is not zero.
 389:Drivers/lvgl/src/core/lv_obj_draw.c ****      *Zero is the default value if the spec. attr. are not defined.*/
 390:Drivers/lvgl/src/core/lv_obj_draw.c ****     else if(s_new != 0) {
 391:Drivers/lvgl/src/core/lv_obj_draw.c ****         lv_obj_allocate_spec_attr(obj);
 392:Drivers/lvgl/src/core/lv_obj_draw.c ****         obj->spec_attr->ext_draw_size = s_new;
 393:Drivers/lvgl/src/core/lv_obj_draw.c ****     }
 394:Drivers/lvgl/src/core/lv_obj_draw.c **** 
 395:Drivers/lvgl/src/core/lv_obj_draw.c ****     if(s_new != s_old) lv_obj_invalidate(obj);
 396:Drivers/lvgl/src/core/lv_obj_draw.c ****     LV_PROFILER_DRAW_END;
 397:Drivers/lvgl/src/core/lv_obj_draw.c **** }
