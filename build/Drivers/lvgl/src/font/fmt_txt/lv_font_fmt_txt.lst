 506:Drivers/lvgl/src/font/fmt_txt/lv_font_fmt_txt.c ****     uint8_t bit_mask;
 507:Drivers/lvgl/src/font/fmt_txt/lv_font_fmt_txt.c ****     switch(len) {
 508:Drivers/lvgl/src/font/fmt_txt/lv_font_fmt_txt.c ****         case 1:
