 516:Drivers/lvgl/src/font/fmt_txt/lv_font_fmt_txt.c ****             break;
 517:Drivers/lvgl/src/font/fmt_txt/lv_font_fmt_txt.c ****         case 4:
 518:Drivers/lvgl/src/font/fmt_txt/lv_font_fmt_txt.c ****             bit_mask = 0xF;
 519:Drivers/lvgl/src/font/fmt_txt/lv_font_fmt_txt.c ****             break;
 520:Drivers/lvgl/src/font/fmt_txt/lv_font_fmt_txt.c ****         case 8:
 521:Drivers/lvgl/src/font/fmt_txt/lv_font_fmt_txt.c ****             bit_mask = 0xFF;
 522:Drivers/lvgl/src/font/fmt_txt/lv_font_fmt_txt.c ****             break;
 523:Drivers/lvgl/src/font/fmt_txt/lv_font_fmt_txt.c ****         default:
