 141:Drivers/lvgl/src/draw/../misc/lv_text_private.h **** /**
 142:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****  * Test if char is break char or not (a text can broken here or not)
 143:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****  * @param letter a letter
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//ccoFZlXa.s 			page 4


 144:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****  * @return false: 'letter' is not break char
 145:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****  */
 146:Drivers/lvgl/src/draw/../misc/lv_text_private.h **** static inline bool lv_text_is_break_char(uint32_t letter)
 147:Drivers/lvgl/src/draw/../misc/lv_text_private.h **** {
 148:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****     uint8_t i;
 149:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****     bool ret = false;
 150:Drivers/lvgl/src/draw/../misc/lv_text_private.h **** 
 151:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****     /*Compare the letter to TXT_BREAK_CHARS*/
 152:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****     for(i = 0; LV_TXT_BREAK_CHARS[i] != '\0'; i++) {
 153:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****         if(letter == (uint32_t)LV_TXT_BREAK_CHARS[i]) {
 154:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****             ret = true; /*If match then it is break char*/
 155:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****             break;
 156:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****         }
 157:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****     }
 158:Drivers/lvgl/src/draw/../misc/lv_text_private.h **** 
 159:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****     return ret;
 160:Drivers/lvgl/src/draw/../misc/lv_text_private.h **** }
 161:Drivers/lvgl/src/draw/../misc/lv_text_private.h **** 
 162:Drivers/lvgl/src/draw/../misc/lv_text_private.h **** /**
 163:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****  * Test if char is break char or not (a text can broken here or not)
 164:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****  * @param letter a letter
 165:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****  * @return false: 'letter' is not break char
 166:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****  */
 167:Drivers/lvgl/src/draw/../misc/lv_text_private.h **** static inline bool lv_text_is_a_word(uint32_t letter)
 168:Drivers/lvgl/src/draw/../misc/lv_text_private.h **** {
 169:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****     /*Cheap check on invalid letter*/
 170:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****     if(letter == 0) return false;
 171:Drivers/lvgl/src/draw/../misc/lv_text_private.h **** 
 172:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****     /*CJK Unified Ideographs*/
 173:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****     if(letter >= 0x4E00 && letter <= 0x9FFF) {
 174:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****         return true;
 175:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****     }
 176:Drivers/lvgl/src/draw/../misc/lv_text_private.h **** 
 177:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****     /*Fullwidth ASCII variants*/
 178:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****     if(letter >= 0xFF01 && letter <= 0xFF5E) {
 179:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****         return true;
 180:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****     }
 181:Drivers/lvgl/src/draw/../misc/lv_text_private.h **** 
 182:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****     /*CJK symbols and punctuation*/
 183:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****     if(letter >= 0x3000 && letter <= 0x303F) {
 184:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****         return true;
 185:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****     }
 186:Drivers/lvgl/src/draw/../misc/lv_text_private.h **** 
 187:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****     /*CJK Radicals Supplement*/
 188:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****     if(letter >= 0x2E80 && letter <= 0x2EFF) {
 189:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****         return true;
 190:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****     }
 191:Drivers/lvgl/src/draw/../misc/lv_text_private.h **** 
 192:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****     /*CJK Strokes*/
 193:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****     if(letter >= 0x31C0 && letter <= 0x31EF) {
 194:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****         return true;
 195:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****     }
 196:Drivers/lvgl/src/draw/../misc/lv_text_private.h **** 
 197:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****     /*Hiragana and Katakana*/
 198:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****     if(letter >= 0x3040 && letter <= 0x30FF) {
 199:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****         return true;
 200:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****     }
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//ccoFZlXa.s 			page 5


 201:Drivers/lvgl/src/draw/../misc/lv_text_private.h **** 
 202:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****     /*Chinese Vertical Forms*/
 203:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****     if(letter >= 0xFE10 && letter <= 0xFE1F) {
 204:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****         return true;
 205:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****     }
 206:Drivers/lvgl/src/draw/../misc/lv_text_private.h **** 
 207:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****     /*CJK Compatibility Forms*/
 208:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****     if(letter >= 0xFE30 && letter <= 0xFE4F) {
 209:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****         return true;
 210:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****     }
 211:Drivers/lvgl/src/draw/../misc/lv_text_private.h **** 
 212:Drivers/lvgl/src/draw/../misc/lv_text_private.h ****     return false;
 213:Drivers/lvgl/src/draw/../misc/lv_text_private.h **** }
