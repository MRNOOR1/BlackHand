 328:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c **** 
 329:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     /*If not cached use the free entry with lowest life*/
 330:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     lv_draw_sw_mask_radius_circle_dsc_t * entry = NULL;
 331:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     for(i = 0; i < LV_DRAW_SW_CIRCLE_CACHE_SIZE; i++) {
 332:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         if(_circle_cache[i].used_cnt == 0) {
 333:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****             if(!entry) entry = &(_circle_cache[i]);
 334:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****             else if(_circle_cache[i].life < entry->life) entry = &(_circle_cache[i]);
 335:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         }
