 340:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         entry = lv_malloc_zeroed(sizeof(lv_draw_sw_mask_radius_circle_dsc_t));
 341:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         LV_ASSERT_MALLOC(entry);
 342:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         entry->life = -1;
 343:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     }
 344:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     else {
 345:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         entry->used_cnt++;
 346:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         entry->life = 0;
 347:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         CIRCLE_CACHE_AGING(entry->life, radius);
 348:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     }
 349:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c **** 
 350:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     param->circle = entry;
 351:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c **** 
