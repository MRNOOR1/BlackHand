 581:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     x_at_y = (int32_t)((int32_t)p->xy_steep * (abs_y)) >> 10;
 582:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     if(x_at_y > abs_x + len) {
 583:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         if(p->inv) {
 584:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****             return LV_DRAW_SW_MASK_RES_TRANSP;
 585:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         }
 586:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         else {
 587:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****             return LV_DRAW_SW_MASK_RES_FULL_COVER;
 588:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         }
 589:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     }
 590:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c **** 
 591:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     /*X start*/
 592:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     int32_t xs = ((abs_y * 256) * p->xy_steep) >> 10;
 593:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     int32_t xsi = xs >> 8;
 594:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     int32_t xsf = xs & 0xFF;
