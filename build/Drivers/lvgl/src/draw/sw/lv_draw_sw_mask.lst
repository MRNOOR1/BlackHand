 605:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         xsf = 0xFF;
 606:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         xsi = xei;
 607:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         k--;
 608:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     }
 609:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c **** 
 610:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     if(xsi == xei) {
 611:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         if(k >= 0 && k < len) {
 612:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****             m = (xsf + xef) >> 1;
 613:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****             if(p->inv) m = 255 - m;
 614:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****             mask_buf[k] = mask_mix(mask_buf[k], m);
 615:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         }
 616:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         k++;
 617:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c **** 
 618:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         if(p->inv) {
 619:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****             k = xsi - abs_x;
