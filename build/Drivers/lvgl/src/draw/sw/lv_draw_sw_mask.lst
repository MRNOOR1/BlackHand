1176:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     /*The point on the 1/8 circle is special, calculate it manually*/
1177:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     int32_t mid = radius * 723;
1178:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     int32_t mid_int = mid >> 10;
1179:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     if(cir_x[cir_size - 1] != mid_int || cir_y[cir_size - 1] != mid_int) {
1180:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         int32_t tmp_val = mid - (mid_int << 10);
1181:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         if(tmp_val <= 512) {
1182:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****             tmp_val = tmp_val * tmp_val * 2;
1183:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****             tmp_val = tmp_val >> (10 + 6);
1184:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         }
1185:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         else {
1186:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****             tmp_val = 1024 - tmp_val;
1187:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****             tmp_val = tmp_val * tmp_val * 2;
1188:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****             tmp_val = tmp_val >> (10 + 6);
1189:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****             tmp_val = 15 - tmp_val;
1190:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         }
1191:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c **** 
1192:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         cir_x[cir_size] = mid_int;
1193:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         cir_y[cir_size] = mid_int;
1194:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         c->cir_opa[cir_size] = tmp_val;
1195:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         c->cir_opa[cir_size] *= 16;
1196:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         cir_size++;
1197:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     }
1198:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c **** 
1199:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     /*Build the second octet by mirroring the first*/
1200:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     for(i = cir_size - 2; i >= 0; i--, cir_size++) {
1201:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         cir_x[cir_size] = cir_y[i];
1202:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         cir_y[cir_size] = cir_x[i];
1203:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         c->cir_opa[cir_size] = c->cir_opa[i];
1204:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     }
