 236:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     p2y = (lv_trigo_sin(angle) >> 5) + py;
 237:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c **** 
 238:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     lv_draw_sw_mask_line_points_init(param, p1x, py, p2x, p2y, side);
 239:Drivers/lvgl/src/draw/sw/lv_draw_sw_mask.c **** }
