 121:Drivers/lvgl/src/draw/sw/blend/lv_draw_sw_blend_to_argb8888_premultiplied.c **** /**
 122:Drivers/lvgl/src/draw/sw/blend/lv_draw_sw_blend_to_argb8888_premultiplied.c ****  * @brief Blend a solid color into an ARGB8888 premultiplied buffer.
 123:Drivers/lvgl/src/draw/sw/blend/lv_draw_sw_blend_to_argb8888_premultiplied.c ****  *
 124:Drivers/lvgl/src/draw/sw/blend/lv_draw_sw_blend_to_argb8888_premultiplied.c ****  * This function applies a solid color to the destination buffer with optional
 125:Drivers/lvgl/src/draw/sw/blend/lv_draw_sw_blend_to_argb8888_premultiplied.c ****  * opacity and masking. The input color is first converted to a premultiplied
 126:Drivers/lvgl/src/draw/sw/blend/lv_draw_sw_blend_to_argb8888_premultiplied.c ****  * alpha format before blending.
 127:Drivers/lvgl/src/draw/sw/blend/lv_draw_sw_blend_to_argb8888_premultiplied.c ****  *
 128:Drivers/lvgl/src/draw/sw/blend/lv_draw_sw_blend_to_argb8888_premultiplied.c ****  * @param dsc Blending descriptor containing destination buffer, color, and opacity
 129:Drivers/lvgl/src/draw/sw/blend/lv_draw_sw_blend_to_argb8888_premultiplied.c ****  */
 130:Drivers/lvgl/src/draw/sw/blend/lv_draw_sw_blend_to_argb8888_premultiplied.c **** void LV_ATTRIBUTE_FAST_MEM lv_draw_sw_blend_color_to_argb8888_premultiplied(lv_draw_sw_blend_fill_d
 131:Drivers/lvgl/src/draw/sw/blend/lv_draw_sw_blend_to_argb8888_premultiplied.c **** {
