 332:Drivers/lvgl/src/draw/sw/blend/../../../misc/../font/../draw/../misc/lv_color.h ****  * Check if a color with an RGB888 color is within the color range defined by l_color and h_color.
 333:Drivers/lvgl/src/draw/sw/blend/../../../misc/../font/../draw/../misc/lv_color.h ****  * @param color   the color to check
 334:Drivers/lvgl/src/draw/sw/blend/../../../misc/../font/../draw/../misc/lv_color.h ****  * @param l_color the lower bound color
 335:Drivers/lvgl/src/draw/sw/blend/../../../misc/../font/../draw/../misc/lv_color.h ****  * @param h_color the upper bound color
 336:Drivers/lvgl/src/draw/sw/blend/../../../misc/../font/../draw/../misc/lv_color.h ****  * @return        true: pixel is within the color range
 337:Drivers/lvgl/src/draw/sw/blend/../../../misc/../font/../draw/../misc/lv_color.h ****  */
 338:Drivers/lvgl/src/draw/sw/blend/../../../misc/../font/../draw/../misc/lv_color.h **** static inline bool lv_color_is_in_range(lv_color_t color, lv_color_t l_color, lv_color_t h_color)
 339:Drivers/lvgl/src/draw/sw/blend/../../../misc/../font/../draw/../misc/lv_color.h **** {
 340:Drivers/lvgl/src/draw/sw/blend/../../../misc/../font/../draw/../misc/lv_color.h ****     return (color.red <= h_color.red &&
 341:Drivers/lvgl/src/draw/sw/blend/../../../misc/../font/../draw/../misc/lv_color.h ****             color.green <= h_color.green &&
 342:Drivers/lvgl/src/draw/sw/blend/../../../misc/../font/../draw/../misc/lv_color.h ****             color.blue <= h_color.blue &&
 343:Drivers/lvgl/src/draw/sw/blend/../../../misc/../font/../draw/../misc/lv_color.h ****             color.red >= l_color.red &&
 344:Drivers/lvgl/src/draw/sw/blend/../../../misc/../font/../draw/../misc/lv_color.h ****             color.green >= l_color.green &&
 345:Drivers/lvgl/src/draw/sw/blend/../../../misc/../font/../draw/../misc/lv_color.h ****             color.blue >= l_color.blue);
 346:Drivers/lvgl/src/draw/sw/blend/../../../misc/../font/../draw/../misc/lv_color.h **** }
 347:Drivers/lvgl/src/draw/sw/blend/../../../misc/../font/../draw/../misc/lv_color.h **** 
