  38:Drivers/lvgl/src/draw/sw/blend/../../../misc/../stdlib/lv_string.h ****  */
  39:Drivers/lvgl/src/draw/sw/blend/../../../misc/../stdlib/lv_string.h **** void * lv_memcpy(void * dst, const void * src, size_t len);
  40:Drivers/lvgl/src/draw/sw/blend/../../../misc/../stdlib/lv_string.h **** 
  41:Drivers/lvgl/src/draw/sw/blend/../../../misc/../stdlib/lv_string.h **** /**
  42:Drivers/lvgl/src/draw/sw/blend/../../../misc/../stdlib/lv_string.h ****  * @brief Fills a block of memory with a specified value.
  43:Drivers/lvgl/src/draw/sw/blend/../../../misc/../stdlib/lv_string.h ****  * @param dst Pointer to the destination array to fill with the specified value.
  44:Drivers/lvgl/src/draw/sw/blend/../../../misc/../stdlib/lv_string.h ****  * @param v Value to be set. The value is passed as an int, but the function fills
  45:Drivers/lvgl/src/draw/sw/blend/../../../misc/../stdlib/lv_string.h ****  *          the block of memory using the unsigned char conversion of this value.
  46:Drivers/lvgl/src/draw/sw/blend/../../../misc/../stdlib/lv_string.h ****  * @param len Number of bytes to be set to the value.
  47:Drivers/lvgl/src/draw/sw/blend/../../../misc/../stdlib/lv_string.h ****  */
  48:Drivers/lvgl/src/draw/sw/blend/../../../misc/../stdlib/lv_string.h **** void lv_memset(void * dst, uint8_t v, size_t len);
  49:Drivers/lvgl/src/draw/sw/blend/../../../misc/../stdlib/lv_string.h **** 
  50:Drivers/lvgl/src/draw/sw/blend/../../../misc/../stdlib/lv_string.h **** /**
  51:Drivers/lvgl/src/draw/sw/blend/../../../misc/../stdlib/lv_string.h ****  * @brief Move a block of memory from source to destination
  52:Drivers/lvgl/src/draw/sw/blend/../../../misc/../stdlib/lv_string.h ****  * @param dst Pointer to the destination array where the content is to be copied.
  53:Drivers/lvgl/src/draw/sw/blend/../../../misc/../stdlib/lv_string.h ****  * @param src Pointer to the source of data to be copied.
