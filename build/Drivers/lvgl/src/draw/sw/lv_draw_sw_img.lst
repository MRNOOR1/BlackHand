  57:Drivers/lvgl/src/draw/sw/blend/../../../misc/../stdlib/lv_string.h **** void * lv_memmove(void * dst, const void * src, size_t len);
  58:Drivers/lvgl/src/draw/sw/blend/../../../misc/../stdlib/lv_string.h **** 
  59:Drivers/lvgl/src/draw/sw/blend/../../../misc/../stdlib/lv_string.h **** /**
  60:Drivers/lvgl/src/draw/sw/blend/../../../misc/../stdlib/lv_string.h ****  * @brief This function will compare two memory blocks
