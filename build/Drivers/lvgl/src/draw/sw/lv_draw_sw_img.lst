  66:Drivers/lvgl/src/draw/sw/blend/../../../misc/../stdlib/lv_string.h **** int lv_memcmp(const void * p1, const void * p2, size_t len);
  67:Drivers/lvgl/src/draw/sw/blend/../../../misc/../stdlib/lv_string.h **** 
  68:Drivers/lvgl/src/draw/sw/blend/../../../misc/../stdlib/lv_string.h **** /**
  69:Drivers/lvgl/src/draw/sw/blend/../../../misc/../stdlib/lv_string.h ****  * Same as `memset(dst, 0x00, len)`.
  70:Drivers/lvgl/src/draw/sw/blend/../../../misc/../stdlib/lv_string.h ****  * @param dst pointer to the destination buffer
