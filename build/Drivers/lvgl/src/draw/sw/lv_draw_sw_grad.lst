 125:Drivers/lvgl/src/draw/sw/lv_draw_sw_grad.c **** {
 126:Drivers/lvgl/src/draw/sw/lv_draw_sw_grad.c ****     if(extend == LV_GRAD_EXTEND_PAD) {                  /**< Repeat the same color*/
