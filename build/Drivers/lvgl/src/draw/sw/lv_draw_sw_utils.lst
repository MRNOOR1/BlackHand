 198:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c **** 
 199:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     /*Make the buffer aligned*/
 200:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     while(((uintptr_t)(byte_buf) & (sizeof(int) - 1)) && buf_size > 0) {
