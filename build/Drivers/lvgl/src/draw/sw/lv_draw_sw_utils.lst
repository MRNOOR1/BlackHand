 202:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****         byte_buf++;
 203:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****         buf_size--;
 204:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     }
 205:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c **** 
 206:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     if(buf_size >= sizeof(uint32_t)) {
 207:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****         uint32_t * aligned_addr = (uint32_t *)byte_buf;
 208:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****         uint32_t word_count = buf_size / 4;
 209:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c **** 
