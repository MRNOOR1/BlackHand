 212:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****         }
 213:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c **** 
 214:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****         byte_buf = (uint8_t *)(aligned_addr + word_count);
 215:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****         buf_size = buf_size % sizeof(uint32_t);
 216:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     }
 217:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c **** 
 218:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     for(i = 0; i < buf_size; ++i) {
