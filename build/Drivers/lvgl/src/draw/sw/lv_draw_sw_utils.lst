 223:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c **** void lv_draw_sw_i1_convert_to_vtiled(const void * buf, uint32_t buf_size, uint32_t width, uint32_t 
 224:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****                                      void * out_buf,
 225:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****                                      uint32_t out_buf_size, bool bit_order_lsb)
 226:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c **** {
 227:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     LV_ASSERT(buf && out_buf);
 228:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     LV_ASSERT(width % 8 == 0 && height % 8 == 0);
 229:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     LV_ASSERT(buf_size >= (width / 8) * height);
 230:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     LV_ASSERT(out_buf_size >= buf_size);
 231:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c **** 
 232:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     lv_memset(out_buf, 0, out_buf_size);
 233:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c **** 
 234:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     const uint8_t * src_buf = (uint8_t *)buf;
 235:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     uint8_t * dst_buf = (uint8_t *)out_buf;
 236:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c **** 
 237:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     for(uint32_t y = 0; y < height; y++) {
 238:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****         for(uint32_t x = 0; x < width; x++) {
 239:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****             uint32_t src_index = y * width + x;
 240:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****             uint32_t dst_index = x * height + y;
 241:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****             uint8_t bit = (src_buf[src_index / 8] >> (7 - (src_index % 8))) & 0x01;
 242:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****             if(bit_order_lsb) {
 243:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****                 dst_buf[dst_index / 8] |= (bit << (dst_index % 8));
 244:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****             }
 245:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****             else {
 246:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****                 dst_buf[dst_index / 8] |= (bit << (7 - (dst_index % 8)));
 247:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****             }
 248:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****         }
 249:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     }
 250:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c **** }
