 129:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c **** void lv_draw_sw_i1_to_argb8888(const void * buf_i1, void * buf_argb8888, uint32_t width, uint32_t h
 130:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****                                uint32_t buf_i1_stride, uint32_t buf_argb8888_stride, uint32_t index
 131:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c **** {
 132:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     /*Extract the bits of I1 px_map and convert them to ARGB8888*/
 133:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     const uint8_t * src = buf_i1;
 134:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     uint32_t * dst = buf_argb8888;
 135:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     uint32_t i1_row_byte_count = width / 8;
 136:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     for(uint32_t row = 0; row < height; row++) {
 137:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****         uint32_t * dst_p = dst;
 138:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****         for(uint32_t i = 0; i < i1_row_byte_count; i++) {
 139:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****             /*From MSB to LSB (pixel 0 to pixel 7 in a byte)*/
 140:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****             for(int32_t bit = 7; bit >= 0; bit--) {
 141:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****                 *dst_p++ = ((src[i] >> bit) & 1) ? index1_color : index0_color;
 142:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****             }
 143:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****         }
 144:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****         src += buf_i1_stride;
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//cc6QIpZo.s 			page 4


 145:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****         dst += buf_argb8888_stride / 4;
 146:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     }
 147:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c **** }
 148:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c **** 
 149:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c **** void lv_draw_sw_rgb565_swap(void * buf, uint32_t buf_size_px)
 150:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c **** {
 151:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     if(LV_DRAW_SW_RGB565_SWAP(buf, buf_size_px) == LV_RESULT_OK) return;
 152:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c **** 
 153:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     uint16_t * buf16 = buf;
 154:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c **** 
 155:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     /*2 pixels will be processed later, so handle 1 pixel alignment*/
 156:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     if((lv_uintptr_t)buf16 & 0x2) {
 157:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****         buf16[0] = ((buf16[0] & 0xff00) >> 8) | ((buf16[0] & 0x00ff) << 8);
 158:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****         buf16++;
 159:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****         buf_size_px--;
 160:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     }
 161:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c **** 
 162:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     uint32_t * buf32 = (uint32_t *)buf16;
 163:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     uint32_t u32_cnt = buf_size_px / 2;
 164:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c **** 
 165:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     while(u32_cnt >= 8) {
 166:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****         buf32[0] = ((buf32[0] & 0xff00ff00) >> 8) | ((buf32[0] & 0x00ff00ff) << 8);
 167:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****         buf32[1] = ((buf32[1] & 0xff00ff00) >> 8) | ((buf32[1] & 0x00ff00ff) << 8);
 168:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****         buf32[2] = ((buf32[2] & 0xff00ff00) >> 8) | ((buf32[2] & 0x00ff00ff) << 8);
 169:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****         buf32[3] = ((buf32[3] & 0xff00ff00) >> 8) | ((buf32[3] & 0x00ff00ff) << 8);
 170:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****         buf32[4] = ((buf32[4] & 0xff00ff00) >> 8) | ((buf32[4] & 0x00ff00ff) << 8);
 171:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****         buf32[5] = ((buf32[5] & 0xff00ff00) >> 8) | ((buf32[5] & 0x00ff00ff) << 8);
 172:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****         buf32[6] = ((buf32[6] & 0xff00ff00) >> 8) | ((buf32[6] & 0x00ff00ff) << 8);
 173:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****         buf32[7] = ((buf32[7] & 0xff00ff00) >> 8) | ((buf32[7] & 0x00ff00ff) << 8);
 174:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****         buf32 += 8;
 175:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****         u32_cnt -= 8;
 176:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     }
 177:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c **** 
 178:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     while(u32_cnt) {
 179:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****         *buf32 = ((*buf32 & 0xff00ff00) >> 8) | ((*buf32 & 0x00ff00ff) << 8);
 180:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****         buf32++;
 181:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****         u32_cnt--;
 182:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     }
 183:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c **** 
 184:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     /*Process the last pixel if needed*/
 185:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     if(buf_size_px & 0x1) {
 186:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****         uint32_t e = buf_size_px - 1;
 187:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****         buf16[e] = ((buf16[e] & 0xff00) >> 8) | ((buf16[e] & 0x00ff) << 8);
 188:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     }
 189:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c **** 
 190:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c **** }
 191:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c **** 
 192:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c **** void lv_draw_sw_i1_invert(void * buf, uint32_t buf_size)
 193:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c **** {
 194:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     if(buf == NULL) return;
 195:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c **** 
 196:Drivers/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     uint8_t * byte_buf = (uint8_t *)buf;
