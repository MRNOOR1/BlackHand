  67:Drivers/lvgl/src/draw/sw/lv_draw_sw_blur.c ****     /*On larger radius skip some pixels as the result is a blob anyways, so not all pixels matter
  68:Drivers/lvgl/src/draw/sw/lv_draw_sw_blur.c ****      *This only every 2nd or 3rd px will be blurred, the result will be stored in the layers buffer
  69:Drivers/lvgl/src/draw/sw/lv_draw_sw_blur.c ****      *and finally the missing pixels are set to nearest blurred pixel. We loose precision but it lo
  70:Drivers/lvgl/src/draw/sw/lv_draw_sw_blur.c ****      *and and it's very fast.
  71:Drivers/lvgl/src/draw/sw/lv_draw_sw_blur.c ****      */
  72:Drivers/lvgl/src/draw/sw/lv_draw_sw_blur.c ****     int32_t skip_cnt = 1;
  73:Drivers/lvgl/src/draw/sw/lv_draw_sw_blur.c ****     if(dsc->quality == LV_BLUR_QUALITY_AUTO) {
  74:Drivers/lvgl/src/draw/sw/lv_draw_sw_blur.c ****         if(blur_radius >= 32 && dsc->corner_radius == 0) skip_cnt = 3;
  75:Drivers/lvgl/src/draw/sw/lv_draw_sw_blur.c ****         else if(blur_radius >= 8) skip_cnt = 2;
  76:Drivers/lvgl/src/draw/sw/lv_draw_sw_blur.c ****     }
  77:Drivers/lvgl/src/draw/sw/lv_draw_sw_blur.c ****     else if(dsc->quality == LV_BLUR_QUALITY_SPEED) {
  78:Drivers/lvgl/src/draw/sw/lv_draw_sw_blur.c ****         if(blur_radius >= 24) skip_cnt = 3;
  79:Drivers/lvgl/src/draw/sw/lv_draw_sw_blur.c ****         else skip_cnt = 2;
  80:Drivers/lvgl/src/draw/sw/lv_draw_sw_blur.c ****     }
  81:Drivers/lvgl/src/draw/sw/lv_draw_sw_blur.c **** 
  82:Drivers/lvgl/src/draw/sw/lv_draw_sw_blur.c ****     /*The blurring are must be multiples of skip_cnt so the blurring is all directions
  83:Drivers/lvgl/src/draw/sw/lv_draw_sw_blur.c ****      * blur the same pixels if some pixels are skipped*/
  84:Drivers/lvgl/src/draw/sw/lv_draw_sw_blur.c ****     clipped_coords.x1 = ((clipped_coords.x1 + (skip_cnt - 1)) / skip_cnt) * skip_cnt;
  85:Drivers/lvgl/src/draw/sw/lv_draw_sw_blur.c ****     clipped_coords.x2 = ((clipped_coords.x2 - (skip_cnt - 1)) / skip_cnt) * skip_cnt;
