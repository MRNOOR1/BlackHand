 344:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** #if LV_USE_OS
 345:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** static void render_thread_cb(void * ptr)
 346:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** {
 347:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     lv_draw_sw_thread_dsc_t * thread_dsc = ptr;
 348:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** 
 349:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     lv_thread_sync_init(&thread_dsc->sync);
 350:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     thread_dsc->inited = true;
 351:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** 
 352:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     while(1) {
 353:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         while(thread_dsc->task_act == NULL) {
 354:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****             if(thread_dsc->exit_status) {
 355:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****                 break;
 356:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****             }
 357:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****             lv_thread_sync_wait(&thread_dsc->sync);
 358:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         }
 359:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** 
 360:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         if(thread_dsc->exit_status) {
 361:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****             LV_LOG_INFO("ready to exit software rendering thread");
 362:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****             break;
 363:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         }
 364:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** 
 365:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         execute_drawing(thread_dsc->task_act);
 366:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** #if LV_USE_PARALLEL_DRAW_DEBUG
 367:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         parallel_debug_draw(thread_dsc->task_act, thread_dsc->idx);
 368:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** #endif
 369:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         thread_dsc->task_act->state = LV_DRAW_TASK_STATE_FINISHED;
 370:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         thread_dsc->task_act = NULL;
 371:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** 
 372:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         /*The draw unit is free now. Request a new dispatching as it can get a new task*/
 373:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         lv_draw_dispatch_request();
 374:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** 
 375:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     }
 376:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** 
 377:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     thread_dsc->inited = false;
 378:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     lv_thread_sync_delete(&thread_dsc->sync);
 379:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     LV_LOG_INFO("exit software rendering thread");
 380:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** }
 381:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** #endif
