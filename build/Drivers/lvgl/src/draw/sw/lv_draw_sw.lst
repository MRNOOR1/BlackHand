 250:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** static int32_t dispatch(lv_draw_unit_t * draw_unit, lv_layer_t * layer)
 251:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** {
 252:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     LV_PROFILER_DRAW_BEGIN;
 253:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     lv_draw_sw_unit_t * draw_sw_unit = (lv_draw_sw_unit_t *) draw_unit;
 254:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** 
 255:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** #if LV_USE_OS
 256:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     uint32_t i;
 257:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     uint32_t taken_cnt = 0;
 258:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     /* All idle (couldn't take any tasks): return LV_DRAW_UNIT_IDLE;
 259:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****      * All busy: return 0; as 0 tasks were taken
 260:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****      * Otherwise return taken_cnt;
 261:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****      */
 262:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** 
 263:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     /*If at least one is busy, it's not all idle*/
 264:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     bool all_idle = true;
 265:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     for(i = 0; i < LV_DRAW_SW_DRAW_UNIT_CNT; i++) {
 266:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         if(draw_sw_unit->thread_dscs[i].task_act) {
 267:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****             all_idle = false;
 268:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****             break;
 269:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         }
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//ccYBRO69.s 			page 8


 270:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     }
 271:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** 
 272:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     lv_draw_task_t * t = NULL;
 273:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     for(i = 0; i < LV_DRAW_SW_DRAW_UNIT_CNT; i++) {
 274:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         lv_draw_sw_thread_dsc_t * thread_dsc = &draw_sw_unit->thread_dscs[i];
 275:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** 
 276:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         /*Do nothing if busy*/
 277:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         if(thread_dsc->task_act) continue;
 278:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** 
 279:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         /*Find an available task. Start from the previously taken task.*/
 280:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         t = lv_draw_get_next_available_task(layer, t, DRAW_UNIT_ID_SW);
 281:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** 
 282:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         /*If there is not available task don't try other threads as there won't be available
 283:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****          *tasks for then either*/
 284:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         if(t == NULL) {
 285:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****             LV_PROFILER_DRAW_END;
 286:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****             if(all_idle) return LV_DRAW_UNIT_IDLE;  /*Couldn't start rendering*/
 287:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****             else return taken_cnt;
 288:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         }
 289:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** 
 290:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         /*Allocate a buffer if not done yet.*/
 291:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         void * buf = lv_draw_layer_alloc_buf(layer);
 292:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         /*Do not return is failed. The other thread might already have a buffer can do something. *
 293:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         if(buf == NULL) continue;
 294:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** 
 295:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         /*Take the task*/
 296:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         all_idle = false;
 297:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         taken_cnt++;
 298:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         t->state = LV_DRAW_TASK_STATE_IN_PROGRESS;
 299:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         thread_dsc->task_act = t;
 300:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** 
 301:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         /*Let the render thread work*/
 302:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         if(thread_dsc->inited) lv_thread_sync_signal(&thread_dsc->sync);
 303:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     }
 304:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** 
 305:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     if(all_idle) return LV_DRAW_UNIT_IDLE;  /*Couldn't start rendering*/
 306:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     else return taken_cnt;
 307:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** 
 308:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** #else
 309:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     /*Return immediately if it's busy with draw task*/
 310:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     if(draw_sw_unit->task_act) {
 311:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         LV_PROFILER_DRAW_END;
 312:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         return 0;
 313:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     }
 314:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** 
 315:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     lv_draw_task_t * t = NULL;
 316:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     t = lv_draw_get_available_task(layer, NULL, DRAW_UNIT_ID_SW);
 317:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     if(t == NULL) {
 318:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         LV_PROFILER_DRAW_END;
 319:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         return LV_DRAW_UNIT_IDLE;  /*Couldn't start rendering*/
 320:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     }
 321:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** 
 322:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     void * buf = lv_draw_layer_alloc_buf(layer);
 323:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     if(buf == NULL) {
 324:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         LV_PROFILER_DRAW_END;
 325:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****         return LV_DRAW_UNIT_IDLE;  /*Couldn't start rendering*/
 326:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     }
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//ccYBRO69.s 			page 9


 327:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** 
 328:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     t->state = LV_DRAW_TASK_STATE_IN_PROGRESS;
 329:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     draw_sw_unit->task_act = t;
 330:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** 
 331:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     execute_drawing(t);
 332:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     draw_sw_unit->task_act->state = LV_DRAW_TASK_STATE_FINISHED;
 333:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     draw_sw_unit->task_act = NULL;
 334:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** 
 335:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     /*The draw unit is free now. Request a new dispatching as it can get a new task*/
 336:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     lv_draw_dispatch_request();
 337:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** 
 338:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     LV_PROFILER_DRAW_END;
 339:Drivers/lvgl/src/draw/sw/lv_draw_sw.c ****     return 1;
 340:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** #endif
 341:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** 
 342:Drivers/lvgl/src/draw/sw/lv_draw_sw.c **** }
