 345:Drivers/lvgl/src/draw/sw/../../misc/../font/../draw/../misc/lv_color.h ****             color.blue >= l_color.blue);
 346:Drivers/lvgl/src/draw/sw/../../misc/../font/../draw/../misc/lv_color.h **** }
