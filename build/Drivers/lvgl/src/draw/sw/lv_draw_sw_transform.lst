 175:Drivers/lvgl/src/draw/sw/lv_draw_sw_transform.c **** 
 176:Drivers/lvgl/src/draw/sw/lv_draw_sw_transform.c ****     /*If scaled only make some simplification to avoid rounding errors.
 177:Drivers/lvgl/src/draw/sw/lv_draw_sw_transform.c ****      *For example if there is a 100x100 image zoomed to 300%
 178:Drivers/lvgl/src/draw/sw/lv_draw_sw_transform.c ****      *The destination area in X will be x1=0; x2=299
 179:Drivers/lvgl/src/draw/sw/lv_draw_sw_transform.c ****      *When the step is calculated below it will think that stepping
 180:Drivers/lvgl/src/draw/sw/lv_draw_sw_transform.c ****      *1/3 pixels on the original image will result in 300% zoom.
 181:Drivers/lvgl/src/draw/sw/lv_draw_sw_transform.c ****      *However this way the last pixel will be on the 99.67 coordinate.
 182:Drivers/lvgl/src/draw/sw/lv_draw_sw_transform.c ****      *As it's larger than 99.5 LVGL will start to mix the next coordinate
 183:Drivers/lvgl/src/draw/sw/lv_draw_sw_transform.c ****      *which is out of the image, so will make the pixel more transparent.
 184:Drivers/lvgl/src/draw/sw/lv_draw_sw_transform.c ****      *To avoid it in case of scale only limit the coordinates to the 0..297 range,
 185:Drivers/lvgl/src/draw/sw/lv_draw_sw_transform.c ****      *that is to 0..(src_w-1)*zoom */
 186:Drivers/lvgl/src/draw/sw/lv_draw_sw_transform.c ****     if(is_rotated == false) {
 187:Drivers/lvgl/src/draw/sw/lv_draw_sw_transform.c ****         int32_t xs1_ups, ys1_ups, xs2_ups, ys2_ups;
