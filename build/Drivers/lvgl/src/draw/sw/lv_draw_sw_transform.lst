 122:Drivers/lvgl/src/draw/sw/lv_draw_sw_transform.c ****     int32_t angle_low = tr_dsc.angle / 10;
 123:Drivers/lvgl/src/draw/sw/lv_draw_sw_transform.c ****     int32_t angle_high = angle_low + 1;
 124:Drivers/lvgl/src/draw/sw/lv_draw_sw_transform.c ****     int32_t angle_rem = tr_dsc.angle  - (angle_low * 10);
 125:Drivers/lvgl/src/draw/sw/lv_draw_sw_transform.c **** 
 126:Drivers/lvgl/src/draw/sw/lv_draw_sw_transform.c ****     int32_t s1 = lv_trigo_sin(angle_low);
 127:Drivers/lvgl/src/draw/sw/lv_draw_sw_transform.c ****     int32_t s2 = lv_trigo_sin(angle_high);
 128:Drivers/lvgl/src/draw/sw/lv_draw_sw_transform.c **** 
 129:Drivers/lvgl/src/draw/sw/lv_draw_sw_transform.c ****     int32_t c1 = lv_trigo_sin(angle_low + 90);
 130:Drivers/lvgl/src/draw/sw/lv_draw_sw_transform.c ****     int32_t c2 = lv_trigo_sin(angle_high + 90);
 131:Drivers/lvgl/src/draw/sw/lv_draw_sw_transform.c **** 
 132:Drivers/lvgl/src/draw/sw/lv_draw_sw_transform.c ****     tr_dsc.sinma = (s1 * (10 - angle_rem) + s2 * angle_rem) / 10;
 133:Drivers/lvgl/src/draw/sw/lv_draw_sw_transform.c ****     tr_dsc.cosma = (c1 * (10 - angle_rem) + c2 * angle_rem) / 10;
 134:Drivers/lvgl/src/draw/sw/lv_draw_sw_transform.c ****     tr_dsc.sinma = tr_dsc.sinma >> (LV_TRIGO_SHIFT - 10);
 135:Drivers/lvgl/src/draw/sw/lv_draw_sw_transform.c ****     tr_dsc.cosma = tr_dsc.cosma >> (LV_TRIGO_SHIFT - 10);
