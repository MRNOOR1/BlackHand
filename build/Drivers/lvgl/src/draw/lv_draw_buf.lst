 483:Drivers/lvgl/src/draw/lv_draw_buf.c ****     if(res == LV_RESULT_OK) {
 484:Drivers/lvgl/src/draw/lv_draw_buf.c ****         lv_area_t area = {0, 0, draw_buf->header.w - 1, draw_buf->header.h - 1};
 485:Drivers/lvgl/src/draw/lv_draw_buf.c ****         if(LV_COLOR_FORMAT_IS_INDEXED(draw_buf->header.cf)) {
 486:Drivers/lvgl/src/draw/lv_draw_buf.c ****             /**
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//ccxF66nk.s 			page 10


 487:Drivers/lvgl/src/draw/lv_draw_buf.c ****              * We only need to flush the palette table, so we set y2 equal to y1 to improve perform
 488:Drivers/lvgl/src/draw/lv_draw_buf.c ****              * and reduce cache flush overhead.
 489:Drivers/lvgl/src/draw/lv_draw_buf.c ****              */
 490:Drivers/lvgl/src/draw/lv_draw_buf.c ****             area.y2 = 0;
 491:Drivers/lvgl/src/draw/lv_draw_buf.c ****         }
 492:Drivers/lvgl/src/draw/lv_draw_buf.c **** 
 493:Drivers/lvgl/src/draw/lv_draw_buf.c ****         lv_draw_buf_set_flag(draw_buf, LV_IMAGE_FLAGS_PREMULTIPLIED);
 494:Drivers/lvgl/src/draw/lv_draw_buf.c ****         lv_draw_buf_flush_cache(draw_buf, &area);
 495:Drivers/lvgl/src/draw/lv_draw_buf.c ****     }
 496:Drivers/lvgl/src/draw/lv_draw_buf.c **** 
 497:Drivers/lvgl/src/draw/lv_draw_buf.c ****     LV_PROFILER_DRAW_END;
 498:Drivers/lvgl/src/draw/lv_draw_buf.c ****     return res;
