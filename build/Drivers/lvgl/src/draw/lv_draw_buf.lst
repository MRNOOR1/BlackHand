 578:Drivers/lvgl/src/draw/lv_draw_buf.c **** 
 579:Drivers/lvgl/src/draw/lv_draw_buf.c ****     if(dest_area == NULL) line_width = dest->header.w;
 580:Drivers/lvgl/src/draw/lv_draw_buf.c ****     else line_width = lv_area_get_width(dest_area);
 581:Drivers/lvgl/src/draw/lv_draw_buf.c **** 
 582:Drivers/lvgl/src/draw/lv_draw_buf.c ****     /* For indexed image, copy the palette if we are copying full image area*/
 583:Drivers/lvgl/src/draw/lv_draw_buf.c ****     if(dest_area == NULL || src_area == NULL) {
 584:Drivers/lvgl/src/draw/lv_draw_buf.c ****         if(LV_COLOR_FORMAT_IS_INDEXED(dest->header.cf)) {
 585:Drivers/lvgl/src/draw/lv_draw_buf.c ****             lv_memcpy(dest->data, src->data, LV_COLOR_INDEXED_PALETTE_SIZE(dest->header.cf) * sizeo
 586:Drivers/lvgl/src/draw/lv_draw_buf.c ****         }
 587:Drivers/lvgl/src/draw/lv_draw_buf.c ****     }
 588:Drivers/lvgl/src/draw/lv_draw_buf.c **** 
 589:Drivers/lvgl/src/draw/lv_draw_buf.c ****     /*Check source and dest area have same width*/
 590:Drivers/lvgl/src/draw/lv_draw_buf.c ****     if((src_area == NULL && line_width != src->header.w) || \
 591:Drivers/lvgl/src/draw/lv_draw_buf.c ****        (src_area != NULL && line_width != lv_area_get_width(src_area))) {
 592:Drivers/lvgl/src/draw/lv_draw_buf.c ****         LV_ASSERT_MSG(0, "Source and destination areas have different width");
 593:Drivers/lvgl/src/draw/lv_draw_buf.c ****         LV_PROFILER_DRAW_END;
 594:Drivers/lvgl/src/draw/lv_draw_buf.c ****         return;
 595:Drivers/lvgl/src/draw/lv_draw_buf.c ****     }
 596:Drivers/lvgl/src/draw/lv_draw_buf.c **** 
 597:Drivers/lvgl/src/draw/lv_draw_buf.c ****     if(src_area) src_bufc = lv_draw_buf_goto_xy(src, src_area->x1, src_area->y1);
 598:Drivers/lvgl/src/draw/lv_draw_buf.c ****     else src_bufc = lv_draw_buf_goto_xy(src, 0, 0);
 599:Drivers/lvgl/src/draw/lv_draw_buf.c **** 
 600:Drivers/lvgl/src/draw/lv_draw_buf.c ****     if(dest_area) dest_bufc = lv_draw_buf_goto_xy(dest, dest_area->x1, dest_area->y1);
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//ccxF66nk.s 			page 12


 601:Drivers/lvgl/src/draw/lv_draw_buf.c ****     else dest_bufc = lv_draw_buf_goto_xy(dest, 0, 0);
 602:Drivers/lvgl/src/draw/lv_draw_buf.c **** 
 603:Drivers/lvgl/src/draw/lv_draw_buf.c ****     int32_t start_y, end_y;
 604:Drivers/lvgl/src/draw/lv_draw_buf.c ****     if(dest_area) {
