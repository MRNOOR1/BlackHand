  41:Drivers/lvgl/src/draw/lv_draw_buf.h ****     (LV_DRAW_BUF_STRIDE(w, cf) * (h) + LV_DRAW_BUF_ALIGN + \
  42:Drivers/lvgl/src/draw/lv_draw_buf.h ****      LV_COLOR_INDEXED_PALETTE_SIZE(cf) * sizeof(lv_color32_t))
