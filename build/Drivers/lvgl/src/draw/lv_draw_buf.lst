  37:Drivers/lvgl/src/draw/lv_draw_buf.h ****     LV_ROUND_UP(((w) * LV_COLOR_FORMAT_GET_BPP(cf) + 7) / 8, LV_DRAW_BUF_STRIDE_ALIGN)
  38:Drivers/lvgl/src/draw/lv_draw_buf.h **** 
  39:Drivers/lvgl/src/draw/lv_draw_buf.h **** /** Allocate a slightly larger buffer, so we can adjust the start address to meet alignment */
