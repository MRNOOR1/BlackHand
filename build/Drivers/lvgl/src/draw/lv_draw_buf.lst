 375:Drivers/lvgl/src/draw/lv_draw_buf.c **** void * lv_draw_buf_goto_xy(const lv_draw_buf_t * buf, uint32_t x, uint32_t y)
 376:Drivers/lvgl/src/draw/lv_draw_buf.c **** {
 377:Drivers/lvgl/src/draw/lv_draw_buf.c ****     LV_ASSERT_NULL(buf);
 378:Drivers/lvgl/src/draw/lv_draw_buf.c ****     if(buf == NULL) return NULL;
 379:Drivers/lvgl/src/draw/lv_draw_buf.c **** 
 380:Drivers/lvgl/src/draw/lv_draw_buf.c ****     if(x >= buf->header.w || y >= buf->header.h) {
 381:Drivers/lvgl/src/draw/lv_draw_buf.c ****         LV_LOG_ERROR("coordinates out of range, x: %" LV_PRIu32 ", y: %"LV_PRIu32", w: %"LV_PRIu32"
 382:Drivers/lvgl/src/draw/lv_draw_buf.c ****                      (uint32_t)buf->header.w, (uint32_t)buf->header.h);
 383:Drivers/lvgl/src/draw/lv_draw_buf.c ****         return NULL;
 384:Drivers/lvgl/src/draw/lv_draw_buf.c ****     }
 385:Drivers/lvgl/src/draw/lv_draw_buf.c **** 
 386:Drivers/lvgl/src/draw/lv_draw_buf.c ****     uint8_t * data = buf->data;
 387:Drivers/lvgl/src/draw/lv_draw_buf.c **** 
 388:Drivers/lvgl/src/draw/lv_draw_buf.c ****     /*Skip palette*/
 389:Drivers/lvgl/src/draw/lv_draw_buf.c ****     data += LV_COLOR_INDEXED_PALETTE_SIZE(buf->header.cf) * sizeof(lv_color32_t);
 390:Drivers/lvgl/src/draw/lv_draw_buf.c ****     data += buf->header.stride * y;
 391:Drivers/lvgl/src/draw/lv_draw_buf.c **** 
 392:Drivers/lvgl/src/draw/lv_draw_buf.c ****     if(x == 0) return data;
 393:Drivers/lvgl/src/draw/lv_draw_buf.c **** 
 394:Drivers/lvgl/src/draw/lv_draw_buf.c ****     return data + x * lv_color_format_get_bpp(buf->header.cf) / 8;
 395:Drivers/lvgl/src/draw/lv_draw_buf.c **** }
 396:Drivers/lvgl/src/draw/lv_draw_buf.c **** 
 397:Drivers/lvgl/src/draw/lv_draw_buf.c **** lv_result_t lv_draw_buf_adjust_stride(lv_draw_buf_t * src, uint32_t stride)
 398:Drivers/lvgl/src/draw/lv_draw_buf.c **** {
 399:Drivers/lvgl/src/draw/lv_draw_buf.c ****     LV_ASSERT_NULL(src);
 400:Drivers/lvgl/src/draw/lv_draw_buf.c ****     LV_ASSERT_NULL(src->data);
 401:Drivers/lvgl/src/draw/lv_draw_buf.c ****     if(src == NULL) return LV_RESULT_INVALID;
 402:Drivers/lvgl/src/draw/lv_draw_buf.c ****     if(src->data == NULL) return LV_RESULT_INVALID;
 403:Drivers/lvgl/src/draw/lv_draw_buf.c ****     LV_PROFILER_DRAW_BEGIN;
 404:Drivers/lvgl/src/draw/lv_draw_buf.c **** 
 405:Drivers/lvgl/src/draw/lv_draw_buf.c ****     const lv_image_header_t * header = &src->header;
 406:Drivers/lvgl/src/draw/lv_draw_buf.c ****     uint32_t w = header->w;
 407:Drivers/lvgl/src/draw/lv_draw_buf.c ****     uint32_t h = header->h;
 408:Drivers/lvgl/src/draw/lv_draw_buf.c **** 
 409:Drivers/lvgl/src/draw/lv_draw_buf.c ****     if(!lv_draw_buf_has_flag(src, LV_IMAGE_FLAGS_MODIFIABLE)) {
 410:Drivers/lvgl/src/draw/lv_draw_buf.c ****         LV_PROFILER_DRAW_END;
 411:Drivers/lvgl/src/draw/lv_draw_buf.c ****         return LV_RESULT_INVALID;
 412:Drivers/lvgl/src/draw/lv_draw_buf.c ****     }
 413:Drivers/lvgl/src/draw/lv_draw_buf.c **** 
 414:Drivers/lvgl/src/draw/lv_draw_buf.c ****     /*Use global stride*/
 415:Drivers/lvgl/src/draw/lv_draw_buf.c ****     if(stride == 0) stride = lv_draw_buf_width_to_stride(w, header->cf);
 416:Drivers/lvgl/src/draw/lv_draw_buf.c **** 
 417:Drivers/lvgl/src/draw/lv_draw_buf.c ****     /*Check if stride already match*/
 418:Drivers/lvgl/src/draw/lv_draw_buf.c ****     if(header->stride == stride) {
 419:Drivers/lvgl/src/draw/lv_draw_buf.c ****         LV_PROFILER_DRAW_END;
 420:Drivers/lvgl/src/draw/lv_draw_buf.c ****         return LV_RESULT_OK;
 421:Drivers/lvgl/src/draw/lv_draw_buf.c ****     }
 422:Drivers/lvgl/src/draw/lv_draw_buf.c **** 
 423:Drivers/lvgl/src/draw/lv_draw_buf.c ****     /*Calculate the minimal stride allowed from bpp*/
 424:Drivers/lvgl/src/draw/lv_draw_buf.c ****     uint32_t bpp = lv_color_format_get_bpp(header->cf);
 425:Drivers/lvgl/src/draw/lv_draw_buf.c ****     uint32_t min_stride = (w * bpp + 7) >> 3;
 426:Drivers/lvgl/src/draw/lv_draw_buf.c ****     if(stride < min_stride) {
 427:Drivers/lvgl/src/draw/lv_draw_buf.c ****         LV_LOG_WARN("New stride is too small. min: %" LV_PRId32, min_stride);
 428:Drivers/lvgl/src/draw/lv_draw_buf.c ****         LV_PROFILER_DRAW_END;
 429:Drivers/lvgl/src/draw/lv_draw_buf.c ****         return LV_RESULT_INVALID;
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//ccxF66nk.s 			page 9


 430:Drivers/lvgl/src/draw/lv_draw_buf.c ****     }
 431:Drivers/lvgl/src/draw/lv_draw_buf.c **** 
 432:Drivers/lvgl/src/draw/lv_draw_buf.c ****     /*Check if buffer has enough space. */
 433:Drivers/lvgl/src/draw/lv_draw_buf.c ****     uint32_t new_size = _calculate_draw_buf_size(w, h, header->cf, stride);
 434:Drivers/lvgl/src/draw/lv_draw_buf.c ****     if(new_size > src->data_size) {
 435:Drivers/lvgl/src/draw/lv_draw_buf.c ****         LV_PROFILER_DRAW_END;
 436:Drivers/lvgl/src/draw/lv_draw_buf.c ****         return LV_RESULT_INVALID;
 437:Drivers/lvgl/src/draw/lv_draw_buf.c ****     }
 438:Drivers/lvgl/src/draw/lv_draw_buf.c **** 
 439:Drivers/lvgl/src/draw/lv_draw_buf.c ****     uint32_t offset = LV_COLOR_INDEXED_PALETTE_SIZE(header->cf) * 4;
 440:Drivers/lvgl/src/draw/lv_draw_buf.c **** 
 441:Drivers/lvgl/src/draw/lv_draw_buf.c ****     if(stride > header->stride) {
 442:Drivers/lvgl/src/draw/lv_draw_buf.c ****         /*Copy from the last line to the first*/
 443:Drivers/lvgl/src/draw/lv_draw_buf.c ****         uint8_t * src_data = src->data + offset + header->stride * (h - 1);
 444:Drivers/lvgl/src/draw/lv_draw_buf.c ****         uint8_t * dst_data = src->data + offset + stride * (h - 1);
 445:Drivers/lvgl/src/draw/lv_draw_buf.c ****         for(uint32_t y = 0; y < h; y++) {
 446:Drivers/lvgl/src/draw/lv_draw_buf.c ****             lv_memmove(dst_data, src_data, min_stride);
 447:Drivers/lvgl/src/draw/lv_draw_buf.c ****             src_data -= header->stride;
 448:Drivers/lvgl/src/draw/lv_draw_buf.c ****             dst_data -= stride;
 449:Drivers/lvgl/src/draw/lv_draw_buf.c ****         }
 450:Drivers/lvgl/src/draw/lv_draw_buf.c ****     }
 451:Drivers/lvgl/src/draw/lv_draw_buf.c ****     else {
 452:Drivers/lvgl/src/draw/lv_draw_buf.c ****         /*Copy from the first line to the last*/
 453:Drivers/lvgl/src/draw/lv_draw_buf.c ****         uint8_t * src_data = src->data + offset;
 454:Drivers/lvgl/src/draw/lv_draw_buf.c ****         uint8_t * dst_data = src->data + offset;
 455:Drivers/lvgl/src/draw/lv_draw_buf.c ****         for(uint32_t y = 0; y < h; y++) {
 456:Drivers/lvgl/src/draw/lv_draw_buf.c ****             lv_memmove(dst_data, src_data, min_stride);
 457:Drivers/lvgl/src/draw/lv_draw_buf.c ****             src_data += header->stride;
 458:Drivers/lvgl/src/draw/lv_draw_buf.c ****             dst_data += stride;
 459:Drivers/lvgl/src/draw/lv_draw_buf.c ****         }
 460:Drivers/lvgl/src/draw/lv_draw_buf.c ****     }
