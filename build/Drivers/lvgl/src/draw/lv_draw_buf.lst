 168:Drivers/lvgl/src/draw/lv_draw_buf.c **** void lv_draw_buf_clear(lv_draw_buf_t * draw_buf, const lv_area_t * a)
 169:Drivers/lvgl/src/draw/lv_draw_buf.c **** {
 170:Drivers/lvgl/src/draw/lv_draw_buf.c ****     LV_ASSERT_NULL(draw_buf);
 171:Drivers/lvgl/src/draw/lv_draw_buf.c ****     LV_PROFILER_DRAW_BEGIN;
 172:Drivers/lvgl/src/draw/lv_draw_buf.c **** 
 173:Drivers/lvgl/src/draw/lv_draw_buf.c ****     const lv_image_header_t * header = &draw_buf->header;
 174:Drivers/lvgl/src/draw/lv_draw_buf.c ****     uint32_t stride = header->stride;
 175:Drivers/lvgl/src/draw/lv_draw_buf.c **** 
 176:Drivers/lvgl/src/draw/lv_draw_buf.c ****     if(a == NULL) {
 177:Drivers/lvgl/src/draw/lv_draw_buf.c ****         uint8_t * buf = lv_draw_buf_goto_xy(draw_buf, 0, 0);
 178:Drivers/lvgl/src/draw/lv_draw_buf.c ****         lv_memzero(buf, header->h * stride);
 179:Drivers/lvgl/src/draw/lv_draw_buf.c ****         lv_draw_buf_flush_cache(draw_buf, a);
 180:Drivers/lvgl/src/draw/lv_draw_buf.c ****         LV_PROFILER_DRAW_END;
 181:Drivers/lvgl/src/draw/lv_draw_buf.c ****         return;
 182:Drivers/lvgl/src/draw/lv_draw_buf.c ****     }
 183:Drivers/lvgl/src/draw/lv_draw_buf.c **** 
 184:Drivers/lvgl/src/draw/lv_draw_buf.c ****     lv_area_t a_draw_buf;
 185:Drivers/lvgl/src/draw/lv_draw_buf.c ****     a_draw_buf.x1 = 0;
 186:Drivers/lvgl/src/draw/lv_draw_buf.c ****     a_draw_buf.y1 = 0;
 187:Drivers/lvgl/src/draw/lv_draw_buf.c ****     a_draw_buf.x2 = draw_buf->header.w - 1;
 188:Drivers/lvgl/src/draw/lv_draw_buf.c ****     a_draw_buf.y2 = draw_buf->header.h - 1;
 189:Drivers/lvgl/src/draw/lv_draw_buf.c **** 
 190:Drivers/lvgl/src/draw/lv_draw_buf.c ****     lv_area_t a_clipped;
 191:Drivers/lvgl/src/draw/lv_draw_buf.c ****     if(!lv_area_intersect(&a_clipped, a, &a_draw_buf)) {
 192:Drivers/lvgl/src/draw/lv_draw_buf.c ****         LV_PROFILER_DRAW_END;
 193:Drivers/lvgl/src/draw/lv_draw_buf.c ****         return;
 194:Drivers/lvgl/src/draw/lv_draw_buf.c ****     }
 195:Drivers/lvgl/src/draw/lv_draw_buf.c **** 
 196:Drivers/lvgl/src/draw/lv_draw_buf.c ****     if(lv_area_get_width(&a_clipped) <= 0) {
 197:Drivers/lvgl/src/draw/lv_draw_buf.c ****         LV_PROFILER_DRAW_END;
 198:Drivers/lvgl/src/draw/lv_draw_buf.c ****         return;
 199:Drivers/lvgl/src/draw/lv_draw_buf.c ****     }
 200:Drivers/lvgl/src/draw/lv_draw_buf.c **** 
 201:Drivers/lvgl/src/draw/lv_draw_buf.c ****     if(lv_area_get_height(&a_clipped) <= 0) {
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//ccxF66nk.s 			page 5


 202:Drivers/lvgl/src/draw/lv_draw_buf.c ****         LV_PROFILER_DRAW_END;
 203:Drivers/lvgl/src/draw/lv_draw_buf.c ****         return;
 204:Drivers/lvgl/src/draw/lv_draw_buf.c ****     }
 205:Drivers/lvgl/src/draw/lv_draw_buf.c **** 
 206:Drivers/lvgl/src/draw/lv_draw_buf.c ****     uint8_t * buf = lv_draw_buf_goto_xy(draw_buf, a_clipped.x1, a_clipped.y1);
 207:Drivers/lvgl/src/draw/lv_draw_buf.c ****     uint8_t bpp = lv_color_format_get_bpp(header->cf);
 208:Drivers/lvgl/src/draw/lv_draw_buf.c ****     uint32_t line_length = (lv_area_get_width(&a_clipped) * bpp + 7) >> 3;
 209:Drivers/lvgl/src/draw/lv_draw_buf.c ****     int32_t y;
 210:Drivers/lvgl/src/draw/lv_draw_buf.c ****     for(y = a_clipped.y1; y <= a_clipped.y2; y++) {
 211:Drivers/lvgl/src/draw/lv_draw_buf.c ****         lv_memzero(buf, line_length);
 212:Drivers/lvgl/src/draw/lv_draw_buf.c ****         buf += stride;
 213:Drivers/lvgl/src/draw/lv_draw_buf.c ****     }
 214:Drivers/lvgl/src/draw/lv_draw_buf.c ****     lv_draw_buf_flush_cache(draw_buf, a);
 215:Drivers/lvgl/src/draw/lv_draw_buf.c ****     LV_PROFILER_DRAW_END;
 216:Drivers/lvgl/src/draw/lv_draw_buf.c **** }
