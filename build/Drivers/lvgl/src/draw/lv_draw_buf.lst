 658:Drivers/lvgl/src/draw/lv_draw_buf.c **** /**
 659:Drivers/lvgl/src/draw/lv_draw_buf.c ****  * For given width, height, color format, and stride, calculate the size needed for a new draw buff
 660:Drivers/lvgl/src/draw/lv_draw_buf.c ****  */
 661:Drivers/lvgl/src/draw/lv_draw_buf.c **** static uint32_t _calculate_draw_buf_size(uint32_t w, uint32_t h, lv_color_format_t cf, uint32_t str
 662:Drivers/lvgl/src/draw/lv_draw_buf.c **** {
 663:Drivers/lvgl/src/draw/lv_draw_buf.c ****     uint32_t size;
 664:Drivers/lvgl/src/draw/lv_draw_buf.c **** 
 665:Drivers/lvgl/src/draw/lv_draw_buf.c ****     if(stride == 0) stride = lv_draw_buf_width_to_stride(w, cf);
 666:Drivers/lvgl/src/draw/lv_draw_buf.c **** 
 667:Drivers/lvgl/src/draw/lv_draw_buf.c ****     size = stride * h;
 668:Drivers/lvgl/src/draw/lv_draw_buf.c ****     if(cf == LV_COLOR_FORMAT_RGB565A8) {
 669:Drivers/lvgl/src/draw/lv_draw_buf.c ****         size += (stride / 2) * h; /*A8 mask*/
 670:Drivers/lvgl/src/draw/lv_draw_buf.c ****     }
 671:Drivers/lvgl/src/draw/lv_draw_buf.c ****     else if(LV_COLOR_FORMAT_IS_INDEXED(cf)) {
 672:Drivers/lvgl/src/draw/lv_draw_buf.c ****         /*@todo we have to include palette right before image data*/
 673:Drivers/lvgl/src/draw/lv_draw_buf.c ****         size += LV_COLOR_INDEXED_PALETTE_SIZE(cf) * 4;
 674:Drivers/lvgl/src/draw/lv_draw_buf.c ****     }
 675:Drivers/lvgl/src/draw/lv_draw_buf.c **** 
 676:Drivers/lvgl/src/draw/lv_draw_buf.c ****     return size;
 677:Drivers/lvgl/src/draw/lv_draw_buf.c **** }
