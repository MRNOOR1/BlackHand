 474:Drivers/lvgl/src/draw/lv_draw_buf.c **** 
 475:Drivers/lvgl/src/draw/lv_draw_buf.c ****     if(!lv_draw_buf_has_flag(draw_buf, LV_IMAGE_FLAGS_MODIFIABLE)) {
 476:Drivers/lvgl/src/draw/lv_draw_buf.c ****         LV_LOG_WARN("draw buf is not modifiable: 0x%04x", draw_buf->header.flags);
 477:Drivers/lvgl/src/draw/lv_draw_buf.c ****         return LV_RESULT_INVALID;
 478:Drivers/lvgl/src/draw/lv_draw_buf.c ****     }
