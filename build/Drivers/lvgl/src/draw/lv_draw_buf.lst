 615:Drivers/lvgl/src/draw/lv_draw_buf.c ****     uint32_t line_bytes = (line_width * lv_color_format_get_bpp(dest->header.cf) + 7) >> 3;
 616:Drivers/lvgl/src/draw/lv_draw_buf.c **** 
 617:Drivers/lvgl/src/draw/lv_draw_buf.c ****     for(; start_y <= end_y; start_y++) {
 618:Drivers/lvgl/src/draw/lv_draw_buf.c ****         lv_memcpy(dest_bufc, src_bufc, line_bytes);
