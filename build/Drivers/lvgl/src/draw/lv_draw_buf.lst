 568:Drivers/lvgl/src/draw/lv_draw_buf.c ****                      const lv_draw_buf_t * src, const lv_area_t * src_area)
 569:Drivers/lvgl/src/draw/lv_draw_buf.c **** {
 570:Drivers/lvgl/src/draw/lv_draw_buf.c ****     LV_PROFILER_DRAW_BEGIN;
