 468:Drivers/lvgl/src/draw/lv_draw_buf.c **** lv_result_t lv_draw_buf_premultiply(lv_draw_buf_t * draw_buf)
 469:Drivers/lvgl/src/draw/lv_draw_buf.c **** {
 470:Drivers/lvgl/src/draw/lv_draw_buf.c ****     LV_ASSERT_NULL(draw_buf);
 471:Drivers/lvgl/src/draw/lv_draw_buf.c ****     if(draw_buf == NULL) return LV_RESULT_INVALID;
 472:Drivers/lvgl/src/draw/lv_draw_buf.c **** 
