 214:Drivers/lvgl/src/draw/lv_draw.c **** void lv_draw_dispatch(void)
 215:Drivers/lvgl/src/draw/lv_draw.c **** {
 216:Drivers/lvgl/src/draw/lv_draw.c ****     LV_PROFILER_DRAW_BEGIN;
 217:Drivers/lvgl/src/draw/lv_draw.c ****     bool task_dispatched = false;
 218:Drivers/lvgl/src/draw/lv_draw.c ****     lv_display_t * disp = lv_refr_get_disp_refreshing();
 219:Drivers/lvgl/src/draw/lv_draw.c ****     if(disp != NULL) {
 220:Drivers/lvgl/src/draw/lv_draw.c ****         lv_layer_t * layer = disp->layer_head;
 221:Drivers/lvgl/src/draw/lv_draw.c ****         while(layer) {
 222:Drivers/lvgl/src/draw/lv_draw.c ****             if(lv_draw_dispatch_layer(disp, layer))
 223:Drivers/lvgl/src/draw/lv_draw.c ****                 task_dispatched = true;
 224:Drivers/lvgl/src/draw/lv_draw.c ****             layer = layer->next;
 225:Drivers/lvgl/src/draw/lv_draw.c ****         }
 226:Drivers/lvgl/src/draw/lv_draw.c ****     }
 227:Drivers/lvgl/src/draw/lv_draw.c ****     if(!task_dispatched) {
 228:Drivers/lvgl/src/draw/lv_draw.c ****         lv_draw_wait_for_finish();
 229:Drivers/lvgl/src/draw/lv_draw.c ****         lv_draw_dispatch_request();
 230:Drivers/lvgl/src/draw/lv_draw.c ****     }
 231:Drivers/lvgl/src/draw/lv_draw.c ****     LV_PROFILER_DRAW_END;
 232:Drivers/lvgl/src/draw/lv_draw.c **** }
