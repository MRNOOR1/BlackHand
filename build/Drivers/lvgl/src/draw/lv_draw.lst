 234:Drivers/lvgl/src/draw/lv_draw.c **** bool lv_draw_dispatch_layer(lv_display_t * disp, lv_layer_t * layer)
 235:Drivers/lvgl/src/draw/lv_draw.c **** {
 236:Drivers/lvgl/src/draw/lv_draw.c ****     LV_PROFILER_DRAW_BEGIN;
 237:Drivers/lvgl/src/draw/lv_draw.c ****     /*Remove the finished tasks first*/
 238:Drivers/lvgl/src/draw/lv_draw.c ****     lv_draw_task_t * t_prev = NULL;
 239:Drivers/lvgl/src/draw/lv_draw.c ****     lv_draw_task_t * t = layer->draw_task_head;
 240:Drivers/lvgl/src/draw/lv_draw.c ****     lv_draw_task_t * t_next;
 241:Drivers/lvgl/src/draw/lv_draw.c ****     bool remove_task = false;
 242:Drivers/lvgl/src/draw/lv_draw.c ****     while(t) {
 243:Drivers/lvgl/src/draw/lv_draw.c ****         t_next = t->next;
 244:Drivers/lvgl/src/draw/lv_draw.c ****         if(t->state == LV_DRAW_TASK_STATE_FINISHED) {
 245:Drivers/lvgl/src/draw/lv_draw.c ****             cleanup_task(t, disp);
 246:Drivers/lvgl/src/draw/lv_draw.c ****             remove_task = true;
 247:Drivers/lvgl/src/draw/lv_draw.c ****             if(t_prev != NULL)
 248:Drivers/lvgl/src/draw/lv_draw.c ****                 t_prev->next = t_next;
