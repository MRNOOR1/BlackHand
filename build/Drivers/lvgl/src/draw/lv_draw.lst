 544:Drivers/lvgl/src/draw/lv_draw.c **** /**
 545:Drivers/lvgl/src/draw/lv_draw.c ****  * Check if there are older draw task overlapping the area of `t_check`
 546:Drivers/lvgl/src/draw/lv_draw.c ****  * @param layer         the draw ctx to search in
 547:Drivers/lvgl/src/draw/lv_draw.c ****  * @param t_check       check this task if it overlaps with the older ones
 548:Drivers/lvgl/src/draw/lv_draw.c ****  * @param draw_unit_id  draw unit ID for which the independence check is called
 549:Drivers/lvgl/src/draw/lv_draw.c ****  * @return              true: `t_check` is not overlapping with older tasks so it's independent
 550:Drivers/lvgl/src/draw/lv_draw.c ****  */
 551:Drivers/lvgl/src/draw/lv_draw.c **** static bool is_independent(lv_layer_t * layer, lv_draw_task_t * t_check, uint8_t draw_unit_id)
 552:Drivers/lvgl/src/draw/lv_draw.c **** {
 553:Drivers/lvgl/src/draw/lv_draw.c ****     LV_PROFILER_DRAW_BEGIN;
 554:Drivers/lvgl/src/draw/lv_draw.c ****     lv_draw_task_t * t = layer->draw_task_head;
 555:Drivers/lvgl/src/draw/lv_draw.c **** 
 556:Drivers/lvgl/src/draw/lv_draw.c ****     /*If t_check is outside of the older tasks then it's independent*/
 557:Drivers/lvgl/src/draw/lv_draw.c ****     while(t && t != t_check) {
 558:Drivers/lvgl/src/draw/lv_draw.c ****         /*It's independent of finished draw tasks, and queued draw tasks of the same draw unit,
 559:Drivers/lvgl/src/draw/lv_draw.c ****          *so no need to check it*/
 560:Drivers/lvgl/src/draw/lv_draw.c ****         if(t->state == LV_DRAW_TASK_STATE_FINISHED ||
 561:Drivers/lvgl/src/draw/lv_draw.c ****            (t->state == LV_DRAW_TASK_STATE_QUEUED && t->preferred_draw_unit_id == draw_unit_id)) {
 562:Drivers/lvgl/src/draw/lv_draw.c ****             t = t->next;
 563:Drivers/lvgl/src/draw/lv_draw.c ****             continue;
 564:Drivers/lvgl/src/draw/lv_draw.c ****         }
 565:Drivers/lvgl/src/draw/lv_draw.c **** 
 566:Drivers/lvgl/src/draw/lv_draw.c ****         lv_area_t a;
 567:Drivers/lvgl/src/draw/lv_draw.c ****         if(lv_area_intersect(&a, &t->_real_area, &t_check->_real_area)) {
 568:Drivers/lvgl/src/draw/lv_draw.c ****             LV_PROFILER_DRAW_END;
 569:Drivers/lvgl/src/draw/lv_draw.c ****             return false;
 570:Drivers/lvgl/src/draw/lv_draw.c ****         }
 571:Drivers/lvgl/src/draw/lv_draw.c ****         t = t->next;
 572:Drivers/lvgl/src/draw/lv_draw.c ****     }
 573:Drivers/lvgl/src/draw/lv_draw.c ****     LV_PROFILER_DRAW_END;
 574:Drivers/lvgl/src/draw/lv_draw.c **** 
 575:Drivers/lvgl/src/draw/lv_draw.c ****     return true;
 576:Drivers/lvgl/src/draw/lv_draw.c **** }
