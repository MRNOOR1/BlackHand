 156:Drivers/lvgl/src/draw/lv_image_decoder.c ****     /*
 157:Drivers/lvgl/src/draw/lv_image_decoder.c ****      * We assume that if a decoder can get the info, it can open the image.
 158:Drivers/lvgl/src/draw/lv_image_decoder.c ****      * If decoder open failed, free the source and return error.
 159:Drivers/lvgl/src/draw/lv_image_decoder.c ****      * If decoder open succeed, add the image to cache if enabled.
 160:Drivers/lvgl/src/draw/lv_image_decoder.c ****      * */
 161:Drivers/lvgl/src/draw/lv_image_decoder.c ****     LV_PROFILER_DECODER_BEGIN_TAG(dsc->decoder->name);
 162:Drivers/lvgl/src/draw/lv_image_decoder.c ****     lv_result_t res = dsc->decoder->open_cb(dsc->decoder, dsc);
 163:Drivers/lvgl/src/draw/lv_image_decoder.c ****     LV_PROFILER_DECODER_END_TAG(dsc->decoder->name);
 164:Drivers/lvgl/src/draw/lv_image_decoder.c **** 
 165:Drivers/lvgl/src/draw/lv_image_decoder.c ****     if(res == LV_RESULT_OK && dsc->decoded != NULL) {
 166:Drivers/lvgl/src/draw/lv_image_decoder.c ****         LV_ASSERT_MSG(dsc->decoded->unaligned_data && dsc->decoded->handlers, "Invalid draw buffer"
 167:Drivers/lvgl/src/draw/lv_image_decoder.c **** 
 168:Drivers/lvgl/src/draw/lv_image_decoder.c ****         /* Flush the D-Cache if enabled and the image was successfully opened */
 169:Drivers/lvgl/src/draw/lv_image_decoder.c ****         if(dsc->args.flush_cache) {
 170:Drivers/lvgl/src/draw/lv_image_decoder.c ****             lv_draw_buf_flush_cache(dsc->decoded, NULL);
 171:Drivers/lvgl/src/draw/lv_image_decoder.c ****             LV_LOG_INFO("Flushed D-cache: src %p (%s) (W%d x H%d, data: %p cf: %d)",
 172:Drivers/lvgl/src/draw/lv_image_decoder.c ****                         src,
 173:Drivers/lvgl/src/draw/lv_image_decoder.c ****                         dsc->src_type == LV_IMAGE_SRC_FILE ? (const char *)src : "c-array",
 174:Drivers/lvgl/src/draw/lv_image_decoder.c ****                         dsc->decoded->header.w,
 175:Drivers/lvgl/src/draw/lv_image_decoder.c ****                         dsc->decoded->header.h,
 176:Drivers/lvgl/src/draw/lv_image_decoder.c ****                         (void *)dsc->decoded->data,
 177:Drivers/lvgl/src/draw/lv_image_decoder.c ****                         dsc->decoded->header.cf);
 178:Drivers/lvgl/src/draw/lv_image_decoder.c ****         }
 179:Drivers/lvgl/src/draw/lv_image_decoder.c ****     }
 180:Drivers/lvgl/src/draw/lv_image_decoder.c **** 
