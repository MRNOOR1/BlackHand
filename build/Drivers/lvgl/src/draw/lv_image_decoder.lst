 464:Drivers/lvgl/src/draw/lv_image_decoder.c **** static uint32_t img_width_to_stride(lv_image_header_t * header)
 465:Drivers/lvgl/src/draw/lv_image_decoder.c **** {
 466:Drivers/lvgl/src/draw/lv_image_decoder.c ****     if(header->cf == LV_COLOR_FORMAT_RGB565A8) {
 467:Drivers/lvgl/src/draw/lv_image_decoder.c ****         return header->w * 2;
 468:Drivers/lvgl/src/draw/lv_image_decoder.c ****     }
 469:Drivers/lvgl/src/draw/lv_image_decoder.c ****     else {
 470:Drivers/lvgl/src/draw/lv_image_decoder.c ****         return ((uint32_t)header->w * lv_color_format_get_bpp(header->cf) + 7) >> 3;
