 190:Drivers/lvgl/src/draw/lv_draw_image.c **** lv_image_src_t lv_image_src_get_type(const void * src)
 191:Drivers/lvgl/src/draw/lv_draw_image.c **** {
 192:Drivers/lvgl/src/draw/lv_draw_image.c ****     if(src == NULL) return LV_IMAGE_SRC_UNKNOWN;
 193:Drivers/lvgl/src/draw/lv_draw_image.c ****     const uint8_t * u8_p = src;
 194:Drivers/lvgl/src/draw/lv_draw_image.c **** 
 195:Drivers/lvgl/src/draw/lv_draw_image.c ****     /*The first byte shows the type of the image source*/
 196:Drivers/lvgl/src/draw/lv_draw_image.c ****     if(u8_p[0] >= 0x20 && u8_p[0] <= 0x7F) {
 197:Drivers/lvgl/src/draw/lv_draw_image.c ****         return LV_IMAGE_SRC_FILE; /*If it's an ASCII character then it's file name*/
 198:Drivers/lvgl/src/draw/lv_draw_image.c ****     }
 199:Drivers/lvgl/src/draw/lv_draw_image.c ****     else if(u8_p[0] >= 0x80) {
 200:Drivers/lvgl/src/draw/lv_draw_image.c ****         return LV_IMAGE_SRC_SYMBOL; /*Symbols begins after 0x7F*/
 201:Drivers/lvgl/src/draw/lv_draw_image.c ****     }
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//cczvNWBT.s 			page 5


 202:Drivers/lvgl/src/draw/lv_draw_image.c ****     else {
 203:Drivers/lvgl/src/draw/lv_draw_image.c ****         return LV_IMAGE_SRC_VARIABLE; /*`lv_image_dsc_t` is draw to the first byte < 0x20*/
 204:Drivers/lvgl/src/draw/lv_draw_image.c ****     }
 205:Drivers/lvgl/src/draw/lv_draw_image.c **** }
