  24:Drivers/lvgl/src/stdlib/builtin/lv_sprintf_builtin.c **** //
  25:Drivers/lvgl/src/stdlib/builtin/lv_sprintf_builtin.c **** // \brief Tiny printf, sprintf and (v)snprintf implementation, optimized for speed on
  26:Drivers/lvgl/src/stdlib/builtin/lv_sprintf_builtin.c **** //        embedded systems with a very limited resources. These routines are thread
  27:Drivers/lvgl/src/stdlib/builtin/lv_sprintf_builtin.c **** //        safe and reentrant!
  28:Drivers/lvgl/src/stdlib/builtin/lv_sprintf_builtin.c **** //        Use this instead of the bloated standard/newlib printf cause these use
  29:Drivers/lvgl/src/stdlib/builtin/lv_sprintf_builtin.c **** //        malloc for printf (and may not be thread safe).
  30:Drivers/lvgl/src/stdlib/builtin/lv_sprintf_builtin.c **** //
