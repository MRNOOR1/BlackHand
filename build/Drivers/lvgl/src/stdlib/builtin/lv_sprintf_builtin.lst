  49:Drivers/lvgl/src/stdlib/builtin/lv_sprintf_builtin.c **** #endif
  50:Drivers/lvgl/src/stdlib/builtin/lv_sprintf_builtin.c **** 
  51:Drivers/lvgl/src/stdlib/builtin/lv_sprintf_builtin.c **** // 'ftoa' conversion buffer size, this must be big enough to hold one converted
  52:Drivers/lvgl/src/stdlib/builtin/lv_sprintf_builtin.c **** // float number including padded zeros (dynamically created on stack)
  53:Drivers/lvgl/src/stdlib/builtin/lv_sprintf_builtin.c **** // default: 32 byte
  54:Drivers/lvgl/src/stdlib/builtin/lv_sprintf_builtin.c **** #ifndef PRINTF_FTOA_BUFFER_SIZE
