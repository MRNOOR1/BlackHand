  44:Drivers/lvgl/src/stdlib/builtin/lv_sprintf_builtin.c **** // 'ntoa' conversion buffer size, this must be big enough to hold one converted
  45:Drivers/lvgl/src/stdlib/builtin/lv_sprintf_builtin.c **** // numeric number including padded zeros (dynamically created on stack)
  46:Drivers/lvgl/src/stdlib/builtin/lv_sprintf_builtin.c **** // default: 32 byte
  47:Drivers/lvgl/src/stdlib/builtin/lv_sprintf_builtin.c **** #ifndef PRINTF_NTOA_BUFFER_SIZE
