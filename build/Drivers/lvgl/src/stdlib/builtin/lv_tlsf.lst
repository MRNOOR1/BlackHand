 554:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** static block_header_t * search_suitable_block(control_t * control, int * fli, int * sli)
 555:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** {
 556:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     int fl = *fli;
 557:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     int sl = *sli;
 558:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 559:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     /*
 560:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     ** First, search for a block in the list associated with the given
 561:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     ** fl/sl index.
 562:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     */
 563:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     unsigned int sl_map = control->sl_bitmap[fl] & (~0U << sl);
 564:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     if(!sl_map) {
 565:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****         /* No block exists. Search in the next largest first-level list. */
 566:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****         const unsigned int fl_map = control->fl_bitmap & (~0U << (fl + 1));
 567:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****         if(!fl_map) {
 568:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****             /* No free blocks available, memory has been exhausted. */
 569:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****             return 0;
 570:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****         }
 571:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 572:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****         fl = tlsf_ffs(fl_map);
 573:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****         *fli = fl;
 574:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****         sl_map = control->sl_bitmap[fl];
 575:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     }
 576:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     tlsf_assert(sl_map && "internal error - second level bitmap is null");
 577:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     sl = tlsf_ffs(sl_map);
 578:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     *sli = sl;
 579:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 580:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     /* Return the first block in the free list. */
 581:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     return control->blocks[fl][sl];
 582:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** }
 583:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
