  88:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     const int bit = 32 - __builtin_clz(reverse);
  89:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     return bit - 1;
  90:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** }
  91:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
  92:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** #else
  93:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
  94:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** tlsf_decl int tlsf_ffs(unsigned int word)
  95:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** {
  96:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     return __builtin_ffs(word) - 1;
  97:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** }
  98:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
  99:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** #endif
