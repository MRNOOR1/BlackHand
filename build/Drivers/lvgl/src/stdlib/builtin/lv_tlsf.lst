 228:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** } tlsf_public;
 229:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 230:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** /* Private constants: do not modify. */
 231:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** typedef enum {
 232:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** #if defined (TLSF_64BIT)
 233:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     /* All allocation sizes and addresses are aligned to 8 bytes. */
 234:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     ALIGN_SIZE_LOG2 = 3,
 235:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** #else
 236:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     /* All allocation sizes and addresses are aligned to 4 bytes. */
 237:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     ALIGN_SIZE_LOG2 = 2,
 238:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** #endif
 239:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     ALIGN_SIZE = (1 << ALIGN_SIZE_LOG2),
 240:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 241:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     /*
 242:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     ** We support allocations of sizes up to (1 << FL_INDEX_MAX) bits.
 243:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     ** However, because we linearly subdivide the second-level lists, and
 244:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     ** our minimum size granularity is 4 bytes, it doesn't make sense to
 245:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     ** create first-level lists for sizes smaller than SL_INDEX_COUNT * 4,
 246:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     ** or (1 << (SL_INDEX_COUNT_LOG2 + 2)) bytes, as there we will be
 247:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     ** trying to split size ranges into more slots than we have available.
 248:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     ** Instead, we calculate the minimum threshold size, and place all
 249:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     ** blocks below that size into the 0th first-level list.
 250:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     */
 251:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 252:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** #if defined (TLSF_MAX_POOL_SIZE)
 253:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     FL_INDEX_MAX = TLSF_LOG2_CEIL(TLSF_MAX_POOL_SIZE),
 254:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** #elif defined (TLSF_64BIT)
 255:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     /*
 256:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     ** TODO: We can increase this to support larger sizes, at the expense
 257:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     ** of more overhead in the TLSF structure.
 258:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     */
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//cccJA90f.s 			page 6


 259:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     FL_INDEX_MAX = 32,
 260:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** #else
 261:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     FL_INDEX_MAX = 30,
 262:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** #endif
 263:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     SL_INDEX_COUNT = (1 << SL_INDEX_COUNT_LOG2),
 264:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     FL_INDEX_SHIFT = (SL_INDEX_COUNT_LOG2 + ALIGN_SIZE_LOG2),
 265:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     FL_INDEX_COUNT = (FL_INDEX_MAX - FL_INDEX_SHIFT + 1),
 266:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 267:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     SMALL_BLOCK_SIZE = (1 << FL_INDEX_SHIFT),
 268:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** } tlsf_private;
 269:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 270:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** /*
 271:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** Cast and min/max macros.
 272:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** */
 273:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 274:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** #define tlsf_cast(t, exp)   ((t) (exp))
 275:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** #define tlsf_min(a, b)      ((a) < (b) ? (a) : (b))
 276:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** #define tlsf_max(a, b)      ((a) > (b) ? (a) : (b))
 277:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 278:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** /*
 279:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** Set assert macro, if it has not been provided by the user.
 280:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** */
 281:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** #define tlsf_assert LV_ASSERT
 282:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 283:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** #if !defined (tlsf_assert)
 284:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     #define tlsf_assert assert
 285:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** #endif
 286:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 287:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** /*
 288:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** Static assertion mechanism.
 289:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** */
 290:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 291:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** #define _tlsf_glue2(x, y) x ## y
 292:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** #define _tlsf_glue(x, y) _tlsf_glue2(x, y)
 293:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** #define tlsf_static_assert(exp) \
 294:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     typedef char _tlsf_glue(static_assert, __LINE__) [(exp) ? 1 : -1]
 295:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 296:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** /* This code has been tested on 32- and 64-bit (LP/LLP) architectures. */
 297:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** tlsf_static_assert(sizeof(int) * CHAR_BIT == 32);
 298:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** tlsf_static_assert(sizeof(size_t) * CHAR_BIT >= 32);
 299:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** tlsf_static_assert(sizeof(size_t) * CHAR_BIT <= 64);
 300:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 301:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** /* SL_INDEX_COUNT must be <= number of bits in sl_bitmap's storage type. */
 302:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** tlsf_static_assert(sizeof(unsigned int) * CHAR_BIT >= SL_INDEX_COUNT);
 303:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 304:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** /* Ensure we've properly tuned our sizes. */
 305:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** tlsf_static_assert(ALIGN_SIZE == SMALL_BLOCK_SIZE / SL_INDEX_COUNT);
 306:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 307:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** /*
 308:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** Data structures and associated constants.
 309:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** */
 310:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 311:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** /*
 312:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** Block header structure.
 313:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** **
 314:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** There are several implementation subtleties involved:
 315:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** - The prev_phys_block field is only valid if the previous block is free.
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//cccJA90f.s 			page 7


 316:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** - The prev_phys_block field is actually stored at the end of the
 317:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** **   previous block. It appears at the beginning of this structure only to
 318:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** **   simplify the implementation.
 319:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** - The next_free / prev_free fields are only valid if the block is free.
 320:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** */
 321:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** typedef struct block_header_t {
 322:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     /* Points to the previous physical block. */
 323:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     struct block_header_t * prev_phys_block;
 324:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 325:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     /* The size of this block, excluding the block header. */
 326:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     size_t size;
 327:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 328:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     /* Next and previous free blocks. */
 329:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     struct block_header_t * next_free;
 330:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     struct block_header_t * prev_free;
 331:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** } block_header_t;
 332:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 333:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** /*
 334:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** Since block sizes are always at least a multiple of 4, the two least
 335:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** significant bits of the size field are used to store the block status:
 336:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** - bit 0: whether block is busy or free
 337:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** - bit 1: whether previous block is busy or free
 338:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** */
 339:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** static const size_t block_header_free_bit = 1 << 0;
 340:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** static const size_t block_header_prev_free_bit = 1 << 1;
 341:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 342:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** /*
 343:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** The size of the block header exposed to used blocks is the size field.
 344:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** The prev_phys_block field is stored *inside* the previous free block.
 345:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** */
 346:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** static const size_t block_header_overhead = sizeof(size_t);
 347:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 348:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** /* User data starts directly after the size field in a used block. */
 349:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** static const size_t block_start_offset =
 350:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     offsetof(block_header_t, size) + sizeof(size_t);
 351:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 352:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** /*
 353:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** A free block must be large enough to store its header minus the size of
 354:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** the prev_phys_block field, and no larger than the number of addressable
 355:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** bits for FL_INDEX.
 356:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** */
 357:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** static const size_t block_size_min =
 358:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     sizeof(block_header_t) - sizeof(block_header_t *);
 359:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** static const size_t block_size_max = tlsf_cast(size_t, 1) << FL_INDEX_MAX;
 360:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 361:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** /* The TLSF control structure. */
 362:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** typedef struct control_t {
 363:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     /* Empty lists point at this block to indicate they are free. */
 364:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     block_header_t block_null;
 365:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 366:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     /* Bitmaps for free lists. */
 367:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     unsigned int fl_bitmap;
 368:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     unsigned int sl_bitmap[FL_INDEX_COUNT];
 369:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 370:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     /* Head of free lists. */
 371:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     block_header_t * blocks[FL_INDEX_COUNT][SL_INDEX_COUNT];
 372:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** } control_t;
