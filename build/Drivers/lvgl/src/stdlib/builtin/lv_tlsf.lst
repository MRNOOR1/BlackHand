 522:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** /*
 523:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** TLSF utility functions. In most cases, these are direct translations of
 524:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** the documentation found in the white paper.
 525:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** */
 526:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 527:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** static void mapping_insert(size_t size, int * fli, int * sli)
 528:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** {
 529:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     int fl, sl;
 530:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     if(size < SMALL_BLOCK_SIZE) {
 531:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****         /* Store small blocks in first list. */
 532:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****         fl = 0;
 533:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****         sl = tlsf_cast(int, size) / (SMALL_BLOCK_SIZE / SL_INDEX_COUNT);
 534:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     }
 535:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     else {
 536:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****         fl = tlsf_fls_sizet(size);
 537:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****         sl = tlsf_cast(int, size >> (fl - SL_INDEX_COUNT_LOG2)) ^ (1 << SL_INDEX_COUNT_LOG2);
 538:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****         fl -= (FL_INDEX_SHIFT - 1);
 539:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     }
 540:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     *fli = fl;
 541:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     *sli = sl;
 542:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** }
 543:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 544:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** /* This version rounds up to the next block size (for allocations) */
 545:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** static void mapping_search(size_t size, int * fli, int * sli)
 546:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** {
 547:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     if(size >= SMALL_BLOCK_SIZE) {
 548:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****         const size_t round = (1 << (tlsf_fls_sizet(size) - SL_INDEX_COUNT_LOG2)) - 1;
 549:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****         size += round;
 550:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     }
 551:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     mapping_insert(size, fli, sli);
 552:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** }
 553:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
