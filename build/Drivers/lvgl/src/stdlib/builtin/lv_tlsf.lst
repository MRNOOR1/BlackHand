  25:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** /*
  26:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** Architecture-specific bit manipulation routines.
  27:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** **
  28:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** TLSF achieves O(1) cost for malloc and free operations by limiting
  29:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** the search for a free block to a free list of guaranteed size
  30:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** adequate to fulfill the request, combined with efficient free list
ARM GAS  /var/folders/qx/2_175_4n2s19vhvtspjhb3qh0000gn/T//cccJA90f.s 			page 2


  31:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** queries using bitmasks and architecture-specific bit-manipulation
  32:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** routines.
  33:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** **
  34:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** Most modern processors provide instructions to count leading zeroes
  35:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** in a word, find the lowest and highest set bit, etc. These
  36:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** specific implementations will be used when available, falling back
  37:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** to a reasonably efficient generic implementation.
  38:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** **
  39:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** NOTE: TLSF spec relies on ffs/fls returning value 0..31.
  40:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** ffs/fls return 1-32 by default, returning 0 for error.
  41:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** */
  42:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
  43:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** /*
  44:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** Detect whether or not we are building for a 32- or 64-bit (LP/LLP)
  45:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** architecture. There is no reliable portable method at compile-time.
  46:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** */
  47:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** #if defined (__alpha__) || defined (__ia64__) || defined (__x86_64__) \
  48:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     || defined (_WIN64) || defined (__LP64__) || defined (__LLP64__)
  49:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     #define TLSF_64BIT
  50:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** #endif
  51:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
  52:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** /*
  53:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** Returns one plus the index of the most significant 1-bit of n,
  54:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** or if n is zero, returns zero.
  55:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** */
  56:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** #ifdef TLSF_64BIT
  57:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     #define TLSF_FLS(n) ((n) & 0xffffffff00000000ull ? 32 + TLSF_FLS32((size_t)(n) >> 32) : TLSF_FL
  58:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** #else
  59:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****     #define TLSF_FLS(n) TLSF_FLS32(n)
  60:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** #endif
  61:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
  62:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** #define TLSF_FLS32(n) ((n) & 0xffff0000 ? 16 + TLSF_FLS16((n) >> 16) : TLSF_FLS16(n))
  63:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** #define TLSF_FLS16(n) ((n) & 0xff00     ?  8 + TLSF_FLS8 ((n) >>  8) : TLSF_FLS8 (n))
  64:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** #define TLSF_FLS8(n)  ((n) & 0xf0       ?  4 + TLSF_FLS4 ((n) >>  4) : TLSF_FLS4 (n))
  65:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** #define TLSF_FLS4(n)  ((n) & 0xc        ?  2 + TLSF_FLS2 ((n) >>  2) : TLSF_FLS2 (n))
  66:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** #define TLSF_FLS2(n)  ((n) & 0x2        ?  1 + TLSF_FLS1 ((n) >>  1) : TLSF_FLS1 (n))
  67:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** #define TLSF_FLS1(n)  ((n) & 0x1        ?  1 : 0)
  68:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
  69:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** /*
  70:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** Returns round up value of log2(n).
  71:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** Note: it is used at compile time.
  72:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** */
  73:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** #define TLSF_LOG2_CEIL(n) ((n) & (n - 1) ? TLSF_FLS(n) : TLSF_FLS(n) - 1)
  74:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
  75:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** /*
  76:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** gcc 3.4 and above have builtin support, specialized for architecture.
  77:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** Some compilers masquerade as gcc; patchlevel test filters them out.
  78:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** */
  79:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** #if defined (__GNUC__) && (__GNUC__ > 3 || (__GNUC__ == 3 && __GNUC_MINOR__ >= 4)) \
