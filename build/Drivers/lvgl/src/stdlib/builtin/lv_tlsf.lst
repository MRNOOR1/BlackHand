 848:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****             const int fl_map = control->fl_bitmap & (1U << i);
 849:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****             const int sl_list = control->sl_bitmap[i];
 850:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****             const int sl_map = sl_list & (1U << j);
 851:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****             const block_header_t * block = control->blocks[i][j];
 852:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 853:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****             /* Check that first- and second-level lists agree. */
 854:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****             if(!fl_map) {
 855:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****                 tlsf_insist(!sl_map && "second-level map must be null");
 856:Drivers/lvgl/src/stdlib/builtin/lv_tlsf.c ****             }
