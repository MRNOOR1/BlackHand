 735:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c **** {
 736:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   int32_t  d;/* Decision Variable */ 
 737:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   uint32_t  curx;/* Current X Value */
 738:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   uint32_t  cury;/* Current Y Value */ 
