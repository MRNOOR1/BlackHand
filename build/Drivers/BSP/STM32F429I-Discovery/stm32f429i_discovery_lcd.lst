 157:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c **** uint8_t BSP_LCD_Init(void)
 158:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c **** { 
 159:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   /* On STM32F429I-DISCO, it is not possible to read ILI9341 ID because */
 160:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   /* PIN EXTC is not connected to VDD and then LCD_READ_ID4 is not accessible. */
 161:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   /* In this case, ReadID function is bypassed.*/  
 162:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   /*if(ili9341_drv.ReadID() == ILI9341_ID)*/
 163:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c **** 
 164:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     /* LTDC Configuration ----------------------------------------------------*/
 165:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     LtdcHandler.Instance = LTDC;
 166:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     
 167:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     /* Timing configuration  (Typical configuration from ILI9341 datasheet)
 168:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****           HSYNC=10 (9+1)
 169:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****           HBP=20 (29-10+1)
 170:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****           ActiveW=240 (269-20-10+1)
 171:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****           HFP=10 (279-240-20-10+1)
 172:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     
 173:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****           VSYNC=2 (1+1)
