 864:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   else if ((bitpixel/8) == 2)
 865:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   {
 866:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     inputcolormode = CM_RGB565;
 867:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   }
 868:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   else
 869:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   {
 870:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     inputcolormode = CM_RGB888;
 871:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   }
