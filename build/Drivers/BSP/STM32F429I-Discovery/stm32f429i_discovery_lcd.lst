 663:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   if (Y2 >= Y1)                 /* The y-values are increasing */
 664:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   {
 665:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     yinc1 = 1;
 666:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     yinc2 = 1;
