 847:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   width |= (*(uint16_t *) (pBmp + 20)) << 16;
 848:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c **** 
