 669:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   {
 670:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     yinc1 = -1;
 671:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     yinc2 = -1;
 672:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   }
 673:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   
 674:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   if (deltax >= deltay)         /* There is at least one x-value for every y-value */
 675:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   {
 676:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     xinc1 = 0;                  /* Don't change the x when numerator >= denominator */
 677:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     yinc2 = 0;                  /* Don't change the y for every iteration */
 678:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     den = deltax;
 679:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     num = deltax / 2;
 680:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     numadd = deltay;
 681:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     numpixels = deltax;         /* There are more x-values than y-values */
 682:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   }
 683:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   else                          /* There is at least one y-value for every x-value */
 684:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   {
 685:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     xinc2 = 0;                  /* Don't change the x for every iteration */
 686:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     yinc1 = 0;                  /* Don't change the y when numerator >= denominator */
 687:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     den = deltay;
 688:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     num = deltay / 2;
 689:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     numadd = deltax;
 690:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     numpixels = deltay;         /* There are more y-values than x-values */
 691:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   }
 692:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   
 693:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   for (curpixel = 0; curpixel <= numpixels; curpixel++)
 694:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   {
 695:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     BSP_LCD_DrawPixel(x, y, DrawProp[ActiveLayer].TextColor);   /* Draw the current pixel */
 696:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     num += numadd;                            /* Increase the numerator by the top of the fraction 
 697:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     if (num >= den)                           /* Check if numerator >= denominator */
 698:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     {
 699:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****       num -= den;                             /* Calculate the new numerator value */
 700:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****       x += xinc1;                             /* Change the x as appropriate */
 701:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****       y += yinc1;                             /* Change the y as appropriate */
 702:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     }
 703:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     x += xinc2;                               /* Change the x as appropriate */
 704:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     y += yinc2;                               /* Change the y as appropriate */
 705:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   }
