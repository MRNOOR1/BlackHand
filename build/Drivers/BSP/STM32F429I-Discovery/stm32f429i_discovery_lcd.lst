 740:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   d = 3 - (Radius << 1);
 741:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   curx = 0;
