 802:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c **** void BSP_LCD_DrawEllipse(int Xpos, int Ypos, int XRadius, int YRadius)
 803:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c **** {
 804:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   int x = 0, y = -YRadius, err = 2-2*XRadius, e2;
 805:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   float k = 0, rad1 = 0, rad2 = 0;
 806:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   
 807:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   rad1 = XRadius;
