 659:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     xinc1 = -1;
 660:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     xinc2 = -1;
