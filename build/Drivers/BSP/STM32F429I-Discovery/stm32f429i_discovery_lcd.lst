 642:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c **** {
 643:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   int16_t deltax = 0, deltay = 0, x = 0, y = 0, xinc1 = 0, xinc2 = 0, 
