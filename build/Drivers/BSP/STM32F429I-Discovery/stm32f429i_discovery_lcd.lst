 810:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   k = (float)(rad2/rad1);
 811:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   
 812:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   do { 
 813:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     BSP_LCD_DrawPixel((Xpos-(uint16_t)(x/k)), (Ypos+y), DrawProp[ActiveLayer].TextColor);
 814:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     BSP_LCD_DrawPixel((Xpos+(uint16_t)(x/k)), (Ypos+y), DrawProp[ActiveLayer].TextColor);
 815:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     BSP_LCD_DrawPixel((Xpos+(uint16_t)(x/k)), (Ypos-y), DrawProp[ActiveLayer].TextColor);
 816:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     BSP_LCD_DrawPixel((Xpos-(uint16_t)(x/k)), (Ypos-y), DrawProp[ActiveLayer].TextColor);      
 817:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     
 818:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     e2 = err;
 819:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     if (e2 <= x) {
 820:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****       err += ++x*2+1;
 821:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****       if (-y == x && e2 <= y) e2 = 0;
 822:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     }
 823:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****     if (e2 > y) err += ++y*2+1;
 824:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   }
 825:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c ****   while (y <= 0);
 826:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_lcd.c **** }
