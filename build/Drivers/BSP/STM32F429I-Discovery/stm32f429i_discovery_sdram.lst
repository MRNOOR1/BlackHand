 147:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c **** /**
 148:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   * @brief  Programs the SDRAM device.
 149:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   * @param  RefreshCount: SDRAM refresh counter value 
 150:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   * @retval None
 151:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   */
 152:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c **** void BSP_SDRAM_Initialization_sequence(uint32_t RefreshCount)
 153:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c **** {
 154:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   __IO uint32_t tmpmrd =0;
 155:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   
 156:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   /* Step 1:  Configure a clock configuration enable command */
 157:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   Command.CommandMode             = FMC_SDRAM_CMD_CLK_ENABLE;
 158:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   Command.CommandTarget           = FMC_SDRAM_CMD_TARGET_BANK2;
 159:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   Command.AutoRefreshNumber       = 1;
 160:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   Command.ModeRegisterDefinition  = 0;
 161:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c **** 
 162:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   /* Send the command */
 163:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   HAL_SDRAM_SendCommand(&SdramHandle, &Command, SDRAM_TIMEOUT);
 164:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c **** 
 165:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   /* Step 2: Insert 100 us minimum delay */ 
 166:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   /* Inserted delay is equal to 1 ms due to systick time base unit (ms) */
 167:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   HAL_Delay(1);
 168:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c **** 
 169:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   /* Step 3: Configure a PALL (precharge all) command */ 
 170:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   Command.CommandMode             = FMC_SDRAM_CMD_PALL;
 171:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   Command.CommandTarget           = FMC_SDRAM_CMD_TARGET_BANK2;
 172:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   Command.AutoRefreshNumber       = 1;
