 103:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c **** {
 104:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   /* SDRAM device configuration */
 105:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   SdramHandle.Instance = FMC_SDRAM_DEVICE;
 106:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c **** 
 107:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   /* FMC Configuration -------------------------------------------------------*/
 108:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   /* FMC SDRAM Bank configuration */
 109:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   /* Timing configuration for 90 Mhz of SD clock frequency (180Mhz/2) */
 110:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   /* TMRD: 2 Clock cycles */
 111:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   Timing.LoadToActiveDelay    = 2;
 112:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   /* TXSR: min=70ns (7x11.11ns) */
 113:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   Timing.ExitSelfRefreshDelay = 7;
 114:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   /* TRAS: min=42ns (4x11.11ns) max=120k (ns) */
 115:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   Timing.SelfRefreshTime      = 4;
 116:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   /* TRC:  min=70 (7x11.11ns) */
 117:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   Timing.RowCycleDelay        = 7;
 118:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   /* TWR:  min=1+ 7ns (1+1x11.11ns) */
 119:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   Timing.WriteRecoveryTime    = 2;
 120:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   /* TRP:  20ns => 2x11.11ns*/
 121:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   Timing.RPDelay              = 2;
 122:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   /* TRCD: 20ns => 2x11.11ns */
 123:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   Timing.RCDDelay             = 2;
 124:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   
 125:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   /* FMC SDRAM control configuration */
 126:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   SdramHandle.Init.SDBank             = FMC_SDRAM_BANK2;
 127:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   /* Row addressing: [7:0] */
 128:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   SdramHandle.Init.ColumnBitsNumber   = FMC_SDRAM_COLUMN_BITS_NUM_8;
 129:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   /* Column addressing: [11:0] */
 130:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   SdramHandle.Init.RowBitsNumber      = FMC_SDRAM_ROW_BITS_NUM_12;
 131:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   SdramHandle.Init.MemoryDataWidth    = SDRAM_MEMORY_WIDTH;
 132:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   SdramHandle.Init.InternalBankNumber = FMC_SDRAM_INTERN_BANKS_NUM_4;
 133:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   SdramHandle.Init.CASLatency         = SDRAM_CAS_LATENCY;
 134:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   SdramHandle.Init.WriteProtection    = FMC_SDRAM_WRITE_PROTECTION_DISABLE;
 135:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   SdramHandle.Init.SDClockPeriod      = SDCLOCK_PERIOD;
 136:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   SdramHandle.Init.ReadBurst          = SDRAM_READBURST;
 137:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   SdramHandle.Init.ReadPipeDelay      = FMC_SDRAM_RPIPE_DELAY_1;
 138:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****                     
 139:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   /* SDRAM controller initialization */
 140:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   MspInit();
 141:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   HAL_SDRAM_Init(&SdramHandle, &Timing);
 142:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   
 143:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   /* SDRAM initialization sequence */
 144:Drivers/BSP/STM32F429I-Discovery/stm32f429i_discovery_sdram.c ****   BSP_SDRAM_Initialization_sequence(REFRESH_COUNT);
