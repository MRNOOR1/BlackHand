  89:Core/Src/freertos.c **** /* USER CODE BEGIN 2 */
  90:Core/Src/freertos.c **** __weak void vApplicationIdleHook( void )
  91:Core/Src/freertos.c **** {
  92:Core/Src/freertos.c ****    /* vApplicationIdleHook() will only be called if configUSE_IDLE_HOOK is set
  93:Core/Src/freertos.c ****    to 1 in FreeRTOSConfig.h. It will be called on each iteration of the idle
  94:Core/Src/freertos.c ****    task. It is essential that code added to this hook function never attempts
  95:Core/Src/freertos.c ****    to block in any way (for example, call xQueueReceive() with a block time
  96:Core/Src/freertos.c ****    specified, or call vTaskDelay()). If the application makes use of the
  97:Core/Src/freertos.c ****    vTaskDelete() API function (as this demo application does) then it is also
  98:Core/Src/freertos.c ****    important that vApplicationIdleHook() is permitted to return to its calling
  99:Core/Src/freertos.c ****    function, because it is the responsibility of the idle task to clean up
 100:Core/Src/freertos.c ****    memory allocated by the kernel to any task that has since been deleted. */
 101:Core/Src/freertos.c **** }
 102:Core/Src/freertos.c **** /* USER CODE END 2 */
 103:Core/Src/freertos.c **** 
 104:Core/Src/freertos.c **** /* USER CODE BEGIN 4 */
 105:Core/Src/freertos.c **** __weak void vApplicationStackOverflowHook(xTaskHandle xTask, signed char *pcTaskName)
 106:Core/Src/freertos.c **** {
 107:Core/Src/freertos.c ****    /* Run time stack overflow checking is performed if
 108:Core/Src/freertos.c ****    configCHECK_FOR_STACK_OVERFLOW is defined to 1 or 2. This hook function is
 109:Core/Src/freertos.c ****    called if a stack overflow is detected. */
 110:Core/Src/freertos.c **** }
 111:Core/Src/freertos.c **** /* USER CODE END 4 */
 112:Core/Src/freertos.c **** 
 113:Core/Src/freertos.c **** /* USER CODE BEGIN 5 */
 114:Core/Src/freertos.c **** __weak void vApplicationMallocFailedHook(void)
 115:Core/Src/freertos.c **** {
 116:Core/Src/freertos.c ****    /* vApplicationMallocFailedHook() will only be called if
 117:Core/Src/freertos.c ****    configUSE_MALLOC_FAILED_HOOK is set to 1 in FreeRTOSConfig.h. It is a hook
 118:Core/Src/freertos.c ****    function that will get called if a call to pvPortMalloc() fails.
 119:Core/Src/freertos.c ****    pvPortMalloc() is called internally by the kernel whenever a task, queue,
 120:Core/Src/freertos.c ****    timer or semaphore is created. It is also called by various parts of the
 121:Core/Src/freertos.c ****    demo application. If heap_1.c or heap_2.c are used, then the size of the
 122:Core/Src/freertos.c ****    heap available to pvPortMalloc() is defined by configTOTAL_HEAP_SIZE in
 123:Core/Src/freertos.c ****    FreeRTOSConfig.h, and the xPortGetFreeHeapSize() API function can be used
 124:Core/Src/freertos.c ****    to query the size of free heap space that remains (although it does not
 125:Core/Src/freertos.c ****    provide information on how the remaining heap might be fragmented). */
 126:Core/Src/freertos.c **** }
 127:Core/Src/freertos.c **** /* USER CODE END 5 */
 128:Core/Src/freertos.c **** 
