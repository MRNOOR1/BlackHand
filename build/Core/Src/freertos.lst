 102:Core/Src/freertos.c **** __weak void vApplicationStackOverflowHook(xTaskHandle xTask, signed char *pcTaskName)
 103:Core/Src/freertos.c **** {
 104:Core/Src/freertos.c ****    /* Run time stack overflow checking is performed if
 105:Core/Src/freertos.c ****    configCHECK_FOR_STACK_OVERFLOW is defined to 1 or 2. This hook function is
 106:Core/Src/freertos.c ****    called if a stack overflow is detected. */
 107:Core/Src/freertos.c **** 
 108:Core/Src/freertos.c ****    /* FIXED: Indicate error with LED rapid blink pattern */
 109:Core/Src/freertos.c ****    (void)xTask;
 110:Core/Src/freertos.c ****    (void)pcTaskName;
 111:Core/Src/freertos.c **** 
 112:Core/Src/freertos.c ****    while(1) {
 113:Core/Src/freertos.c ****        HAL_GPIO_TogglePin(GPIOG, GPIO_PIN_13 | GPIO_PIN_14);  /* Blink both LEDs */
 114:Core/Src/freertos.c ****        for(volatile uint32_t i = 0; i < 100000; i++);  /* Fast blink = ERROR */
 115:Core/Src/freertos.c ****    }
 116:Core/Src/freertos.c **** }
 117:Core/Src/freertos.c **** /* USER CODE END 4 */
 118:Core/Src/freertos.c **** 
 119:Core/Src/freertos.c **** /* USER CODE BEGIN 5 */
 120:Core/Src/freertos.c **** __weak void vApplicationMallocFailedHook(void)
 121:Core/Src/freertos.c **** {
 122:Core/Src/freertos.c ****    /* vApplicationMallocFailedHook() will only be called if
 123:Core/Src/freertos.c ****    configUSE_MALLOC_FAILED_HOOK is set to 1 in FreeRTOSConfig.h. It is a hook
 124:Core/Src/freertos.c ****    function that will get called if a call to pvPortMalloc() fails.
 125:Core/Src/freertos.c ****    pvPortMalloc() is called internally by the kernel whenever a task, queue,
 126:Core/Src/freertos.c ****    timer or semaphore is created. It is also called by various parts of the
 127:Core/Src/freertos.c ****    demo application. If heap_1.c or heap_2.c are used, then the size of the
 128:Core/Src/freertos.c ****    heap available to pvPortMalloc() is defined by configTOTAL_HEAP_SIZE in
 129:Core/Src/freertos.c ****    FreeRTOSConfig.h, and the xPortGetFreeHeapSize() API function can be used
 130:Core/Src/freertos.c ****    to query the size of free heap space that remains (although it does not
 131:Core/Src/freertos.c ****    provide information on how the remaining heap might be fragmented). */
 132:Core/Src/freertos.c **** 
 133:Core/Src/freertos.c ****    /* FIXED: Indicate error with LED constant on */
 134:Core/Src/freertos.c ****    HAL_GPIO_WritePin(GPIOG, GPIO_PIN_13 | GPIO_PIN_14, GPIO_PIN_SET);  /* Both LEDs ON = MALLOC FAI
 135:Core/Src/freertos.c ****    while(1);
 136:Core/Src/freertos.c **** }
 137:Core/Src/freertos.c **** /* USER CODE END 5 */
