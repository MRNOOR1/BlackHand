 229:Core/Src/freertos.c **** /* Private application code --------------------------------------------------*/
 230:Core/Src/freertos.c **** /* USER CODE BEGIN Application */
 231:Core/Src/freertos.c **** void LVGL_Task(void const *argument)
 232:Core/Src/freertos.c **** {
 233:Core/Src/freertos.c ****   uint32_t task_delay_ms = 5;  /* 5ms = 200Hz update rate */
 234:Core/Src/freertos.c **** 
 235:Core/Src/freertos.c ****   for(;;)
 236:Core/Src/freertos.c ****   {
 237:Core/Src/freertos.c ****     /* Acquire mutex before LVGL operations */
 238:Core/Src/freertos.c ****     if(osMutexWait(lvglMutexHandle, osWaitForever) == osOK)
 239:Core/Src/freertos.c ****     {
 240:Core/Src/freertos.c ****       /* Call LVGL timer handler - processes UI updates */
 241:Core/Src/freertos.c ****       uint32_t next_delay = lv_timer_handler();
 242:Core/Src/freertos.c **** 
 243:Core/Src/freertos.c ****       /* Use adaptive delay if LVGL suggests one */
 244:Core/Src/freertos.c ****       if(next_delay > 0 && next_delay < 1000) {
 245:Core/Src/freertos.c ****         task_delay_ms = next_delay;
 246:Core/Src/freertos.c ****       }
 247:Core/Src/freertos.c **** 
 248:Core/Src/freertos.c ****       /* Release mutex */
 249:Core/Src/freertos.c ****       osMutexRelease(lvglMutexHandle);
 250:Core/Src/freertos.c ****     }
 251:Core/Src/freertos.c **** 
 252:Core/Src/freertos.c ****     osDelay(task_delay_ms);
 253:Core/Src/freertos.c ****   }
 254:Core/Src/freertos.c **** }
