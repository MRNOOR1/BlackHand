  87:Core/Src/freertos.c **** __weak void vApplicationIdleHook( void )
  88:Core/Src/freertos.c **** {
  89:Core/Src/freertos.c ****    /* vApplicationIdleHook() will only be called if configUSE_IDLE_HOOK is set
  90:Core/Src/freertos.c ****    to 1 in FreeRTOSConfig.h. It will be called on each iteration of the idle
  91:Core/Src/freertos.c ****    task. It is essential that code added to this hook function never attempts
  92:Core/Src/freertos.c ****    to block in any way (for example, call xQueueReceive() with a block time
  93:Core/Src/freertos.c ****    specified, or call vTaskDelay()). If the application makes use of the
  94:Core/Src/freertos.c ****    vTaskDelete() API function (as this demo application does) then it is also
  95:Core/Src/freertos.c ****    important that vApplicationIdleHook() is permitted to return to its calling
  96:Core/Src/freertos.c ****    function, because it is the responsibility of the idle task to clean up
  97:Core/Src/freertos.c ****    memory allocated by the kernel to any task that has since been deleted. */
  98:Core/Src/freertos.c **** }
  99:Core/Src/freertos.c **** /* USER CODE END 2 */
