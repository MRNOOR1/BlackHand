 154:Core/Src/freertos.c ****   /* USER CODE BEGIN Init */
 155:Core/Src/freertos.c ****   
 156:Core/Src/freertos.c ****   // LED task
 157:Core/Src/freertos.c ****   osThreadDef(ledTask, StartLedTask, osPriorityAboveNormal, 0, 128);
 158:Core/Src/freertos.c ****   ledTaskHandle = osThreadCreate(osThread(ledTask), NULL);
 159:Core/Src/freertos.c **** 
 160:Core/Src/freertos.c ****   // UART task
 161:Core/Src/freertos.c ****   osThreadDef(uartTask, StartUartTask, osPriorityAboveNormal, 0, 128);
 162:Core/Src/freertos.c ****   uartTaskHandle = osThreadCreate(osThread(uartTask), NULL);
 163:Core/Src/freertos.c **** 
 164:Core/Src/freertos.c ****   // LVGL task (increased stack to 1024 words/4KB)
 165:Core/Src/freertos.c ****   osThreadDef(lvglTask, LVGL_Task, osPriorityHigh, 0, 1024);
 166:Core/Src/freertos.c ****   lvglTaskHandle = osThreadCreate(osThread(lvglTask), NULL);
 167:Core/Src/freertos.c **** 
 168:Core/Src/freertos.c ****   // Button task
 169:Core/Src/freertos.c ****   osThreadDef(buttonTask, StartButtonTask, osPriorityAboveNormal, 0, 128);
 170:Core/Src/freertos.c ****   buttonTaskHandle = osThreadCreate(osThread(buttonTask), NULL);
 171:Core/Src/freertos.c **** 
 172:Core/Src/freertos.c ****   // Default task
 173:Core/Src/freertos.c ****   osThreadDef(defaultTask, StartDefaultTask, osPriorityNormal, 0, 4096);
 174:Core/Src/freertos.c ****   defaultTaskHandle = osThreadCreate(osThread(defaultTask), NULL);
 175:Core/Src/freertos.c **** 
 176:Core/Src/freertos.c ****   /* USER CODE END Init */
 177:Core/Src/freertos.c **** }
